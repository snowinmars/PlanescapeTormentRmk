IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #724 /* ~"Nejsem si jistý... ale když spolu mluvíme cítím, že se mi vrací útržky paměti. Řekni mi víc. Snad mi tvá slova pomohou vyhnat stíny z mysli, Deionarro."~ */ GOTO 9
