IF ~  !NearbyDialog("DMorte") Global("Morte_Deionarra_Quip_1","GLOBAL",0) ~ THEN REPLY #9616 /* ~Odejdi.~ */ DO ~SetGlobal("Deio_Wake_Up","GLOBAL",0) ~ EXIT
END 
IF WEIGHT #0 ~  Global("Deionarra","GLOBAL",0) !Global("Current_Area","GLOBAL",1203) !Global("Current_Area","GLOBAL",1200)
~ THEN BEGIN 1 // from:
SAY #5 /* ~Vidíš před sebou přízrak neobyčejně krásné ženy; má zkřížené ruce a zavřené oči, dlouhé plavé vlasy a zdá se, že s jejími šaty si pohrává lehounký vánek. Vidíš, jak se lehounce hýbe a její řasy se chvějí.~ */
IF ~~ THEN REPLY #703 /* ~"Zdravím...?"~ */ GOTO 2
IF ~~ THEN REPLY #704 /* ~Počkej.~ */ GOTO 2
IF ~~ THEN REPLY #705 /* ~Odejdi předtím než se duch zorientuje.~ */ DO ~SetGlobal("Deio_Wake_Up","GLOBAL",0) ~ EXIT
END

IF ~~ THEN BEGIN 2 // from: 1.0 1.1
SAY #706 /* ~Její oči se pomalu otevírají a v počátečním zmatku zamrká, jakoby si nebyla jistá, kde je. Rozhlíží se pomalu kolem a pak tě uvidí. Její poklidný obličej se náhle změnil. "Ty! Co *tebe* sem přivádí?! Přišel ses snad podívat na výsledek neštěstí, které jsi způsobil? Nebo snad, i po mé smrti, v tobě stále zůstal kousíček ze mne...?" Její hlas se změnil v šepot. "...'má lásko'."~ [DEN001] */
IF ~~ THEN REPLY #707 /* ~"Kdo jsi?"~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) ~ GOTO 3
IF ~  CheckStatGT(Protagonist,11,INT) CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #708 /* ~"'Má lásko?' Znám tě snad?"~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) ~ GOTO 3
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #709 /* ~"'Má lásko?' Znám tě snad?"~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) ~ GOTO 3
END

IF ~~ THEN BEGIN 3 // from: 2.0 2.1 2.2 10.0
SAY #710 /* ~Duch něco naznačuje rukama, nějaké tobě neznámé pohyby. "Jak se to mohlo stát, že ti zloději mysli ukradli z paměti mé jméno? *Nevzpomínáš* si na mne, má lásko?" Duch k tobě natahuje ruce. "Přemýšlej..." V jejím hlase je cítit zoufalost. "...jméno *Deionarra* musí přece v tobě vyvolávat nějaké vzpomínky."~ */
IF ~~ THEN REPLY #711 /* ~"Ne, promiň. Ztratil jsem paměť. "~ */ GOTO 6
IF ~~ THEN REPLY #712 /* ~Lež: "Ano... ano, to jméno mi *zní* hodně povědomě."~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Deionarra_1","GLOBALGood",-1) IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_1","GLOBALLaw",-1) ~ GOTO 7
IF ~  CheckStatGT(Protagonist,11,INT) CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #713 /* ~"*Myslím*, že se mi vrací útržky paměti... řekni mi něco víc. Snad mi tvá slova pomohou vyhnat stíny z mysli, Deionarro."~ */ GOTO 9
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #714 /* ~"*Myslím*, že se mi vrací útržky paměti... řekni mi něco víc. Snad mi tvá slova pomohou vyhnat stíny z mysli, Deionarro."~ */ GOTO 9
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #1308 /* ~"To ne. Sbohem... Deionarro."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #6080 /* ~"To nic. Sbohem... Deionarro."~ */ GOTO 26
END 
IF WEIGHT #1 ~  Global("Deionarra","GLOBAL",2) !Global("Current_Area","GLOBAL",1203) !Global("Current_Area","GLOBAL",1200)
~ THEN BEGIN 4 // from:
SAY #715 /* ~Deionarra se znovu zjevila... tentokrát má obličej naplněn zoufalstvím a ruce natažené vpřed, jakoby se chtěla něčeho dotknout. Když se zjevila úplně, její zoufalství se změnilo v zuřivost. "Už jsi zase přišel! Chceš mě znovu trápit?"~ [DEN002] */
IF ~~ THEN REPLY #765 /* ~"Potřebuju vědět mnohem více. Měl bych pro tebe nějaké otázky..."~ */ GOTO 33
IF ~~ THEN REPLY #1307 /* ~"Už tě nebudu víc trápit. Sbohem."~ */ GOTO 26
END 
IF WEIGHT #2 ~  Global("Deionarra","GLOBAL",1) !Global("Current_Area","GLOBAL",1203) !Global("Current_Area","GLOBAL",1200)
~ THEN BEGIN 5 // from:
SAY #716 /* ~Deionarra se znovu zjevila... tentokrát má obličej naplněn zoufalstvím a ruce natažené vpřed, jakoby se chtěla něčeho dotknout. Když se zjevila úplně, zoufalý výraz v jejím obličeji se změnil v úlevu. "Má lásko... vrátil ses ke mně! Je to snad tím, že se ti vrátila paměť?"~ [DEN003A] */
IF ~~ THEN REPLY #766 /* ~"Měl bych na tebe nějaké otázky..."~ */ GOTO 10
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #767 /* ~"Ještě ne. Sbohem, Deionarro."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #1309 /* ~"Teď ne. Sbohem, Deionarro."~ */ GOTO 0
END

IF ~~ THEN BEGIN 6 // from: 3.0
SAY #717 /* ~"Toho jsem se obávala. Opravdu jsem se v tobě zmýlila... a pak když máš potíže, použiješ jako omluvu, že si mne nemůžeš vybavit v hlavě proto, žes ztratil paměť!"~ */
IF ~~ THEN REPLY #720 /* ~"'Potíže?' 'Vybavit v hlavě?' Já tě neznám duchu... nemám vůbec žádné vzpomínky. Řekni mi... kdo jsi? Co o mně víš?"~ */ GOTO 11
IF ~  CheckStatGT(Protagonist,11,INT) CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #718 /* ~"*Myslím*, že se mi vrací útržky paměti... řekni mi něco víc. Snad mi tvá slova pomohou vyhnat stíny z mysli, Deionarro."~ */ GOTO 9
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #719 /* ~"*Myslím*, že se mi vrací útržky paměti... řekni mi něco víc. Snad mi tvá slova pomohou vyhnat stíny z mysli, Deionarro."~ */ GOTO 9
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #721 /* ~"Jestli jsem tě už jednou vypustil z hlavy, nevím proč bych to nemohl udělat znovu. Sbohem duchu."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #1310 /* ~"Musím jít, Deionarro. Sbohem."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #1311 /* ~"Už jsem tě jednou pustil z hlavy a vypadá to, že to budu muset udělat znovu. Sbohem duchu."~ */ GOTO 26
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #764 /* ~"Musím jít, Deionarro. Sbohem."~ */ GOTO 26
END

