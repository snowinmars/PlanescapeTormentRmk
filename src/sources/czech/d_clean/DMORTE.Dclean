IF ~~ THEN REPLY #4704 /* ~"Aha. Chtěl jsem vědět ještě něco..."~ */ EXTERN ~DVAXIS~ 43
IF ~~ THEN REPLY #4705 /* ~"Jo, už se těším, až toho zloděje najdu. Hele, možná budu mít nějaké otázky později. Nikam nechoď."~ */ EXIT
