END

IF ~~ THEN BEGIN 436 // from:
SAY #41636 /* ~"Tys slyšela slovo 'bordel' a hned sis myslela, že si tady vyděláš nějaký prachy, ty zablešená kozí děvko? Heh! Nemůžu uvěřit, že tě vůbec pustili do dveří, zvlášť, když ještě klapeš těma svejma vochrnutejma chundelatejma hnátama!"~ */
IF ~~ THEN REPLY #41637 /* ~"To už by stačilo, nechte toho vy dva."~ */ GOTO 435
IF ~~ THEN REPLY #41638 /* ~Nechej je pokračovat.~ */ EXTERN ~DKIMASXI~ 3
