IF ~~ THEN REPLY #1845 /* ~"Uh... no, řekl bych, že *moc* velkou škodu tím nenapáchám..."~ */ DO ~SetGlobal("Morte_Harlot_Quip_1","GLOBAL",1) ~ EXTERN ~DHARLOTN~ 7
