IF ~~ THEN REPLY #5050 /* ~"Chtěl bych si s tímhle písařem promluvit. Mohl by vědět něco o tom, jak jsem se sem dostal."~ */ GOTO 103
END

IF ~~ THEN BEGIN 103 // from: 102.0
