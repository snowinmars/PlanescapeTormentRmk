IF ~~ THEN REPLY #12859 /* ~Otoč se zpět na krysaře.~ */ EXTERN ~DCREED~ 32
END

IF ~~ THEN BEGIN 157 // from: 155.1 156.1
SAY #12623 /* ~Morte koulí očima, jakoby rozpačitě. "To je... mluvící encyklopedie. Nic, na co bych byl pyšný. Hele, ještě si poslechnem toho chlapika, jo?"~ */
IF ~~ THEN REPLY #12860 /* ~"Velmi dobře."~ */ DO ~SetGlobal("Morte_Mimir","GLOBAL",1) ~ EXTERN ~DCREED~ 32
IF ~~ THEN REPLY #12861 /* ~"Ne, už jsem slyšel dost. Sbohem, krysaři."~ */ DO ~SetGlobal("Morte_Mimir","GLOBAL",1) ~ EXTERN ~DCREED~ 59
END

IF ~~ THEN BEGIN 158 // from: 156.0
SAY #12624 /* ~"Oh,  ve svý podstatě šéfe... proč bych ti pomáhal? Už jsem ti řek všechno užitečný, co *Já* vím. Ať se ten hlupák stará o svoje malichernosti."~ */
IF ~~ THEN REPLY #12862 /* ~"Velmi dobře."~ */ EXTERN ~DCREED~ 32
IF ~~ THEN REPLY #12863 /* ~"Nevadí. Pojďme... sbohem, krysaři."~ */ EXTERN ~DCREED~ 59
END

IF ~~ THEN BEGIN 159 // from:
