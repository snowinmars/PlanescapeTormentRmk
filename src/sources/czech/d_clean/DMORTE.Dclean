END

IF ~~ THEN BEGIN 553 // from: 552.0
SAY #54249 /* ~"No..." Morte se odmlčel. "Jo, je tady jedna věc, kterou bys měl vědět - TY, kterýho jsem znal dřív, TY, který nás sem ved, ten vůbec nebyl jako ty. Vůbec ne."~ */
IF ~  GlobalGT("BD_MORTE_MORALE","GLOBAL",5) ~ THEN REPLY #54250 /* ~"Co tím myslíš?"~ */ GOTO 554
