IF ~~ THEN REPLY #13779 /* ~"Aha. Díky za informaci."~ */ EXIT
END

IF ~~ THEN BEGIN 165 // from:
SAY #13828 /* ~"No, je to strom s příliš mnoha prasklými větvemi." Morte koulí očima. "Rozhovor s Chaotiky nemá žádný smysl, šéfíku. Je to přitroublá banda."~ */
