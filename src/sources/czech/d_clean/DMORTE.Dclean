IF ~~ THEN REPLY #9033 /* ~"Ještě nejsem připravený odejít. Nejdřív se ho na něco zeptám..."~ */ EXTERN ~DGITH~ 7
IF ~~ THEN REPLY #9034 /* ~Nechej githa být.~ */ EXIT
