IF ~~ THEN REPLY #35281 /* ~"Možná chtěla, abys *šel pryč.* Byla příliš rozrušená ze MNE, než aby věnovala pozornost nějaké pitomé poletující hlavě s velkou hubou." ~ */ DO ~IncrementGlobalOnceEx("GLOBALMorte_Zombie_1","GLOBALLaw",-1) ~ GOTO 368
IF ~~ THEN REPLY #35284 /* ~"Myslím, že si to představuješ. Je zombie. Mrtvola. Mrtvá osoba. Nejspíš tě ani nezaregistrovala."~ */ GOTO 369
IF ~~ THEN REPLY #35287 /* ~"Myslím si, že ty a tvoje představivost byste se měli na čas rozejít a dát si pauzu."~ */ GOTO 369
IF ~~ THEN REPLY #35288 /* ~"No jo, Morte. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 368 // from: 367.0
SAY #35282 /* ~"Z Tebe? Jo, to určo! Věř mi, holky, co si prošly hrobem, si na fyzičnost moc nepotrpí, nesere je 'Já mám tělo' a 'Jsem zjizvenej tvrďák'. Chtějí chlápka, kerej má DUCHA! To sem já, šéfe. Mrtvoly jako TY sou běžnější než zlomená grešle." ~ */
IF ~~ THEN REPLY #35283 /* ~"No jo, Morte. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 369 // from: 367.1 367.2
SAY #35285 /* ~"Jo, jasně. Když seš mrtvej tak dlouho jako já, naučíš se to poznávat. Ty signály jsou pro tebe možná moc NEZŘETELNÝ, ale proto já trávím SVÉ noci s nějakýma nadrženýma právě zemřelýma kočkama, zatímco ty někde jen tak obstáváš, huh? Co je? Co-se-děje? Kde je m-m-moje pamm-mmměť?" ~ */
IF ~~ THEN REPLY #35286 /* ~"No jo, Morte. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 370 // from: 377.3
SAY #35310 /* ~"Hmmm. Zajímalo by mě, jestli by tomuhle šedovousovi vadilo, kdybych si půjčil jeho tělo..."~ */
IF ~~ THEN REPLY #35311 /* ~"Šedovous?"~ */ GOTO 371
IF ~~ THEN REPLY #35326 /* ~"Nemyslím si, že je v postavení, kdy by mohl něco namítat."~ */ GOTO 372
IF ~~ THEN REPLY #35327 /* ~"Něco mi říká, že bys byl dvakrát tak otravnější, kdybys měl ruce. Pojďme."~ */ GOTO 373
END

IF ~~ THEN BEGIN 371 // from: 370.0
SAY #35312 /* ~"Šedovous... no, víš, starej paprika, dědek... zkrátka někdo věkovitej."~ */
IF ~~ THEN REPLY #35313 /* ~"No, myslím si, že není v pozici, kdy by mohl něco namítat.  Proč si nevzít jeho tělo?"~ */ GOTO 372
IF ~~ THEN REPLY #35325 /* ~"Něco mi říká, že bys byl dvakrát tak otravnější, kdybys měl ruce. Pojďme."~ */ GOTO 373
END

IF ~~ THEN BEGIN 372 // from: 370.1 371.0
SAY #35314 /* ~Morte si chvíli prohlíží kostlivce, pak zavrtí hlavou. "Pche... potřebuju trochu čerstvějšího. A něco, co má o trochu víc důstojnosti... tendle je celej popraskanej a polámanej."~ */
IF ~~ THEN REPLY #35315 /* ~"A ty ne?"~ */ GOTO 373
IF ~~ THEN REPLY #35324 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 373 // from: 370.2 371.1 372.0
SAY #35316 /* ~"Oh, seš hromada směšnosti." Morte na tebe zlobně zírá. "Kromě toho, TY MÁŠ tak co mluvit, vole. Lituju všechny chudinky zrcadla, který potkáš."~ */
IF ~~ THEN REPLY #35317 /* ~"Jo tak? No *JÁ* mám alespoň všechny své části."~ */ GOTO 374
IF ~~ THEN REPLY #35323 /* ~"Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 374 // from: 373.0
SAY #35318 /* ~Morte si odfrkl. Nemáš potuchy, jak to bez plic dokázal.~ */
IF ~~ THEN REPLY #35319 /* ~"Víš, Morte, není nic lepšího a uspokojujícího, než chodit kolem, rozhazovat rukama, dýchat plícemi ostrý vzduch. Je to SKVĚLÝ, mít tělo."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Skeleton_Mort_1","GLOBALLaw",-1) ~ GOTO 375
IF ~~ THEN REPLY #35322 /* ~"Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 375 // from: 374.0
SAY #35320 /* ~"Musím ti říct, že svý rozhodnutí pomoct ti na útěku z přípravny jsem přidal do svýho narůstajícího seznamu věcí, kterejch lituju." Morte si znovu odfrkl. "Měl jsem tě nechat shnít... aspoň o trochu víc."~ */
IF ~~ THEN REPLY #35321 /* ~"Jsem rád, že to tak cítíš. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 376 // from:
SAY #35341 /* ~"Uau, šéfe. To je vandalismus! Ty nesmysly byly asi to jediný, co tu kupu kostí drželo pohromadě. Nekromancie s takovejma funguje jenom do určitý míry, víš?"~ */
IF ~~ THEN REPLY #35342 /* ~"Takže?"~ */ DO ~IncrementGlobal("Good","GLOBAL",-1) ~ GOTO 377
IF ~~ THEN REPLY #35360 /* ~"Oh... Nechtěl jsem způsobit žádnou trvalou škodu."~ */ DO ~IncrementGlobal("Good","GLOBAL",1) ~ GOTO 377
IF ~~ THEN REPLY #35361 /* ~"Dobra tedy, to nevadí. Možná někdy jindy."~ */ GOTO 377
END

IF ~~ THEN BEGIN 377 // from: 376.0 376.1 376.2
SAY #35343 /* ~"Oh, to není problém." Morte se podivně zakýval, jako by krčil rameny. "Jenom sem si nebyl jistej, estli to víš, nebo ne. No, jen pokračuj." ~ */
IF ~  !PartyHasItem("Prybar") CheckStatLT(Protagonist,13,STR) ~ THEN REPLY #35344 /* ~Zkus kostlivci vytáhnout svorky z kloubů.~ */ EXTERN ~DS1221~ 4
IF ~  !PartyHasItem("Prybar") CheckStatGT(Protagonist,12,STR) ~ THEN REPLY #35352 /* ~Zkus kostlivci vytáhnout svorky z kloubů.~ */ EXTERN ~DS1221~ 5
IF ~  PartyHasItem("Prybar") ~ THEN REPLY #35355 /* ~Zkus kostlivci vytáhnout svorky z kloubů.~ */ EXTERN ~DS1221~ 6
IF ~  Global("Morte_Skel_Mort_Quip","GLOBAL",0) ~ THEN REPLY #35358 /* ~To nic. Možná někdy jindy.~ */ DO ~SetGlobal("Morte_Skel_Mort_Quip","GLOBAL",1) ~ GOTO 370
IF ~  Global("Morte_Skel_Mort_Quip","GLOBAL",1) ~ THEN REPLY #35359 /* ~To nic. Možná někdy jindy.~ */ EXIT
