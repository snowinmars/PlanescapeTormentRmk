IF ~~ THEN BEGIN 534 // from: 540.3 541.2 542.2 543.1 544.1 545.2 546.1 547.1 548.4 549.2 550.2 551.1 552.1 553.2 554.2 555.2 556.1 557.1 562.0 563.0 564.0
SAY #54155 /* ~"Proč ne, šéfe?" Morte zavrtěl hlavou. "Víš, už jsme byli na mnoha DALŠÍCH děsnejch sférach mnohovesmíru, na který si vzpomenu. Tak proč neudělat další krůček?" Rachotivě si povzdychl. "Jseš připravenej TY? Protože jestli ne..."~ */
IF ~~ THEN REPLY #54156 /* ~"Můžeš mi znovu říct vše, co víš o tom, co je za portálem?"~ */ GOTO 544
IF ~~ THEN REPLY #54157 /* ~"Jsem připravený, Morte. Není už nic, co bych mohl udělat. Jsi se mnou?"~ */ GOTO 535
IF ~~ THEN REPLY #54158 /* ~"Možná máš pravdu... měl bych se nejdřív připravit."~ */ EXIT
END

IF ~~ THEN BEGIN 535 // from: 534.1
SAY #54159 /* ~"No, já..." Morte se podíval na blýskající závoj a vydal ze sebe další rachotivý vzdych. "Jasně. Pojďme. Kde jinde bychom si mohli pokecat líp, než v Márnici, že?"~ */
