IF ~~ THEN REPLY #65579 /* ~"V pořádku, tedy. Mám nějaké další otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65580 /* ~"V pořádku, tedy. Pojďme."~ */ EXIT
