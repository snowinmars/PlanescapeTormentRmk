IF ~~ THEN REPLY #12865 /* ~"Rozumím. Jiná otázka..."~ */ EXTERN ~DCREED~ 15
IF ~~ THEN REPLY #12866 /* ~"Díky za informace. Sbohem."~ */ EXTERN ~DCREED~ 59
END

IF ~~ THEN BEGIN 161 // from:
SAY #12627 /* ~"Umřít, šéfe... umřít."~ */
IF ~~ THEN REPLY #12867 /* ~"Ah... Co jsi to říkal o lidech platících za mrtvé krysy?"~ */ EXTERN ~DCREED~ 18
IF ~~ THEN REPLY #12868 /* ~"Aha. Mám otázku o něčem jiném..."~ */ EXTERN ~DCREED~ 15
IF ~~ THEN REPLY #12869 /* ~"Rozumím. Sbohem."~ */ EXTERN ~DCREED~ 59
END

IF ~~ THEN BEGIN 162 // from:
SAY #13748 /* ~"Nuže, je to strom s příliš mnoha prasklejma větvema." Morte koulí očima. "Rozhovor s Chaotiky nemá žádný smysl, šéfíku. Je to banda pitomců."~ */
IF ~  Global("Know_Chaosmen","GLOBAL",0) ~ THEN REPLY #13774 /* ~"Chaotici?"~ */ DO ~SetGlobal("Morte_SDThug_Quip_1","GLOBAL",1) SetGlobal("Know_Chaosmen","GLOBAL",1) ~ GOTO 163
IF ~  Global("Know_Chaosmen","GLOBAL",1) ~ THEN REPLY #13775 /* ~"Ještě jednou, kdo že jsou Chaotici?"~ */ DO ~SetGlobal("Morte_SDThug_Quip_1","GLOBAL",1) ~ GOTO 163
IF ~  Global("Know_Chaosmen","GLOBAL",1) ~ THEN REPLY #13776 /* ~"Stejně si myslím, že bych se od něj mohl něco dozvědět. No nic, pojďme."~ */ DO ~SetGlobal("Morte_SDThug_Quip_1","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 163 // from: 162.0 162.1
SAY #13749 /* ~"Jsou společenství, co nemají žádná pravidla... krom toho, aby jim žádná myšlenka příliš dlouho netrápila hlavu. Někdy se jim říká 'Chaotici'. Není třeba vysvětlovat proč."~ */
IF ~~ THEN REPLY #13777 /* ~"Jak nabírají členy?"~ */ GOTO 164
IF ~~ THEN REPLY #13778 /* ~"Aha. Pojďme."~ */ EXIT
END

