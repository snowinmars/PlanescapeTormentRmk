IF ~~ THEN BEGIN 0 // from:
SAY #986 /* ~"Hej, šéfe. Seš v pořádku? Hraješ si na mrtváka nebo se jenom snažíš oblbnout Spalovače? Už jsem si v jednu chvíli fakt myslel, že seš úplně tuhej."~ */
IF ~~ THEN REPLY #987 /* ~"Kdo jsi?"~ */ GOTO 1
IF ~~ THEN REPLY #989 /* ~Ignoruj tu ukecanou lebku a prohledej místnost.~ */ EXIT
IF ~~ THEN REPLY #988 /* ~Zhluboka se nadýchni, zakruť hlavou a ignoruj lebku, která na tebe mluví.~ */ EXIT
IF ~~ THEN REPLY #17833 /* ~"Jsem si jist, že máš tisíc "mouder", která chceš říct, Morte, ale já potřebuju abys zavřel klapačku a připojil se ke mně, TEĎ HNED."~ */ DO ~GiveItem("KeyPR",Protagonist) SetGlobal("Morte","GLOBAL",1) SetGlobal("Scars","GLOBAL",1) ChangeAIScript("pcmorte",DEFAULT) JoinPartyEx(TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 1 // from: 0.0 29.0 31.0
SAY #990 /* ~"Já?" Lebka vypadá pobouřeně. "Co kdybys začal *ty* první, zjizvenče? Kdo seš?"~ */
IF ~~ THEN REPLY #992 /* ~"Já... nevím."~ */ GOTO 2
IF ~~ THEN REPLY #995 /* ~"Já nevím... nemůžu si vzpomenout."~ */ GOTO 3
IF ~~ THEN REPLY #993 /* ~"Já se tě ptal první, lebko."~ */ GOTO 4
IF ~~ THEN REPLY #991 /* ~Ignoruj lebku a prohledej místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 2 // from: 1.0 4.0 5.0
SAY #997 /* ~"Ty nevíš, kdo seš, jo? Tos mi *měl* rovnou říct, 'vyliž si, kámo.' Dobře, to je v pohodě... předstírejme, že seš úplně mimo. Uvidím jestli jsem ve formě. Já jsem Morte. Zdravím tě, vítej a tak dále a tak dále."~ */
IF ~~ THEN REPLY #998 /* ~"Kde to jsem, Morte?"~ */ GOTO 6
IF ~  Global("Scars","GLOBAL",1) ~ THEN REPLY #1006 /* ~"Víš, jak se odtud můžu teď dostat pryč?"~ */ GOTO 21
IF ~~ THEN REPLY #1080 /* ~"Jak jsem se sem dostal?"~ */ GOTO 20
IF ~~ THEN REPLY #1087 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 3 // from: 1.1 4.1 5.1
SAY #999 /* ~"Ty si *nevzpomínáš?* To teda musela bejt noc. Doufám, žes nikoho nezranil... jmenuju se Morte. Zdravím tě, vítej a tak dále a tak dále." Na chvíli mlčí. "Řekněme, že se tě *musím* na něco zeptat: seš jeden z těch Vnímavejch co sami sebe mrzačej nebo tě někdo podaroval těmahle hezkejma jizvama?" ~ */
IF ~~ THEN REPLY #1000 /* ~"Vnímavejch?"~ */ GOTO 12
IF ~~ THEN REPLY #1001 /* ~"Jizvy?"~ */ GOTO 13
IF ~~ THEN REPLY #1002 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 4 // from: 1.2
SAY #1003 /* ~"Jo a já se tě ptal druhej. Jak se menuješ?"~ */
IF ~~ THEN REPLY #1004 /* ~"Já... nevím."~ */ GOTO 2
IF ~~ THEN REPLY #1005 /* ~"Já nevím... nemůžu si vzpomenout."~ */ GOTO 3
IF ~~ THEN REPLY #1007 /* ~"Ty první, lebko."~ */ GOTO 5
IF ~~ THEN REPLY #994 /* ~Ignoruj lebku a prohledej místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 5 // from: 4.2
SAY #1008 /* ~"Chlape, ty seš víc kluzkej než mokrá guma. Dobře, dobře... *budu* teda hodnej kluk... já, já sem Morte. Morte Rictusgrin. A teď mi řekni to svoje nešťastný méno?"~ */
IF ~~ THEN REPLY #1009 /* ~"Já... nevím."~ */ GOTO 2
IF ~~ THEN REPLY #1010 /* ~"Já nevím... nemůžu si na nic vzpomenout."~ */ GOTO 3
IF ~~ THEN REPLY #1011 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 6 // from: 2.0 29.1 31.1
SAY #1012 /* ~"Teď seš v díře zvané Márnice... je to velká černá stavba připomínající svou architekturou gravidního pavouka."~ */
IF ~~ THEN REPLY #1013 /* ~"'Márnice?' Jsem mrtvý?"~ */ GOTO 7
IF ~  Global("Scars","GLOBAL",1) ~ THEN REPLY #1015 /* ~"Jak se odtud dostanu pryč?"~ */ GOTO 21
IF ~~ THEN REPLY #1085 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 7 // from: 6.0 9.0
SAY #1014 /* ~"No, teď to sám nevím... ale Márnice má prostě nejblíž k márnici, nic jinýho v tom šéfe nehledej. Chlapíci sem tahaj mrtvoly, jiní je pohřbívaj a spalujou a kdybys měl *opravdový* štěstí, probudil by ses jako otrok. Není to zrovna nejlepší místo na Sférách. Bejt tebou, prokopal bych se nejbližším východem ven a dal bych tomudle místu sbohem."~ */
IF ~~ THEN REPLY #1016 /* ~"Promiň... 'Márnice?' Co je tohle za místo?"~ */ GOTO 10
IF ~~ THEN REPLY #1017 /* ~"Probudit se jako otrok?"~ */ GOTO 9
IF ~~ THEN REPLY #1018 /* ~"Dokud ještě můžu chodit?"~ */ GOTO 11
IF ~  CheckStatGT(Protagonist,11,INT) ~ THEN REPLY #1019 /* ~"Říkáš, že sem lidi tahají mrtvá těla? Takhle jsem se sem dostal?"~ */ GOTO 8
IF ~~ THEN REPLY #1020 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 8 // from: 7.3
SAY #1021 /* ~Zmlkne. "Joo, myslím, že jo. Možná si nějakej povaleč myslel, žes byl mrtvej a sebral tě z ulice. To tvoje zjizvený tělo *mě* dost zblblo... možná bys měl najít toho chlápka, co tě sem dotáhnul a zeptat se ho, ne?" Morte přikyvuje. "Sem rád, že je tvoje hlava ještě vcelku."~ */
IF ~~ THEN REPLY #1029 /* ~"Proč by mě sem někdo přivedl?"~ */ GOTO 14
IF ~~ THEN REPLY #1030 /* ~"Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1137 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 9 // from: 7.1
SAY #1022 /* ~"Joo, vypadáš naprosto rozkošně... s výjimkou použití toho smradlavýho formaldehydu a zpětnýho přišití tvý nohy, která ti upadla, je to paráda."~ */
IF ~~ THEN REPLY #1113 /* ~"Předpokládám, že jsem tady? Jsem mrtvý?"~ */ GOTO 7
IF ~~ THEN REPLY #1114 /* ~"Jak vypadám? Jsem hodně zjizvený?"~ */ GOTO 13
IF ~~ THEN REPLY #1115 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1116 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 10 // from: 7.0
SAY #1023 /* ~"No... přesně jak sem řek, Márnice. Seš v pohodě, šéfe? Nevypadáš moc dobře."~ */
IF ~~ THEN REPLY #1109 /* ~"Předpokládám, že jsem tady? Jsem mrtvý?"~ */ GOTO 16
IF ~~ THEN REPLY #1110 /* ~"Jak *vypadám*? Jak hodně jsem zjizvený?"~ */ GOTO 13
IF ~~ THEN REPLY #1111 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1112 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 11 // from: 7.2
SAY #1024 /* ~"Šéfe, já bych to viděl tak, že tvoje povalování na tomhle šutru bylo pouze mrhání časem. Jestli chceš vědět můj názor, vypadáš, jako bys v noci souložil s chlastem."~ */
IF ~~ THEN REPLY #1133 /* ~"Je to možný, že jsem mrtvý? A proto jsem tady?"~ */ GOTO 16
IF ~~ THEN REPLY #1134 /* ~"Jak moc špatně vypadám?"~ */ GOTO 13
IF ~~ THEN REPLY #1135 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1136 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 12 // from: 3.0 33.0
SAY #1025 /* ~"Ty nevíš kdo jsou to Vnímaví? Aaaa, *běž* se léčit! Je to skupina hňupů, která všechno co se na sférách vyskytuje, musí odzkoušet, včetně... no teď to nebudu rozebírat. Jak jsi k těm jizvám přišel?"~ */
IF ~~ THEN REPLY #1027 /* ~"Jizvy?"~ */ GOTO 13
IF ~~ THEN REPLY #1028 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1143 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 13 // from: 3.1 9.1 10.1 11.1 12.0 33.1
SAY #1026 /* ~"To je jako by se nějakej čipera rozhodl, že tě pomaluje nožem. Máš jizvy opravdu všude... dokonce i na zádech, jizvy nemáš snad jenom na..." Zmlkne. "Řekněme, že máš na zádech celou tetovací galerii, šéfe. Snad se to dá i přečíst..."~ */
IF ~~ THEN REPLY #1088 /* ~"Co se říká?"~ */ DO ~SetGlobal("Scars","GLOBAL",1) ~ GOTO 34
IF ~~ THEN REPLY #1089 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1090 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 14 // from: 8.0 29.3
SAY #1031 /* ~"Někteří lidi sbíraj mrtvoly z ulic a prodávají je sem za škváru. Není to zrovna nejlepší způsob obživy, ale když žiješ v týdle díře na Sférách, tvý možnosti jsou hodně omezený."~ */
IF ~~ THEN REPLY #1032 /* ~"Škváru? Jakou škváru'?"~ */ GOTO 15
IF ~~ THEN REPLY #1033 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1142 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 15 // from: 14.0
SAY #1034 /* ~"No... prachy. Škvára jsou prachy. Tam odkud pocházíš, to snad neměli?"~ */
IF ~~ THEN REPLY #1035 /* ~"Nemůžu si vzpomenout, odkud sem."~ */ GOTO 19
IF ~~ THEN REPLY #1036 /* ~"Zapomeň na to. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1138 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 16 // from: 10.0 11.0
SAY #1037 /* ~Odmlčí se. "Nevím. Ty se mnou *mluvíš*... ty chodící mrtvoly tady okolo to obvykle nedělají. Já bych to viděl tak, že Spalovači udělali chybu a tys nebyl ještě mrtvej. Nevzpomeneš si, nepodepsal jsi nějakej druh smlouvy? Když se nad tím zamyslím, obvykle si nechaj podepisovat různý druhy legálních papírů před tím, než můžou někoho zapsat do Knihy mrtvejch."~ */
IF ~~ THEN REPLY #1038 /* ~"Co... smlouva? Ne, nevzpomínám si, že bych nějakou podepisoval. Já... si nevzpomínám totiž skoro na nic."~ */ GOTO 32
IF ~~ THEN REPLY #1039 /* ~"Knihy mrtvých?"~ */ GOTO 17
IF ~~ THEN REPLY #1040 /* ~"Legálních?"~ */ GOTO 18
IF ~~ THEN REPLY #1041 /* ~"Zapomeň na to. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1150 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 17 // from: 16.1 18.0
SAY #1042 /* ~"Joo, 'knihy mrtvejch.' Znáš to? Hmm, možná taky ne. Podívej, zapomeň na 'knihu mrtvejch.' Ty seš naživu, takže v ní zapsanej nejseš."~ */
IF ~~ THEN REPLY #1151 /* ~"Co to bylo ta legální... smlouva... o které ses zmiňoval?"~ */ GOTO 18
IF ~~ THEN REPLY #1152 /* ~"Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1153 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 18 // from: 16.2 17.0
SAY #1043 /* ~"Jo, nechtěl bys náhodou rozbít tyhle cihly? V Sigilu platí takový práva, že nemůžeš ani vypustit duši bez toho aniž bys nepodepsal jednu z těchhle smluv."~ */
IF ~~ THEN REPLY #1154 /* ~"Cos to říkal o 'knize mrtvých?'"~ */ GOTO 17
IF ~~ THEN REPLY #1155 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1156 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 19 // from: 15.0
SAY #1044 /* ~"U všemocnýho Boha a jeho mámy, *ty* seš úplně mimo. Vůbec tě nenapadá odkud pocházíš? Někde v neznámý dáli, národ Blbců postrádá svýho krále. To jsi byl vždycky takhle neznalej?"~ */
IF ~~ THEN REPLY #1139 /* ~"Já nevím... nemůžu si na nic vzpomenout."~ */ GOTO 32
IF ~~ THEN REPLY #1140 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1141 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 20 // from: 2.2 31.2
SAY #1045 /* ~"Šéfe, nic kloudnýho mě nenapadá. I když musím uznat, pěkně sis tu hrál na mrtvolku. Když jsi tu ležel, vůbec sem neviděl hejbat se tvou hruď, oči ani nemrkly... no prostě nic. Tys chlastal? Tak ses sem dostal?"~ */
IF ~~ THEN REPLY #1097 /* ~"Já nevím... nemůžu si na nic vzpomenout."~ */ GOTO 32
IF ~~ THEN REPLY #1098 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1099 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 21 // from: 2.1 6.1 29.2 30.0 31.3 34.2 35.1 36.1
SAY #1046 /* ~"Jo, to *je* dobrá otázka. Ubíhá ti čas, šéfe. Spalovači tě najdou a budou se snažit napravit ten "problém" s tvým vzkříšením tak, že tě hoděj do krematoria. A jestli si chceš dál tady hrát na mrtváka, dostaneš se do krematoria stejně. Takže co budem teď dělat?"~ */
IF ~~ THEN REPLY #1047 /* ~"Spalovači?"~ */ GOTO 30
IF ~~ THEN REPLY #1048 /* ~"Já... uteču."~ */ GOTO 22
IF ~~ THEN REPLY #1049 /* ~"Vysvětlím ti postavení těchhle... Spalovačů."~ */ GOTO 25
IF ~  CheckStatLT(Protagonist,12,INT) ~ THEN REPLY #1050 /* ~"Co mám dělat?"~ */ GOTO 23
IF ~  CheckStatGT(Protagonist,11,INT) ~ THEN REPLY #1051 /* ~"Proč mi to neřekneš? Zní to jako bys už znal odpověď."~ */ GOTO 23
IF ~~ THEN REPLY #1081 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 22 // from: 21.1
SAY #1052 /* ~"Ooo, *skvělej* nápad, šéfe! Proč *sem* na tohle nepřišel dřív? Jak chceš asi utýct, co? Dám ti takový malý vodítko: to vyžaduje trochu spolupráce."~ */
IF ~~ THEN REPLY #1053 /* ~"To mě zajímá. Pokračuj."~ */ GOTO 23
IF ~~ THEN REPLY #1054 /* ~"Zapomeň na to. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1145 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 23 // from: 21.3 21.4 22.0 26.0
SAY #1055 /* ~"Jak tak koukám, je úplně jasný, že musíš odtud vypadnout. Co se týče mě, já si můžu dovolit tady ještě počkat. Jediný nebezpečí *pro mne* je to, že tu chcípnu nudou. Mohli bysme si navzájem podat pomocnou ruku."~ */
IF ~~ THEN REPLY #1058 /* ~"Mluv dál..."~ */ GOTO 24
IF ~~ THEN REPLY #1059 /* ~"Vždyť nemáš žádný ruce. Jak bys mi *ty* mohl pomoct?"~ */ GOTO 24
IF ~~ THEN REPLY #1060 /* ~"Zapomeň na to. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1146 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 24 // from: 23.0 23.1
SAY #1061 /* ~"Možná to tak nevypadá, ale mohl bych ti pomoct vocaď vypadnout a ty bys zase mohl pomoct vocaď mně. Sice nemám ruce, takže sem trošku v nevýhodě, ale ty máš zase v hlavě prázdno. Já mám hodně zkušeností a vědomostí o tom, jak se z týdle díry dostat ven. Spolupracujme a dejme *naše hlavy dohromady.* Domluveno, šéfe?"~ */
IF ~~ THEN REPLY #1057 /* ~"Dohodnuto."~ */ GOTO 28
IF ~~ THEN REPLY #1062 /* ~"Domluveno. Mám takový divný pocit, že osud tomu chtěl, abychom cestovali spolu, Morte."~ */ GOTO 27
IF ~~ THEN REPLY #1063 /* ~"Zapomeň na to. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1147 /* ~"Ne díky. Povídání s tebou je dost únavný. Najdu si cestu odtud sám."~ */ EXIT
END

IF ~~ THEN BEGIN 25 // from: 21.2
SAY #1064 /* ~"Ooo, *skvělej* nápad, šéfe! Proč *jsem* na to nepřišel dřív?" Jeho tón hlasu zní posměvačně. "Mimochodem, pane Spalovač, zemřel sem a pak sem se probudil na kamenný desce vaší malý Márničky. Můžete mi prosím pomoct?" Jo, oni ti pomůžou, to teda joo. Budou se na tebe pár sekund dívat, pak zavolaj stráže a mrsknou tě do tvojí soukromý pece."~ */
IF ~~ THEN REPLY #1065 /* ~"To zní trošku přehnaně drsně... proč by to dělali?"~ */ GOTO 26
IF ~~ THEN REPLY #1066 /* ~"Nno, jejich strážní by museli být zatraceně dobří hoši, aby mě dostali."~ */ GOTO 26
IF ~~ THEN REPLY #1067 /* ~"Zapomeň na to. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1149 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 26 // from: 25.0 25.1
SAY #1068 /* ~"Věř mi... vůbec nezáleží na tom, jestli si myslíš, jakej seš tvrdej chlapák nebo co jim řekneš, oni tě zkrátka dostanou. Nemáš dost síly na to, aby ses proboural zdima týdle krypty a ani nemůžeš přežít žár Ohně z Elementární sféry. Probuzení z mrtvých je dost velkej problém, co se týče tady těch hlídačů. Nebuď idiot."~ */
IF ~~ THEN REPLY #1069 /* ~"Takže tvůj plán je...?"~ */ GOTO 23
IF ~~ THEN REPLY #1070 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1148 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 27 // from: 24.1
SAY #1071 /* ~"Osud může nakopat prdel každýmu, koho znáš. Poslouchej, šéfe. Podívej se na to, jak často se 'zlo' a 'osud' dostavujou spolu v jedný chvíli, a pak porozumíš jednomu z malých životních tajemství. Nejlepší věcí, kterou můžeš udělat, je říct osudu, aby si sbalil svejch pět švestek a šel o dům dál; je tu *vždycky* jiná volba, kterou ti osud nemůže nabídnout." ~ */
IF ~~ THEN REPLY #1073 /* ~"Budu si to pamatovat."~ */ GOTO 28
IF ~~ THEN REPLY #1074 /* ~"Už bylo dost keců. Jakej máš plán?"~ */ GOTO 28
END

IF ~~ THEN BEGIN 28 // from: 24.0 27.0 27.1
SAY #1072 /* ~"Fajn... tak padáme pryč, dejme tomuhle místu sbohem. Všechny dveře jsou zavřený, takže by se nám šiknul klíč. Možný je, že ho bude mít jedna z těch chodících mrtvol."~ */
IF ~~ THEN REPLY #1079 /* ~"Chodící mrtvoly?"~ */ DO ~SetGlobal("Morte","GLOBAL",1) ChangeAIScript("pcmorte",DEFAULT) JoinPartyEx(TRUE) ~ GOTO 240
END

IF ~~ THEN BEGIN 29 // from:
SAY #996 /* ~"Ooo, takže *teď* by sis chtěl znova pokecat s Mortem, joo?"~ */
IF ~~ THEN REPLY #1075 /* ~"Kdo jsi?"~ */ GOTO 1
IF ~~ THEN REPLY #1076 /* ~"Kde to jsem?"~ */ GOTO 6
IF ~  Global("Scars","GLOBAL",1) ~ THEN REPLY #1077 /* ~"Víš, jak se můžu dostat odtud ven?"~ */ GOTO 21
IF ~~ THEN REPLY #1078 /* ~"Jak jsem se sem dostal?"~ */ GOTO 14
IF ~~ THEN REPLY #1086 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 30 // from: 21.0
SAY #1082 /* ~"Spalovači? Oni hlídaj tohle místo tady. Nemůžeš je přehlídnout... jsou to ty lidičky s přičmoudlejma ksichtama. Říkaj si 'Spalovači' a hrajou si na to, že jsou společenství, ale je to jenom zkažená banda zbožňovatelů mrtvol. Já jen abys věděl, s kým máš tu čest."~ */
IF ~  Global("Scars","GLOBAL",1) ~ THEN REPLY #1083 /* ~"Takže jak se odtud dostanu pryč?"~ */ GOTO 21
IF ~~ THEN REPLY #1084 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
