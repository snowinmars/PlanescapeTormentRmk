IF ~~ THEN EXTERN ~DDAKKON~ 175
END

IF ~~ THEN BEGIN 566 // from:
SAY #54841 /* ~"Lebka, to jsem byl já," řekl MOrte potichu. "Žena byla nějaká kočka jménem Deionarra; toho lučištníka jsem nikdy neznal..."~ */
IF ~~ THEN EXTERN ~DDAKKON~ 177
END

IF ~~ THEN BEGIN 567 // from:
SAY #54842 /* ~"Jo..." Morte se otřásl. "Šéfe, ta Pevnost - *všude* jsou tam stíny..." stíny *všude*..."~ */
IF ~~ THEN EXTERN ~DDAKKON~ 178
END

IF ~~ THEN BEGIN 568 // from:
SAY #54843 /* ~"Mluvili ke mně jako Pilíř lebek..." Mortův hlas ztichl. "Oni *věděli*..."~ */
IF ~~ THEN REPLY #54844 /* ~"Dobře; hele vy dva: potřebuju, abyste mi řekli o Pevnosti všechno, co víte..."~ */ EXTERN ~DDAKKON~ 179
END

IF ~~ THEN BEGIN 569 // from:
SAY #54845 /* ~"Nemůžu ti víc říct, šéfe - jenom, že se rozdělíme, jakmile tam dorazíme. A to je VELKÝ místo a všude tam lezou stíny... a někde v té pevnosti je něco mnohem mocnější než *kdokoli* z nás."~ */
IF ~~ THEN EXTERN ~DDAKKON~ 182
END

IF ~~ THEN BEGIN 570 // from:
SAY #54846 /* ~"Nemůžu ti víc říct, šéfe - jenom, že se rozdělíme, jakmile tam dorazíme. A to je VELKÝ místo a všude tam lezou stíny... a někde v té pevnosti je něco mnohem mocnější než cokoli, na co jsi kdy narazil."~ */
IF ~~ THEN EXTERN ~DDAKKON~ 182
END

IF ~~ THEN BEGIN 571 // from:
SAY #55832 /* ~"Šéfe, máme tady problém - tenhle modron se vzbouřil."~ */
IF ~~ THEN REPLY #55833 /* ~"Vzbouřil?"~ */ GOTO 572
END

IF ~~ THEN BEGIN 572 // from: 571.0
SAY #55834 /* ~"Víš, někdy se do modrona dostane kousek chaosu a pak se to stane... no, řekl bych, že *nejlepší* vysvětlení je, že vzbouřenej modron je něco jako... nazpátek modron, převrácenej modron."~ */
IF ~~ THEN REPLY #55836 /* ~"Takže tohle je... převrácený modron?"~ */ EXTERN ~DNORDOM~ 21
END

IF ~~ THEN BEGIN 573 // from:
SAY #55837 /* ~"Šéfe, i když je to sranda, páčení stoličky z držky nějakýho baatezu by bylo asi užitečnější, než vykecávání se s tím pitomým polygonem."~ */
IF ~~ THEN REPLY #55839 /* ~"*Ty* víš, co jsou mechaničtí duchové, Morte?"~ */ GOTO 574
END

IF ~~ THEN BEGIN 574 // from: 573.0
SAY #55841 /* ~"Šéfe, nemám tušáka, vo čem to ta krychle točí."~ */
IF ~~ THEN REPLY #55842 /* ~"Myslel jsem, že ty jsi *expert* na Sféry."~ */ GOTO 575
IF ~~ THEN REPLY #55843 /* ~"Dobrá tedy. Nordome, mám pro tebe ještě další otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55844 /* ~"Tak na to zapomeň. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 575 // from: 574.0
SAY #55845 /* ~"Cco- Vím víc, než *ty*, ty vymazanej amneziaku! Kromě toho, tady máš tři kousky znalostí, ať ti v kebuli rachotí aspoň něco: za prvé, nejsou ŽÁDNÍ experti na sféry, za druhé, jsem tomu tvýmu expertovi blíž než kdokoli jiný, koho kdy potkáš, a za třetí, očekávám od tebe nějaký respekt. Proč? Viz druhej kousek."~ */
IF ~~ THEN REPLY #55846 /* ~"Dobrá tedy. Nordome, mám pro tebe ještě další otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55847 /* ~"Tak na to zapomeň. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 576 // from:
SAY #55848 /* ~"Mechanus? Nudný v každým slova smyslu, náčelníku. Představ si plac plnej modronů a velkejch votáčejících se koleček a máš velkou NUDNOU sféru Mechanus. Příliš mnoho zákonů, strašná otrava. Místo, na který nechceš ani myslet, natož ho navštívit."~ */
IF ~  NearbyDialog("DGrace") ~ THEN DO ~SetGlobal("Know_Source","GLOBAL",1) ~ EXTERN ~DGRACE~ 184
IF ~  !NearbyDialog("DGrace") ~ THEN REPLY #55849 /* ~"Nordome, co jsi to před tím myslel tím 'Nulovým domovem?'"~ */ EXTERN ~DNORDOM~ 65
IF ~  !NearbyDialog("DGrace") ~ THEN REPLY #55850 /* ~"To nic, Morte. Už jsem slyšel dost. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 577 // from:
SAY #55855 /* ~"Promiňte MI, Slečno Kněžko Zbožnosti, ale Mechanus JE nejnudnější místo ve vesmíru... jediná zajímavá věc na něm by byla, kdybys ji navštívila *ty*..." Morte zkroutil očima. "Ale mám pocit že i *to* by za chvíli ztratilo své kouzlo."~ */
IF ~~ THEN REPLY #55857 /* ~"Nordome, co jsi to před tím myslel tím 'Nulovým domovem?'"~ */ EXTERN ~DNORDOM~ 65
IF ~~ THEN REPLY #55858 /* ~"To nic, Morte. Už jsem slyšel dost. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 578 // from:
SAY #55860 /* ~"Všichni modroni jsou součásti té 'rezervy,' šéfe, je to něco jako velká energetická banka... když jeden z nich zemře, energie použitá na vytvoření modrona je absorbovaná do banky zpátky a je zní udělanej novej modron. Ale jde o to, že... když modron kapku zblbne, tak se nějak přeruší to spojení, ale modronovi zůstane trochu té energie."~ */
IF ~  NearbyDialog("Dgrace") ~ THEN EXTERN ~DGRACE~ 186
IF ~~ THEN REPLY #55862 /* ~"Takže... Nordome, je ten Mechanus zdrojem energie?"~ */ EXTERN ~DNORDOM~ 67
IF ~~ THEN REPLY #55864 /* ~"Aha. Nordome, mám pro tebe ještě další otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55865 /* ~"To je všechno, co jsem chtěl vědět. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 579 // from:
SAY #55867 /* ~Morte vrhl na Fall-From-Grace vražedný pohled. "*Dovolíš?* Já na tu otázku odpověděl. *JÁ jsem* tady zdroj informací, NE ty, jasný?"~ */
IF ~~ THEN EXTERN ~DGRACE~ 187
END

IF ~~ THEN BEGIN 580 // from:
SAY #55870 /* ~"Oh, už to chápu. Možná kdybych byl sukuba, poslouchal bys MĚ častějc, že jo? Možná kdybych ti ukázal sem tam kousek holý kůže, konečně bys mě trochu respektoval, he? To je pěkně slabý šéfe, pěkně slabý! Měl bych - "~ */
IF ~~ THEN EXTERN ~DGRACE~ 191
END

IF ~~ THEN BEGIN 581 // from:
SAY #55871 /* ~NULOVÝ UZEL~ */
IF ~~ THEN EXIT
END

IF ~~ THEN BEGIN 582 // from:
SAY #55873 /* ~"Oh, tak?! Já...?! No...! Jo, ty zkrátka... jo, slyšíš to, šéfe, co ta sukuba řekla? Má pravdu. Snáz se mi rozumí, jasný? Takže mě potřebuješ blízko sebe, jasan?"~ */
IF ~  CheckStatGT(Protagonist,15,INT) ~ THEN REPLY #55875 /* ~"Správně, takže mám další otázku: oba říkáte, že Nordom je částí toho Zdroje, ale je od něj odříznutý. A když modron zemře, tak ho Zdroj absorbuje. Jak to bude se Nordomem?"~ */ GOTO 583
IF ~~ THEN REPLY #55876 /* ~"Nikdy jsem netvrdil opak, Morte... Takže, Nordome, ten zdroj enegie, o kterém jsi mluvil, ten je z Mechanu?"~ */ EXTERN ~DNORDOM~ 67
IF ~~ THEN REPLY #55877 /* ~"Dobrá. Nordome, mám pro tebe ještě další otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55879 /* ~"To je všechno, co jsem chtěl vědět. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 583 // from: 582.0
SAY #55882 /* ~Morte přikývl.~ */
IF ~~ THEN REPLY #55884 /* ~"A když zemře, je vytvořen další Nordom."~ */ GOTO 584
END

IF ~~ THEN BEGIN 584 // from: 583.0
SAY #55886 /* ~"Eh... ne."~ */
IF ~~ THEN REPLY #55887 /* ~"Co se stane?"~ */ GOTO 585
END

IF ~~ THEN BEGIN 585 // from: 584.0
SAY #55890 /* ~"No, vezmou si jeho energii, náčelníku, a vyplivnou dalšího modrona, ale už to nebude Nordom, protože on už vlastně není modron. Má v sobě moc ze Sfér. Udělají náhradu, ale nebude jako Nordom."~ */
IF ~~ THEN REPLY #55892 /* ~"Takže... tím, že se vzbouřil, se stal... smrtelným?"~ */ GOTO 586
IF ~~ THEN REPLY #55894 /* ~"Dobrá. Nordome, mám pro tebe ještě další otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55895 /* ~"To je všechno, co jsem chtěl vědět. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 586 // from: 585.0
SAY #55897 /* ~Morte se na chvíli odmlčel. "No... jo, dalo by se to tak říct. Kdyby si nevzal do hlavy, že si zahraje na odpadlíka, byl by v pohodě... kdyby umřel, objevil by se úplně stejnej modron. Ale jelikož je 'naopak' - no, ta jeho část, kvůli který je on, bude fuč, jestli umře."~ */
IF ~~ THEN REPLY #55898 /* ~"Dobrá. Nordome, mám pro tebe ještě další otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55900 /* ~"To je všechno, co jsem chtěl vědět. Pojďme."~ */ EXTERN ~DNORDOM~ 74
END

IF ~~ THEN BEGIN 587 // from:
SAY #55901 /* ~"Aighhhh! Pro rány boží a kvůli mému zdravému rozumu, nech toho! Zadřou se mu kolečka, jestli se ho na to budeš vyptávat pořád dokola!"~ */
IF ~~ THEN REPLY #55902 /* ~"O *to* mi taky jde, Morte."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Nordom_5","GLOBALLaw",-1) ~ GOTO 588
IF ~~ THEN REPLY #55905 /* ~"No, chci znát odpověď, tak se jí z něj snažím vypáčit."~ */ GOTO 589
IF ~~ THEN REPLY #55906 /* ~"To nic. Mám pro Nordoma nějaké jiné otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55907 /* ~"Zapomeň na to. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 588 // from: 587.0
SAY #55909 /* ~"Oh." Morte se 'zašklebil.' "Mohls něco ŘÍCT. No, jen pokračuj. Jasně..." Morte *zacvakal* zubama v ubohé imitaci Nordoma. "Jestli chceš o modronech něco vědět, měl by ses zeptat MNE."~ */
IF ~~ THEN REPLY #55910 /* ~"Dobře, Morte... co mi můžeš říct o modronech?"~ */ GOTO 590
IF ~~ THEN REPLY #55912 /* ~"To nic. Mám pro Nordoma nějaké jiné otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55913 /* ~"Zapomeň na to. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 589 // from: 587.1
SAY #55914 /* ~"Hele, šéfe, NORMÁLNÍ modroni skoro vůbec nerozumí ničemu kromě svých základních úkolů, a tímdleten blbej polygon právě vlezl do Sfér. Nesnaž se tu krychli zmást, okej? Alespoň proto, že je docela dobře ozbrojenej. Jestli se chceš na něco zeptat ohledně modronů, ptej se mně, ne jeho."~ */
IF ~~ THEN REPLY #55915 /* ~"Dobře, Morte... co mi můžeš říct o modronech?"~ */ GOTO 590
IF ~~ THEN REPLY #55917 /* ~"To nic. Mám pro Nordoma nějaké jiné otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55918 /* ~"Zapomeň na to. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 590 // from: 588.0 589.0
SAY #55921 /* ~"Je to takhle, šéfe: Modroni, to sou tydle pitomý geometrický tvary, který pocvakávaj po svý domovský sféře Mechanus -- jsou tak organizovaní, uhlazení, a chtěli by, aby takovej byl i ZBYTEK mnohovesmíru. Proto jsou tak otravní."~ */
IF ~~ THEN REPLY #55923 /* ~"Co je špatného na tom, když se někdo snaží mnohovesmír víc zorganizovat?"~ */ GOTO 592
IF ~~ THEN REPLY #55925 /* ~"Co je Mechanus?"~ */ DO ~SetGlobal("Know_Mechanus","GLOBAL",1) ~ GOTO 591
IF ~~ THEN REPLY #55926 /* ~"To nic. Mám pro Nordoma nějaké jiné otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55928 /* ~"Zapomeň na to. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 591 // from: 590.1
SAY #55930 /* ~"Je to sféra, odkud jsou všechny tydle pružinkový mechanismy. Zeptej se ho na to, uvidíš, co ti řekne. Tam seděj a všechno uhlazujou a organizujou... zkatalogizuj tohle, dej *tohle* do pořádku, dej *támto* do pořádku, ať je to podle řádu a tak dále."~ */
IF ~~ THEN REPLY #55931 /* ~Pravdivě: "To mi zní jako ušlechtilý cíl. Co je špatného na tom, když se někdo snaží mnohovesmír víc zorganizovat?"~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Nordom_2","GLOBALLaw",2) ~ GOTO 592
IF ~~ THEN REPLY #55935 /* ~"Asi tě to zrovna nenadchlo."~ */ GOTO 592
IF ~~ THEN REPLY #55936 /* ~"Mám pro Nordoma nějaké jiné otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55937 /* ~"Zapomeň na to. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 592 // from: 590.0 591.0 591.1
SAY #55938 /* ~Morte přejel pohledem Nordoma, který drží svou levou kuši u hlavy, jako by jí naslouchal.~ */
IF ~~ THEN GOTO 593
END

IF ~~ THEN BEGIN 593 // from: 592.0
SAY #55940 /* ~"Protože, šéfe, chaos má svý místo. A dyž bude všecko tak, jak to vidí *modroni*, nebude to zrovna život, kerej by za cosi stál... teda alespoň ne pro mě. Chtěj mít všechno *strukturalizovaný*. Pfuj."~ */
IF ~~ THEN REPLY #55941 /* ~Pravdivě: "Souhlasím, chaos má své místo... příliš mnoho řádu a vše bude stagnovat. Hele, mám pro Nordoma nějaké jiné otázky..."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Nordom_4","GLOBALLaw",-2) ~ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55942 /* ~"Aha. Hele, mám pro Nordoma nějaké jiné otázky..."~ */ EXTERN ~DNORDOM~ 74
IF ~~ THEN REPLY #55944 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 594 // from:
SAY #56029 /* ~"*Líbí* se mi, jak voní. Je to hezké."~ */
IF ~~ THEN EXTERN ~DFHJULL~ 27
END

IF ~~ THEN BEGIN 595 // from:
SAY #56030 /* ~"Vydrž, šéfe... Baator, to jsou ŠPATNÉ zprávy. Ten fiend nám nejspíš lže... a i kdyby byl nějaký 'Pilíř Lebek', určitě najdeme někoho dalšího, kdo ví, jak dosáhnout Pevnosti *bez* toho, že bychom museli jít na jedno z nejnebezpečnějších míst v mnohovesmíru."~ */
IF ~~ THEN REPLY #56031 /* ~"Lžeš mi, Jedovatý Jazyku?"~ */ EXTERN ~DFHJULL~ 88
IF ~~ THEN REPLY #56032 /* ~"Proč tam nechceš jít, Morte?"~ */ GOTO 596
END

IF ~~ THEN BEGIN 596 // from: 595.1
SAY #56033 /* ~"Je to nebezpečné místo, šéfe. Radši bych tam nešel. Už sem tam byl a vůbec to tam není hezký. Jasný?"~ */
IF ~~ THEN REPLY #56034 /* ~"Promluvíme si o tom ještě později. Jedovatý Jazyku, mám nějaké otázky..."~ */ EXTERN ~DFHJULL~ 46
END

IF ~~ THEN BEGIN 597 // from:
SAY #56936 /* ~"Ten chlápek je *všude*!"~ */
IF ~~ THEN REPLY #56937 /* ~"Ano, ale pomohl nám. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 598 // from:
SAY #59827 /* ~(Prázdný)~ */
IF ~~ THEN EXIT
END

IF ~~ THEN BEGIN 599 // from:
SAY #60950 /* ~"Hej, být mrtvej zas nejni tak špatný. Koukni na to z tý světlý stránky... konečně už nebudeš muset debatovat s těma směšnejma kreténama."~ */
IF ~~ THEN REPLY #61111 /* ~"Ticho Morte. Já to zařídím. Můžeš mi říct co se stalo?"~ */ EXIT
IF ~~ THEN REPLY #61112 /* ~"Zapomeň na to. Odejdu v míru."~ */ EXIT
END

IF ~~ THEN BEGIN 600 // from:
SAY #61408 /* ~"Eh... no tak šéfiku... co na to říkáš? Co dybys pučil starýmu Mortemu zepár drobáků? Už si ani nepamatuju, kdy sem naposled, no však víš..."~ */
IF ~  PartyGoldGT(499) ~ THEN REPLY #61411 /* ~"Jistě, proč ne. Slečno?"~ */ EXTERN ~DUCHO~ 9
IF ~  PartyGoldLT(500) ~ THEN REPLY #61412 /* ~"Promiň Morte; ale nejsme na tom nejlíp."~ */ EXIT
IF ~~ THEN REPLY #61413 /* ~"Morte, už vážně musíme jít. Sbohem slečno."~ */ EXIT
END

IF ~~ THEN BEGIN 601 // from:
SAY #61409 /* ~"Paráda! Dík šéfiku!" Morte se otočil aby následoval ženu.~ */
IF ~~ THEN REPLY #61414 /* ~Počkej dokud se nevrátí.~ */ DO ~FadeToColor([20.0],0) Wait(3) FadeFromColor([20.0],0) ~ EXTERN ~DUCHO~ 10
END

IF ~~ THEN BEGIN 602 // from:
SAY #61410 /* ~Zdá se, že Morte jen matně zaregistroval tvou přítomnost a střídavě se pochichtává, nebo vzdychá.~ */
IF ~~ THEN REPLY #61415 /* ~"Fajn... nakonec to všechno dobře dopadlo. Sbohem slečno."~ */ EXIT
END

IF ~~ THEN BEGIN 603 // from:
SAY #61481 /* ~"Já? Já jsem hlava Vecny."~ [MRT562] */
IF ~~ THEN DO ~IncrementGlobal("Grace_Talked_Morte","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 604 // from:
SAY #61482 /* ~"Bohové jsou milosrdní!!"~ [MRT485] */
IF ~~ THEN DO ~IncrementGlobal("Grace_Talked_Morte","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 605 // from:
SAY #61483 /* ~"Je to dlouhej příběh kterej zahrnuje Hlavu Vecny. Nechci o tom mluvit."~ [MRT559A] */
IF ~~ THEN EXTERN ~BGRACE~ 3
END

IF ~~ THEN BEGIN 606 // from:
SAY #61484 /* ~"Můžeme *prosím* změnit téma?"~ [MRT559B] */
IF ~~ THEN DO ~IncrementGlobal("Grace_Talked_Morte","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 607 // from:
SAY #61485 /* ~"Já? Já jsem *slaďoušek Morte.*"~ [MRT560] */
IF ~~ THEN DO ~IncrementGlobal("Grace_Talked_Morte","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 608 // from:
SAY #61486 /* ~"Co mám říct? Jsem *strážníček Morte.*"~ [MRT561] */
IF ~~ THEN DO ~IncrementGlobal("Grace_Talked_Morte","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 609 // from:
SAY #61487 /* ~"Jen když si budu moct odpočinout na tvých poduškách."~ [MRT486A] */
IF ~~ THEN EXTERN ~BGRACE~ 7
END

IF ~~ THEN BEGIN 610 // from:
SAY #61488 /* ~"Nic! Vůbec nic. Absolutně nic."~ [MRT486B] */
IF ~~ THEN DO ~IncrementGlobal("Grace_Talked_Morte","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 611 // from:
SAY #61489 /* ~"Arf! Arf! Heh! Heh! Heh!"~ [MRT484] */
IF ~~ THEN DO ~SetGlobal("Grace_Talked_Morte","GLOBAL",0) ~ EXIT
END

IF ~~ THEN BEGIN 612 // from:
SAY #62890 /* ~"Ona je tanar'ri... sukuba, šefí."~ */
IF ~~ THEN EXTERN ~DGRACE~ 213
END

IF ~~ THEN BEGIN 613 // from:
SAY #63454 /* ~"No, hele, já se jaksi jen tak někam nepostavím. Víš, to je práce pro nohy."~ [MRT482] */
IF ~~ THEN EXTERN ~BANNAH~ 1
END

IF ~~ THEN BEGIN 614 // from:
SAY #63455 /* ~"Myslel jsem, že vypadáš dobře, ale už vim, že jsem měl šedej zákal!"~ [MRT483] */
IF ~~ THEN EXTERN ~BANNAH~ 3
END

IF ~~ THEN BEGIN 615 // from:
SAY #63456 /* ~"Když si mi poprvý vlezla na oči, myslel sem, že z toho šoku přestanu dejchat."~ [MRT524] */
IF ~~ THEN DO ~SetGlobal("Annah_Talked_Morte","GLOBAL",3) ~ EXIT
END

IF ~~ THEN BEGIN 616 // from:
SAY #63457 /* ~"Jak se tak říká... NARODIL JSEM SE S MÉNEM!"~ [MRT526] */
IF ~~ THEN EXTERN ~BANNAH~ 6
END

IF ~~ THEN BEGIN 617 // from:
SAY #63458 /* ~"Divný, že to vůbec vytahuješ... no, jenom jsem se jich ptal, kolik by za tebe zaplatili."~ [MRT531] */
IF ~~ THEN EXTERN ~BANNAH~ 8
END

IF ~~ THEN BEGIN 618 // from:
SAY #63459 /* ~"Poslyš, možná by bylo lepší neotvírat vůbec hubu. Vypadáš tak líp."~ [MRT530] */
IF ~~ THEN EXTERN ~BANNAH~ 10
END

IF ~~ THEN BEGIN 619 // from:
SAY #63460 /* ~"Oh, ale ty už sis získala mé srdce."~ [MRT532] */
IF ~~ THEN EXTERN ~BANNAH~ 12
END

IF ~~ THEN BEGIN 620 // from:
SAY #63462 /* ~"Nenapadá mě pitomější možnost."~ [MRT525] */
IF ~~ THEN DO ~SetGlobal("Annah_Talked_Morte","GLOBAL",8) ~ EXIT
END

IF ~~ THEN BEGIN 621 // from:
SAY #63463 /* ~"Víš, ty si taky tak *trochu* fiend."~ [MRT533A] */
IF ~~ THEN EXTERN ~BANNAH~ 15
END

IF ~~ THEN BEGIN 622 // from:
SAY #63464 /* ~"Hele, mám takovou otázečku. Nejseš náhodou taky tak trochu fiend?"~ [MRT533B] */
IF ~~ THEN DO ~SetGlobal("Annah_Talked_Morte","GLOBAL",0) ~ EXIT
END

IF ~~ THEN BEGIN 623 // from:
SAY #63666 /* ~"To už jsem postřeh. Proč nejdeš taky pro změnu otravovat šéfíka, co?"~ [MRT563] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Morte","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 624 // from:
SAY #63667 /* ~"Kvůli levitaci, ty stupidní pikslo."~ [MRT468A] */
IF ~~ THEN EXTERN ~BNORDOM~ 2
END

IF ~~ THEN BEGIN 625 // from:
SAY #63668 /* ~"Tak proč nejseš i ty výřečnějsí než samotný slova, chrastící pikslo?"~ [MRT469A] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Morte","GLOBAL",3) ~ EXIT
END

IF ~~ THEN BEGIN 626 // from:
SAY #63669 /* ~"Počkej, počkej. Nic takovýho bych já z huby nevypustil!"~ [MRT470B] */
IF ~~ THEN EXTERN ~DANNAH~ 315
END

IF ~~ THEN BEGIN 627 // from:
SAY #63670 /* ~"Ještě nosí Annah oblečení?"~ [MRT565A] */
IF ~~ THEN EXTERN ~BNORDOM~ 6
END

IF ~~ THEN BEGIN 628 // from:
SAY #63671 /* ~"Takže odpovídám: mám cíl."~ [MRT565B] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Morte","GLOBAL",5) ~ EXIT
END

IF ~~ THEN BEGIN 629 // from:
SAY #63672 /* ~"Budeš mít i devatenáctej, jestli nesklapneš poklop."~ [MRT564] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Morte","GLOBAL",6) ~ EXIT
END

IF ~~ THEN BEGIN 630 // from:
SAY #63673 /* ~"Jestli myslíš, že mě otravuješ, kdy se ti zachce, pak jo."~ [MRT569A] */
IF ~~ THEN EXTERN ~BNORDOM~ 9
END

IF ~~ THEN BEGIN 631 // from:
SAY #63674 /* ~"Vítam tě ve sférách, chlapče."~ [MRT569B] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Morte","GLOBAL",7) ~ EXIT
END

IF ~~ THEN BEGIN 632 // from:
SAY #63675 /* ~"Už je Fall-From-Grace nahá?"~ [MRT568A] */
IF ~~ THEN EXTERN ~BNORDOM~ 11
END

IF ~~ THEN BEGIN 633 // from:
SAY #63676 /* ~"Ano, mám cíl."~ [MRT568B] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Morte","GLOBAL",8) ~ EXIT
END

IF ~~ THEN BEGIN 634 // from:
SAY #63677 /* ~"Když se ty, Annah a Fall-From-Grace koupete v Cimmerianským bahně."~ [MRT571A] */
IF ~~ THEN EXTERN ~BNORDOM~ 13
END

IF ~~ THEN BEGIN 635 // from:
SAY #63678 /* ~"Počkej, počkej. Někdo si slovník přečtě, někdo ho ale napíše, víš."~ [MRT572B] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Morte","GLOBAL",9) ~ EXIT
END

IF ~~ THEN BEGIN 636 // from:
SAY #63679 /* ~"Annah, flaška Furyondianskýho ohnivýho jantaru a průvod na Radnici."~ [MRT573] */
IF ~~ THEN EXTERN ~BNORDOM~ 15
END

IF ~~ THEN BEGIN 637 // from:
SAY #63680 /* ~"Drrrrrrrrrrrrrrrrž Hubu!"~ [MRT471D] */
IF ~~ THEN EXTERN ~BNORDOM~ 17
END

IF ~~ THEN BEGIN 638 // from:
SAY #63681 /* ~"Hele, bež otravovat někoho jinýho, příteli Bedno."~ [MRT576A] */
IF ~~ THEN EXTERN ~BNORDOM~ 19
END

IF ~~ THEN BEGIN 639 // from:
SAY #63682 /* ~"Sakra já nevim. Pochop to. Právě je... je... vždyť víš...  no někam si odskočilo."~ [MRT576B] */
IF ~~ THEN EXTERN ~BNORDOM~ 20
END

IF ~~ THEN BEGIN 640 // from:
SAY #63683 /* ~"Já ti ukážu, jestli nezavřeš hubu, err, teda víko."~ [MRT576C] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Morte","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 641 // from:
SAY #63684 /* ~"Polib mědvědí prdel."~ [MRT575A] */
IF ~~ THEN EXTERN ~DGRACE~ 373
END

IF ~~ THEN BEGIN 642 // from:
SAY #63685 /* ~"Věř mi. Annah by se ten polibek hodil."~ [MRT575B] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Morte","GLOBAL",0) ~ EXIT
END

IF ~~ THEN BEGIN 643 // from:
SAY #63686 /* ~::Prapodivně zaskřípal::~ [MRT472A] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Annah","GLOBAL",0) ~ EXIT
END

IF ~~ THEN BEGIN 644 // from:
SAY #63688 /* ~"Přiznej se, že sis to vymyslel!"~ [MRT473D] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Grace","GLOBAL",2) ~ EXIT
END

IF ~~ THEN BEGIN 645 // from:
SAY #63689 /* ~"To je čistě biologická záležitost, bedno skopová. No... nic, co bys pochopil."~ [MRT577] */
IF ~~ THEN DO ~SetGlobal("Nordom_Talked_Grace","GLOBAL",3) ~ EXIT
END

IF ~~ THEN BEGIN 646 // from:
SAY #63858 /* ~"Věř mi, nikdy si se s ním nesetkal."~ [MRT475AA] */
IF ~~ THEN EXTERN ~BVHAILOR~ 1
END

IF ~~ THEN BEGIN 647 // from:
SAY #64990 /* ~"Počkej, šéfe... podívej na tohle." Upřením zraku dolů, sis všiml množství špinavých stop, které vedly do výklenku... a neotáčely se. "Musí tu být portál nebo něco."~ */
IF ~~ THEN REPLY #64991 /* ~"Portál? Jak ho můžeme otevřít?"~ */ GOTO 648
IF ~~ THEN REPLY #64993 /* ~"Možná. Pojďme tedy."~ */ EXIT
END

IF ~~ THEN BEGIN 648 // from: 647.0
SAY #64992 /* ~"Nepropadej panice šéfe. Může to být nějaký obyčejný klíč - podívej se na ten provoz, co tudy prochází! Možná by to mohl vědět někdo z těch níže žijících..."~ */
IF ~~ THEN REPLY #64994 /* ~"Poptám se kolem. Pojďme tedy."~ */ EXIT
END

IF ~~ THEN BEGIN 649 // from: 329.0 729.0
SAY #65552 /* ~"Ah, *no tak,* šéfe. Neříkej mi, že si znovu zapomněl."~ */
IF ~~ THEN REPLY #65553 /* ~"Potřebuji si jen vzpomenout."~ */ GOTO 650
IF ~  Global("Morte_Warning","GLOBAL",1) ~ THEN REPLY #65554 /* ~"Ne, myslím, že jsem už o tom slyšel už všechno - pokračuj, připomeň mi to."~ */ GOTO 650
IF ~~ THEN REPLY #65555 /* ~"V pořádku. Mám nějaké další otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65556 /* ~"Zapomeň na to. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 650 // from: 649.0 649.1
SAY #65557 /* ~"Sázím se, že to budu poslouchat ještě dlouho." Morte křičí zplna hrdla. "Podívejme se..."  "Vím, že se cítíš, jako bys vypil několik džberů bahna z řeky Styx, ale teď by ses měl trošičku soustředit. Někde kolem tebe by se měl válet deník, který ti osvětlí, co se vlastně děje. Zbytek ti dopoví Pharod, pokud tedy ještě není zapsán v Knize mrtvých."~ */
IF ~  Global("Pharod","GLOBAL",0) ~ THEN REPLY #65558 /* ~"Pharod... hmmm. Nepřestávej."~ */ GOTO 651
IF ~  GlobalGT("Pharod","GLOBAL",0) ~ THEN REPLY #65559 /* ~"Nepřestávej."~ */ GOTO 651
IF ~~ THEN REPLY #65560 /* ~"V pořádku. Chci se tě ještě na něco zeptat..."~ */ GOTO 329
IF ~~ THEN REPLY #65561 /* ~"Zapomeň na to. Slyšel jsem dost. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 651 // from: 650.0 650.1
SAY #65562 /* ~"Budu, budu, vydrž." Morte na chvíli zmlkl. "V pořádku, toto je poslední..."  "Hlavně ten deník neztrať, protože pak bychom zase byli v bahně Styxu. A ať už děláš cokoliv, neříkej NIKOMU, kdo jsi nebo co se ti stalo, jinak by ses taky mohl pěkně rychle podívat do krematoria. Udělej, co ti říkám: PŘEČTI si deník, pak NAJDI Pharoda."~ */
IF ~  Global("Morte_Tattoo_XP","GLOBAL",1) ~ THEN GOTO 653
IF ~  Global("Morte_Warning","GLOBAL",1) ~ THEN REPLY #65566 /* ~"No tak. Co je tam dál?"~ */ GOTO 652
IF ~  Global("Journal","GLOBAL",0) ~ THEN REPLY #65565 /* ~"A neměl jsem u sebe deník když jsem se probral?"~ */ GOTO 682
IF ~~ THEN REPLY #65567 /* ~"V pořádku, tedy. Mám nějaké další otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65568 /* ~"Zapomeň na to. Slyšel jsem dost. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 652 // from: 651.1
SAY #65563 /* ~"O čem to hovoříš, šéfe? Tam není nic víc."~ */
IF ~  Global("Morte_Tattoo_XP","GLOBAL",0) ~ THEN REPLY #65569 /* ~"Co například, 'Nevěř lebce?'"~ */ DO ~SetGlobal("Morte_Tattoo_XP","GLOBAL",1) AddexperienceParty(1000) JOURNAL #65573 /* ~Řekl jsem Mortemu o novém řádku na mých zádech, který "zapomněl" přečíst. Tvrdil, že to není nic podstatného, tak mi to nepřečetl. Vím, že lže, ale ještě nevím proč. ~ */ GOTO 654
IF ~  Global("Morte_Tattoo_XP","GLOBAL",1) ~ THEN REPLY #65570 /* ~"Co například, 'Nevěř lebce?'"~ */ GOTO 654
IF ~~ THEN REPLY #65571 /* ~"Nevadí. Mám další otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65572 /* ~"V pořádku, tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 653 // from: 651.0
SAY #65564 /* ~"A samozřejmě, tahle troška nakonec, o nevěřících lebkách."~ */
