IF ~  !InParty("Morte") ~ THEN REPLY #54833 /* ~"Rozumím; díky za radu, Morte. Jsem připravený projít portálem."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 563 // from: 558.3
SAY #54834 /* ~"To, co Ravel řekla v bludišti, a to, co nám Fell řekl o tom symbolu - že k sobě přitahuješ trpící lidi, jako magnet." Morte zavrtěl hlavou. "Možná proto, že *ty* trpíš celou dobu. Možná, že až to vyřešíš... možná, že *všichni* poznáme kousek míru. Možná."~ */
IF ~  InParty("Morte") ~ THEN REPLY #54835 /* ~"Možná. Takže... jsi se mnou, Morte?"~ */ GOTO 534
IF ~  !InParty("Morte") ~ THEN REPLY #54836 /* ~"Rozumím; díky za radu, Morte. Jsem připravený projít portálem."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 564 // from: 558.4
SAY #54837 /* ~"Znám tě dlouho, šéfe. *Něco* na tobě je - přitajuješ k sobě trpící lidi jako magnet." Morte zavrtěl hlavou. "Možná proto, že *ty* trpíš celou dobu. Možná, že až to vyřešíš... možná že *všichni* poznáme kousek míru. Možná."~ */
IF ~  InParty("Morte") ~ THEN REPLY #54838 /* ~"Možná. Takže... jsi se mnou, Morte?"~ */ GOTO 534
