IF ~~ THEN EXTERN ~DDHALL~ 0
END

IF ~~ THEN BEGIN 104 // from:
SAY #5053 /* ~"A už vůbec bys neměl kecat s nemocnejma Spalovákama. No tak, pojď, vypadneme. Čím rychlejc z tohodle místa vypadneme, tím líp --"~ */
IF ~~ THEN EXTERN ~DDHALL~ 1
END

IF ~~ THEN BEGIN 105 // from:
SAY #6071 /* ~"Seš zpátky se mnou, šéfe? Si byl tak ňák kapku mimo."~ */
IF ~~ THEN REPLY #6075 /* ~"Ne, jsem v pořádku. Nevíš, co to bylo za ducha?"~ */ DO ~SetGlobal("Morte_Deionarra_Quip_1","GLOBAL",1) ~ GOTO 106
IF ~~ THEN REPLY #6076 /* ~"Jsem v pořádku. Jdeme dál."~ */ EXIT
END

