IF ~  Global("Mortai_Contract","GLOBAL",0) Global("Coppereyes_Contract","GLOBAL",0) ~ THEN REPLY #14278 /* ~"Dobře. Vypadněme odsud."~ */ EXTERN ~DAWAIT~ 15
END

IF ~~ THEN BEGIN 169 // from:
SAY #15339 /* ~"Roztrhni ho na dva kousky, šéfe. Ukaž mu, jak se to dělá!"~ */
IF ~~ THEN EXTERN ~DADYZOEL~ 19
END

IF ~~ THEN BEGIN 170 // from:
SAY #15340 /* ~"Jo, odpověz na otázky!"~ */
IF ~~ THEN EXTERN ~DADYZOEL~ 13
END

IF ~~ THEN BEGIN 171 // from:
SAY #15341 /* ~"Vsadím deset měděnejch na toho velkýho zjizvenýho!" Morte přilétne k tobě a zašeptá: To jsi jako ty, šéfe. Nepotop nás."~ */
IF ~~ THEN EXTERN ~DADYZOEL~ 20
END

IF ~~ THEN BEGIN 172 // from:
SAY #15342 /* ~"Dobře, šéfíku: Dej mu! Zkus na něj nějaký finty!"~ */
IF ~~ THEN EXTERN ~DADYZOEL~ 19
END

IF ~~ THEN BEGIN 173 // from:
SAY #15343 /* ~"To je pravda ty nafoukanej, navoněnej, cukroprdelatej elitisto... slyšels ho!"~ */
IF ~~ THEN EXTERN ~DADYZOEL~ 32
END

IF ~~ THEN BEGIN 174 // from:
SAY #15344 /* ~"Kdo že *jsem*? Mohl jsem být tvůj otec, ale ta opice mě předběhla na schodech!"~ */
IF ~~ THEN REPLY #15490 /* ~"Morte, buď už zticha."~ */ GOTO 175
IF ~~ THEN REPLY #15491 /* ~Nechej Morteho pokračovat.~ */ GOTO 175
END

IF ~~ THEN BEGIN 175 // from: 174.0 174.1
SAY #15345 /* ~"Copak princezno? Ztráta slov? Rač si zvednout spadlou čelist, než ti něco vlítne do krku! Jo, jo, slyšelas dobře! Sbal si svý zdobený podprsenky a běž se schovat pod maminčinu sukni, kam patříš! A vyřiď jí že ji pozdravu."~ */
IF ~~ THEN REPLY #15492 /* ~"Morte! ztichni už"~ */ DO ~IncrementGlobal("BD_MORTE_MORALE","GLOBAL",-1) ~ GOTO 176
IF ~~ THEN REPLY #15493 /* ~Nechej Morteho pokračovat.~ */ GOTO 177
END

IF ~~ THEN BEGIN 176 // from: 175.0
SAY #15346 /* ~"Co? Ó... promiň, šéfíku. Tenhle druh chlápka mě nebere..."~ */
IF ~~ THEN EXTERN ~DADYZOEL~ 33
END

IF ~~ THEN BEGIN 177 // from: 175.1
SAY #15347 /* ~"Proč, jestli jsem neznal nic lepšího, řekl bych-"~ */
IF ~~ THEN EXTERN ~DADYZOEL~ 33
END

IF ~~ THEN BEGIN 178 // from:
SAY #15348 /* ~"Co? Já jsem jenom mimir, šéfíku! Neumím se bít!'"~ */
IF ~~ THEN DO ~SetGlobal("Know_Mimir","GLOBAL",1) ~ EXTERN ~DADYZOEL~ 35
END

IF ~~ THEN BEGIN 179 // from:
SAY #15349 /* ~"To je, uuh... druh mluvící encyklopedie. Nerad o tom mluvím; je to trapné, skutečně."~ */
IF ~  GlobalLT("Morte_Mimir","GLOBAL",2) ~ THEN DO ~IncrementGlobalOnceEx("GLOBALMorte_Mimir","GLOBALMorte_Mimir",0) ~ EXTERN ~DADYZOEL~ 36
IF ~  GlobalGT("Morte_Mimir","GLOBAL",1) ~ THEN REPLY #65537 /* ~"Ale ty NEJSI mimir, Morte..."~ */ EXTERN ~DADYZOEL~ 36
END

IF ~~ THEN BEGIN 180 // from:
SAY #15350 /* ~"Hele, šéfíku... Ty ho necháš jen tak odejít? Pojď mu nakopat prdel! Půjdu mu po očích, zatímco ty po něm vyjedeš!"~ */
IF ~~ THEN REPLY #15494 /* ~"Máš pravdu... jdeme na něj."~ */ EXTERN ~DADYZOEL~ 19
IF ~~ THEN REPLY #15495 /* ~"Už je čas, Morte. Jdeme."~ */ DO ~SetGlobal("Adyzoel","AR0400",2) ~ EXIT
END

IF ~~ THEN BEGIN 181 // from: 185.0
SAY #16613 /* ~"He? Hm, jistě, náčelníku, samo -- jak poroučíš."~ */
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #16881 /* ~"Díky. Ale ještě něco mi leží na mysli, Truchlící..."~ */ EXTERN ~DMFTREE~ 28
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #16882 /* ~"Morte, já to myslím vážně. Tak mohl bys vyvinout nějakou snahu?"~ */ DO ~IncrementGlobal("Tree_Helpers","AR0400",1) ~ GOTO 182
IF ~~ THEN REPLY #16883 /* ~"Díky Morte. Sbohem, Truchlící za Stromy."~ */ EXIT
END

IF ~~ THEN BEGIN 182 // from: 181.1
SAY #16614 /* ~Morte na tebe chvíli v tichosti hledí a pak přitaká. "Jistě, můžu. Je-li to pro tebe důležité, udělám to."~ */
IF ~  NearbyDialog("DAnnah") Global("Tree_A","AR0400",0) ~ THEN REPLY #16884 /* ~"Díky. Annah? Mohla bys?"~ */ DO ~SetGlobal("Tree_A","AR0400",1) ~ EXTERN ~DANNAH~ 99
IF ~  NearbyDialog("DIgnus") Global("Tree_I","AR0400",0) ~ THEN REPLY #16885 /* ~"Díky. Ignusi?"~ */ DO ~SetGlobal("Tree_I","AR0400",1) ~ EXTERN ~DIGNUS~ 11
IF ~  NearbyDialog("DGrace") Global("Tree_G","AR0400",0) ~ THEN REPLY #16886 /* ~"Díky. Grace, zvážila bys to?"~ */ DO ~SetGlobal("Tree_G","AR0400",1) ~ EXTERN ~DGRACE~ 14
IF ~  NearbyDialog("DDakkon") Global("Tree_D","AR0400",0) ~ THEN REPLY #16887 /* ~"Díky. Dak'kone, mohl bys pomoci tomuto muži?"~ */ DO ~SetGlobal("Tree_D","AR0400",1) ~ EXTERN ~DDAKKON~ 74
IF ~  NearbyDialog("DDakkon") Global("Tree_D","AR0400",0) Global("Dakkon_Slave","Global",1) ~ THEN REPLY #16888 /* ~"Díky. Dak'kone, pomož tomuto muži."~ */ DO ~IncrementGlobal("BD_DAKKON_MORALE","GLOBAL",-1) SetGlobal("Tree_D","AR0400",1) ~ EXTERN ~DDAKKON~ 75
IF ~  NearbyDialog("DNordom") Global("Tree_N","AR0400",0) ~ THEN REPLY #16889 /* ~"Díky. Nordome, myslíš, že bys mohl pomoci tomuto muži?"~ */ DO ~SetGlobal("Tree_N","AR0400",1) ~ EXTERN ~DNORDOM~ 1
IF ~  NearbyDialog("DVhail") Global("Tree_V","AR0400",0) ~ THEN REPLY #16890 /* ~"Díky. Vhailore, zvládl bys pomoci?"~ */ DO ~SetGlobal("Tree_V","AR0400",1) ~ EXTERN ~DVHAIL~ 1
IF ~~ THEN REPLY #16891 /* ~"Díky. Ale ještě něco mi leží na mysli, Truchlící..."~ */ EXTERN ~DMFTREE~ 28
IF ~~ THEN REPLY #16892 /* ~"Díky Morte. Sbohem, Truchlící za Stromy."~ */ EXIT
END

IF ~~ THEN BEGIN 183 // from:
SAY #16615 /* ~"Víš, já *fakt* nevidím, že by to někam vedlo. Já si myslím - co tě nepálí, nehas. Stejnak tahle sorta lidí bude po špičkách obcházet na zahradě květák a v žádném případě nezahubí mola nebo červotoče - jsou to přece živé bytosti!"~ */
IF ~~ THEN EXTERN ~DNORDOM~ 2
END

IF ~~ THEN BEGIN 184 // from:
SAY #16616 /* ~"No, kluku a je to tady. Nemůžu *uveřit* tomu, že se hodláš babrat s takovým nesmyslem!"~ */
IF ~~ THEN EXTERN ~DNORDOM~ 3
END

IF ~~ THEN BEGIN 185 // from:
SAY #16617 /* ~"Víš, šéfíku, nejsem včerejší, už jsem leccos zažil... ale fakt, že to bylo *možné* mi moc klidné spaní nepřinese.~ */
IF ~  NearbyDialog("DMorte") Global("Tree_M","AR0400",0) ~ THEN REPLY #16893 /* ~"Děkuji ti, Nordome. Morte, jaký je tvůj názor?"~ */ DO ~SetGlobal("Tree_M","AR0400",1) ~ GOTO 181
IF ~  NearbyDialog("DAnnah") Global("Tree_A","AR0400",0) ~ THEN REPLY #16894 /* ~"Děkuji ti, Nordome. Annah, můžeš?"~ */ DO ~SetGlobal("Tree_A","AR0400",1) ~ EXTERN ~DANNAH~ 99
IF ~  NearbyDialog("DIgnus") Global("Tree_I","AR0400",0) ~ THEN REPLY #16895 /* ~"Děkuji ti, Nordome. Ignusi?"~ */ DO ~SetGlobal("Tree_I","AR0400",1) ~ EXTERN ~DIGNUS~ 11
IF ~  NearbyDialog("DGrace") Global("Tree_G","AR0400",0) ~ THEN REPLY #16896 /* ~"Děkuji ti, Nordome. Grace, mohla bys to zvážit?"~ */ DO ~SetGlobal("Tree_G","AR0400",1) ~ EXTERN ~DGRACE~ 14
IF ~  NearbyDialog("DDakkon") Global("Tree_D","AR0400",0) ~ THEN REPLY #16897 /* ~"Děkuji ti, Nordome. Dak'kone, dokázal bys pomoci tomuto muži?"~ */ DO ~SetGlobal("Tree_D","AR0400",1) ~ EXTERN ~DDAKKON~ 74
IF ~  NearbyDialog("DDakkon") Global("Tree_D","AR0400",0) Global("Dakkon_Slave","Global",1) ~ THEN REPLY #16898 /* ~"Děkuji ti, Nordome. Dak'kone: pomož tomuto muži."~ */ DO ~IncrementGlobal("BD_DAKKON_MORALE","GLOBAL",-1) SetGlobal("Tree_D","AR0400",1) ~ EXTERN ~DDAKKON~ 75
IF ~  NearbyDialog("DVhail") Global("Tree_V","AR0400",0) ~ THEN REPLY #16899 /* ~"Děkuji ti, Nordome. Vhailore, mohl bys pomoci?"~ */ DO ~SetGlobal("Tree_V","AR0400",1) ~ EXTERN ~DVHAIL~ 1
IF ~~ THEN REPLY #16900 /* ~"Děkuji ti, Nordome. Ještě bych se na něco přeptal, Truchlící..."~ */ EXTERN ~DMFTREE~ 28
IF ~~ THEN REPLY #16901 /* ~"Jsem ti vděčný, Nordome. Sbohem, Truchlící za Stromy."~ */ EXIT
END

IF ~~ THEN BEGIN 186 // from:
SAY #16618 /* ~"Sakra! Na to se nemůžu dívat!"~ */
IF ~~ THEN EXTERN ~DIGNUS~ 13
END

IF ~~ THEN BEGIN 187 // from:
SAY #17533 /* ~"Proč ne, šéfe? Až se budem nudit, můžem do nich kopat, ne? Hmm... No, vlastně do nich budeš kopat za mě. A taky bych chtěl vidět ten patnáct stop dlouhej skok!"~ */
IF ~  NearbyDialog("DAnnah") ~ THEN REPLY #17583 /* ~"Co myslíš, Annah?"~ */ EXTERN ~DANNAH~ 107
IF ~  PartyGoldGT(39) ~ THEN REPLY #17584 /* ~"Jednoho si vezmu, obchodníku."~ */ DO ~TakePartyGold(40) ~ EXTERN ~D300MER5~ 5
IF ~  PartyGoldGT(39) ~ THEN REPLY #17585 /* ~"Nechce se mi utrácet. Mám pár otázek, obchodníku..."~ */ EXTERN ~D300MER5~ 2
IF ~  PartyGoldGT(39) ~ THEN REPLY #17586 /* ~"Nechám si svoje měďáky, obchodníku. Sbohem."~ */ EXIT
IF ~  PartyGoldLT(40) ~ THEN REPLY #17587 /* ~"Nemám dost peněz, obchodníku, ale mám pár otázek..."~ */ EXTERN ~D300MER5~ 2
IF ~  PartyGoldLT(40) ~ THEN REPLY #17588 /* ~"Zapomeň na to obchodníku; Nemám na něj peníze. Sbohem."~ */ EXIT
END

IF ~~ THEN BEGIN 188 // from:
SAY #18801 /* ~Morte se otočí k Úlanovi. "Vypadni."~ */
IF ~~ THEN REPLY #18802 /* ~"Nedostaneš tu lebku."~ */ DO ~IncrementGlobal("BD_MORTE_MORALE","GLOBAL",1) ~ EXTERN ~DCOLYLFN~ 5
IF ~~ THEN REPLY #18803 /* ~"Toto není tvá lebka." ~ */ EXTERN ~DCOLYLFN~ 6
IF ~~ THEN REPLY #18804 /* ~Pravda: "Běž, vezmi si ji."~ */ EXTERN ~DCOLYLFN~ 9
IF ~~ THEN REPLY #18805 /* ~Zaútoč na něj, dokud se nebrání: "Běž, vezmi si ji."~ */ EXTERN ~DCOLYLFN~ 10
IF ~~ THEN REPLY #18578 /* ~Pravda: "Pokud mi nějak dokážeš, že tahle lebka ti právem patří, vrátím ti ji. To je fér"~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Yellow_1","GLOBALLaw",1) ~ EXTERN ~DCOLYLFN~ 12
IF ~~ THEN REPLY #18807 /* ~"Kdo jsi?"~ */ EXTERN ~DCOLYLFN~ 13
IF ~~ THEN REPLY #18808 /* ~"Koupím od tebe tu lebku. Platí?"~ */ DO ~IncrementGlobalOnceEx("GLOBALGood_Yellow_1","GLOBALGood",1) ~ EXTERN ~DCOLYLFN~ 14
END

IF ~~ THEN BEGIN 189 // from:
SAY #18809 /* ~Morte drží jeden z mužových prstů mezi zuby jako cigáro. Kecá přes tento prst: "Dotkni se mě ještě jednou a tvá ruka se přidá k tomuto prstu."~ */
IF ~~ THEN REPLY #18810 /* ~"Morte! Vrať tomu chlapovi jeho prst."~ */ GOTO 190
IF ~~ THEN REPLY #18811 /* ~"Chmm. Vypadni, ty psisko."~ */ EXTERN ~DCOLYLFN~ 11
IF ~~ THEN REPLY #18812 /* ~"To byla těžká zkouška. Sbohem."~ */ EXTERN ~DCOLYLFN~ 11
END

IF ~~ THEN BEGIN 190 // from: 189.0
SAY #18813 /* ~Morte vyplivne prst zpět na chlapa. Prst brnkne o mužovu hruď  a spadne na zem.~ */
IF ~~ THEN REPLY #18814 /* ~"Vypadni, pse."~ */ EXTERN ~DCOLYLFN~ 11
IF ~~ THEN REPLY #18815 /* ~"To byla těžká zkouška. Sbohem."~ */ EXTERN ~DCOLYLFN~ 11
END

IF ~~ THEN BEGIN 191 // from:
SAY #18816 /* ~Morte zahaleká: "Šéfiku, nic tomu mrzákovi nedávej."~ */
IF ~~ THEN REPLY #18817 /* ~"Já..." ~ */ EXTERN ~DCOLYLFN~ 15
END

IF ~~ THEN BEGIN 192 // from:
SAY #18818 /* ~Morte se otočí k chlapovi. "*Nemluvil* jsem s tebou, ty vypatlanej mozku. Až s tebou budu mluvit, tak to poznáš, protože budu vrčet a supět. Pochopils, doufám."~ */
IF ~~ THEN EXTERN ~DCOLYLFN~ 16
END

IF ~~ THEN BEGIN 193 // from:
SAY #18819 /* ~"Šéfe, *ne*"~ */
IF ~  PartyGoldGT(4) ~ THEN REPLY #18820 /* ~Dej mu pět měďáků. ~ */ DO ~TakePartyGold(5) ~ EXTERN ~DCOLYLFN~ 18
IF ~  PartyGoldGT(49) ~ THEN REPLY #18821 /* ~Dej mu padesát měďáků.~ */ DO ~TakePartyGold(50) ~ EXTERN ~DCOLYLFN~ 18
IF ~  PartyGoldGT(99) ~ THEN REPLY #18822 /* ~Dej mu sto měďáků.~ */ DO ~TakePartyGold(100) ~ EXTERN ~DCOLYLFN~ 18
IF ~  PartyGoldGT(499) ~ THEN REPLY #18823 /* ~Dej mu pět set měďáků.~ */ DO ~TakePartyGold(500) ~ EXTERN ~DCOLYLFN~ 18
IF ~  PartyGoldLT(5) ~ THEN REPLY #18824 /* ~"Nemám tolik peněz"~ */ EXTERN ~DCOLYLFN~ 19
IF ~~ THEN REPLY #18825 /* ~"Zapomeň na nabídku. Tahle lebka ti nepatří, takže na ni zapomeň"~ */ EXTERN ~DCOLYLFN~ 6
END

IF ~~ THEN BEGIN 194 // from:
SAY #18826 /* ~"Putuju s největším idiotem v mnohovesmíru."~ */
IF ~~ THEN REPLY #18827 /* ~"...a co teď, Žlutoprstej, hm? Okradu tě, a co ty teď uděláš, hm??"*~ */ EXTERN ~DCOLYLFN~ 20
IF ~~ THEN REPLY #18828 /* ~"A teď z jiného soudku, Žlutoprstej, mám pár otázek..."~ */ EXTERN ~DCOLYLFN~ 23
IF ~  CheckStatGT(Protagonist,11,INT) ~ THEN REPLY #18829 /* ~"Sbohem, Žlutoprstej."~ */ EXTERN ~DCOLYLFN~ 41
IF ~  CheckStatLT(Protagonist,12,INT) ~ THEN REPLY #18830 /* ~"Sbohem, Žlutoprstej."~ */ DO ~DestroyPartyGold(5) ~ EXIT
END

IF ~~ THEN BEGIN 195 // from:
SAY #18831 /* ~"Šéfe. Jdem"~ */
IF ~~ THEN EXTERN ~DCOLYLFN~ 52
END

IF ~~ THEN BEGIN 196 // from:
SAY #18832 /* ~"Není to vůbec  pěkný, v co se měním."~ */
IF ~  PartyGoldGT(4) ~ THEN REPLY #18833 /* ~Dej mu pět měďáků.~ */ DO ~TakePartyGold(5) ~ EXTERN ~DCOLYLFN~ 53
IF ~  PartyGoldGT(9) ~ THEN REPLY #18834 /* ~Dej mu deset měďáků.~ */ DO ~TakePartyGold(10) ~ EXTERN ~DCOLYLFN~ 53
IF ~  PartyGoldGT(49) ~ THEN REPLY #18835 /* ~Dej mu padesát měďáků.~ */ DO ~TakePartyGold(50) IncrementGlobalOnceEx("GLOBALGood_Yellow_2","GLOBALGood",1) ~ EXTERN ~DCOLYLFN~ 53
IF ~  PartyGoldGT(99) ~ THEN REPLY #18836 /* ~Dej mu sto měďáků.~ */ DO ~TakePartyGold(100) IncrementGlobalOnceEx("GLOBALGood_Yellow_2","GLOBALGood",1) ~ EXTERN ~DCOLYLFN~ 53
IF ~~ THEN REPLY #18837 /* ~"Beru to zpět. Odejdi a nechci tě už vidět."~ */ EXTERN ~DCOLYLFN~ 61
END

IF ~~ THEN BEGIN 197 // from:
SAY #19031 /* ~"Haló bouchači! Jak se daří tvému příteli ze stěny?"~ */
IF ~~ THEN EXTERN ~DOJO~ 11
END

IF ~~ THEN BEGIN 198 // from:
SAY #19032 /* ~Morte sklopil hlavu. "Nepovídej, šéfe."~ */
IF ~~ THEN REPLY #19033 /* ~"Dobrá. Ojo, mám nějaké otázky."~ */ EXTERN ~DOJO~ 12
IF ~~ THEN REPLY #19034 /* ~"To je v pořádku. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 199 // from:
SAY #19551 /* ~"Jů, šéfe... jaká to krása, eh? Ne všude se můžeš setkat s takovým lístečkem, jako je tento, víš."~ */
IF ~~ THEN REPLY #19666 /* ~"Na shnilých mrtvolách toho nacházím málo atraktivního, Morte, ať už jsou to ženy nebo ne."~ */ GOTO 200
IF ~~ THEN REPLY #19667 /* ~"No, když zapomeneme na ten pach hniloby, červy, rozpadající se maso..."~ */ GOTO 201
END

IF ~~ THEN BEGIN 200 // from: 199.0
SAY #19552 /* ~Morte koulí očima uvnitř celé lebky. "Huh! Jednou uvidíš, co tím myslím."~ */
IF ~  Global("Speak_With_Dead","GLOBAL",0) ~ THEN REPLY #19668 /* ~Ignoruj ho a pozdrav zombie.~ */ EXTERN ~DZOMCITF~ 1
IF ~  Global("Speak_With_Dead","GLOBAL",1) ~ THEN REPLY #19669 /* ~Ignoruj ho a pozdrav zombie.~ */ EXTERN ~DZOMCITF~ 3
END

IF ~~ THEN BEGIN 201 // from: 199.1
SAY #19553 /* ~"Jo, koukej, to je důvod, proč jsem... hej!" Morte se k tobě otočil čelem. "Pokračuješ v utahování si ze mě?"~ */
IF ~  Global("Speak_With_Dead","GLOBAL",0) ~ THEN REPLY #19670 /* ~Ignoruj ho a pozdrav zombie.~ */ EXTERN ~DZOMCITF~ 1
IF ~  Global("Speak_With_Dead","GLOBAL",1) ~ THEN REPLY #19671 /* ~Ignoruj ho a pozdrav zombie.~ */ EXTERN ~DZOMCITF~ 3
END

IF ~~ THEN BEGIN 202 // from:
SAY #19681 /* ~"Eh... nejsem si jistý, že si chceš promluvit s tou... věcí."~ */
IF ~~ THEN REPLY #19691 /* ~"Proč ne, Morte?"~ */ GOTO 203
IF ~~ THEN REPLY #19692 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
IF ~~ THEN REPLY #19693 /* ~Ignoruj Morteho a pozdrav ghúla.~ */ EXTERN ~DGHOCITM~ 1
END

IF ~~ THEN BEGIN 203 // from: 202.0
SAY #19682 /* ~"Dřív to bývali lidi... oni nebo jejich předci se krmili těly a stalo se z nich tohleto. Pěkně odporná banda, šéfe... nejsou fakt nic víc než zvířata. *Nebezpečný* zvířata, náčelníku. Hodně nebezpečný, zvlášť když ty vypadáš, jako jejich oblíbená potrava."~ */
IF ~~ THEN REPLY #19694 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
IF ~~ THEN REPLY #19695 /* ~"Stejně si s ním promluvím."~ */ EXTERN ~DGHOCITM~ 1
END

IF ~~ THEN BEGIN 204 // from:
SAY #19702 /* ~"Eh... nejsem si jistý, že si chceš promluvit s tou... věcí."~ */
IF ~~ THEN REPLY #19713 /* ~"Překvapuješ mne, Morte... je to nemrtvé, je to ženská. To tě většinou přece bere."~ */ GOTO 206
IF ~~ THEN REPLY #19714 /* ~"Proč ne, Morte?"~ */ GOTO 205
IF ~~ THEN REPLY #19715 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
IF ~~ THEN REPLY #19716 /* ~Ignoruj Morteho a pozdrav ghúla.~ */ EXTERN ~DGHOCITF~ 1
END

IF ~~ THEN BEGIN 205 // from: 204.1 206.0
SAY #19703 /* ~"Dřív to bývali lidi... oni nebo jejich předci se krmili těly a stalo se z nich tohleto. Pěkně odporná banda, šéfe... nejsou fakt nic víc než zvířata. *Nebezpečný* zvířata, náčelníku. Hodně nebezpečný, zvlášť když ty vypadáš jako jejich oblíbená potrava."~ */
IF ~~ THEN REPLY #19717 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
IF ~~ THEN REPLY #19718 /* ~"Stejně si s ní promluvím."~ */ EXTERN ~DGHOCITF~ 1
END

IF ~~ THEN BEGIN 206 // from: 204.0
SAY #19704 /* ~"Není to zrovna to samý. šéfe..."~ */
IF ~~ THEN GOTO 205
END

IF ~~ THEN BEGIN 207 // from:
SAY #20469 /* ~"Je slepá a skoro hluchá."~ */
IF ~~ THEN EXTERN ~DMARTA~ 9
END

IF ~~ THEN BEGIN 208 // from:
SAY #20470 /* ~"Myslím, že mluví o orgánech. Doufám, že mluví o orgánech."~ */
IF ~~ THEN EXTERN ~DMARTA~ 15
END

IF ~~ THEN BEGIN 209 // from:
SAY #20471 /* ~Morte se otočil k Martě. "Ano, 'věcičky'." Pak se otočil k tobě. "Jde o sémantiku."~ */
IF ~  GlobalLT("Know_Marta_Work","GLOBAL",3) ~ THEN REPLY #20612 /* ~"Marto, proč vytahuješ z mrtvol stehy a zuby?"~ */ DO ~SetGlobal("Know_Marta_Work","GLOBAL",3) JOURNAL #20538 /* ~Švadlena Marta má zajímavou práci - nosí k ní mrtvoly, ona jim vyrazí zuby, odpárá stehy a podívá se po jakýchkoli cennostech, které jsou na nebo dokonce v těle, pak je zase sešije dohromady.~ */ EXTERN ~DMARTA~ 16
IF ~  GlobalGT("Know_Marta_Work","GLOBAL",2) ~ THEN REPLY #20613 /* ~"Marto, proč vytahuješ z mrtvol stehy a zuby?"~ */ JOURNAL #20538 /* ~Švadlena Marta má zajímavou práci - nosí k ní mrtvoly, ona jim vyrazí zuby, odpárá stehy a podívá se po jakýchkoli cennostech, které jsou na nebo dokonce v těle, pak je zase sešije dohromady.~ */ EXTERN ~DMARTA~ 16
IF ~~ THEN REPLY #20614 /* ~"Uh... dobrá. Musím jít, Marto. Sbohem."~ */ EXIT
END

IF ~~ THEN BEGIN 210 // from:
SAY #20472 /* ~"Na tohle se dívat *nebudu*."~ */
IF ~~ THEN EXTERN ~DMARTA~ 24
END

IF ~~ THEN BEGIN 211 // from:
SAY #21602 /* ~"Oh, Při Mocnostech...! Zatracený dabus."~ */
IF ~~ THEN REPLY #24695 /* ~"Co se stalo?"~ */ GOTO 212
END

IF ~~ THEN BEGIN 212 // from: 211.0
SAY #21603 /* ~"Je to dabus. Oni 'mluví' v rébusech, tedy v těch debilních hádankách. Jestli nevíš co říká, tak bude lepší najít někoho zdejšího nebo jinej způsob k domluvě s ním... jestli s ním chceme mluvit. Nepříjemná banda. Můj tip? On *umí* mluvit, jenom radši každýho pošle do prdele tou svojí hádankou."~ */
IF ~~ THEN REPLY #24696 /* ~"Co je 'dabus?'"~ */ GOTO 213
END

IF ~~ THEN BEGIN 213 // from: 212.0
SAY #21604 /* ~"Jsou to sluhové Paní bolesti. Vznášejí se ve vzduchu okolo a rozbíjejí, opravují a záplatují Sigil podle jejích přání. Jsou méně než mouchy." Morte vzdychá. "Nicméně je nemůžeš zaplácnout, jinak by Paní byla... rozčarovaná."~ */
IF ~  Global("Know_Lady","GLOBAL",0) ~ THEN REPLY #24697 /* ~"'Paní Bolesti?' Kdo to je?"~ */ DO ~SetGlobal("Know_Lady","GLOBAL",1) ~ GOTO 214
IF ~  Global("Know_Lady","GLOBAL",1) ~ THEN REPLY #24698 /* ~"Co mi můžeš říct o Paní Bolesti?"~ */ GOTO 214
IF ~  Global("Know_Lady","GLOBAL",1) ~ THEN REPLY #24699 /* ~"Vím."~ */ EXTERN ~DFELL~ 8
END

IF ~~ THEN BEGIN 214 // from: 213.0 213.1
SAY #21605 /* ~"Řídí tohle město. Až ji uvidíš, tak ji poznáš: Má takový čepele kolem obličeje, je vysoká asi jako obr, a vznáší se nad zemí, zrovna jako tady ty chlápkové." Morte ukazuje na dabuse, který vás pozoruje. "Nikdo toho o ní moc neví... ona moc nemluví. Všechno co potřebuješ vědět je, že jí nechceš nasrat. Až jí uvidíš, radím ti: utíkej."~ */
IF ~  CheckStatLT(Protagonist,13,WIS) CheckStatGT(Protagonist,12,INT) ~ THEN REPLY #24700 /* ~"Uh... počkej chvíli. Řekl jsi, že dabusové se vznáší, správně? Jenže tenhle chodí po zemi."~ */ GOTO 215
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #24701 /* ~"Uh... počkej chvíli. Řekl jsi, že dabusové se vznáší, správně? Jenže tenhle chodí po zemi."~ */ GOTO 215
IF ~~ THEN REPLY #24702 /* ~"Vím."~ */ EXTERN ~DFELL~ 8
END

IF ~~ THEN BEGIN 215 // from: 214.0 214.1
SAY #21606 /* ~Morte kouká na Daba, a jeho oči se rozšíří. "Á-há! Já vím, že vy kozí hlavy umíte chodit! Já to vím!" Morte se k tobě nadšeně otáčí. "Cha! Tady ten nemůže bejt dost daleko, aby se zvednul ze země."~ */
IF ~~ THEN REPLY #24703 /* ~"Možná je to tak..."~ */ EXTERN ~DFELL~ 8
END

IF ~~ THEN BEGIN 216 // from:
SAY #21607 /* ~Morte se šklebí. "To dřív prolezu vnitřnostma tanar'riho než rozluštím co tadle kozí hlava chce říct. Chceš tlumočníka? Najdi si nějakýho Sigilana."~ */
IF ~~ THEN REPLY #24704 /* ~"Vím."~ */ EXTERN ~DFELL~ 8
END

IF ~~ THEN BEGIN 217 // from:
SAY #21608 /* ~Morte se šklebí. "To dřív prolezu vnitřnostma tanar'riho než rozluštím co tyhle lítající kozí hlavy zkoušej říct. Chceš tlumočníka? Vem si na to to fiendský mrně." Ukazuje na Annah. "Ona je z Úlu."~ */
IF ~~ THEN REPLY #24705 /* ~"Možná, že..."~ */ EXTERN ~DFELL~ 8
END

IF ~~ THEN BEGIN 218 // from:
SAY #21609 /* ~Morte se šklebí. "To dřív prolezu vnitřnostma tanar'riho než rozluštím co tyhle lítající kozí hlavy zkoušej říct. Chceš tlumočníka?" Ukáže na Dak'kona. "Vem si Svatějšího-než-ty-a-dvakrát-klidnějšího aby ti to přeložil."~ */
IF ~~ THEN REPLY #24706 /* ~"Možná, že..."~ */ EXTERN ~DFELL~ 8
END

IF ~~ THEN BEGIN 219 // from:
SAY #21610 /* ~Morte se šklebí. "To dřív prolezu vnitřnostma tanar'riho než rozluštím co tyhle lítající kozí hlavy zkoušej říct. Chceš tlumočníka? Vem si na to tanar'riho." Ukazuje na Fall-from-Grace. "Pravděpodobně si s tady těma hochama musela celou dobu vyměňovat novinky."~ */
IF ~~ THEN REPLY #24707 /* ~"Možná, že..."~ */ EXTERN ~DFELL~ 8
END

IF ~~ THEN BEGIN 220 // from:
SAY #22061 /* ~"Chceš je jen zabít. Vnímaví ohrožují Spalovače."~ */
IF ~~ THEN REPLY #22062 /* ~"Měl bych jiné otázky..."~ */ EXTERN ~DSOEGO~ 83
IF ~~ THEN REPLY #22063 /* ~"To je vše, co jsem si přál vědět. Sbohem."~ */ EXIT
END

IF ~~ THEN BEGIN 221 // from:
SAY #22849 /* ~Morte na tebe třeští oči a kýve hlavou.~ */
IF ~~ THEN REPLY #22850 /* ~"Co to je, krychlohrdino? 'Morte je stupidní lebka?' Proč, ano to je, nebo ne, krychlohrdino?"~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Cube_3","GLOBALLaw",-1) ~ GOTO 222
IF ~~ THEN REPLY #22851 /* ~Dej krychli pryč.~ */ EXIT
END

IF ~~ THEN BEGIN 222 // from: 221.0
SAY #22852 /* ~"Hej! To jsem neřekl!"~ */
IF ~~ THEN REPLY #22853 /* ~"Ale jo! Řekl!"~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Cube_4","GLOBALLaw",-1) ~ GOTO 223
IF ~~ THEN REPLY #22854 /* ~Dej krychli pryč.~ */ EXIT
END

IF ~~ THEN BEGIN 223 // from: 222.0
SAY #22855 /* ~"Což --?! Dej mi tu věc!"~ */
IF ~~ THEN REPLY #22856 /* ~"Ne, je moje. Každopádně mi tě chtěl vzít. Nemyslíš, krychlohrdino? Jasně, že jo!"~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Cube_5","GLOBALLaw",-1) ~ GOTO 224
IF ~~ THEN REPLY #22857 /* ~Dej krychli pryč.~ */ EXIT
END

IF ~~ THEN BEGIN 224 // from: 223.0
SAY #22858 /* ~"Já. Si. To. Jen. Chci. Na. Chvíli. Podržet."~ */
IF ~~ THEN REPLY #22859 /* ~"Ale ty nemáš žádný ruce."~ */ GOTO 225
IF ~~ THEN REPLY #22860 /* ~Dej krychli pryč.~ */ EXIT
END

IF ~~ THEN BEGIN 225 // from: 224.0
SAY #22861 /* ~"Podržím to v ZUBECH."~ */
IF ~~ THEN REPLY #22862 /* ~"Ne, myslím, že už to radši schovám."~ */ GOTO 226
END

IF ~~ THEN BEGIN 226 // from: 225.0
SAY #22863 /* ~"Rozmlátím tu modronskou krychli na kousíčky."~ [MRT251] */
IF ~~ THEN REPLY #22864 /* ~"Slyšíš něco, krychlohrdino? Ani já ne!"~ */ EXIT
END

IF ~~ THEN BEGIN 227 // from:
SAY #22892 /* ~"Oooooh!" Jak Craddock upouští páru, Mortemu scvaknou zuby... skoro slyšíš, jak si ve své lebce zapisuje poznámky.~ [MRT387] */
IF ~~ THEN EXTERN ~DCRADDO~ 15
END

IF ~~ THEN BEGIN 228 // from:
SAY #24174 /* ~"Víš, šéfe, dělá se mi na nic z těch jeho... pravidelných... pauz... konec konců... je to ... dobrá věc... že zavřel klapačku... teď."~ */
IF ~~ THEN REPLY #24175 /* ~"Moc legrační, Morte. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 229 // from:
SAY #24176 /* ~"Šéfe, co budeme dělat s nevyčerpatelným zdrojem vody? Kde je ten oheň, huh?"~ */
IF ~~ THEN REPLY #24177 /* ~"Může to být užitečné později, Morte. Jdeme."~ */ EXIT
IF ~~ THEN REPLY #24178 /* ~"Děláme správnou věc, Morte."~ */ GOTO 230
END

IF ~~ THEN BEGIN 230 // from: 229.1
SAY #24179 /* ~"Děláme správnou věc? V tom případě jsi asi zapomněl, šéfe, žes podnikl vlastní výpravu, aby ses postaral! Hej, cokoliv chceš dělat, tady velíš samozřejmě ty. Tsss..."~ */
IF ~~ THEN REPLY #24180 /* ~"Díky za tvůj souhlas, Morte. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 231 // from:
SAY #24903 /* ~"Hej... jsi v pořádku? Myslel jsem, že je z tebe určitě chladná mrtvola."~ */
IF ~~ THEN REPLY #24904 /* ~"Co...? Kdo jsi?"~ */ DO ~SetGlobal("Morte","GLOBAL",1) ~ GOTO 232
IF ~~ THEN REPLY #24905 /* ~"Jsem si jist, že se chystáš vyslovit ještě stovky moudrostí, Morte, ale já potřebuji, abys už, proboha, držel hubu a TEĎ se ke mně přidal."~ */ DO ~SetGlobal("Morte","GLOBAL",1) ChangeAIScript("pcmorte",DEFAULT) JoinPartyEx(TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 232 // from: 231.0
SAY #24906 /* ~"Oh... kdo jsem? Co kdybys začal *ty?* Jaké je tvé ctěné jméno?"~ */
IF ~~ THEN REPLY #24907 /* ~"Já... nevím. Nemohu si vzpomenout."~ */ GOTO 233
IF ~~ THEN REPLY #24908 /* ~"Ptal jsem se tě *první* lebko."~ */ GOTO 234
END

IF ~~ THEN BEGIN 233 // from: 232.0 234.0 235.0
SAY #24909 /* ~"Nemůžeš si vzpomenout na svoje *jméno?* Hehe. Mno, příště, až strávíš noc ve městě, snaž se vyhnout hospodě. Jmenuju se Morte. Jsem tu taky uvězněnej."~ */
IF ~~ THEN REPLY #24910 /* ~"Uvězněnej?"~ */ GOTO 236
END

IF ~~ THEN BEGIN 234 // from: 232.1
SAY #24911 /* ~"Jo, jenže já jsem se tě ptal *druhej.* Jak se jmenuješ?"~ */
IF ~~ THEN REPLY #24912 /* ~"Já... nevím. nemůžu si vzpomenout."~ */ GOTO 233
IF ~~ THEN REPLY #24913 /* ~"Ty první, lebko. Tohle je naposledy, co se tě ptám."~ */ GOTO 235
END

IF ~~ THEN BEGIN 235 // from: 234.1
SAY #24914 /* ~"Tssss... seš otravnější, než muchomůrka zelená. Ale no dobře, *budu* hodnej kluk a řeknu ti to. Jmenuju se Morte. Kdo seš ty?"~ */
IF ~~ THEN REPLY #24915 /* ~"Já... nevím. nemůžu si vzpomenout."~ */ GOTO 233
END

IF ~~ THEN BEGIN 236 // from: 233.0
SAY #24916 /* ~"Jo, zatím co sis tu válel prdel, tak sem  to tu trochu vobhlídl: vyzkoušel jsem všechny dveře, ale tahle místnost je zamčená líp, než kterejkoliv pás cudnosti."~ */
IF ~~ THEN REPLY #24917 /* ~"Jsme zamčeni... kde? Co je tohle za místo?"~ */ GOTO 237
END

IF ~~ THEN BEGIN 237 // from: 236.0
SAY #24918 /* ~"Jmenuje se to tady 'Márnice'... Je to velká černá stavba připomínající svou architekturou gravidního pavouka."~ */
IF ~~ THEN REPLY #24919 /* ~"'Márnice?' Cože... jsem mrtev?"~ */ GOTO 238
END

IF ~~ THEN BEGIN 238 // from: 237.0
SAY #24920 /* ~"Z mýho pohledu ne. Máš hodně jizev... vypadáš, jako by po tobě nějakej debil maloval nožem. Přestože všechny důvody, aby sem kdokoliv přišel a dokončil svou vyřezávací práci, jsou k smíchu."~ */
IF ~~ THEN REPLY #24921 /* ~"Jak se odtud dostaneme pryč?"~ */ GOTO 239
END

IF ~~ THEN BEGIN 239 // from: 238.0
SAY #24922 /* ~"No, všechny dveře jsou zamčené, takže potřebujeme klíč. Je tu šance, že některá z chodících mrtvol v této místnosti ho má."~ */
IF ~~ THEN REPLY #24923 /* ~"Chodící mrtvoly?"~ */ GOTO 240
END

IF ~~ THEN BEGIN 240 // from: 28.0 239.0
SAY #24924 /* ~"Jo, majitelé Márnice používají mrtvá těla jako levnou pracovní silu. Mrtvoly jsou úplně pitomý, ale jsou neškodné, nezaútočí na tebe, dokud nezaútočíš ty první."~ */
IF ~~ THEN REPLY #24925 /* ~"Je tu nějaká jiná cesta? Nechci je pozabíjet jenom kvůli klíči."~ */ DO ~IncrementGlobalOnceEx("GLOBALGood_Morte_1","GLOBALGood",1) ~ GOTO 241
IF ~~ THEN REPLY #24926 /* ~"Takže mám napadnout jednu z těch mrtvol a obrat ji o klíč?"~ */ GOTO 242
END

IF ~~ THEN BEGIN 241 // from: 240.0
SAY #24927 /* ~"Cože, myslíš si snad, že jim bude vadit, když je zabiješ? Oni jsou už MRTVÍ. Ale má to vlastně i světlou stránku: když je zabiješ, můžou si na chvíli odpočinout, než je majitelé pošlou opět do roboty."~ */
IF ~~ THEN REPLY #24928 /* ~"Dobře, v pořádku... já tedy jednu sundám a seberu ten klíč."~ */ GOTO 242
END

IF ~~ THEN BEGIN 242 // from: 240.1 241.0
SAY #24929 /* ~"Dobře, ale než to spravíš, měl by ses vyzbrojit. Myslím, že v některé z polic jsem viděl skalpel."  POZNÁMKA: Prohledej police v téhle místnosti, abys našel zbraň na mrtvoly.~ */
IF ~~ THEN REPLY #24930 /* ~"V pořádku, poohlédnu se po něm."~ */ GOTO 243
END

IF ~~ THEN BEGIN 243 // from: 242.0
SAY #24931 /* ~"Ještě něco: Tyhle mrtvoly jsou pomalý jako šneci, ale když nějakou praštíš, je to, jako bys kopl do vosího hnízda. Když tě začnou otravovat, pamatuj si, že můžeš UTÍKAT, ale oni nemůžou. Používej to k vytvoření odstupu od nich, když si budeš chtít oddechnout."  POZNÁMKA: Pro BĚH drž klávesu CTRL a levým tlačítkem myši klikni na místo kam chceš utíkat. Když jsi už blízko smrti, používej běh na útěk před zombie, aby sis  mohl odpočinout.~ */
IF ~~ THEN REPLY #24932 /* ~"Dobře. Díky za radu."~ */ DO ~ChangeAIScript("pcmorte",DEFAULT) JoinPartyEx(TRUE) JOURNAL #24933 /* ~Abych si udržel jasnou hlavu, začal jsem si zapisovat své zkušenosti a doufám, že se mi to bude někdy hodit. Probral jsem se v místě zvaném "Márnice"... a skutečně to jako Márnice vypadá. Nevím, kdo jsem, co tu dělám a jak jsem se sem dostal. První věc, kterou jsem potkal, je užvaněná lebka - Morte. Řekl mi, že jsme tu zamčeni, ale že některá z mrtvol motajících se kolem by mohla mít u sebe klíč. Navrhl mi, abych se poohlédl po skalpelu v jedné z polic kolem a pak se s ním vrhl na zombie a ubodal je k "smrti."~ */ EXIT
END

IF ~~ THEN BEGIN 244 // from:
SAY #25962 /* ~"Něco jako mluvící encyklopedie, šéfe. Ale vo tom fakt nechci mluvit."~ */
IF ~  GlobalLT("Morte_Mimir","GLOBAL",2) ~ THEN DO ~IncrementGlobalOnceEx("GLOBALMorte_Mimir","GLOBALMorte_Mimir",0) ~ EXTERN ~DCWRUSHF~ 27
IF ~  GlobalGT("Morte_Mimir","GLOBAL",1) ~ THEN REPLY #66902 /* ~"Ale ty NEJSI mimir, Morte..."~ */ EXTERN ~DCWRUSHF~ 27
END

IF ~~ THEN BEGIN 245 // from:
SAY #25964 /* ~Morte zakýval obočím a rozletěl se k ženě. "To není všechno, co."~ */
IF ~~ THEN REPLY #25965 /* ~"Už dost, Morte."~ */ GOTO 246
END

IF ~~ THEN BEGIN 246 // from: 245.0
SAY #25966 /* ~"Jó, Jó. Jasan." Morte zatočil očima a začal si mumlat pod nos. "Pfff. Stejně tak bysem moh bejt *mrtvej*..."~ */
IF ~  CheckStatGT(Protagonist,14,INT) ~ THEN REPLY #25967 /* ~"Hele, řekla jsi sám o sobě? To oni normálně nedělají?"~ */ EXTERN ~DCWRUSHF~ 28
IF ~~ THEN REPLY #25968 /* ~"Mám pro tu ženu nějaké otázky..."~ */ EXTERN ~DCWRUSHF~ 2
IF ~~ THEN REPLY #25969 /* ~Nechej ženu být.~ */ EXIT
END

IF ~~ THEN BEGIN 247 // from:
SAY #25970 /* ~Morte ji přerušil: "No hele, náčelníku, vono to všechno záleží na *kvalitě* mimira. Někerý, jako třeba já, jsou víc očarovaní, než ostatní, to je všechno... Oni si víc... uh... uvědomují sami sebe, tak je to přesný."~ */
IF ~~ THEN REPLY #25971 /* ~"Hmm."~ */ EXTERN ~DCWRUSHF~ 29
IF ~~ THEN REPLY #25972 /* ~"Aha."~ */ EXTERN ~DCWRUSHF~ 29
END

IF ~~ THEN BEGIN 248 // from:
SAY #25973 /* ~"Hej! Já se jenom snažím kapku pobavit, šéfe!"~ */
IF ~~ THEN EXTERN ~DCWRUSHF~ 27
END

IF ~~ THEN BEGIN 249 // from:
SAY #27285 /* ~"Dám ti radu, šéfku: Držel bych teď zobák - netřeba víc zdechlin do knihy smrti, než je nutné... zvlášť ženskejch. Navíc, zabíjení by sem mohlo přivést zřízence."~ */
IF ~~ THEN REPLY #27303 /* ~"Myslím, že ses o tom ještě nezmínil. *Kdo* jsou ti zřízenci?"~ */ GOTO 250
IF ~~ THEN REPLY #27304 /* ~"Ta těla tady... odkud se vzala?"~ */ GOTO 252
IF ~~ THEN REPLY #27305 /* ~"Proč se zajímáš o těla žen?"~ */ GOTO 253
IF ~~ THEN REPLY #27306 /* ~"Dobře... Já... zkusím si to zapamatovat."~ */ GOTO 257
END

IF ~~ THEN BEGIN 250 // from: 249.0 252.0 256.0
SAY #27286 /* ~"Říkají si 'Spalovači.' Nemůžeš je minout: Sou posedlí černou a na xichtě mají rigor mortis. Je to zkažená banda ghúlských uctívačů smrti. Věří, že každej má zemřít... čím dřív tim líp."~ */
IF ~~ THEN REPLY #27307 /* ~"To mě trochu mate... proč by se měli tihle Spalovači starat o to, jestli uteču, nebo ne?"~ */ GOTO 251
END

IF ~~ THEN BEGIN 251 // from: 250.0
SAY #27287 /* ~"Neposlouchals? Říkal sem, že Spalovači věřej, že KAŽDEJ má zemřít, a čím dřív tím líp. Myslíš si, že těla, cos viděl knize mrtvejch sou šťastnější než ty venku?"~ */
IF ~~ THEN REPLY #27308 /* ~"Ta těla, která jsem tady viděl... odkud se sem dostala?"~ */ GOTO 252
IF ~~ THEN REPLY #27309 /* ~"Předtím jsi říkal něco o tom, že bych neměl zabíjet žádná *ženská* těla. Proč?"~ */ GOTO 253
IF ~~ THEN REPLY #27310 /* ~"Dobře... Já... zkusím si to zapamatovat."~ */ GOTO 257
END

IF ~~ THEN BEGIN 252 // from: 249.1 251.0 256.1
SAY #27288 /* ~"Smrť  navštěvuje sféry každej den, šéfe. Tihleti to je všechno, co zbylo z ubožáků, kteří po smrti prodali svý těla zřízencům."~ */
IF ~~ THEN REPLY #27311 /* ~"Pouč mě...*kdo* jsou ti zřízenci?"~ */ GOTO 250
IF ~~ THEN REPLY #27312 /* ~"Předtím jsi říkal něco o tom, že bych neměl zabíjet žádná *ženská* těla. Proč?"~ */ GOTO 253
IF ~~ THEN REPLY #27313 /* ~"Dobře... Já... zkusím si to zapamatovat."~ */ GOTO 257
END

IF ~~ THEN BEGIN 253 // from: 249.2 251.1 252.1
SAY #27289 /* ~"Ccc - děláš si *srandu?* Hele, šéfe, tyhle mrtvý škvrňata sou poslední šance pro bandu tvrdejch mlátiček jako jsme my. Musíme bejt *rytířští* - žádný vosekávání kvůli klíčům, žádný ořezávání hnátů a takový ty věci."~ */
IF ~~ THEN REPLY #27314 /* ~"Poslední šance? Co... o čem to mluvíš?"~ */ GOTO 254
END

IF ~~ THEN BEGIN 254 // from: 253.0
SAY #27290 /* ~"Šéfe, sou MRTVÍ, MY SME mrtví... chápeš, co tím myslím? Jo?"~ */
IF ~~ THEN REPLY #27315 /* ~"Ne... ne, vlastně ne."~ */ GOTO 255
IF ~  CheckStatGT(Protagonist,12,INT) ~ THEN REPLY #27316 /* ~"To nemůžeš myslet vážně."~ */ GOTO 255
END

IF ~~ THEN BEGIN 255 // from: 254.0 254.1
SAY #27291 /* ~"Šéfe, už se nám tady hrne řada těch kulhajících dám. *Všichni* jsme zemřeli aspoň jednou: máme si o čem vyprávět. Oceňujou chlapy, co maj zkušenost se smrtí jako my."~ */
IF ~~ THEN REPLY #27317 /* ~"Ale... počkej... neříkal jsi předtím, že já *nejsem* mrtvý?"~ */ GOTO 256
END

IF ~~ THEN BEGIN 256 // from: 255.0
SAY #27292 /* ~"No... dobře, *ty* možná nejseš mrtvej, ale *JÁ* jsem. A jak se tak koukám, vůbec by mi nevadilo sdílet rakev s některou z těchle fajnovejch houževnatejch mrtovolek." Morte začal obdivně klapat zuby. " Jasně, zřízenci by se s nima nejdřív museli rozloučit a to nejni zrovna pravděpodobný."~ */
IF ~~ THEN REPLY #27318 /* ~"Kdo že jsou to ti zřízenci?"~ */ GOTO 250
IF ~~ THEN REPLY #27319 /* ~"Ale odkud se tady vzala všechna ta těla?"~ */ GOTO 252
IF ~~ THEN REPLY #27320 /* ~"Dobře... Já... zkusím si to zapamatovat."~ */ GOTO 257
END

IF ~~ THEN BEGIN 257 // from: 249.3 251.2 252.2 256.2
SAY #27293 /* ~"Hele, šéfe. Po tom polibku smrti seš furt kapku zmatenej. Takže tady máš dvě rady: Zaprvý, jestli se chceš na něco zeptat, *zeptej* se mě, oukej?"  POZNÁMKA: Jestli si chceš promluvit se členem své party, vyber si 'mluv' z menu a pak klikni levým tlačítkem na toho, s kým chceš hovořit.~ */
IF ~~ THEN REPLY #27321 /* ~"Dobře... jestli budu mít nějaké otázky, zeptám se tě."~ */ GOTO 258
END

IF ~~ THEN BEGIN 258 // from: 257.0
SAY #27294 /* ~"Zadruhý, jestli si jenom *z poloviny* tak zapomětlivej, jak mi připadáš, začni si šecko zapisovat. Nikdy nevíš, kdy narazíš na něco důležitýho, tak ať na to nezapomeneš."~ */
IF ~~ THEN REPLY #27322 /* ~"Jako deník?"~ */ GOTO 259
END

IF ~~ THEN BEGIN 259 // from: 258.0
SAY #27295 /* ~"Jo, jako deník. Jestli začneš bejt zmatenej v důležitejch věcech, jako třebas kde seš, prolistuj ho a osvěž si paměť. Jasný?"  POZNÁMKA: Ke svému deníku se dostaneš tlačítkem deník ve spodním pravém rohu světové obrazovky, nebo si vyber tlačítko deník z rychlého menu.~ */
IF ~~ THEN REPLY #27323 /* ~"Dobře... Pochopil jsem. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 260 // from:
SAY #27296 /* ~"Někde tady kolem na poličce by měl bejt skalpel. Já bych ho nejdřív našel, než bych si dal taneček s některou zdechlinou tady kolem."~ */
IF ~~ THEN REPLY #27324 /* ~"Dobře... budu hledat dál."~ */ EXIT
END 
IF WEIGHT #8 /* Triggers after states #: 729 444 325 281 742 737 733 487 even though they appear after this state */ ~  Global("Mortuary_Walkthrough","GLOBAL",0) PartyHasItem("Scalpel") Global("ZM782_Dead_KAPUTZ","GLOBAL",0)
~ THEN BEGIN 261 // from:
SAY #27297 /* ~"Super, našels skalpel, máš bod. A teď jdem na ty mrtvoly... neměj strach, zůstanu vzádu a budu ti dodávat cenný taktický rady."~ */
IF ~~ THEN REPLY #27325 /* ~"Možná bys mi mohl *pomoct*, Morte."~ */ GOTO 262
IF ~~ THEN REPLY #27326 /* ~"Dobře."~ */ EXIT
END

IF ~~ THEN BEGIN 262 // from: 261.0
SAY #27298 /* ~"Já ti BUDU pomáhat. Dobrá rada, na tu jen tak nenatrefíš, šéfe."~ */
IF ~~ THEN REPLY #27327 /* ~"Myslel jsem pomoct s útokem na *mrtvolu*."~ */ GOTO 263
IF ~~ THEN REPLY #27328 /* ~"Dobrá tedy."~ */ EXIT
END

IF ~~ THEN BEGIN 263 // from: 262.0
SAY #27299 /* ~"Já? Já  jsem romantik, ne voják. Jenom bych překážel."~ */
IF ~~ THEN REPLY #27329 /* ~"Až zaútočím na to tělo, bude lepší, když budeš se mnou, nebo budeš ta další věc, do které vrazím tenhle skalpel."~ */ GOTO 264
IF ~~ THEN REPLY #27330 /* ~"Dobrá tedy."~ */ EXIT
END

IF ~~ THEN BEGIN 264 // from: 263.0
SAY #27300 /* ~"Eh... dobře. Píchnu ti s nima."  POZNÁMKA: Jestli chceš, aby Morte zaútočil s tebou, stačí, abyste byli oba označení, když zaútočíš na mrtvolu. Morte se přidá k útoku. ~ */
IF ~~ THEN REPLY #27331 /* ~"Jsem rád, že si rozumíme. Takže do toho."~ */ EXIT
END

IF ~~ THEN BEGIN 265 // from:
SAY #27301 /* ~"Dobře, postaral ses vo tu správnou zdechlinu. Teď musíš najít klíč. Měl by bejt někde na těle. Jakmile ho dostaneme, můžeme vocaď vypadnout."~ */
IF ~~ THEN REPLY #27332 /* ~"Dobře."~ */ EXIT
END

IF ~~ THEN BEGIN 266 // from:
SAY #27302 /* ~"Dobře, to je ten klíč. Musí pasovat do zámku některejch dveří."~ */
IF ~~ THEN REPLY #27333 /* ~"Tak tedy zkusím všechny dveře."~ */ EXIT
END

IF ~~ THEN BEGIN 267 // from:
SAY #27911 /* ~Morte do tvého ucha zasyčel: "Právník."~ */
IF ~~ THEN EXTERN ~DCWCAFEF~ 15
END

IF ~~ THEN BEGIN 268 // from:
SAY #27912 /* ~"Druh mluvící encyklopedie, šéfe. O tom opravdu nerad mluvím."~ */
IF ~  GlobalLT("Morte_Mimir","GLOBAL",2) ~ THEN DO ~IncrementGlobalOnceEx("GLOBALMorte_Mimir","GLOBALMorte_Mimir",0) ~ EXTERN ~DCWCAFEF~ 50
IF ~  GlobalGT("Morte_Mimir","GLOBAL",1) ~ THEN REPLY #65536 /* ~"Ale ty NEJSI mimir, Morte..."~ */ EXTERN ~DCWCAFEF~ 50
END

IF ~~ THEN BEGIN 269 // from:
SAY #27913 /* ~Morte zakmital obočím a začal plout k ženě. "To není všechno co jsem-"~ */
IF ~~ THEN REPLY #27914 /* ~"To stačí, Morte."~ */ GOTO 270
END

IF ~~ THEN BEGIN 270 // from: 269.0
SAY #27915 /* ~"Jo, jo. Dobrá." Morte zakoulel očima a začal mumlat. "Tss, já také můžu být *mrtvý*..."~ */
IF ~  CheckStatGT(Protagonist,14,INT) ~ THEN REPLY #27916 /* ~"Říkáš... řekla jsi 'samo'? Oni obvykle nemluví?"~ */ EXTERN ~DCWCAFEF~ 51
IF ~~ THEN REPLY #27917 /* ~"Chci se něco zeptat této ženy..."~ */ EXTERN ~DCWCAFEF~ 4
IF ~~ THEN REPLY #27918 /* ~Odejdi od ženy v klidu.~ */ EXIT
END

IF ~~ THEN BEGIN 271 // from:
SAY #27919 /* ~Morte ji přerušil: "No vidíš, šéfe, je to všechno jenom o rozdílech v *kvalitě* tvého mimira. Někteří - jako já -- jsou více okouzlující než jiní, to je všechno. A navíc... hmm... 'vědom si sám sebe,' to je to správné slovo."~ */
IF ~~ THEN REPLY #27920 /* ~"Hmm."~ */ EXTERN ~DCWCAFEF~ 52
IF ~~ THEN REPLY #27921 /* ~"Aha."~ */ EXTERN ~DCWCAFEF~ 52
END

IF ~~ THEN BEGIN 272 // from:
SAY #27922 /* ~"Hej! Jenom se to tady snažím pobavit, šéfe!"~ */
IF ~~ THEN EXTERN ~DCWCAFEF~ 50
END

IF ~~ THEN BEGIN 273 // from:
SAY #28036 /* ~Morte na tebe znalecky kývl. "Hej, tenhle chlápek není špatnej."~ */
IF ~~ THEN REPLY #28041 /* ~"Dobrá, tu máš... vem si své peníze zpět, Malmanere."~ */ DO ~TakePartyGold(10) ~ EXTERN ~DMALMANR~ 13
IF ~~ THEN REPLY #28042 /* ~Hoď deset měďáků po Malmanerovi.~ */ DO ~TakePartyGold(10) ~ EXTERN ~DMALMANR~ 14
IF ~~ THEN REPLY #28043 /* ~"Opravdu? Nic takového jsem neslyšel, Morte. Jdeme."~ */ EXTERN ~DMALMANR~ 15
END

IF ~~ THEN BEGIN 274 // from:
SAY #28037 /* ~Morte na tebe znalecky kývl. "Hej, tento chlápek není špatný."~ */
IF ~  Global("Malmaner","GLOBAL",3) !Global("Chaotic_Malmaner_1","GLOBAL",1) ~ THEN REPLY #28038 /* ~"Dobrá, tu máš... vem si své peníze zpět, Malmanere."~ */ DO ~TakePartyGold(30) ~ EXTERN ~DMALMANR~ 13
IF ~  Global("Malmaner","GLOBAL",3) !Global("Chaotic_Malmaner_1","GLOBAL",1) ~ THEN REPLY #28039 /* ~Hoď třicet měďáků po Malmanerovi.~ */ DO ~TakePartyGold(30) ~ EXTERN ~DMALMANR~ 14
IF ~  Global("Malmaner","GLOBAL",3) Global("Chaotic_Malmaner_1","GLOBAL",1) ~ THEN REPLY #28040 /* ~"Dobrá, tu máš... vem si své peníze zpět, Malmanere."~ */ DO ~TakePartyGold(50) ~ EXTERN ~DMALMANR~ 13
IF ~  Global("Malmaner","GLOBAL",3) Global("Chaotic_Malmaner_1","GLOBAL",1) ~ THEN REPLY #28044 /* ~Hoď padesát měďáků po Malmanerovi.~ */ DO ~TakePartyGold(50) ~ EXTERN ~DMALMANR~ 14
IF ~  Global("Malmaner","GLOBAL",5) !Global("Chaotic_Malmaner_1","GLOBAL",3) ~ THEN REPLY #28045 /* ~"Dobrá, tu máš... vem si své peníze zpět, Malmanere."~ */ DO ~TakePartyGold(50) ~ EXTERN ~DMALMANR~ 13
IF ~  Global("Malmaner","GLOBAL",5) !Global("Chaotic_Malmaner_1","GLOBAL",3) ~ THEN REPLY #28046 /* ~Hoď padesát měďáků po Malmanerovi.~ */ DO ~TakePartyGold(50) ~ EXTERN ~DMALMANR~ 14
IF ~  Global("Malmaner","GLOBAL",5) Global("Chaotic_Malmaner_1","GLOBAL",3) ~ THEN REPLY #28047 /* ~"Dobrá, tu máš... vem si své peníze zpět, Malmanere."~ */ DO ~TakePartyGold(80) ~ EXTERN ~DMALMANR~ 13
IF ~  Global("Malmaner","GLOBAL",5) Global("Chaotic_Malmaner_1","GLOBAL",3) ~ THEN REPLY #28048 /* ~Hoď osmdesát měďáků po Malmanerovi.~ */ DO ~TakePartyGold(80) ~ EXTERN ~DMALMANR~ 14
IF ~~ THEN REPLY #28049 /* ~"Opravdu? Nic takového jsem neslyšel, Morte. Jdeme."~ */ EXTERN ~DMALMANR~ 15
END

IF ~~ THEN BEGIN 275 // from:
SAY #28630 /* ~"To zní blbě."~ */
IF ~~ THEN EXTERN ~DGRACE~ 60
END

IF ~~ THEN BEGIN 276 // from:
SAY #28631 /* ~"Je tanar'ri... sukuba šéfiku."~ */
IF ~~ THEN EXTERN ~DGRACE~ 72
END

IF ~~ THEN BEGIN 277 // from:
SAY #28632 /* ~"To si piš dáblice!" Morte cvaknul zuby. "Jsem PRO aby ta sukuba šla s náma... A bohové vědí, že ty Annah seš vtipná, jako dyby se ti ve střevech producíroval ježek."~ */
IF ~~ THEN EXTERN ~DANNAH~ 166
END

IF ~~ THEN BEGIN 278 // from:
SAY #28633 /* ~"Hej, počkej minutku! *JÁ* jsem znalec Sfér! Je to má práce šéfiku!"~ */
IF ~~ THEN REPLY #28634 /* ~"Mít v partě dva lidi znalé Sfér, mi připadá celkem mazané. A navíc bych Morte řekl, že to bude větší zábava."~ */ GOTO 279
END

IF ~~ THEN BEGIN 279 // from: 278.0
SAY #28635 /* ~"Ty to možna vidíš jako zábavu! JÁ to spíš vidím tak, že kdejaké žábě stačí, když na tebe zakoulí očima a ty seš z toho hned celej vedle!" Morte se utišil. "A piš si, že sem to myslel vážně. A sem rád, že sem to zmínil."~ */
IF ~~ THEN REPLY #28636 /* ~"Budu si to pamatovat Morte. Slečno Grace, omluv mě pokud budu nějak neomalený, ale nemáš chuť cestovat s námi?"~ */ EXTERN ~DGRACE~ 79
END

IF ~~ THEN BEGIN 280 // from:
SAY #28637 /* ~"Co se můj zjizvený společník pokouší říct je, že DVA z nás... Mimochodem, já jsem Morte: omluvte prosím společníkovu nevychovanost, že nás nepředstavil... se domnívají, že by byl opravdu VÝBORNÝ nápad, kdyby ses k nám připojila. Máme spoustu místa pro sukubu. SPOUSTU místa."~ */
IF ~~ THEN EXTERN ~DGRACE~ 119
END 
IF WEIGHT #4 /* Triggers after states #: 742 737 733 487 even though they appear after this state */ ~  Global("Morte_Stolen","GLOBAL",2) !GlobalGT("Fortress_Morte","GLOBAL",2)
~ THEN BEGIN 281 // from:
SAY #28738 /* ~"Díkes, šéfíku. Neumíš si představit, jak rád zase lítám s tebou." V jeho hlase to zavání sarkasmem. "Naučil sem se novej trik, zatimco jsem tu trčel."~ */
IF ~~ THEN REPLY #28743 /* ~"Hurá, sláva. Konečně tě mám zpátky."~ */ DO ~SetGlobal("Morte_Stolen","GLOBAL",3) ~ EXIT
IF ~  CheckStatGT(Protagonist,14,CHR) ~ THEN REPLY #28744 /* ~"Promiň, kámo. Zkoušel jsem ho oblafnout."~ */ DO ~IncrementGlobal("BD_MORTE_MORALE","GLOBAL",2) SetGlobal("Morte_Stolen","GLOBAL",3) ~ GOTO 282
IF ~  CheckStatLT(Protagonist,15,CHR) ~ THEN REPLY #28745 /* ~"Promiň, kámo. Zkoušel jsem ho oblafnout."~ */ DO ~SetGlobal("Morte_Stolen","GLOBAL",3) ~ GOTO 283
END

IF ~~ THEN BEGIN 282 // from: 281.1
SAY #28739 /* ~"Vážně? To se ti podobá, šéfe. Skvělej nápad. Ale protentokrát ti odpouštím. Hlavně to už nedělej znova." ~ */
IF ~~ THEN REPLY #28746 /* ~"Jak myslíš, Morte. Můžem jít."~ */ EXIT
END

IF ~~ THEN BEGIN 283 // from: 281.2
SAY #28740 /* ~"Hele, nevěřím ti ani slůvko. Prostě zapomenem, co se stalo, jo? Teď už bysme měli jít."~ */
IF ~~ THEN REPLY #28747 /* ~"Fajn."~ */ EXIT
IF ~~ THEN REPLY #28748 /* ~"Morte, jenom jsem blafoval. To pochopíš."~ */ EXIT
END

IF ~~ THEN BEGIN 284 // from:
SAY #28741 /* ~"Díky šéfe. A teď se odsaď vypaříme!" Morte na chvíli ztichl. "Jo, a jen tak mimochodem... tidle hoši dali hlavy dohromady. Naučili mě něco pěkně mazanýho."~ */
IF ~~ THEN REPLY #28749 /* ~"Tak jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 285 // from:
SAY #28962 /* ~"Eh... šéfíku? Už jsi někdy viděl sochu, že jo? Víš snad, že sochy nechodí a tak podobně."~ */
IF ~  CheckStatGT(Protagonist,14,INT) ~ THEN REPLY #28967 /* ~"Podívej, Morte: ty jsi létající mluvící lebka, která zavrhuje možnost existence živých soch."~ */ GOTO 286
IF ~  Global("CW_Sal_Hint","GLOBAL",1) ~ THEN REPLY #28968 /* ~"Potkal jsem mága jménem Salabesh, který mluvil o jistém kamenném muži. Jsi to ty?"~ */ DO ~SetGlobal("Qui_Sai","GLOBAL",2) ~ EXTERN ~DQUISAI~ 5
IF ~~ THEN REPLY #28969 /* ~"Vím, Morte. Jenom se jí dotknu..."~ */ EXTERN ~DQUISAI~ 3
