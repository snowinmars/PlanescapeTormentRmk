IF ~~ THEN REPLY #40850 /* ~"Dobře, Morte. Tak pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 430 // from: 429.0
SAY #40851 /* ~Morte vydal zvuk, znamenající nejvyšší znechucení. "Co k nim říct? Otravný malý chodící hodinový strojky... dycinky se pokoušej udržovat řád a zákon a takový nesmysly po celým mnohovesmíru. A to není *dobrý*, to ne... jenom *řád*. Hele, vykašleme se na ně a půjdeme hodit pokec s nějakým tím sexy kotětem, kerých je tady spousta, co?"~ */
IF ~~ THEN REPLY #40852 /* ~Ignoruj Morteho a pozdrav modrony.~ */ DO ~SetGlobal("Met_Modrons","GLOBAL",1) ~ EXTERN ~DBROCUS6~ 3
IF ~~ THEN REPLY #40853 /* ~"Omlouvám se, Morte, ale já si s těmi modrony chci promluvit."~ */ GOTO 431
IF ~~ THEN REPLY #40854 /* ~"Dobře, Morte. Tak pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 431 // from: 429.2 430.1
SAY #40855 /* ~Morte si hlasitě povzdechl. "Fajn, no jó, jak chceš. Ale pak mi neříkej, že sem tě nevaroval, jasný? Stejně z nich nejspíš nic nevytáhneš, náčelníku... je to divná banda, domluva s nima zrovna není, to se spíš domluvíš s hromadou kamení, ta dává srozumitelnější odpovědi. Někdy."~ */
IF ~~ THEN REPLY #40856 /* ~"Zdravím..."~ */ DO ~SetGlobal("Met_Modrons","GLOBAL",1) ~ EXTERN ~DBROCUS6~ 3
