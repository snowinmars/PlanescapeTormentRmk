IF ~~ THEN BEGIN 414 // from: 409.1 410.2 411.1 412.0 413.0
SAY #39571 /* ~"To takhle seděl stařec v temnotě na cestě, jasný? Nebyl si totiž jistej, kterym směrem má jít, a navíc zapomněl, kdo vlastně je a kam jde. Na chviličku si sednul, aby odpočinul nohám když tu najednou zvedne zrak a co to nevidí? Před ním stojí nějaká postarší ženská, cení na něj zuby, který stejně nemá, a do toho štěbetá: 'A teď tvé třetí přání. Co to bude?'"~ */
IF ~~ THEN REPLY #39724 /* ~"Pokračuj, Morte..."~ */ GOTO 415
IF ~~ THEN REPLY #39725 /* ~"Počkej... měl bych dotaz na Yves..."~ */ EXTERN ~DYVES~ 4
IF ~~ THEN REPLY #39726 /* ~"Zbytek si poslechneme jindy, Morte. Sbohem, Yves."~ */ EXIT
END

IF ~~ THEN BEGIN 415 // from: 414.0
SAY #39572 /* ~"'Třetí přání?' Koukal na ní dědouš jako čerstvě vyvoraná myš. 'Jak můžu mít třetí přání, když jsem ještě neměl první ani druhé přání?'"~ */
IF ~~ THEN REPLY #39727 /* ~"Pokračuj, Morte..."~ */ GOTO 416
IF ~~ THEN REPLY #39728 /* ~"Počkej... měl bych dotaz na Yves..."~ */ EXTERN ~DYVES~ 4
IF ~~ THEN REPLY #39729 /* ~"Zbytek si poslechneme jindy, Morte. Sbohem, Yves."~ */ EXIT
END

IF ~~ THEN BEGIN 416 // from: 415.0
SAY #39573 /* ~"'Už jsi měl dvě přání,' odpověděla mu ta stará babizna, 'ale tvé druhé přání bylo, abych vše uvedla do stavu před tvým prvním přáním. To proto si nic nepamatuješ; zapomněl jsi totiž všechno, co se stalo po tvém úplně prvním přání.' Vykulila na toho nebohýho dědulu oči. Asi takhle..." Morte na tebe vyvalil oči." Takže teď už ti zbývá jen jedno přání.'"~ */
IF ~~ THEN REPLY #39752 /* ~"Pokračuj, Morte..."~ */ GOTO 417
IF ~~ THEN REPLY #39753 /* ~"Vydrž... měl bych dotaz pro Yves..."~ */ EXTERN ~DYVES~ 4
IF ~~ THEN REPLY #39754 /* ~"Poslechnem si to jindy, Morte. Sbohem, Yves."~ */ EXIT
END

IF ~~ THEN BEGIN 417 // from: 416.0
SAY #39574 /* ~"'Tak dobrá,' řekl jí ten chlap, "Sice tomu nevěřím, ale jak mi může přání ublížit. Přeju si vědět, kdo vlastně jsem.'"  "'Legrační,' stihla ještě říct čarodějka, než splnila to přání a nastálo zmizela. 'Takové bylo tvé první přání.'" ~ */
IF ~~ THEN EXTERN ~DYVES~ 55
