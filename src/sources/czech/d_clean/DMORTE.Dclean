IF ~~ THEN BEGIN 540 // from: 537.0 537.2 539.0 539.2
SAY #54175 /* ~"Tohle... uh, není to POPRVÉ, co tímhle procházíme... víš, už jsme v tý 'Pevnosti Lítosti' byli dřív... i když... my... já... tenkrát jsem to nevěděl."~ */
IF ~~ THEN REPLY #54176 /* ~"Ty jsi *nevěděl*? Jak je to možné?"~ */ GOTO 541
IF ~~ THEN REPLY #54177 /* ~"Takže, ÚPLNĚ OD ZAČÁTKU... jsi mi mohl ŘÍCT, kde je ten portál, JAKÝ je klíč k portálu, PROČ jsem nesmrtelný, CO se stalo mé smrtelnosti a skutečnost, že je v té Pevnosti?! Morte! Já tě *ZABIJU*!!!!"~ */ GOTO 542
IF ~~ THEN REPLY #54178 /* ~"Morte, očekávám vysvětlení... žádné lži nebo okliky. Teď ne. Mluv."~ */ GOTO 541
