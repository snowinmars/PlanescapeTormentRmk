IF ~~ THEN REPLY #65583 /* ~"V pořádku, tedy. Mám nějaké další otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65584 /* ~"V pořádku, tedy. Pojďme."~ */ EXIT
