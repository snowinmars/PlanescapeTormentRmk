IF ~~ THEN BEGIN 33 // from: 32.0
SAY #1104 /* ~"U všemocnýho Boha a jeho matky... dobře šéfe, s největší pravděpodobností se tvoje vzpomínky ponořily někam do neznáma. Se štěstím zase brzo vyplujou na povrch, věř mi. Tos teda musel mít krušnou noc. Doufám, žes nikoho nezranil nebo neporušil zákon... když už spolu mluvíme, řekni mi, seš jeden z těch Vnímavejch, co sebe mrzačej nebo ti někdo daroval tyhle nádherný jizvy?" ~ */
IF ~~ THEN REPLY #1105 /* ~"Vnímavý?"~ */ GOTO 12
IF ~~ THEN REPLY #1106 /* ~"Jizvy?"~ */ GOTO 13
IF ~~ THEN REPLY #1107 /* ~"Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1108 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 34 // from: 13.0
SAY #1117 /* ~"Hohó! Tak se mi zdá, že tu máš napsaný pokyny..." prohodil Morte. "Tak se na to podíváme... začíná to...  POZNÁMKA: "Vím, že se cítíš, jako bys vypil několik džberů bahna z řeky Styx, ale teď by ses měl trošičku soustředit. Někde kolem tebe by se měl povalovat deník, který ti osvětlí, co se vlastně děje. Zbytek ti dopoví Pharod, pokud tedy ještě není zapsán v Knize mrtvých.  Hlavně ten deník neztrať, protože pak bychom zase byli ve styxském bahně. A ať už děláš cokoliv, neříkej NIKOMU, kdo jsi nebo co se ti stalo, jinak by ses taky mohl pěkně rychle podívat do krematoria."~ */
IF ~~ THEN REPLY #1118 /* ~"No už se nedivím, že mě ta záda tak bolí. Znáš člověka jménem Pharod?"~ */ GOTO 36
IF ~~ THEN REPLY #1119 /* ~"Neviděl jsi tady někde můj deník když jsem tady ležel?"~ */ GOTO 35
IF ~  Global("Scars","GLOBAL",1) ~ THEN REPLY #1120 /* ~"Nevíš jak se odtud dostanu pryč?"~ */ GOTO 21
IF ~~ THEN REPLY #1121 /* ~"Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1122 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 35 // from: 34.1 36.0
SAY #1123 /* ~"Ne... byl jsi svlečenej až na kůži když tě sem přivezli. Ostatně, vypadá to, že máš kus deníku napsanýho na tvým těle."~ */
IF ~~ THEN REPLY #1124 /* ~"Znáš někoho jménem Pharod?"~ */ GOTO 36
IF ~  Global("Scars","GLOBAL",1) ~ THEN REPLY #1125 /* ~"Jak se odtud dostanu pryč?"~ */ GOTO 21
IF ~~ THEN REPLY #1126 /* ~"Nevadí. Měl bych nějaké další otázky..."~ */ GOTO 31
IF ~~ THEN REPLY #1127 /* ~Ignoruj Morteho a zkontroluj místnost.~ */ EXIT
END

IF ~~ THEN BEGIN 36 // from: 34.0 35.0
SAY #1128 /* ~"Nikdo, koho bych měl znát. Ještě jednou, neznám hodně lidí. Ale nějaký troubové určitě budou vědět, kde toho chlapa najít... až se dostanem tady vocaď, tak potom."~ */
IF ~~ THEN REPLY #1129 /* ~"Měl jsem u sebe deník, když sem tu ležel?"~ */ GOTO 35
IF ~  Global("Scars","GLOBAL",1) ~ THEN REPLY #1130 /* ~"Jak se odtud dostanu pryč?"~ */ GOTO 21
