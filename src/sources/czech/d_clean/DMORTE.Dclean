IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) !InParty("Morte") ~ THEN REPLY #54272 /* ~"To nic, Morte. Co se stalo, stalo se. Teď jdu skrz portál."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 556 // from: 554.0 554.1 555.0 555.1
SAY #54273 /* ~"Ne..." Morte se odmlčel. "Ještě jedna věc - možná jsem toho *druhého* neměl moc rád, ale byl to jeden zatraceně chytrej parchant - nejchytřejší, jakého jsem kdy znal, počítal úplně se vším. Pokud umřel v Pevnosti, znamená to... no..."~ */
IF ~~ THEN REPLY #54274 /* ~"Nemyslíš si, že mám šanci na úspěch, viď?"~ */ GOTO 557
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) InParty("Morte") ~ THEN REPLY #54275 /* ~"To nic, Morte. Jsem připraven jít portálem. Jdeš se mnou?"~ */ GOTO 534
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) !InParty("Morte") ~ THEN REPLY #54276 /* ~"To nic, Morte. Co se stalo, stalo se. Teď jdu skrz portál."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 557 // from: 556.0
SAY #54277 /* ~"Ne..." Morte zavrtěl hlavou. "O tohle nejde, šéfe. Protože ne vždycky je ten nejchytřejší zároveň i nesilnější nebo nejodolnější... někdy dojde na to, kdo jsi, a co *doopravdy* chceš. Tím myslím, kdysi jsi chtěl být nesmrtelný - ale nakonec - je to *opravdu* to, cos chtěl? Zkrátka, buď si jist tím, co tentokrát chceš, to ti říkám."~ */
IF ~  InParty("Morte") Global("Morte_Morale_Fortress_Portal","AR0202",0) ~ THEN REPLY #54278 /* ~"Rozumím. Podívej, Morte... nikdy jsme o tom vlastně nemluvili, ale víš, že tam se mnou nemusíš jít, že jo? Pochopím to, jestli nebudeš chtít."~ */ DO ~IncrementGlobal("BD_MORTE_MORALE","GLOBAL",1) SetGlobal("Morte_Morale_Fortress_Portal","AR0202",1) ~ GOTO 558
IF ~  InParty("Morte") ~ THEN REPLY #54279 /* ~"Rozumím. Pokud ses vymluvil, pojďme. Jsi připravený?"~ */ GOTO 534
IF ~  !InParty("Morte") ~ THEN REPLY #54280 /* ~"Rozumím; díky za radu, Morte. Jsem připravený projít portálem."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 558 // from: 557.0
SAY #54281 /* ~"Jo... já vím, šéfe. A nemůžu ti lhát... nechci tam jít... ale půjdu. Jenom si pamatuj, že jakmile projdeme tím portálem, už to nebude jenom o *tobě*. Teď si hraješ i s našima životama a my se zpátky nedostaneme, jestli umřeme."~ */
IF ~  GlobalGT("Ravel_Grace","GLOBAL",0) GlobalGT("Ravel_Morte","GLOBAL",0) GlobalLT("Torment_Fell","GLOBAL",2) NearbyDialog("Dgrace") ~ THEN REPLY #54282 /* ~"Tak proč jsi..."~ */ EXTERN ~DGRACE~ 169
