IF ~~ THEN REPLY #2602 /* ~"Tím myslíš ten prázdný hrobový pohled?"~ */ DO ~SetGlobal("Morte_Quip","GLOBAL",1) ~ GOTO 47
END

IF ~~ THEN BEGIN 47 // from: 46.0 46.1 121.1 121.2
SAY #2604 /* ~"Co? Seš SLEPEJ?! Mrkala na mě!  Chtěla mě! CHTĚLA!"~ */
IF ~~ THEN REPLY #2605 /* ~"Možná chtěla, abys *šel pryč.* Byla příliš rozrušená ze MNĚ, než aby věnovala pozornost nějaké pitomé poletující hlavě s velkou hubou."~ */ DO ~IncrementGlobalOnceEx("GLOBALMorte_Zombie_1","GLOBALLaw",-1) ~ GOTO 49
IF ~~ THEN REPLY #2606 /* ~"Myslím, že si to jenom namlouváš. Je zombie. Mrtvola. Mrtvá osoba. Nejspíš tě ani nezaregistrovala."~ */ GOTO 48
IF ~~ THEN REPLY #2607 /* ~"Myslím si, že ty a tvoje představivost byste se měli na čas rozejít a dát si pauzu."~ */ GOTO 48
IF ~~ THEN REPLY #2608 /* ~"No jo, Morte. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 48 // from: 47.1 47.2
SAY #2609 /* ~"Jo, jasně. Když seš mrtvej tak dlouho jako já, naučíš se to poznávat. Ty signály jsou pro tebe možná moc NEZŘETELNÝ, ale proto já trávím SVÝ noci s nějakejma nadrženejma právě zemřelejma kočkama, zatímco ty se někde jen tak poflakuješ, huh? Co je? Co-se-děje? Kde je m-m-moje pamm-mmměť?" ~ */
IF ~~ THEN REPLY #2610 /* ~"No jo, Morte. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 49 // from: 47.0
SAY #2611 /* ~"Tebou? Jo, to určo! Věř mi, holky, co si prošly hrobem, si na fyzičnost moc nepotrpí, nesere je 'Já mám tělo' a 'Jsem zjizvenej tvrďák'. Chtějí chlápka, kterej má DUCHA! To sem já, šéfe. Mrtvoly jako TY sou běžnější než zlomená grešle." ~ */
IF ~~ THEN REPLY #2612 /* ~"No jo, Morte. Pojďme."~ */ EXIT
END

