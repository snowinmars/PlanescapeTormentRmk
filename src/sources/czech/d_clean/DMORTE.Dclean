END

IF ~~ THEN BEGIN 554 // from: 553.0
SAY #54263 /* ~"Ten jinej TY, on... jemu na nikom nezáleželo. Na nikom. Klidně jsme mohli v Pevnosti VŠICHNI umřít, a on by ani nemrknul. Takže... já jenom chci, aby ses držel toho rozdílu, protože... no, takhle *tě* mám raději. MNOHEM raději."~ */
IF ~  CheckStatGT(Protagonist,15,WIS) ~ THEN REPLY #54264 /* ~"Ale to není vše, co mi chceš říct, že?"~ */ GOTO 556
IF ~~ THEN REPLY #54265 /* ~"To je vše?"~ */ GOTO 556
