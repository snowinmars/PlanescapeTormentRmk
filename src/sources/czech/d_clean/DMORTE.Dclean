IF ~  Global("Know_Chaosmen","GLOBAL",1) ~ THEN REPLY #13987 /* ~"Ještě jednou, kdo že jsou Xaositectové?"~ */ DO ~SetGlobal("Morte_Wilder_Quip_1","GLOBAL",1) ~ GOTO 166
IF ~  Global("Know_Chaosmen","GLOBAL",1) ~ THEN REPLY #13988 /* ~"Stejně si myslím, že bych se od něj mohl něco dozvědět. No nic, pojďme."~ */ DO ~SetGlobal("Morte_Wilder_Quip_1","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 166 // from: 165.0 165.1
