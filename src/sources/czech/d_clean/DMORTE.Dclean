SAY #68174 /* ~Znovu ses natáhnul svou mocí...~ */
IF ~  GlobalGT("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68175 /* ~Oživ Annah.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204a0",FALSE) ~ EXIT
