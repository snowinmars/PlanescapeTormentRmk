IF ~~ THEN REPLY #65575 /* ~"V pořádku, tedy. Mám nějaké další otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65576 /* ~"V pořádku, tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 654 // from: 329.4 652.0 652.1 729.4
SAY #65577 /* ~"Oh... *ještě* trocha na konec? Považoval jsem to za smyté, tak jsem tuhle řádku nečetl nahlas."~ */
