IF ~~ THEN REPLY #3979 /* ~"Nemyslím si, že je v postavení, kdy by mohl něco namítat."~ */ GOTO 69
IF ~~ THEN REPLY #3980 /* ~"Něco mi říká, že bys byl dvakrát tak otravnější, kdybys měl ruce. Pojďme."~ */ GOTO 70
END

IF ~~ THEN BEGIN 69 // from: 67.1 68.0
SAY #3981 /* ~Morte si chvíli prohlíží kostlivce, pak zavrtí hlavou. "Ne... potřebuju trochu čerstvějšího. A něco s trochou víc důstojnosti... tendle je celej popraskanej a polámanej."~ */
IF ~~ THEN REPLY #3982 /* ~"A ty ne?"~ */ GOTO 70
IF ~~ THEN REPLY #3983 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 70 // from: 67.2 68.1 69.0 127.0
SAY #3984 /* ~"Oh, seš hromada směšnosti." Morte na tebe zlobně zírá. "Kromě toho,  TY MÁŠ tak co mluvit, vole. Lituju všechny chudinky zrcadla, který potkáš."~ */
IF ~~ THEN REPLY #3985 /* ~"Jo tak? No *JÁ* mám alespoň všechny své části."~ */ GOTO 71
IF ~~ THEN REPLY #3986 /* ~"Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 71 // from: 70.0
SAY #3987 /* ~Morte si odfrkl. Nejsi si zrovna jistý, jak to dokázal bez plic.~ */
IF ~~ THEN REPLY #3988 /* ~"Víš, Morte, není nic lepšího a uspokojujícího, než chodit kolem, rozhazovat rukama, dýchat plícemi ostrý vzduch. Je to SKVĚLÝ, mít tělo."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Skeleton_Mort_1","GLOBALLaw",-1) ~ GOTO 72
IF ~~ THEN REPLY #3989 /* ~"Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 72 // from: 71.0
SAY #3990 /* ~"Musím ti říct, že mé rozhodnutí pomoct ti utéct z přípravny, jsem přidal do svýho narůstajícího seznamu věcí, kterejch lituju." Morte si znovu odfrkl. "Měl jsem tě nechat shnít... aspoň o trochu víc."~ */
IF ~~ THEN REPLY #3991 /* ~"Jsem rád, že to tak cítíš. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 73 // from:
SAY #4018 /* ~Morte se zašklebil.~ */
IF ~~ THEN REPLY #4019 /* ~"Uh, je to ano, nebo...?"~ */ GOTO 74
END

IF ~~ THEN BEGIN 74 // from: 73.0
SAY #4020 /* ~"Oh... sorry." Morte přiletěl k hlavě kostlivce, chvíli na ní zírá a pak sletěl dolů, studujíc zbroj a meč. "Jo, ano. Ano, myslím, že tenhle bude akorát."~ */
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4023 /* ~"Dobrá tedy... dej mi vteřinku, ať mu můžu urvat hlavu."~ */ EXTERN ~DGIANTSK~ 2
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #4024 /* ~"Dobrá tedy... dej mi vteřinku, ať mu můžu urvat hlavu."~ */ EXTERN ~DGIANTSK~ 3
IF ~~ THEN REPLY #4025 /* ~"No, já nevím. Připadá mi to, že tohle bys asi nezvládl."~ */ GOTO 75
IF ~~ THEN REPLY #4026 /* ~"Myslím, že bude lepší, když ho necháme být."~ */ GOTO 75
END

IF ~~ THEN BEGIN 75 // from: 74.2 74.3
SAY #4021 /* ~"Tak proč ses mě PTAL, jestli ho chci? Cvičíš si krutost, parchante?" Morte se rozhořčeně zakýval. "Po všem, co jsem pro tebe udělal..."~ */
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4027 /* ~"Dobrá tedy... dej mi vteřinku, ať mu můžu urvat hlavu."~ */ EXTERN ~DGIANTSK~ 2
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #4028 /* ~"Dobrá tedy... dej mi vteřinku, ať mu můžu urvat hlavu."~ */ EXTERN ~DGIANTSK~ 3
IF ~~ THEN REPLY #4029 /* ~"Myslím na tvé bezpečí, Morte. Bojím se, že kdybych tvoji hlavu připevnil k té věci, mohlo by ti to nějak ublížit..."~ */ DO ~IncrementGlobalOnceEx("GLOBALGood_Giant_Skel_Mort_1","GLOBALGood",1) ~ GOTO 76
IF ~~ THEN REPLY #4030 /* ~"Stejně si myslím, že bychom ho raději měli nechat být. Pojďme odtud."~ */ EXIT
END

IF ~~ THEN BEGIN 76 // from: 75.2
SAY #4022 /* ~Morte na tebe chvíli zírá. "Co? Copak jsme se snad VZALI? Co je to za kecy 'Nechci, aby sis ublížil'?" Morte se tváří zlostně. "Kdyby ses OPRAVDU staral, našel bys způsob, jak přidělat moji hlavu na toho kostlivce."~ */
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4031 /* ~"Dobrá tedy... dej mi vteřinku, ať mu můžu urvat hlavu."~ */ EXTERN ~DGIANTSK~ 2
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #4032 /* ~"Dobrá tedy... dej mi vteřinku, ať mu můžu urvat hlavu."~ */ EXTERN ~DGIANTSK~ 3
IF ~~ THEN REPLY #4033 /* ~"Promiň, ale tolik se o tebe nestarám. Pojďme."~ */ EXIT
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4034 /* ~"A já bych řekl, že ho raději necháme být. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 77 // from:
