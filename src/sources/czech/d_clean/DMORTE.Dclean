IF ~~ THEN REPLY #65540 /* ~"Můžeš mi říct aspoň trošku o Sigilu?"~ */ GOTO 659
IF ~  Global("Morte_Talent","GLOBAL",0) ~ THEN REPLY #65541 /* ~"Morte... Nechci ti do toho kecat, ale mohl by jsi dělat něco *jiného*, kromě toho tlachání?"~ */ GOTO 663
IF ~  Global("Morte_Talent","GLOBAL",1) ~ THEN REPLY #65542 /* ~"Morte... které jsou tvé speciální vlohy?"~ */ GOTO 666
IF ~  Global("Morte_Tattoo_XP","GLOBAL",1) ~ THEN REPLY #65543 /* ~"Morte, proč si mi neřekl o té poslední řádce tetování na mých zádech?"~ */ GOTO 654
IF ~~ THEN REPLY #65544 /* ~"Chtělo by to nějakou radu. Co si myslíš, že bychom měli dělat teď?"~ */ GOTO 669
IF ~  Global("Know_Mimir","GLOBAL",1) Global("Morte_Story","GLOBAL",0) ~ THEN REPLY #65545 /* ~"Říkal si, že seš mimir, je to tak, Morte?"~ */ GOTO 684
IF ~  Global("Morte_Story","GLOBAL",1) ~ THEN REPLY #65546 /* ~"Řekni mi znova jak jsi skončil na Pilíři lebek."~ */ GOTO 693
IF ~  Global("Know_Morte_Pillar","GLOBAL",1) ~ THEN REPLY #65547 /* ~"Morte, proč nechceš déle se mnou cestovat, když jsem tě sundal z pilíře?"~ */ GOTO 715
IF ~  GlobalGT("Know_Blood_War","GLOBAL",0) ~ THEN REPLY #65548 /* ~"Co víš o Válce krve?"~ */ GOTO 723
IF ~  GlobalGT("Know_Ravel","GLOBAL",0) Global("Ravel","GLOBAL",0) ~ THEN REPLY #65549 /* ~"Co víš o čarodějnici Ravel?"~ */ GOTO 722
