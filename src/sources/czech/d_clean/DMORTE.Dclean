IF ~~ THEN BEGIN 85 // from:
SAY #4675 /* ~Morte se šeptem vložil do řeči. "U mocností... ten vůl je *Anarchista.* Maskovat se za zombie, to je první věc, která by ty vypatlané blbečky napadla."~ */
IF ~~ THEN REPLY #4676 /* ~"Anarchista?"~ */ JOURNAL #64512 /* ~Muž, zdánlivě přestrojený za zombie, je členem Anarchistů, jakési frakce, která se vymyká autoritám a ničí vše, co jen vzdáleně zavání 'zákonem.' ~ */ GOTO 86
END

IF ~~ THEN BEGIN 86 // from: 85.0
SAY #4677 /* ~"Anarchisti... to je frakce..." Morte se tváří, jako by chtěl dlouze zanadávat, ale pak si všiml, že ho zombie pozorně poslouchá. "...oni, ehm, chtěj *osvobodit* každého od vlády. Zničit starý řád a zavést nový, který by neměl vůbec žádný řád."~ */
IF ~~ THEN REPLY #4678 /* ~Pravdivě: "To zní docela ušlechtile - pořádek občas potřebuje pořádnou likvidaci."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Vaxis_3","GLOBALLaw",-3) ~ EXTERN ~DVAXIS~ 11
IF ~~ THEN REPLY #4679 /* ~Lži: "To zní ušlechtile. Kterýkoli anarchista, který usiluje o takový cíl je *rozhodně* můj přítel."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Vaxis_4","GLOBALLaw",-1) ~ EXTERN ~DVAXIS~ 11
IF ~~ THEN REPLY #4680 /* ~"To zní docela... nefunkčně."~ */ EXTERN ~DVAXIS~ 10
