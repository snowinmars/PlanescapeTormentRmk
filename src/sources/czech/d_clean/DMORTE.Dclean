IF ~~ THEN BEGIN 41 // from:
SAY #2067 /* ~"Je to tiefling, náčelníku. Maj v sobě krev fienda a tak sou paranoidní a střelený... ale má hezkej vocas, to jo. Škoda že je přilepenej na tak hnusným těle."~ */
IF ~~ THEN REPLY #2068 /* ~"Uau..."~ */ EXTERN ~DANNAH~ 17
