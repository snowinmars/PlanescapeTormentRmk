IF WEIGHT #2 ~  Global("Fortress_Morte","GLOBAL",3) GlobalGT("Absorb","GLOBAL",0)
~ THEN BEGIN 737 // from:
SAY #68310 /* ~Když jsi nasměroval svou moc, Morte se náhle vznesl do vzduchu. ""Eh... momentík, šéfe. Nemusíš mě oživovat, já tady, uh, jenom tak ležel, víš, poslouchal vás dva."~ */
IF ~~ THEN REPLY #68311 /* ~TY JSI PŘEDSTÍRAL SMRT.~ */ GOTO 738
END

IF ~~ THEN BEGIN 738 // from: 737.0
SAY #68312 /* ~"No, jo, víš já *už* jsem mrtvej a ... uh, šéfe, co se ti to stalo s hlasem?"~ */
IF ~~ THEN REPLY #68313 /* ~JÁ... TEĎ JSEM NĚČÍM JINÝM. ČAS BĚŽÍ A BRZY MĚ ČAS A MŮJ OSUD DOŽENOU. VRÁTÍM TĚ DO SIGILU, MORTE, JESTLI CHCEŠ.~ */ GOTO 739
END

IF ~~ THEN BEGIN 739 // from: 738.0
SAY #68314 /* ~"Co --? Vrátíš mě? A co *ty*? No tak, šéfe, možná sem *zbabělec*, ale nemůžu tě jen tak opustiti."~ */
IF ~~ THEN REPLY #68315 /* ~MNOHO JE ZLOČINŮ, KTERÉ BYLY SPÁCHÁNY, KDYŽ JSEM BYL ODDĚLEN OD SVÉ SMRTELNOSTI. A TY ZLOČINY... NĚCO STOJÍ. TAM, KDE JÁ BRZY BUDU, TY JÍT NEMŮŽEŠ.~ */ GOTO 740
END

IF ~~ THEN BEGIN 740 // from: 739.0
SAY #68316 /* ~"No, stejně bych s tebou *mohl* jít, šéfe, jestli chceš - víš, už za sebou máme horší-"~ */
IF ~~ THEN REPLY #68317 /* ~TENTOKRÁT NE. MOŽNÁ SE ZASE JEDNOHO DNE SETKÁME, TY A JÁ, V JINÉ SFÉŘE. ALE NE TEĎ.~ */ GOTO 741
END

