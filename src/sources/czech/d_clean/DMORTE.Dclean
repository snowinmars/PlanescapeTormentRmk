IF ~~ THEN REPLY #33960 /* ~"Teď zrovna ne, Morte."~ */ GOTO 326
END

IF ~~ THEN BEGIN 326 // from: 325.1
SAY #33961 /* ~"Hmmmph. Dobře, nevím, jak dlouho tady počkám, takže ti dávám POSLEDNÍ šanci. Seš si jistej, že nepotřebuješ mou asistenci jakožto mudrce a všeznalce, o mým bystrým rozumu nemluvě?"~ */
