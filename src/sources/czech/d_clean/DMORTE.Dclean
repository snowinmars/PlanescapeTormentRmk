IF ~~ THEN REPLY #4682 /* ~Pravdivě: "To mi nepřipadá rozumné. Nějaký pořádek, řád, musí být vždycky.~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Vaxis_3","GLOBALLaw",3) ~ EXTERN ~DVAXIS~ 10
END

IF ~~ THEN BEGIN 87 // from:
SAY #4683 /* ~Šeptá: "Myslí tím, že jsi šílený, blázen, magor, hňup... a já si to myslím taky. A teď se vykašli na ty řeči typu 'Vstal jsem z mrtvých', jasný?! Štveš mě s tím."~ */
IF ~~ THEN REPLY #4684 /* ~"Já štvu TEBE?"~ */ GOTO 88
IF ~~ THEN REPLY #4685 /* ~"Chtěl jsem jenom vědět, o čem ta... mrtvola mluvila. Jasný?"~ */ GOTO 88
IF ~  CheckStatGT(Protagonist,13,INT) ~ THEN REPLY #4686 /* ~"To není moje vina, že nikdo na tomhle šíleném místě nemluví jako normální osoba... nebo VYPADÁ jako normál."~ */ GOTO 88
IF ~~ THEN REPLY #4687 /* ~"Hele, já mu NEBUDU lhát. Chci s ním jednat na rovinu."~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Vaxis_2","GLOBALLaw",1) IncrementGlobalOnceEx("GLOBALGood_Vaxis_2","GLOBALGood",1) ~ GOTO 88
END

IF ~~ THEN BEGIN 88 // from: 87.0 87.1 87.2 87.3
SAY #4688 /* ~Morte si povzdychl. "Hele, šéfe. Vem rozum do hrsti. Nemůžeš chodit kolem a říkat každýmu pokaždé PRAVDU. Nemůžeme si dovolit, aby si nás vomarkoval každej čórovač, kterýho potkáme, ne?"~ */
IF ~~ THEN REPLY #4689 /* ~"Čórovač? Omarkoval? Co to - uh, no nic."~ */ EXTERN ~DVAXIS~ 15
IF ~~ THEN REPLY #4690 /* ~" Nechej toho, Morte."~ */ EXTERN ~DVAXIS~ 15
IF ~~ THEN REPLY #4691 /* ~"Já si to... zapamatuju. A teď si chci promluvit s tou 'zombie'."~ */ EXTERN ~DVAXIS~ 15
END

IF ~~ THEN BEGIN 89 // from:
SAY #4692 /* ~"Počkej..." Morte zní překvapeně. "Ten vůl je *Anarchista.* Maskovat se za zombie, to je první věc, která by ty vymazané blbečky napadla."~ */
IF ~~ THEN REPLY #4693 /* ~"Anarchista?"~ */ JOURNAL #64512 /* ~Muž, zdánlivě přestrojený za zombie, je členem Anarchistů, jakési frakce, která se vymyká autoritám a ničí vše, co jen vzdáleně zavání 'zákonem.' ~ */ GOTO 90
END

IF ~~ THEN BEGIN 90 // from: 89.0
SAY #4694 /* ~"Anarchisti jsou společenstvím, které se snaží likvidovat místní autority a hledají způsob, jak zničit cokoli, co smrdí řádem nebo kontrolou." Morte si odfrkl. "Anarchisti si myslej, že každej vůl ve sférách bude volnej a šťastnej, když si bude moct najít vlastní 'pravdu', jakmile bude všechna vláda zlikvidována. Chtěj nastolit novej pořádek - vůbec žádnej."~ */
IF ~~ THEN REPLY #4695 /* ~Pravdivě: "To zní docela ušlechtile - pořádek občas potřebuje pořádnou likvidaci."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Vaxis_3","GLOBALLaw",-3) ~ EXTERN ~DVAXIS~ 71
IF ~~ THEN REPLY #4696 /* ~"To zní docela... nefunkčně."~ */ EXTERN ~DVAXIS~ 71
IF ~~ THEN REPLY #4697 /* ~"To je jedna z největších hovadin, jaké jsem kdy slyšel."~ */ EXTERN ~DVAXIS~ 71
IF ~~ THEN REPLY #4698 /* ~"No jo."~ */ EXTERN ~DVAXIS~ 71
IF ~~ THEN REPLY #4699 /* ~Pravdivě: "To mi nepřipadá rozumné. Nějaký pořádek, řád, musí být vždycky.~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Vaxis_3","GLOBALLaw",3) ~ EXTERN ~DVAXIS~ 71
END

IF ~~ THEN BEGIN 91 // from:
SAY #4700 /* ~"Ten vůl Pharod prý prodává spoustu mrtváků - mrtvol - Spalovačům. To dělaj Sběrači - sbírají mrtvý těla a prodávají je Spalovačům. Ale ten Pharod jich prej prodává tolik, že si Spalovači myslej, že je strká do knihy mrtvejch lidi dřív, než nadešel jejich čas - to jako že je zabíjí."~ */
IF ~~ THEN REPLY #4701 /* ~"Aha. Chtěl jsem vědět ještě něco..."~ */ EXTERN ~DVAXIS~ 43
IF ~~ THEN REPLY #4702 /* ~"Ten Pharod zní jako světec. Možná budu mít nějaké otázky později. Nikam nechoď."~ */ EXIT
END

IF ~~ THEN BEGIN 92 // from:
