IF ~~ THEN BEGIN 331 // from: 330.0 330.1
SAY #34992 /* ~"Co? Seš SLEPEJ?! Mrkala na mě!  Chtěla mě! CHTĚLA!"~ */
IF ~~ THEN REPLY #34993 /* ~"Možná chtěla, abys *šel pryč.* Byla příliš rozrušená ze MNE, než aby věnovala pozornost nějaké pitomé poletující hlavě s velkou hubou."~ */ DO ~IncrementGlobalOnceEx("GLOBALMorte_Zombie_1","GLOBALLaw",-1) ~ GOTO 332
IF ~~ THEN REPLY #34996 /* ~"Myslím, že si to představuješ. Je zombie. Mrtvola. Mrtvá osoba. Nejspíš tě ani nezaregistrovala."~ */ GOTO 333
IF ~~ THEN REPLY #34999 /* ~"Myslím si, že ty a tvoje představivost byste se měli na čas rozejít a dát si pauzu."~ */ GOTO 333
IF ~~ THEN REPLY #35000 /* ~"No jo, Morte. Pojďme."~ */ EXIT
END

