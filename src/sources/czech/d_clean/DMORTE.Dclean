END

IF ~~ THEN BEGIN 555 // from: 553.1
SAY #54268 /* ~"Všechno, co chci říct je, že navzdory svýmu chování, TY máš silnějšího ducha, než kdy on měl. Ten jinej TY,on... on byl takovej vzdálenej od všeho. Takže... chci, abys na to pamatoval."~ */
IF ~  CheckStatGT(Protagonist,15,WIS) ~ THEN REPLY #54269 /* ~"Ale to není vše, co mi chceš říct, že?"~ */ GOTO 556
