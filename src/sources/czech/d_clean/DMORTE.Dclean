IF ~~ THEN BEGIN 672 // from: 669.1
SAY #65656 /* ~"Bysem řek, že bysme měli najít tudletu bronzovou kouli co nejdřív a pak se s ní vrátit k tomu starýmu kulhavci."~ */
IF ~~ THEN REPLY #65657 /* ~"Pravda. Mám ještě nějaké otázky..."~ */ GOTO 329
