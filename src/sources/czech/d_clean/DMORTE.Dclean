IF ~  Global("Mortai_Contract","GLOBAL",1) GlobalGT("Coppereyes_Contract","GLOBAL",0) ~ THEN REPLY #14275 /* ~"Dobře. Vypadněme odsud."~ */ EXTERN ~DAWAIT~ 6
IF ~  Global("Mortai_Contract","GLOBAL",1) Global("Coppereyes_Contract","GLOBAL",0) ~ THEN REPLY #14276 /* ~"Dobře. Vypadněme odsud."~ */ EXTERN ~DAWAIT~ 6
