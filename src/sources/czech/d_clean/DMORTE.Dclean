IF ~~ THEN BEGIN 421 // from:
SAY #40068 /* ~Morte tě oblétl, napodobujíc dívčinu naivnost. "Klobouk dolů, šéfe... má pravdu! Nikdy předtím jsem si to nevšiml... všude máš *jizvy!*"~ */
IF ~  !NearbyDialog("DMorte") HPPercent(Protagonist,100) ~ THEN REPLY #40069 /* ~"To jsou všechno staré jizvy. Jsem v pořádku."~ */ EXTERN ~DNENNY~ 2
IF ~  !NearbyDialog("DMorte") HPPercentGT(Protagonist,49) ~ THEN REPLY #40070 /* ~"Jen lehce; Budu v pořádku."~ */ EXTERN ~DNENNY~ 2
