IF ~~ THEN REPLY #5042 /* ~"Já to *udělal*! Zlomil jsem mu vaz! Neměl by se hýbat!"~ */ EXTERN ~DSOEGO~ 21
END

IF ~~ THEN BEGIN 101 // from:
SAY #5043 /* ~"Alespoň že dokáže chodit." Morte si odfrkl. "Poletování kolem je docela zábava, ale ztrácí to svůj půvab, když dostaneš chuť někomu nakopat prdel."~ */
IF ~~ THEN EXTERN ~DSOEGO~ 11
END

IF ~~ THEN BEGIN 102 // from:
