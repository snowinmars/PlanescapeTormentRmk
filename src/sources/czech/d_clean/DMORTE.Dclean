IF ~~ THEN BEGIN 675 // from: 669.5
SAY #65665 /* ~"Asi bysme měli zjistit víc vo tý noční čarodějnici Ravel - a já ti povídám, šéfe, že já se na to *netěším*. Nějaký ti zaprášený mudrcové z Občanský Haly by mohli mít nějakýho tušáka, nebo možná bude něco zajímavýho v některým senzorickým šutráku."~ */
IF ~  Global("AR0601_Visited","GLOBAL",0) ~ THEN REPLY #65666 /* ~"Občanská Hala? Senzorické... kameny?"~ */ JOURNAL #65669 /* ~Morte mi navrhl, abych se podíval do Občanské Haly v Úřednické Čtvrti, kde bych mohl zjistit něco víc o noční čarodějnici Ravel."~ */ GOTO 676
IF ~~ THEN REPLY #65667 /* ~"Máš pravdu. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65668 /* ~"Dobrá. Tak tedy pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 676 // from: 675.0
SAY #65670 /* ~"Soráč, náčelníku. Sem zapomněl, že víš sotva tolik, co totální zelenáč přímo ze Základní materiální. Hele, Hala, to je hlavní bejvák Vnímavejch, je to v Úřednický čtvrti. Mají tam knihovny plný senzorickejch šutráků, ve kterých sou uložený zážitky a zkušenosti, a taky tam smrdí hromada mudrců, vědátorů, učitelů a profesorů, kteří by nám mohli prásknout nějaký zajímavosti na tu Ravel."~ */
IF ~~ THEN REPLY #65671 /* ~"Máš pravdu. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65672 /* ~"Dobrá. Tak tedy pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 677 // from: 669.6
SAY #65673 /* ~"No, Ravel skončila v bludišti. Takže asi bude NĚJAKEJ portál a NĚJAKEJ klíč, který by nás tam mohli dostat, teda pokud eště furt chceš."~ */
IF ~  Global("Know_Ravel_Key","GLOBAL",1) ~ THEN REPLY #65674 /* ~"Nevíš, co by mohl být klíč k jejímu bludišti?"~ */ JOURNAL #65678 /* ~Morte mi navrhl návštěvu Občanské Haly. Někdo tam by mohl vědět, kde získat kousek Ravel. Pokud nikoho takového nenajdu, mám zkusit senzorické kameny. A pokud by i *tohle* selhalo, řekl bych, že opravdu můžeme zajít za nějakýma prostitutkama. Určitě to bude zábavnější, než to neustálé poletování mezi lidma a marná snaha něco zjistit.~ */ GOTO 678
IF ~~ THEN REPLY #65675 /* ~"Nevíš, kde bych našel portál, který vede do toho bludiště?"~ */ GOTO 679
IF ~~ THEN REPLY #65676 /* ~"Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65677 /* ~"Dobrá. Tak tedy pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 678 // from: 677.0
SAY #65679 /* ~"Nemám tušáka - hele, přece si to vem: 'kousek Ravel?' To může být cokoli od její uschlý bradavice přes nějaký umělecký dílo, co spáchala, až po trochu uschlejch slin, co jí steklo z pysku. Je to moc povšechný, chápeš? Ale vsadil bych se, že NĚKDO v Občanský Hale by o tom mohl mít tušáka, jak sehnat kousek tý šílený čarodějnice. Pokud to nevyjde, můžem prolízt senzorický šutry, co tam maj. Možná že některej z těch šutráků bude něco vědět."~ */
IF ~~ THEN REPLY #65680 /* ~"Nevíš, kde bych našel portál, který vede do toho bludiště?"~ */ GOTO 679
IF ~~ THEN REPLY #65681 /* ~"Máš pravdu. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65682 /* ~"Dobrá. Tak budeme hledat dál."~ */ EXIT
END

IF ~~ THEN BEGIN 679 // from: 677.1 678.0
SAY #65683 /* ~"Nemám tušáka, náčelníku. V Sigilu sou tisíce portálů, milióny. Bysem řek, že můžem prubnout Občanskou Halu. Tam asi nebude, ale některej ze senzorickejch šutráků by moh něco vědět. A pokud to nevyjde, tak já povídám todle: Vykašlem se na todleto pobíhání. Dyž nemůžeš něco vyřešit, najdi si někoho schopnýho a otravuj ho tak dlouho, až to vyřeší za tebe. Zkrátka najdeme někoho, kdo nám ten blbej portál UDĚLÁ."~ */
IF ~~ THEN REPLY #65684 /* ~"Dobrá tedy. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65685 /* ~"Dobrá. Tak tedy pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 680 // from: 669.7
SAY #65686 /* ~"Bysem řek, že bysme měli najít, co potřebujem a pak prásknout do bot, až se nám bude vod zadků kouřit, náčelníku. Z tohodle místa mi běhá mráz po zádech a to nemám záda. Jasný?"~ */
IF ~~ THEN REPLY #65687 /* ~"To je fakt. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65688 /* ~"Dobrá tedy. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 681 // from: 669.8
SAY #65689 /* ~"Dostals mě, náčelníku. Teď je to tvoje šou - já si tu akorát poletuju někde kolem tebe."~ */
IF ~~ THEN REPLY #65690 /* ~"To je fakt. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65691 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 682 // from: 651.2
SAY #65692 /* ~"Ne... málem tě stáhli i z kůže. Jak už sem povídal, vypadá to, jako bys měl ten deník naškrábanej na vlastní kůži."~ */
IF ~  Global("Pharod","GLOBAL",0) ~ THEN REPLY #65693 /* ~"A ty si seš jistý, že neznáš nikoho jménem Pharod?"~ */ GOTO 683
IF ~~ THEN REPLY #65694 /* ~"To je fakt. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65695 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 683 // from: 682.0
SAY #65696 /* ~"Ne-e. Ale někdo by to moh vědět. Zeptáme se domorodců."~ */
IF ~~ THEN REPLY #65697 /* ~"Než půjdeme, mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65698 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 684 // from: 329.6 729.6
SAY #65699 /* ~"Jo... mimir je lítající encyklopedie. Dáš do něj informaci, vytáhneš z něj informaci."~ */
IF ~  Global("Grace_Silver_Mimir","GLOBAL",1) ~ THEN REPLY #65700 /* ~"Ale nejsou mimirové udělaní z nějakého stříbřitého kovu?"~ */ GOTO 685
IF ~~ THEN REPLY #65701 /* ~"Aha. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65702 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 685 // from: 684.0
SAY #65703 /* ~"A co? Možná někerý sou, ale *já ne*. A ve Sférách sou i divnější věci, šéfe. Třeba chlast, co některý šílení magoři chlastaj."~ */
IF ~~ THEN REPLY #65704 /* ~"Nemyslím si, že jsi mimir, Morte. Co jsi?"~ */ GOTO 686
IF ~~ THEN REPLY #65705 /* ~"Aha. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65706 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 686 // from: 685.0
SAY #65707 /* ~"Co je to za výslech? Co *ty* vůbec víš o mimirech?"~ */
IF ~  Global("Grace_Smell_Mimir","GLOBAL",1) ~ THEN REPLY #65708 /* ~"Vím dost, abych poznal, že mi lžeš."~ */ GOTO 687
IF ~  Global("Morte_Tattoo_XP","GLOBAL",1) ~ THEN REPLY #65709 /* ~"Vím dost, abych poznal, že mi lžeš. Nejdřív ten řádek na mých zádech, co jsi mi nepřečetl, tvrdil, že ti nemám věřit, teď tohle. Co si mám podle tebe myslet?"~ */ GOTO 687
IF ~~ THEN REPLY #65710 /* ~"No řekl bych že nic. Mám ještě nějaké otázky..."~ */ JOURNAL #65712 /* ~Zkonfrontoval jsem Morta s nesrovnalostí. Prohlašuje o sobě, že je mimir, ale já do něj nemusel nic zapisovat. Myslím, že ho budu muset chytit při nějaké lži, abych z něj dostal pravdu.~ */ GOTO 329
IF ~~ THEN REPLY #65711 /* ~"No tak to nic. Pojďme."~ */ JOURNAL #65712 /* ~Zkonfrontoval jsem Morta s nesrovnalostí. Prohlašuje o sobě, že je mimir, ale já do něj nemusel nic zapisovat. Myslím, že ho budu muset chytit při nějaké lži, abych z něj dostal pravdu.~ */ EXIT
END

IF ~~ THEN BEGIN 687 // from: 686.0 686.1
SAY #65713 /* ~"Oukej, *nejsem* mimir, ale vím spoustu věcí, takže bych klidně *mohl* bejt mimir."~ */
IF ~~ THEN REPLY #65714 /* ~"Tak co tedy jsi?"~ */ GOTO 688
IF ~~ THEN REPLY #65715 /* ~"To nic. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65716 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 688 // from: 687.0
SAY #65717 /* ~"Jsem lítající lebka, co toho spoustu ví."~ */
IF ~  Global("Grace_Smell_Mimir","GLOBAL",1) Global("AR1000_Visited","GLOBAL",0) ~ THEN REPLY #65718 /* ~"A co ten Baatorianský zápach, který se kolem tebe šíří?"~ */ GOTO 690
IF ~  Global("Grace_Smell_Mimir","GLOBAL",1) Global("AR1000_Visited","GLOBAL",1) ~ THEN REPLY #65719 /* ~"A co ten Baatorianský zápach, který se kolem tebe šíří?"~ */ GOTO 689
IF ~~ THEN REPLY #65720 /* ~"To nic. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65721 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 689 // from: 688.1
SAY #65722 /* ~"Jak TY víš, jak smrdí Baator?!"~ */
IF ~~ THEN REPLY #65723 /* ~"Protože jsem tam *byl*, Morte. Procházel jsem Avernem."~ */ GOTO 691
IF ~~ THEN REPLY #65724 /* ~"To nic. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65725 /* ~"Zapomeň na to. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 690 // from: 688.0
SAY #65726 /* ~"Jak TY víš, jak smrdí Baator?! Pokud - hej, ty ses o mě bavil s tou tanar'ri, že jo?! Co ví?!!"~ */
IF ~~ THEN REPLY #65727 /* ~"No, rozhodně se v něčem trefila. Je to zápach Baatoru, že?"~ */ GOTO 691
IF ~~ THEN REPLY #65728 /* ~"To nic. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65729 /* ~"Zapomeň na to. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 691 // from: 689.0 690.0
SAY #65730 /* ~"No, jo, ale - no jo, no. Tak trochu smrdím. *Promiň*."~ */
IF ~~ THEN REPLY #65731 /* ~"*Proč* smrdíš po Baatoru?"~ */ DO ~SetGlobal("Morte_Story","GLOBAL",1) ~ GOTO 692
END

IF ~~ THEN BEGIN 692 // from: 691.0
SAY #65732 /* ~"Byl jsem nějakou dobu v pekle. Dost dlouhou dobu. A toho smradu se už pak jen tak nezbavíš."~ */
IF ~~ THEN REPLY #65733 /* ~"Ty jsi byl v pekle? Co jsi tam DĚLAL?"~ */ DO ~AddexperienceParty(12000) ~ GOTO 693
END

IF ~~ THEN BEGIN 693 // from: 329.7 692.0 729.7
SAY #65734 /* ~"No víš, v Avernu, první vrstvě  Baatoru je takovej *pilíř*. Říká se mu Pilíř Lebek, ale je to spíš velká hromada hlav."~ */
IF ~~ THEN GOTO 694
END

IF ~~ THEN BEGIN 694 // from: 693.0
SAY #65735 /* ~"Podle toho, co jsem slyšel, tak je *prý* většinou z hlav mudrců, učenců a takovejch týpků, kteří zaživa použili svý znalosti tohodle a támhletoho, aby trošinku pokroutili pravdu... tak moc, že díky tomu pak někomu ublížili nebo dokonce někoho zabili. No, když jsem *umřel*, skončil jsem tam. Sranda, co?"~ */
IF ~~ THEN REPLY #65846 /* ~"Ani ne."~ */ GOTO 695
END

IF ~~ THEN BEGIN 695 // from: 694.0
SAY #65736 /* ~"Eh..." Morte je chvíli zticha. "Jo, máš pravdu. Vůbec to není sranda. Hele, myslím, že sem toho zaživa spoustu věděl. A možná když jsem něco věděl, neřekl sem o tom pravdu. Možná sem pravdu trošinku překroutil, jednou nebo dvakrát a možná díky tomu někdo skončil v knize mrtvejch o chvilinku dřív, než by měl."~ */
IF ~~ THEN REPLY #65737 /* ~"Pamatuješ si kdo?"~ */ GOTO 697
IF ~  CheckStatGT(Protagonist,13,WIS) ~ THEN REPLY #65738 /* ~"Byl jsem to já, že?"~ */ GOTO 696
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65739 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65740 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 696 // from: 695.1
SAY #65741 /* ~Morte se na tebe chvíli mlčky dívá. "Jo. Nevím, *jak* to vím, šéfe, ale... myslím si to. Myslím si, že to kvůli tobě mě tam poslali. Ale nemůžu si vzpomenout, co se stalo. Dokonce si ani nepamatuju, jaký to bylo, když jsem byl člověk, vlastně si nepamatuju nic před tím. Než jsem se probral v Pilíři."~ */
IF ~~ THEN REPLY #65742 /* ~"Proč jsi zapomněl?"~ */ GOTO 698
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65743 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65744 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 697 // from: 695.0
SAY #65745 /* ~"Nedokážu říct proč, ale myslím si, že jsi to byl *ty*. Alespoň jednou. Ale nemůžu si vzpomenout, co se stalo. Dokonce si ani nepamatuju, jaký to bylo, když jsem byl člověk, vlastně si nepamatuju nic před tím. Než jsem se probral v Pilíři."~ */
IF ~~ THEN REPLY #65746 /* ~"Proč jsi zapomněl?"~ */ GOTO 698
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65747 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65748 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 698 // from: 696.0 697.0
SAY #65749 /* ~"To už tak bývá, když jeden zdechne. Řek bych, že ty o tom víš taky svý. Zkrátka... zapomeneš. Řek bych, že sem zaživa nebyl zrovna zářným příkladem společnosti... ale ksakru, kdo je?" Morte vzdychl. "Si zkrátka nemůžu pomoct. Nic není tak hnusný, jako bejt furt... *upřímnej.*"~ */
IF ~  Global("Chaotic_Morte_1","GLOBAL",0) ~ THEN REPLY #65750 /* ~"Kromě odsouzení do pekel. To mi připadá jako mnohem horší, než říkat pravdu."~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Morte_1","GLOBALLaw",1) ~ GOTO 699
IF ~  Global("Lawful_Morte_1","GLOBAL",0) ~ THEN REPLY #65751 /* ~"No, to je pravda... ale musíš si vybírat lži opatrně."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Morte_1","GLOBALLaw",-1) IncrementGlobalOnceEx("GLOBALEvil_Morte_1","GLOBALGood",-1) ~ GOTO 699
END

IF ~~ THEN BEGIN 699 // from: 698.0 698.1
SAY #65752 /* ~"Jo... máš pravdu. *Zase.*" Morte zacvakal zubama. "Bych řek, že všechno to dobro a zlo a lhaní a podvádění tě nakonec ťapnou. A když jsem skončil v knize mrtvejch, byl sem na řadě se splátkama."~ */
IF ~~ THEN REPLY #65753 /* ~"Jak jsi utekl z Pilíře?"~ */ JOURNAL #53633 /* ~Morte sdělil, že jsem ho kdysi dávno vytáhl z Pilíře, tak dávno, že už si nepamatuje, jak přesně. Taky mi vysvětlil, že ztratil všechnu shromážděnou znalost Pilíře, když jsem ho od něj odloučil... což by vysvětlovalo, proč nebyl tak *docela* užitečný, jak sliboval mé předchozí inkarnaci.~ */ GOTO 700
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65754 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65755 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 700 // from: 699.0
SAY #65757 /* ~"No... ty si mi pomoh, šéfe. Když ses ukázal u Pilíře, prorval sem se dopředu. Moje skvělý knouhau a okouzlující osobnost připoutaly tvou pozornost - věděl jsi, že *já* jsem ta hlava, která ví nejvíc. A tak sme se dohodli."~ */
IF ~~ THEN REPLY #65758 /* ~"Dohodli?"~ */ DO ~PlaySoundNotRanged("SPTR_01") FadeToColor([20.0],0) Wait(3) FadeFromColor([20.0],0) ~ GOTO 701
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65759 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65760 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 701 // from: 700.0
SAY #65761 /* ~Jak Morte mluví, tvůj pohled zrudnul, slyšíš vytí, příšerný *skřek*, který vznikl splynutím tisíců hlasů, které ječí, vřískají, řvou a VŠECHNY tě prosí, ječí, žebrají o osvobození, a Mortův hlas... slabý, téměř se v tom rámusu ztrácí. Jeho hlas zní zoufale, vyděšeně a... pateticky, tragicky, *ztraceně.*~ */
IF ~~ THEN REPLY #65762 /* ~Ozvěna: "Ty. Lebko. Mluv."~ */ GOTO 702
IF ~~ THEN REPLY #65763 /* ~Zažeň vzpomínku.~ */ DO ~FadeToColor([20.0],0) Wait(3) FadeFromColor([20.0],0) ~ GOTO 706
END

IF ~~ THEN BEGIN 702 // from: 701.0
SAY #65764 /* ~Ječící hlasy pozvolna utichly. Sleduješ malou zrudlou lebku, zkroucené rysy tváře, v pekelném světle podivně deformované. Obrátila k tobě své oči. Po tváři jí stéká krev a nějaký odporný výtok, zuby drkotají, jakoby zimou. "Já... já... m-m-m-můžu ti p-p-p-om-moct. Vím-m-m, c-c-co hledáš. Všechny ty h-h-hlavy... všechno vědění... p-prosím, *prosím* tě, uvolni m-mě. Nech mě, ať ti *pomůžu*. Řeknu ti všechno, *všechno*."~ */
IF ~~ THEN REPLY #65765 /* ~Ozvěna: "*Řekneš*? PŘÍSAHEJ, lebko. PŘÍSAHEJ, že mi budeš sloužit až do konce mých dnů, jinak tě tady nechám."~ */ GOTO 703
IF ~~ THEN REPLY #65766 /* ~Zažeň vzpomínku.~ */ DO ~FadeToColor([20.0],0) Wait(3) FadeFromColor([20.0],0) ~ GOTO 706
END

IF ~~ THEN BEGIN 703 // from: 702.0
SAY #65767 /* ~"Přísahám... přísahám, jenom mě prosím, *prosím* uvolni... já..." Vidíš, jak Morte slabě polkl, zahání zbytečky své hrdosti. "Já... já tě prosím. Nech mě, ať ti pomůžu. Prosím."~ */
IF ~~ THEN REPLY #65768 /* ~Ozvěna: "Dobrá tedy. Uvolním tě."~ */ GOTO 704
IF ~~ THEN REPLY #65769 /* ~Zažeň vzpomínku.~ */ DO ~FadeToColor([20.0],0) Wait(3) FadeFromColor([20.0],0) ~ GOTO 706
END

IF ~~ THEN BEGIN 704 // from: 703.0
SAY #65770 /* ~Pohled se posunul, jako byses pohyboval. Znovu začíná to šílené řvaní a skřehotání, znovu se ozývá ten jek z noční můry, plný výkřiků, nadávek, hrozeb a proseb... cítíš, jak tvé ruce vnikají do špinavé struktury pilíře, cítíš, jak se ti do kůže zarývají zuby, jak ti sežvýkávají kůži a pak... Cítíš, jak se tvé ruce sevřely kolem malé lebky a začínají ji rvát ven, rvou , tahají a vytrhávají ven z pilíře...~ */
IF ~~ THEN REPLY #65771 /* ~Ozvěna: "Je VYKONÁNO."~ */ GOTO 705
IF ~~ THEN REPLY #65772 /* ~Zažeň vzpomínku.~ */ DO ~FadeToColor([20.0],0) Wait(3) FadeFromColor([20.0],0) ~ GOTO 706
END

IF ~~ THEN BEGIN 705 // from: 704.0
SAY #65773 /* ~Díváš se na krvavou lebku, která spočívá v tvých zjizvených dlaních, pokrytá slizem z pilíře. Zuby jí zacvakaly. Jednou, dvakrát. Připomíná ti to nářek bezmocného novorozeněte a připadá ti to - v očích muže, kterým jsi kdysi býval - neuvěřitelně patetické.~ */
IF ~  Global("Memory_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65774 /* ~Ozvěna: "Uvolnil jsem tě. Teď je tvůj život... a tvá smrt mým majetkem... Morte."~ */ DO ~SetGlobal("Memory_Morte_Pillar","GLOBAL",1) GiveExperience(Protagonist,12000) FadeToColor([20.0],0) Wait(3) FadeFromColor([20.0],0) ~ GOTO 706
IF ~  Global("Memory_Morte_Pillar","GLOBAL",1) ~ THEN REPLY #65775 /* ~Ozvěna: "Uvolnil jsem tě. Teď je tvůj život... a tvá smrt mým majetkem... Morte."~ */ DO ~FadeToColor([20.0],0) Wait(3) FadeFromColor([20.0],0) ~ GOTO 706
END

IF ~~ THEN BEGIN 706 // from: 701.1 702.1 703.1 704.1 705.0 705.1
SAY #65776 /* ~Pohled se ti zamlžil, přeludy minulosti odplouvají pryč. Morte pořád něco povídá. "Chvilku jsme si povídali, ty a já, šéfe, vypracovávali jsme dohodu, která bude vyhovovat mně i tobě. Myslím, že oba jsme na toho druhého udělali dojem. Ty jsi mi potom nabídnul, abych šel s tebou. No a do té doby jsem s tebou tak nějak pořád."~ */
IF ~~ THEN REPLY #65777 /* ~"Uh... co se stalo pak?"~ */ GOTO 707
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65778 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65779 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 707 // from: 706.0
SAY #65780 /* ~"No, nevěděl jsem, že když vyjdu ven z Pilíře, ztratím většinu jeho znalostí... teda, jak jsem to jenom mohl vědět, nikdy jsem mimo tu hnusnou věc nebyl. Ale tys to naštěstí pochopil..."~ */
IF ~~ THEN REPLY #65781 /* ~"Ztratil jsi znalosti, které jsi měl...?"~ */ DO ~PlaySoundNotRanged("SPTR_01") FadeToColor([20.0],0) Wait(3) FadeFromColor([20.0],0) ~ GOTO 708
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65782 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65783 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 708 // from: 707.0
SAY #65784 /* ~Tvůj pohled se znovu zkroutil a zamlžil, zamotala se ti hlava. Cítíš, jak se ti svírají vnitřnosti. A slyšíš praskání a lámání kostí a Mortovo vytí. Vyje bolestí, ječí, prosí někoho, aby toho nechal, aby ho *nezabíjel*.. a tvá ruka znovu udeřila a znovu a znovu..."~ */
IF ~~ THEN REPLY #65785 /* ~Ozvěna: "PROKLÍNÁM tě, lebko. LHALA jsi mi. VRAZÍM TĚ ZPÁTKY DO TOHO PROKLETÉHO PILÍŘE A NECHÁM TĚ TAM *CHCÍPNOUT!*"~ */ GOTO 709
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65786 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65787 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 709 // from: 708.0
SAY #65788 /* ~Je slyšet chřestění kostí na něčem, co zní jako kov - podlaha nebo zeď. A taky zachřestění vyražených zubů. Slyšíš Morta, jak kňourá jako zmlácený pes a prosí tě, abys-~ */
IF ~~ THEN REPLY #65789 /* ~Ozvěna: "VĚZ, ŽE TVÉ UTRPENÍ V PILÍŘI JE *NIC* PROTI MUKÁM, KTERÉ TI PŘIPRAVÍM. BUDEŠ *TRPĚT*."~ */ DO ~FadeToColor([20.0],0) Wait(3) FadeFromColor([20.0],0) ~ GOTO 710
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65790 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65791 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 710 // from: 709.0
SAY #65792 /* ~Pohled se znovu zamlžil a Mortův nářek přešel do rytmického blábolení. "Uvědomil sis, že pořád jsem použitelný ke spoustě věcí, a tak jsem zůstal s tebou a od té doby jsem pořád s tebou."~ */
IF ~~ THEN REPLY #65793 /* ~"Morte, co jsem chtěl od Pilíře? A jak je to dlouho, co jsem tě uvolnil?"~ */ GOTO 711
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65794 /* ~"Uh... zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65795 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 711 // from: 710.0
SAY #65796 /* ~Morte chvíli přemýšlí. "No, pokud jde o to, jak přesně dlouho, tak to nevím, šéfe - celý věky, řek bych. Pokaždý jsem dělal, co jsem moh, abych ti pomoh, ale..." Morte vzdychl. "Není to lehký. A co týče toho, cos teda jako chtěl od Pilíře, tak to nevím. Jakmile jsi mě vyrval ven, zapomněl jsem to."~ */
IF ~~ THEN REPLY #65797 /* ~"Morte, proč jsi mi něco NEŘEKL, když jsme byli ještě v Márnici?"~ */ GOTO 712
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65798 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65799 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 712 // from: 711.0
SAY #65800 /* ~Morte se najednou stáhl do obrany. "Protože nikdy *nevím*, co jsi zač! Některé z tvých inkarnací byly šílený, totálně mimo mísu! Jednou ses probral a byl si přesvědčenej, že *já* jsem tvoje lebka a pak jsi mě honil kolem dokola, chtěls mě rozmlátit a sežrat! Naštěstí tě na ulici srazil vůz. Jiná inkarnace, dobrá a zákonná,' se mě snažila vrazit zpátky do Pilíře, protože 'to je místo, kam patřím.'" Morte se zašklebil. "*Proto.* Kromě toho, nic ti to neudělalo, žes to nevěděl..."~ */
IF ~  Global("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65801 /* ~"Takže ty jsi se mnou byl celou tu dobu?"~ */ GOTO 713
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65802 /* ~"Zapomeň na to, Morte. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~  GlobalGT("Know_Morte_Pillar","GLOBAL",0) ~ THEN REPLY #65803 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 713 // from: 712.0
SAY #65804 /* ~"No, jó, šéfe. Říkal jsem, že budu. Morte vždycky dodržuje svý sliby." Odmlčel se. "No, většinu z nich. To bylo jednou jedno kotě v Arboree, která ---"~ */
IF ~~ THEN DO ~SetGlobal("Know_Morte_Pillar","GLOBAL",1) ~ GOTO 714
END

IF ~~ THEN BEGIN 714 // from: 713.0
SAY #65805 /* ~Uvědomil sis, že se Mortův tón změnil - přes jeho vtípky jsi poznal, že se snaží něco ukrýt. Něco o tom, proč je s tebou.~ */
IF ~~ THEN REPLY #65806 /* ~"Morte, vážně. Proč se mnou pořád cestuješ?"~ */ GOTO 715
IF ~~ THEN REPLY #65807 /* ~"Dobrá tedy. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65808 /* ~"To nic, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 715 // from: 329.8 714.0 729.8
SAY #65809 /* ~"Šéfe, říkal jsem ti, že jsem to slíbil, ne?" Vypadá podrážděně. "Proč jinak?"~ */
IF ~~ THEN REPLY #65810 /* ~"Já nevím. Nemusel jsi se mnou zůstat, po tom, co jsem tě uvolnil."~ */ GOTO 716
IF ~~ THEN REPLY #65811 /* ~"To nic. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65812 /* ~"Zapomeň na to, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 716 // from: 715.0
SAY #65813 /* ~"No jasně že ne, šéfe, ale - " A najednou ti hlavou bleskl nápad, snad tě na něj přivedl jeho tón, ale teď už víš, *proč* s tebou zůstal celou tu dobu.~ */
IF ~~ THEN REPLY #65814 /* ~"Cítíš *vinu*. Protože jsi mě před dávnou dobou přivedl na smrt, proto, že ano? A od té doby neustále trpíš."~ */ GOTO 717
END

IF ~~ THEN BEGIN 717 // from: 716.0
SAY #65815 /* ~"Ale, no ták, šéfe. Já? Cítit *vinu*? Neblbni, dyť já jsem Morte."~ */
IF ~~ THEN REPLY #65816 /* ~"Ne, myslím si, že je to tohle. Když jsem tě přišel osvobodit od osudu, který sis zasloužil, nemohl jsi jinak, než mi zkusit pomoct. A když jsi mohl odejít, poté, co jsem tě uvolnil, zůstal jsi. Protože jsi cítil, že mi to dlužíš."~ */ GOTO 718
END

IF ~~ THEN BEGIN 718 // from: 717.0
SAY #65817 /* ~Morte se na tebe chvilku mlčky dívá. "Možná. Víš co je srandovní? Nejdřív jsem nevěděl, co je to za pocit - ono tě to tak nějak pomalu požírá, víš?"~ */
IF ~~ THEN GOTO 719
END

IF ~~ THEN BEGIN 719 // from: 718.0
SAY #65818 /* ~"Víš, nejdřív sem si myslel, že je to nějakej vedlejší efekt kouzla, co jsi na mě poslal... ale o pár set let později sem si uvědomil, že je to *víc* než to... něco hlubšího. Cítil sem, že mě to k tobě táhne, že sem k tobě nějak *připojenej*. Možná je to všechno to tvý utrpení, šéfe... tvý muka. Já nevím. Možná sem cítil... já fakt nevím, možná sem se cítil *zodpovědnej* za to, co jsem udělal. Co když tě do tohohle stavu dostalo něco, co jsem udělal?"~ */
IF ~~ THEN DO ~SetGlobal("Know_Morte_Pillar","GLOBAL",2) ~ GOTO 720
END

IF ~~ THEN BEGIN 720 // from: 719.0
SAY #65820 /* ~"Nemyslím si, že bych - ať už jsem byl kdokoli - měl kdy *vidět* následky svýho lhaní a podvádění. No a když jsem tě viděl poprvé, ještě strčenej v Pilíři, nějak jsem *věděl*, že tebe jsem kdysi zradil. Kdysi... před dávnou dobou." Morte vzdychl. "A to je všechno, co vím."~ */
IF ~~ THEN REPLY #65821 /* ~"Aha. Díky, žes mi to vyjasnil, Morte."~ */ DO ~AddexperienceParty(12000) MoraleInc("Morte",3) PermanentStatChange("Morte",STR,RAISE,4) PermanentStatChange("Morte",DEX,RAISE,2) PermanentStatChange("Morte",CON,RAISE,2) SetGlobal("BD_MorteStory","GLOBAL",1) JOURNAL #65825 /* ~Zjistil jsem, proč se mnou Morte zůstal celou tu dobu... protože se cítil vinný, že jsem kvůli němu kdysi zemřel, když byl ještě živý. Když jsem ho s touhle vinou zkonfrontoval, jakoby to z něj zvedlo tíži, kterou cítí. Stal se silnějším.~ */ GOTO 721
END

IF ~~ THEN BEGIN 721 // from: 720.0
SAY #65822 /* ~"Né, neděkuj mi..." Morte vzdychl a k tvému překvapení jeho hlas zní silněji, sebevědoměji. Některé praskliny v jeho lebce zmizely, jako by se zahojily. "Kdepak, já bych měl děkovat... Cítím se, jako by mi někdo z ramen sundal váhu všech Sfér - obrazně řečeno, to je jasný."~ */
IF ~~ THEN REPLY #65823 /* ~"Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65824 /* ~"Dobrá, Morte. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 722 // from: 329.10 729.10
SAY #65826 /* ~"No, je to noční čarodějnice - a určitě byla dost střelená, aby TĚ udělala nesmrtelným, zrovna tebe ze všech lidí. Víš, myslím jako, že si mohla vybrat třeba mně." Morte zakroutil očima. "No ale kdokoli, kdo je dost praštěnej, aby se zkusil porvat s Paní Bolesti, zkrátka není někdo, koho bysme doopravdy chtěli najít."~ */
IF ~~ THEN REPLY #65827 /* ~"Aha. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65828 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 723 // from: 329.9 729.9
SAY #65829 /* ~"Je to válka. Velká, krvavá, hnusná várka. Odehrává se všude, ale ne vždycky ji můžeš vidět."~ */
IF ~~ THEN REPLY #65830 /* ~"Pokračuj..."~ */ GOTO 724
IF ~~ THEN REPLY #65831 /* ~"To nic. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65832 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 724 // from: 723.0
SAY #65833 /* ~"Hele, šéfe, je to válka mezi dvěma hnusnejma rasama: démonama a ďáblama. Bylo nebylo, před dávnejma dobama o sobě nevěděli. Ďáblové byli zlí, ale byli to 'řádní' zlí. Démoni sou taky zlí, ale jsou to větší pohodáři - jsou impulzivnější, chaotičtí, neorganizovaný. Ďáblové sou jako politici, démoni jako řezníci."~ */
IF ~~ THEN GOTO 725
END

IF ~~ THEN BEGIN 725 // from: 724.0
SAY #65834 /* ~"No a pak se jednoho dne potkali. Podívali se na sebe a ani jedněm se nelíbilo, jak ti druzí provozují zlo. A od tý doby se bijou. Je to jako velká hnusná noční můra. Má to ale přece jenom jednu výhodu. Alespoň se tak bijou mezi sebou a nemají čas otravovat celý Sféry."~ */
IF ~~ THEN REPLY #65835 /* ~"Aha. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65836 /* ~"To je všechno, co jsem chtěl vědět. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 726 // from: 329.11 729.11
SAY #65837 /* ~"Nemám tušáka, šéfe. Sem tak nějak zapomněl, když sem umřel. Ale nedá se říct, že by mě to moc štvalo - alespoň na mě něco po smrti čekalo, i když je to žít jako lítající lebka. Víš, myslím tím, že to klidně mohlo bejt horší."~ */
IF ~~ THEN REPLY #65839 /* ~"Co se stalo s tvým tělem?"~ */ GOTO 727
IF ~~ THEN REPLY #65840 /* ~"Aha. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65841 /* ~"Dobrá tedy. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 727 // from: 726.0
SAY #65838 /* ~"Eh... já nevím, jasný? Je to zkrátka fuč." Morte se na tebe naštvaně dívá. "Ale nemyslí si, že mi CHYBÍ, protože já jsem šťastnej s tím, jakej sem a nepotřebuju tvý přiblblý rozumování nebo trapný poznámky, jasný?"~ */
IF ~~ THEN REPLY #65842 /* ~"Aha. Mám ještě nějaké otázky..."~ */ GOTO 329
IF ~~ THEN REPLY #65843 /* ~"No jo. Pojďme. Pohni kostrou."~ */ GOTO 728
END

IF ~~ THEN BEGIN 728 // from: 727.1
SAY #65844 /* ~Morte tě spaluje pohledem. "Nejsem si zrovna jistý, jestli nejseš nějakej druh chodící kletby, kterou mě někdo proklel, aby mě furt sledovala."~ */
IF ~~ THEN REPLY #65845 /* ~"Hele, kdo to mluví. Pojďme."~ */ EXIT
END 
IF WEIGHT #7 /* Triggers after states #: 742 737 733 even though they appear after this state */ ~  Global("AR0200_Visited","GLOBAL",1) InParty("Morte") !GlobalGT("Fortress_Morte","GLOBAL",2)
~ THEN BEGIN 729 // from:
SAY #66344 /* ~"Co tě žere, náčelníku?"~ [MRT515] */
IF ~~ THEN REPLY #66345 /* ~"Můžeš mi znovu přečíst, co mám vytetováno na zádech?"~ */ GOTO 649
IF ~~ THEN REPLY #66346 /* ~"Můžeš mi říct něco málo o Sigilu?"~ */ GOTO 659
IF ~  Global("Morte_Talent","GLOBAL",0) ~ THEN REPLY #66347 /* ~"Morte... nevadí mi, že jsi se mnou, ale je tady *ještě* něco jiného co dokážeš, kromě kecání?"~ */ GOTO 663
IF ~  Global("Morte_Talent","GLOBAL",1) ~ THEN REPLY #66348 /* ~"Morte... jaké že jsou ty tvoje speciální schopnosti?"~ */ GOTO 666
IF ~  Global("Morte_Tattoo_XP","GLOBAL",1) ~ THEN REPLY #66349 /* ~"Morte, proč jsi mi nepřečetl to poslední tetování na mých zádech?"~ */ GOTO 654
IF ~~ THEN REPLY #66350 /* ~"Hodila by se mi nějaká rada. Co myslíš, co bychom měli udělat teď?"~ */ GOTO 669
IF ~  Global("Know_Mimir","GLOBAL",1) Global("Morte_Story","GLOBAL",0) ~ THEN REPLY #66351 /* ~"Tys říkal, že jsi mimir, že jo, Morte?"~ */ GOTO 684
IF ~  Global("Morte_Story","GLOBAL",1) ~ THEN REPLY #66352 /* ~"Zopakuj mi, jak jsi skončil v Pilíři Lebek."~ */ GOTO 693
IF ~  Global("Know_Morte_Pillar","GLOBAL",1) ~ THEN REPLY #66353 /* ~"Morte, proč se mnou pořád cestuješ?"~ */ GOTO 715
IF ~  GlobalGT("Know_Blood_War","GLOBAL",0) ~ THEN REPLY #66354 /* ~"Co víš o Válce Krve?"~ */ GOTO 723
IF ~  GlobalGT("Know_Ravel","GLOBAL",0) Global("Ravel","GLOBAL",0) ~ THEN REPLY #66355 /* ~"Co víš o čarodějnici Ravel?"~ */ GOTO 722
IF ~~ THEN REPLY #66356 /* ~"Jak jsi zemřel, Morte?"~ */ GOTO 726
IF ~~ THEN REPLY #66357 /* ~"Nic, Morte. Jenom kontroluju, jestli jsi se mnou."~ */ EXIT
END

IF ~~ THEN BEGIN 730 // from:
SAY #66816 /* ~"Hej, šéfe, věřil bys tomu? Mohli by dokonce i *mě* něco málo naučit..."~ [MRT387] */
IF ~~ THEN REPLY #66817 /* ~"Věřím tomu, Morte. Pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 731 // from:
SAY #67510 /* ~"Jenom bych se rád na chvilinku vmísil a oznámil vám, že nebudu říkat nic, čím bych vám pokazil zábavu, šéfíku. Jenom tady budu obletovat a koukat se. Nevšímejte si mě - jenom tady poletuju a koukám se, to jsem já."~ */
IF ~~ THEN EXTERN ~DANNAH~ 418
END

IF ~~ THEN BEGIN 732 // from:
SAY #67600 /* ~"Necháte toho, než budu muset sehnat Dabuse, aby vás od sebe oddělil?" Morte si odfrkl. "Nebo mi aspoň dovolte, ať se k vám přidám."~ */
IF ~~ THEN EXTERN ~DANNAH~ 446
END 
IF WEIGHT #1 ~  Global("Fortress_Morte","GLOBAL",3) Global("Absorb","GLOBAL",0)
~ THEN BEGIN 733 // from:
SAY #68171 /* ~Když ses po něm natáhnul, Morte náhle promluvil. "Hou hou! Počkej, šéfe.. Je tady uh... pár věcí, který ti musím říct."~ [MRT242] */
IF ~~ THEN REPLY #68176 /* ~"Morte...?! Ty nejsi mrtvý!"~ */ DO ~SetGlobal("Fortress_Morte","GLOBAL",4) JoinPartyEx(TRUE) ~ GOTO 734
END

IF ~~ THEN BEGIN 734 // from: 733.0
SAY #68172 /* ~"No, jo -- když seš tak dlouho mrtvej jako já, naučíš se to fakt dobře předstírat. Tak ňák sem poslouchal celou tu vaši řeč. Tu moc, co máš, tak tu použij na někoho jinýho - já ji nepotřebuju."~ */
IF ~~ THEN REPLY #68177 /* ~"Takže ty bys tady jen tak *ležel*, zatímco já bych dostával nakopáno do prdele?!"~ */ GOTO 735
END

IF ~~ THEN BEGIN 735 // from: 734.0
SAY #68173 /* ~"No *jo*, šéfe. Myslím, jako že kdybys zklamal, budeš potřebovat někoho, kdo si za tebe bude pamatovat. Navíc, víš jak jsem neschopnej v boji - teda pokaď nenadávám ňákýmu kouzelníkovi nebo tak..."~ */
IF ~  Global("Trans_Vanish","GLOBAL",0) GlobalGT("Fortress_Party_Roof","GLOBAL",1) ~ THEN REPLY #68178 /* ~"Tak to je možná to, co potřebuju, abys udělal. O tomhle si promluvíme *později*, Morte..."~ */ GOTO 736
IF ~  Global("Trans_Vanish","GLOBAL",1) GlobalGT("Fortress_Dakkon","GLOBAL",0) ~ THEN REPLY #68189 /* ~"Tak to je možná to, co potřebuju, abys udělal. O tomhle si promluvíme *později*, Morte..."~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204d0",FALSE) ~ EXIT
IF ~  Global("Trans_Vanish","GLOBAL",1) Global("Fortress_Dakkon","GLOBAL",0) GlobalGT("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68190 /* ~"Tak to je možná to, co potřebuju, abys udělal. O tomhle si promluvíme *později*, Morte..."~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204a0",FALSE) ~ EXIT
