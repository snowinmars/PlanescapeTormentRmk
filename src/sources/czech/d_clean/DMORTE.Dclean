END

IF ~~ THEN BEGIN 107 // from: 106.0
SAY #6073 /* ~"Ty ses vykecával s nějakou ženskou? Kde? Kde?" Morte se rozhlíží, vypadá rozrušeně. "Jak vypadala?"~ */
IF ~~ THEN REPLY #6078 /* ~"Stála na hrobu, tys ji neviděl?"~ */ GOTO 108
END

IF ~~ THEN BEGIN 108 // from: 107.0
SAY #6074 /* ~"Eh... ne, akorát si chvilku stál jako socha. Sem měl tak trochu strach, že seš zase ňákej popletenej."~ */
IF ~~ THEN REPLY #6079 /* ~"Ne, jsem v pořádku. Myslím. Pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 109 // from:
SAY #6324 /* ~"Připomíná mi to práci, kterou jsem kdysi měl." Vypadá zmateně. "Chmm, chci říci... bez rukou." ~ */
IF ~  HasItem("Cobble","Post") ~ THEN REPLY #6325 /* ~Prozkoumej mrtvolu.~ */ EXTERN ~DPOST~ 3
IF ~  !HasItem("Cobble","Post") ~ THEN REPLY #6326 /* ~Prozkoumej mrtvolu.~ */ EXTERN ~DPOST~ 4
IF ~  CheckStatGT(Protagonist,11,INT) CheckStatLT(Protagonist,12,WIS) ~ THEN REPLY #6327 /* ~"Hmmm. Jestlipak to funguje i s jinými letáky..."~ */ EXTERN ~DPOST~ 5
IF ~  CheckStatGT(Protagonist,11,WIS) ~ THEN REPLY #6328 /* ~"Hmmm. Jestlipak to funguje i s jinými letáky..."~ */ EXTERN ~DPOST~ 5
IF ~  CheckStatLT(Protagonist,12,INT) CheckStatLT(Protagonist,12,WIS) ~ THEN REPLY #6329 /* ~Prozkoumej jiné letáky.~ */ EXTERN ~DPOST~ 5
IF ~  Global("Speak_with_Dead","GLOBAL",1) ~ THEN REPLY #6330 /* ~Použij schopnost Kosti vyprávějte na mrtvolu.~ */ EXTERN ~DPOST~ 2
IF ~~ THEN REPLY #6331 /* ~Nechej mrtvolu být.~ */ EXIT
END

IF ~~ THEN BEGIN 110 // from:
SAY #6609 /* ~"Hej, šéfe. Takovej vandalismus. Tydle šrouby byly asi jediná věc, co držela ten pytel kostí pohromadě. Necromancie s těmahle starejma kostma víc nesvede, chápeš?"~ */
IF ~~ THEN REPLY #6658 /* ~"Tak?"~ */ DO ~IncrementGlobal("Good","GLOBAL",-1) ~ EXTERN ~DS42~ 1
IF ~~ THEN REPLY #6659 /* ~"Oh... Nechtěl jsem způsobit trvalé poškození."~ */ DO ~IncrementGlobal("Good","GLOBAL",1) ~ EXTERN ~DS42~ 1
IF ~~ THEN REPLY #6660 /* ~"Tak dobrá, nevadí. Snad někdy příště."~ */ EXTERN ~DS42~ 1
END

IF ~~ THEN BEGIN 111 // from:
SAY #6610 /* ~"Hmmm. Zajímalo by mě, jestli by tomuhle šedovousovi vadilo, kdybych si *já* půjčil jeho tělo..."~ */
IF ~~ THEN REPLY #6661 /* ~"'Staroch?'"~ */ EXTERN ~DS42~ 1
IF ~~ THEN REPLY #6662 /* ~"Nemyslím, že k tomu má nějaký vztah."~ */ EXTERN ~DS42~ 1
IF ~~ THEN REPLY #6663 /* ~"Něco mi říká, že bys byl dvakrát tak otravný, kdybys měl ruce. Jdeme."~ */ EXTERN ~DS42~ 1
END

IF ~~ THEN BEGIN 112 // from:
SAY #6611 /* ~"Mohl bys to odříznout? Jeho paže odpadnou."~ */
IF ~  Global("42_Secret","GLOBAL",1) ~ THEN REPLY #6664 /* ~Překřiž si ruce na hrudníku.~ */ EXTERN ~DS42~ 4
IF ~  CheckStatGT(Protagonist,12,WIS) Global("42_Secret","GLOBAL",0) ~ THEN REPLY #6665 /* ~Napodob gesto kostlivce... sleduj co se stane.~ */ EXTERN ~DS42~ 9
IF ~~ THEN REPLY #6666 /* ~"Uh..."~ */ EXTERN ~DS42~ 10
IF ~~ THEN REPLY #6667 /* ~Nechej kostlivce být.~ */ EXIT
END

IF ~~ THEN BEGIN 113 // from: 54.0 54.1
SAY #6771 /* ~"Vona vládne tomudle městu. Poznáš ji, až ji uvidíš: Má čepele kolem ksichtu, je velikánská jako vobr, lítá nad zemí, právě jako tidle." Morte kývl na dabuse, který se na vás oba díval. "Nikdo vo ní moc neví... vona toho moc nenakecá. Všecko, co vo ní potřebuješ vědět je, že ji nemáš nasrat. Dyž ji uvidíš, tak ti doporučuju: zdrhej."~ */
IF ~~ THEN REPLY #2784 /* ~"Aha."~ */ EXTERN ~DDABUS~ 3
END

IF ~~ THEN BEGIN 114 // from:
SAY #6784 /* ~Morte se pohrdavě ušklíbl. "To dřív prolezu vnitřnostma tanar'riho než rozluštím co tadle kozí hlava chce říct. Chceš tlumočníka? Najdi si nějakýho Sigilana."~ */
IF ~~ THEN REPLY #6955 /* ~"Aha."~ */ EXTERN ~DDABUS~ 3
END

IF ~~ THEN BEGIN 115 // from:
SAY #6786 /* ~"Oh, oni *mají* jména. Jsem si tím jistý."~ */
IF ~~ THEN EXTERN ~DANNAH~ 43
END

IF ~~ THEN BEGIN 116 // from:
SAY #6790 /* ~"To říkáš *ty*, fiendskej spratku."~ */
IF ~~ THEN REPLY #6956 /* ~"Nech toho, Morte - mohla by ses ho ještě na něco zeptat, Annah?"~ */ EXTERN ~DANNAH~ 40
IF ~~ THEN REPLY #6957 /* ~"Zapomeň na to. Pojďme."~ */ DO ~SetGlobal("Translate_Dabus","GLOBAL",0) ~ EXTERN ~DDABUS~ 6
END

IF ~~ THEN BEGIN 117 // from:
SAY #6794 /* ~Morte se pohrdavě ušklíbne. "To dřív prolezu vnitřnostma tanar'riho než rozluštím co tyhle lítající kozí hlavy zkoušej říct. Chceš tlumočníka? Vem si na to tohle fiendský mrně." Ukazuje na Annah. "Ona je z Úlu."~ */
IF ~~ THEN REPLY #6958 /* ~"Možná udělám..."~ */ EXTERN ~DDABUS~ 3
END

IF ~~ THEN BEGIN 118 // from:
SAY #6797 /* ~Morte se pohrdavě ušklíbne. "To dřív prolezu vnitřnostma tanar'riho než rozluštím co tyhle lítající kozí hlavy zkoušej říct. Chceš tlumočníka?" Ukáže na Dak'kona. "Vem si Svatějšího-než-ty-a-dvakrát-klidnějšího aby ti to přeložil." ~ */
IF ~~ THEN REPLY #6959 /* ~"Možná splním..."~ */ EXTERN ~DDABUS~ 3
END

IF ~~ THEN BEGIN 119 // from:
SAY #6800 /* ~Morte se pohrdavě ušklíbne. "To dřív prolezu vnitřnostma tanar'riho než rozluštím co tyhle lítající kozí hlavy zkoušej říct. Chceš tlumočníka? Vem si na to tanar'riho." Ukazuje na Fall-from-Grace. "Pravděpodobně si s tady těma hochama musela celou dobu vyměňovat novinky."~ */
IF ~~ THEN REPLY #6960 /* ~"Snad vyhovím..."~ */ EXTERN ~DDABUS~ 3
END

IF ~~ THEN BEGIN 120 // from:
SAY #7040 /* ~Odvracíš se, když tu náhle koutkem oka postřehneš, jak na tebe Morte civí. "He?"~ */
IF ~~ THEN REPLY #7055 /* ~"Co to je?"~ */ GOTO 121
END

IF ~~ THEN BEGIN 121 // from: 120.0
SAY #7041 /* ~"*Všiml* sis, jak na mě ta krásná mrtvola zírala?" Morte klape svými zuby pln očekávání. "Určitě hledá ňákýho šťastlivce, co by jí pomoh vyhřát rakev."~ */
IF ~  Global("Morte_Quip","GLOBAL",1) ~ THEN REPLY #7056 /* ~"*Prosím*, nezačínej s tím zase."~ */ DO ~SetGlobal("Morte_Zombie_Female_Bar_Quip","GLOBAL",1) ~ GOTO 122
IF ~  Global("Morte_Quip","GLOBAL",0) ~ THEN REPLY #7057 /* ~"O čem to *mluvíš*?"~ */ DO ~SetGlobal("Morte_Quip","GLOBAL",1) ~ GOTO 47
IF ~  Global("Morte_Quip","GLOBAL",0) ~ THEN REPLY #7058 /* ~"Co ten tvůj prázdný pohled upřený někam do záhrobí?"~ */ DO ~SetGlobal("Morte_Quip","GLOBAL",1) ~ GOTO 47
END

IF ~~ THEN BEGIN 122 // from: 121.0
SAY #7042 /* ~Morte tě nebere na vědomí a pokračuje dále v poněkud zamyšlenějším tónu: "Ve skutečnosti nepotřebuju bejt středem pozornosti... jen bych chtěl bejt vnímanej jako něco víc než jen pouhopouhá lebka, chápeš? Krom základních instinktů, co má každá živá bytost, mám taky city. Chci zkrátka klasický námluvy, nejen čtrnáctidenní flám v mauzoleu."~ */
IF ~~ THEN REPLY #7059 /* ~"Ještě chvilku, já tě *drapnu* a někam zahodím, prevíte."~ */ GOTO 123
IF ~~ THEN REPLY #7060 /* ~"Morte, ty *jsi* prostě lebka. Každý tě bude brát čistě jako lebku. Tak už se s tím smiř."~ */ GOTO 124
IF ~~ THEN REPLY #7061 /* ~"Rozumím. Tak už pojďme odsud, fajn?"~ */ EXIT
END

IF ~~ THEN BEGIN 123 // from: 122.0
SAY #7043 /* ~"Prrr, šéfíku..." Morte se nenápadně vzdálil z dosahu. "Věř mi, holky, co si prošly hrobem, si na fyzičnost moc nepotrpí, nesere je 'Já mám tělo' a 'Jsem zjizvenej tvrďák'. Chtějí chlápka, kerej má DUCHA! To sem já, šéfe. Mrtvoly jako TY sou běžnější než zlomená grešle."~ */
IF ~~ THEN REPLY #7062 /* ~"Ty seš ten *poslední*, kerej by mi měl radit ohledně lásky."~ */ GOTO 126
IF ~~ THEN REPLY #7063 /* ~"Jasně, Morte. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 124 // from: 122.1
SAY #7044 /* ~"No teda dobře, jsem jen pouhopouhá lebka, ale mám skutečně vřelý srdce."~ */
IF ~~ THEN REPLY #7064 /* ~"Abych pravdu řekl, stejně žádné *nemáš*."~ */ GOTO 125
IF ~~ THEN REPLY #7065 /* ~"To víš že jo, Morte. Padáme."~ */ EXIT
END

IF ~~ THEN BEGIN 125 // from: 124.0
SAY #7045 /* ~"Čeho, vmontoval ses do mýho života jen kvůli tomu, abys poplival a pošlapal mý sny a tužby? Budiž tedy po tvém. Srdce teda nemám, zato však duši *rozhodně* jo."~ */
IF ~~ THEN REPLY #7066 /* ~"No, vlastně bych si i vsadil, že ty... ale nech to plavat. Vyrážíme."~ */ EXIT
IF ~~ THEN REPLY #7067 /* ~"Jasně, Morte. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 126 // from: 123.0
SAY #7046 /* ~"Kdyby ti zbyla aspoň část rozumu z doby, než posledně umřels, věděl bys to líp." Nevěřil bys, že něčí hlas může obsahovat takovou dávku samolibosti, Morte trhá rekordy. "Ve věcech lásky sem napsal naučnou brožuru."~ */
IF ~~ THEN REPLY #7068 /* ~"To víš že jo, Morte. Padáme."~ */ EXIT
END

IF ~~ THEN BEGIN 127 // from:
SAY #7071 /* ~Morte chvíli kostru studuje, pak zavrtí hlavou. "Mmm.. tato je moc čistá... nezůstal na ní ani kousek masa. A taky bych nebyl schopný dostat z kostí to bělidlo."~ */
IF ~~ THEN REPLY #7076 /* ~"Nejsem schopný posoudit, jestli je 'příliš čistá'... ale měl by ses naučit pár věcí o čistotnosti, to rozhodně. Neublížilo by ti to."~ */ GOTO 70
IF ~~ THEN REPLY #7077 /* ~"Dobrá tedy. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 128 // from:
SAY #7130 /* ~"Joo!"~ */
IF ~~ THEN EXTERN ~DHIVEF1~ 8
END

IF ~~ THEN BEGIN 129 // from:
SAY #7187 /* ~"Mimir - mluvící encyklopedie. To sem já, šéfe."~ */
IF ~~ THEN REPLY #7483 /* ~"Rozumím. A ty si to koukej zapsat za uši, Morte. Podle toho, jak vypadala, jsem tě od smrti zachránil podruhé."~ */ DO ~IncrementGlobal("BD_MORTE_MORALE","GLOBAL",1) ~ EXTERN ~DHARLOTN~ 8
IF ~~ THEN REPLY #7484 /* ~"Vypadnem odsud. Sbohem, slečno."~ */ EXIT
END

IF ~~ THEN BEGIN 130 // from:
SAY #7188 /* ~Morte jenom civí zcela hypnotizován, zatímco ta děvka uvolnila stavidla a spustila na tebe lavinu verbálního hnoje. Nakonec jí došel dech. Morte je chvilku zticha, pak se však otočí k tobě a celou situaci komentuje: "Fíha, šéfíku, to teda bylo něco. Zas mám ňáký skvělý přírůstky do svýho starýho dobrýho výběru nejlepčích urážek a posměšků." Nato se přiblíží k běhně, která lapá po dechu. "Taky tě miluju."~ [MRT387] */
IF ~~ THEN REPLY #7485 /* ~Odejdi.~ */ DO ~IncrementGlobal("Morte_Taunt","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 131 // from:
SAY #7775 /* ~"Teda náčelníku," vložil se Morte předtím, než si můžeš se stvořením promluvit. "Vykašli se na to. Nechceš přece vykecávat s každým fiendem na ulici. Nech to plavat."~ */
IF ~~ THEN REPLY #7776 /* ~"Můžeš mi odpovědět na..."~ */ GOTO 132
IF ~~ THEN REPLY #7777 /* ~Odejdi od bytosti.~ */ EXIT
END

IF ~~ THEN BEGIN 132 // from: 131.0
SAY #7778 /* ~"Ne, nedělej to." Morte pohlédl na stvoření, pak se otočil k tobě a ztišil hlas do šepotu. "Jsou vznětliví. Pojďme pryč."~ */
IF ~~ THEN REPLY #7779 /* ~"Já to risknu."~ */ EXTERN ~ABISHAB~ 11
IF ~~ THEN REPLY #7780 /* ~Odejdi od stvoření.~ */ EXIT
END

IF ~~ THEN BEGIN 133 // from:
SAY #7805 /* ~Morte si povzdechl zrovna ve chvíli, když ses chystal promluvit s démonem.~ */
IF ~~ THEN REPLY #7806 /* ~"Ano?"~ */ GOTO 134
END

IF ~~ THEN BEGIN 134 // from: 133.0
SAY #7807 /* ~"Och, nic... víš, znáš to - chybami se člověk učí." Pokynul hlavou ke stvoření. "Jen do toho."~ */
IF ~~ THEN REPLY #7808 /* ~"Já chci."~ */ EXTERN ~ABISHAB~ 11
IF ~~ THEN REPLY #7809 /* ~"Dobrá, nech to být. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 135 // from: 44.0 44.1
SAY #2349 /* ~"Jo, 'gith'..." Morte se podíval na githa, který na tebe stále zírá. "Promluvíme si o tom později."~ */
IF ~~ THEN REPLY #9035 /* ~"Ještě nejsem připravený odejít. Nejdřív se ho na něco zeptám..."~ */ EXTERN ~DGITH~ 7
IF ~~ THEN REPLY #9036 /* ~Nechej githa být.~ */ EXIT
END

IF ~~ THEN BEGIN 136 // from:
SAY #9860 /* ~"No tak, šéfe... zabiješ toho hňupa, než se ti ho podaří probrat!"~ */
IF ~~ THEN REPLY #9882 /* ~"Máš pravdu, Morte - pojďme."~ */ EXIT
END

IF ~~ THEN BEGIN 137 // from:
SAY #11946 /* ~Morte připlul blíž. "Vo co gou, šéfe?"~ */
IF ~~ THEN REPLY #11974 /* ~"Vidíš tyhle zuby?"~ */ GOTO 138
IF ~~ THEN REPLY #11975 /* ~"Nic, kašli na to."~ */ EXIT
END

IF ~~ THEN BEGIN 138 // from: 137.0
SAY #11947 /* ~Morte se podíval na tvou dlaň. "Eeeeee." Vypadá to, že ho zuby morbidně fascinují. "To jsou ale malí hnusáci, co?"~ */
IF ~~ THEN EXIT
END

IF ~~ THEN BEGIN 139 // from:
SAY #11948 /* ~"Zapomeň na to." Morte se otřásl. "Ty bys chtěl takový malý hajzlíky v *sobě*?"~ */
IF ~~ THEN REPLY #11976 /* ~"No tak, Morte, vypadá to, že se jim líbíš. Podívej se, jak se na tebe dívají."~ */ GOTO 140
IF ~~ THEN REPLY #11977 /* ~Popadni Morteho a narvi mu zuby do tlamy.~ */ DO ~SetGlobal("Ingress_Teeth_Installed","GLOBAL",1) IncrementGlobalOnceEx("GLOBALChaotic_Ingress_Teeth_2","GLOBALLaw",-1) IncrementGlobalOnceEx("GLOBALEvil_Ingress_Teeth_1","GLOBALGood",-1) ~ GOTO 141
IF ~~ THEN REPLY #11978 /* ~"Tak to nic."~ */ EXIT
END

IF ~~ THEN BEGIN 140 // from: 139.0
SAY #11949 /* ~"Ti malí parchanti ať se ke mně radši nepřibližujou, nebo..." Morte se odmlčel. "Hm, hele, nemám tušáka, čím vyhrožovat zubům."~ */
IF ~~ THEN REPLY #11979 /* ~Prozkoumej zuby.~ */ EXIT
IF ~~ THEN REPLY #11980 /* ~Popadni Morteho a narvi mu zuby do tlamy.~ */ DO ~SetGlobal("Ingress_Teeth_Installed","GLOBAL",1) IncrementGlobalOnceEx("GLOBALChaotic_Ingress_Teeth_2","GLOBALLaw",-1) IncrementGlobalOnceEx("GLOBALEvil_Ingress_Teeth_1","GLOBALGood",-1) ~ GOTO 141
IF ~~ THEN REPLY #11981 /* ~"Tak to nic."~ */ EXIT
END

IF ~~ THEN BEGIN 141 // from: 139.1 140.1
SAY #11950 /* ~Boj je krátký. Popadl jsi Morteho za hlavu - vlastně jediným způsobem, jak ho můžeš chytit - a když se pokoušel prokousat se na svobodu, zuby vyskočily z tvé dlaně a narvaly se mu do čelisti. Morte vyje, protože Ingressiny zuby okamžitě vyrvaly jeho vlastní zuby a nacpaly se do vzniklých otvorů.~ */
IF ~~ THEN REPLY #11982 /* ~"Tak, Morte. Nebylo to zas tak zlý, co?"~ */ DO ~MoraleDec("Morte",1) ~ GOTO 143
END

IF ~~ THEN BEGIN 142 // from: 149.0
SAY #11951 /* ~Morte dál vyje. Zuby se usazují, vyrovnávají a zapouštějí kořeny s hrozivým vrtavým kvílením.~ */
IF ~~ THEN REPLY #11983 /* ~"Morte? Jsi okej?"~ */ DO ~SetGlobal("Ingress_Teeth_Installed","GLOBAL",1) ~ GOTO 143
END

IF ~~ THEN BEGIN 143 // from: 141.0 142.0
SAY #11952 /* ~Vypadá to, že tě Morte neslyší... vyje a vyje, pak náhle začal zuby bušit o sebe. Podařilo se mu vydat ze sebe tři mohutná, mocná kousnutí, než se horní a spodní zuby navzájem zablokovaly a zabránily mu v otvírání čelistí.~ */
IF ~~ THEN REPLY #11984 /* ~"Uau."~ */ GOTO 144
END

IF ~~ THEN BEGIN 144 // from: 143.0
SAY #11953 /* ~Morte si pro sebe něco mumlá, oči má rozšířené.~ */
IF ~  Global("Evil_Ingress_Teeth_1","GLOBAL",1) ~ THEN REPLY #11985 /* ~"Takže... líbí se ti?"~ */ GOTO 145
IF ~  Global("Good_Ingress_Teeth_1","GLOBAL",1) ~ THEN REPLY #11986 /* ~"Morte, jsi okej?"~ */ GOTO 150
END

IF ~~ THEN BEGIN 145 // from: 144.0
SAY #11954 /* ~Zuby se náhle rozdělily a Morte se zhluboka nadechl. "Za tohle tě *zabiju," řekl. "Tohle od tebe bylo fakt hnusný."~ */
IF ~~ THEN REPLY #11987 /* ~"Jaké jsou?"~ */ GOTO 146
END

IF ~~ THEN BEGIN 146 // from: 145.0 150.0
SAY #11955 /* ~Morte zkušebně pohybuje čelistí. "Divný. Ale ne zlý." Náhle se zuby prodloužily do dlouhých ostrých tesáků. "Ooooh! Změnily se.!" Smrskly se na normální velikost, pak opět na tesáky, nakonec zase zpět. "Myslím, že se mi docela líbí."~ */
IF ~  Global("Good_Ingress_Teeth_1","GLOBAL",1) ~ THEN REPLY #11988 /* ~"Promiň, Morte. Nechtěl jsem ti nijak ublížit."~ */ GOTO 147
IF ~  Global("Evil_Ingress_Teeth_1","GLOBAL",1) ~ THEN REPLY #11989 /* ~"Vidíš? Neměl jsem pravdu?"~ */ GOTO 147
END

IF ~~ THEN BEGIN 147 // from: 146.0 146.1
SAY #11956 /* ~"Oh,ale stejně tě za to dostanu." Odpověděl Morte, vyceněné zuby se opět prodloužily na tesáky. "Jen si počkej."~ */
IF ~  Global("Good_Ingress_Teeth_1","GLOBAL",1) ~ THEN REPLY #11990 /* ~"Uh... pomsta nikdy nikomu nepomohla, Morte... uh, pojďme."~ */ EXIT
IF ~  Global("Evil_Ingress_Teeth_1","GLOBAL",1) ~ THEN REPLY #11991 /* ~"Však mi později poděkuješ. Uvidíš."~ */ EXIT
END

IF ~~ THEN BEGIN 148 // from:
SAY #11957 /* ~"Co je špatně?" Morte připlul blíž a podíval se na tvou dlaň. "Hej... vypadá to, jako by se na něco chystaly, že jo?"~ */
IF ~~ THEN REPLY #11992 /* ~"To jo, viď ---"~ */ GOTO 149
END

IF ~~ THEN BEGIN 149 // from: 148.0
SAY #11958 /* ~Co se stalo poté, to se dá jenom těžce popsat... a že to byl bolestný pocit. Rychle, nedávajíce ti šanci sevřít je v ruce, zuby vyskočily z tvé dlaně a narvaly se Mortemu do čelisti. Morte vyje, protože Ingressiny zuby okamžitě vyrvaly jeho vlastní chrup a nacpaly se do vzniklých otvorů.~ */
IF ~~ THEN REPLY #11993 /* ~"Morte!"~ */ GOTO 142
END

IF ~~ THEN BEGIN 150 // from: 144.1
SAY #11959 /* ~Zuby se náhle rozevřely a Morte se zhluboka nadechl. "Za tohle tě *zabiju*! Ty jsi to plánoval! Já to věděl, že na mě něco chystáš!"~ */
IF ~~ THEN REPLY #11994 /* ~"Hele, nechtěl jsem, ať se to stane... dokonce jsem tě varoval. Uh... jaké jsou?"~ */ GOTO 146
END

IF ~~ THEN BEGIN 151 // from:
SAY #12389 /* ~Morte ti zašeptal: "Šéfe, tohle se mi nelíbí. Neměli by tady být. Válka Krve určitě neprobíhá tak, že by nějaký fiend mohl jít na dovolenou. Něco *chcou*. Dej si majzla." Mezitím Tegar'in odpovídá dál svému společníkovi...~ */
IF ~~ THEN EXTERN ~DTEGARIN~ 12
END

IF ~~ THEN BEGIN 152 // from:
SAY #12449 /* ~"Šéfe, jsem si jistej, že ti dva volové něco chystaj. Mám pocit, že dezertovali a teď hledají něco, co by jim pomohlo v Baatoru povýšit. Nemluv s nima, šéfe... nevíš, jakou hru to hrajou, a mohl by ses spálit... doslova."~ */
IF ~~ THEN REPLY #12450 /* ~"Dobrá, Morte. Mám pro ty dva už jenom pár otázek..."~ */ EXTERN ~DAETHEL~ 11
IF ~~ THEN REPLY #12451 /* ~"Dobrá, Morte. Skončil jsem s nimi."~ */ EXIT
END

IF ~~ THEN BEGIN 153 // from:
SAY #12466 /* ~Morte připlul blíž a zašeptal ti do ucha: "*Má* pravdu, šéfe... nechápu, co tě tak vytočilo."~ */
IF ~~ THEN REPLY #12553 /* ~"Velmi dobře... jenom jsem se chtěl na něco zeptat..."~ */ EXTERN ~DBARIA~ 4
IF ~~ THEN REPLY #12554 /* ~"Sklapni, ty ukňučená lebko! A ty, kozí-hlavo: Chcípni..."~ */ DO ~MoraleDec("Morte",2) Enemy() Attack(Protagonist) ChangeAIScript("MDKTNO",DEFAULT) ForceAttack(Protagonist,Myself) ~ EXIT
IF ~~ THEN REPLY #12555 /* ~"Och, ne... to jsi byl *ty*, a budeš toho litovat..."~ */ DO ~Enemy() Attack(Protagonist) ChangeAIScript("MDKTNO",DEFAULT) ForceAttack(Protagonist,Myself) ~ EXIT
IF ~~ THEN REPLY #12556 /* ~"Pak na to zapomeň. Sbohem."~ */ DO ~SetGlobal("BariA","AR0400",2) ~ EXIT
END

IF ~~ THEN BEGIN 154 // from:
SAY #12467 /* ~"Jo, jo! Dobrý!"~ */
IF ~~ THEN EXTERN ~DBARIA~ 20
END

IF ~~ THEN BEGIN 155 // from:
SAY #12621 /* ~Morte vypadá vyveden z konceptu, jak se na něho upřely všechny oči. "Co? Cože?" Máš pocit, že kdyby měl rty, nevinně by si pískal.~ */
IF ~~ THEN REPLY #12854 /* ~"Máš nějaké vysvětlení, Morte?"~ */ GOTO 156
IF ~  Global("Know_Mimir","GLOBAL",0) ~ THEN REPLY #12855 /* ~"Co je 'mimir?'"~ */ DO ~SetGlobal("Know_Mimir","GLOBAL",1) ~ GOTO 157
IF ~~ THEN REPLY #12856 /* ~"Nestarej se o něj... mohl bys mi odpovědět?"~ */ EXTERN ~DCREED~ 30
END

IF ~~ THEN BEGIN 156 // from: 155.0
SAY #12622 /* ~"Dobrá. Hele, ještě si poslechnem toho chlapika, jo?" Morte se otočil a upírá na krysaře tvrdý pohled.~ */
IF ~~ THEN REPLY #12857 /* ~"Ne... pojďme si poslechnout, co nám vyklopíš, Morte."~ */ GOTO 158
