END

IF ~~ THEN BEGIN 440 // from: 444.7 445.2 446.2 447.2 448.2 449.1 450.1 451.2 452.1 453.1 454.1
SAY #41830 /* ~"Koukni, šéfíku. Zdá se, že ses poněkud rozhozenej po tom polibku smrti, tak pro tebe mám malou radu: Až budeš mít votázku, klidně se mě zeptej, jo?"  POZNÁMKA: Pokud si budeš chtít promluvit se členem družiny, vyber volbu 'mluvení' z rychlého menu a poté levým tlačítkem zvol postavu, se kterou chceš hovořit.~ */
IF ~~ THEN REPLY #41831 /* ~"V pořádku... když budu mít nějaké otázky, tak se zeptám."~ */ GOTO 441
END

IF ~~ THEN BEGIN 441 // from: 440.0
SAY #41832 /* ~"Zadruhé, pokud seš aspoň z poloviny tak zapomětlivej jak vypadáš, začni si informace zapisovat - když se dovíš něco co by mohlo bejt důležitý, zapiš si to a nezapomeneš."~ */
IF ~~ THEN REPLY #41833 /* ~"Kdybych měl ten deník, který sem měl mít, dělal bych to tak."~ */ GOTO 442
END

IF ~~ THEN BEGIN 442 // from: 441.0
SAY #41834 /* ~"Tak si udělej novej šéfe. Žádnej problém. Všude kolem se válí spousta pergamenů a ingoustu."~ */
IF ~~ THEN REPLY #41835 /* ~"Hmmmm. Dobře. To mi neublíží... založím si teda nový."~ */ GOTO 443
END

IF ~~ THEN BEGIN 443 // from: 442.0
SAY #41836 /* ~"Používej ho, aby ses na cestách neztratil. A až si nebudeš jistej v nějakech důležitejch bodech, třeba jako kdo seš... nebo ještě líp, kdo sem *já*... pomůže ti osvěžit paměť."  POZNÁMKA: Pro přístup do deníku zvol přislušnou ikonu v právém dolním rohu na světové obrazovce, nebo vyber ikonu z rychlého menu. Tvůj deník se bude automaticky aktualizovat během hry.~ */
IF ~~ THEN REPLY #41837 /* ~"V pořádku... Mám to. Pojďme."~ */ JOURNAL #39516 /* ~Postrádám svůj původní deník, takže jsem musel začít psát nový. Probral jsem se na místě zvaném "Márnice." Nevím, kdo jsem, nevím, co tu dělám a nevím, jak jsem se sem dostal. Jediná bytost, kterou se mi poštěstilo potkat, byla mluvící lebka Morte... když mi o chvíli později prohlížel rány na zádech, narazil na několik vytetovaných 'pokynů':  "Vím, že se cítíš, jako bys vypil několik džberů bahna z Řeky Styx, ale teď by ses měl trošičku soustředit. Někde kolem tebe by se měl válet deník, který ti osvětlí, co se vlastně děje. Zbytek ti dopoví Pharod, pokud tedy ještě není zapsán v Knize mrtvých."  "Hlavně ten deník neztrať, protože pak bychom zase byli v bahně Styxu. A ať už děláš cokoliv, neříkej NIKOMU, kdo jsi nebo co se ti stalo, jinak by ses taky mohl pěkně rychle podívat do krematoria. Udělej, co ti říkám: PŘEČTI si deník, pak NAJDI Pharoda."  Copak jsem tuto zprávu nechal sám sobě? Asi bych vážně měl najít toho 'Pharoda' a svůj deník. ~ */ EXIT
END 
IF WEIGHT #6 /* Triggers after states #: 742 737 733 487 even though they appear after this state */ ~  !Global("Mortuary_Walkthrough","GLOBAL",0) !Global("Mortuary_Walkthrough","GLOBAL",1) Global("AR0200_Visited","GLOBAL",0) InParty("Morte") !GlobalGT("Fortress_Morte","GLOBAL",2)
~ THEN BEGIN 444 // from: 445.1 446.1 447.1 448.1 449.0 450.0 451.1 452.0 453.0 454.0 455.1 456.2 457.1 458.0
SAY #41838 /* ~"Co tě žere šéfiku?"~ [MRT515] */
IF ~~ THEN REPLY #41840 /* ~"Můžeš mi znovu přečíst co mám vytetováno na zádech?~ */ GOTO 445
IF ~~ THEN REPLY #41841 /* ~"Řekni mi ještě jednou co je tohle za místo?"~ */ GOTO 450
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41842 /* ~"Je to tu obrovské... Kdo se tady o všechno stará?"~ */ GOTO 451
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41843 /* ~"Můžeš mi znovu říct kdo to tu spravuje?"~ */ GOTO 451
IF ~~ THEN REPLY #41844 /* ~"Ty mrtvoly... Odkud pocházejí?"~ */ GOTO 454
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41845 /* ~"Předtím si říkal cosi o tom, abych nezabíjel "ženské" zombie. Proč?"~ */ GOTO 455
IF ~  PartyHasItem("Bandage") ~ THEN REPLY #41846 /* ~"Jak mám použít tyhle obvazy?"~ */ GOTO 453
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41847 /* ~"Teď nic, Morte. Jen jsem se chtěl ujistit, že seš pořád se mnou."~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41848 /* ~"Teď nic, Morte. Jen jsem se chtěl ujistit, že seš pořád se mnou."~ */ EXIT
END

IF ~~ THEN BEGIN 445 // from: 444.0
SAY #41849 /* ~"Ale no tak, šéfe. Neříkej, žes to už všecko zas zapomněl."~ */
IF ~~ THEN REPLY #41850 /* ~"Potřebuju si jen osvěžit pamět."~ */ GOTO 446
IF ~~ THEN REPLY #41851 /* ~"Kašli na to. Mám nějaký jiný otázky..."~ */ GOTO 444
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41852 /* ~"Zapomeň na to. Půjdem."~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41853 /* ~"Zapomeň na to. Půjdem."~ */ EXIT
END

IF ~~ THEN BEGIN 446 // from: 445.0
SAY #41854 /* ~"Vsaď se že už sem toho slyšel dost." Morte si odchrchlal. "Tak se na to junkem..."  'Vím že se cítíš, jak dybys vypil pár sudů Styxskejch chcánek, ale musíš se SOUSTŘEDIT. Máš u sebe DENÍK, kterej ti může vnýst do života trochu světla. PHAROD ti může pomoct obnovit paměť, esli už ale není v knize mrtvejch.'~ */
IF ~~ THEN REPLY #41855 /* ~"Pharod... hmmm. Pojďme dál."~ */ GOTO 447
IF ~~ THEN REPLY #41856 /* ~"Nevadí. Mám jiný otázky..."~ */ GOTO 444
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41857 /* ~"Kašli na to, už sem slyšel dost. Jdem."~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41858 /* ~"Kašli na to, už sem slyšel dost. Jdem."~ */ EXIT
END

IF ~~ THEN BEGIN 447 // from: 446.0
SAY #41859 /* ~"Pudu, pudu... vydrž." Morte se na chvilku odmlčel. "V pohodě, tady je poslední kousek..."  'Neztrať deník, nebo to zase zalomíš ve Styxu. A ať budeš dělat cokoliv, nikomu NEŘÍKEJ KDO seš ani co se ti stalo, jináč tě fofrem pošlou na cyhlídkovou cestu krematoriem. Dělej co řeknu: PŘEČTI deník a najdi Pharoda.'~ */
IF ~~ THEN REPLY #41860 /* ~"A to sem u sebe neměl žádnej deník když sem se probral?"~ */ GOTO 448
IF ~~ THEN REPLY #41861 /* ~"V pohodě. Mám ještě jiný otázky..."~ */ GOTO 444
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41862 /* ~"Kašli na to, už sem slyšel dost. Jdem."~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41863 /* ~"Kašli na to, už sem slyšel dost. Jdem."~ */ EXIT
END

IF ~~ THEN BEGIN 448 // from: 447.0
SAY #41864 /* ~"Ne... byls nahej. Jak už sem říkal, podstatnou část deníku máš napsanou na těle."~ */
IF ~~ THEN REPLY #41865 /* ~"A seš si jistej, že neznáš nikoho jménem Pharod?"~ */ GOTO 449
IF ~~ THEN REPLY #41866 /* ~"Pravda. Mám ještě jiný otázky..."~ */ GOTO 444
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41867 /* ~"No dobrá. Jdeme"~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41868 /* ~"No dobrá. Jdeme"~ */ EXIT
END

IF ~~ THEN BEGIN 449 // from: 448.0
SAY #41869 /* ~"Ne. Ale nákej kretén ho určitě zná. Musíš se ptát... Teda až vodsaď vypadnem."~ */
IF ~~ THEN REPLY #41870 /* ~"Než půjdeme, mám ještě jiný otázky..."~ */ GOTO 444
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41871 /* ~"No dobrá. Jdeme"~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41872 /* ~"No dobrá. Jdeme"~ */ EXIT
END

IF ~~ THEN BEGIN 450 // from: 444.1
SAY #41873 /* ~"Říká se mu 'Márnice'... je to velká černá barabizna kerou postavil někdo s architektonickým vkusem těhotnýho pavouka."~ */
IF ~~ THEN REPLY #41874 /* ~"Jasně. Ještě se chci na něco zeptat..."~ */ GOTO 444
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41875 /* ~"Přesně to sem chtěl vědět. Dík."~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41876 /* ~"Přesně to sem chtěl vědět. Dík."~ */ EXIT
END

IF ~~ THEN BEGIN 451 // from: 444.2 444.3
SAY #41877 /* ~"Říkaj si 'Spalovači.' Nemůžeš je minout: Sou posedlí temnotou a záhrobním chladem. Sou nějakej druh ghúlskejch poskoků; věří, že všecko musí umřít... a čím dřív, tím líp."~ */
IF ~~ THEN REPLY #41878 /* ~"Z toho sem zmatený... proč by mělo Spalovače zajímat jestli odejdu?"~ */ GOTO 452
IF ~~ THEN REPLY #41879 /* ~"Jasně. Mám na tebe ještě nějaký otázky..."~ */ GOTO 444
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41880 /* ~"Chápu. Budu opatrný."~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41881 /* ~"Chápu. Budu opatrný."~ */ EXIT
END

IF ~~ THEN BEGIN 452 // from: 451.0
SAY #41882 /* ~"Copa si neposlouchal?! Říkal sem že Spalovači věří, že všechno živý musí umřít. A to radši dřív než pozdějc. Myslíš že mrtvoly cos viděl jsou štastnější v knize mrtvejch, nebo mimo ni?"~ */
IF ~~ THEN REPLY #41883 /* ~"Chápu. Mám pár dalších otázek..."~ */ GOTO 444
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41884 /* ~"V pohodě... pokusím si to zapamatovat."~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41885 /* ~"V pohodě... pokusím si to zapamatovat."~ */ EXIT
END

IF ~~ THEN BEGIN 453 // from: 444.6
SAY #41886 /* ~"No v podstatě... je *použiješ*. Zastaví krvácení a tak."  POZNÁMKA: Pokud chceš obvazy použít na sebe, klikni na ně pravým tlačítkem v inventáři. Když budeš chtíl léčit jinou postavu, dej si obvazy do některého z rychlých slotů v inventáři, vyber tlačítko "použij" z rychlého menu na obrazovce světa, a poté zvol cíl.~ */
IF ~~ THEN REPLY #41887 /* ~"Chápu. Mám pár dalších otázek..."~ */ GOTO 444
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41888 /* ~"Dík. Myslím, že to zvládnu."~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41889 /* ~"Dík. Myslím, že to zvládnu."~ */ EXIT
END

IF ~~ THEN BEGIN 454 // from: 444.4
SAY #41890 /* ~"Smrt chodí po Sférách každej den šéfe. Tihle šmajdalové sou to, co zbylo z jejich ubohejch tělních schránek, kterejma se zaprodali."~ */
IF ~~ THEN REPLY #41891 /* ~"Chápu. Mám pár dalších otázek..."~ */ GOTO 444
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41892 /* ~"V pohodě... pokusím si to zapamatovat."~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41893 /* ~"V pohodě... pokusím si to zapamatovat."~ */ EXIT
END

IF ~~ THEN BEGIN 455 // from: 444.5
SAY #41894 /* ~"Co - to myslíš *vážně?* Hele šéfe, tydle mrtvý žabky sou poslední šance pro takový fešáky jako sme my. Musíme být *gentlemani*... nebudem je rozsekávat kvůli klíčům, utrhávat jejich ruce a tak podobně ."~ */
IF ~~ THEN REPLY #41895 /* ~"Poslední šance? Co to meleš?"~ */ GOTO 456
IF ~~ THEN REPLY #41896 /* ~"Nevadí. Mám ještě nějaký otázky..."~ */ GOTO 444
IF ~~ THEN REPLY #41897 /* ~"V pohodě... pokusím si to zapamatovat."~ */ EXIT
END

IF ~~ THEN BEGIN 456 // from: 455.0
SAY #41898 /* ~"Šéfe, VONY sou mrtvý, MY sme mrtvý... chápeš kam tím mířím? Co?~ */
IF ~~ THEN REPLY #41899 /* ~"Ne... vlastně ani ne."~ */ GOTO 457
IF ~  CheckStatGT(Protagonist,12,INT) ~ THEN REPLY #41900 /* ~"To nemyslíš vážně."~ */ GOTO 457
IF ~~ THEN REPLY #41901 /* ~"Nevadí. Mám ještě nějaký otázky..."~ */ GOTO 444
IF ~~ THEN REPLY #41902 /* ~"Už sem slyšel dost. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 457 // from: 456.0 456.1
SAY #41903 /* ~"Šéfe, teď máme u těchhle slečinek jedinečnou šanci. Všichni sme aspoň jednou zaklepali bačkorama: máme si vo čem poklábosit. Vony upřednostňujou chlapy s náším druhem zkušeností."~ */
IF ~~ THEN REPLY #41904 /* ~"Počkej... neříkal jsi předtím že já *nejsem* mrtvý?"~ */ GOTO 458
IF ~~ THEN REPLY #41905 /* ~"Nevadí. Mám ještě nějaký otázky..."~ */ GOTO 444
IF ~~ THEN REPLY #41906 /* ~"Už sem slyšel dost. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 458 // from: 457.0
SAY #41907 /* ~"No... dobře, možná že *ty* nejseš mrtvej, ale já jo. A z toho důvodu mě nebude vadit, když se s těmadle kráskama co vokolo vidím pomuchlám v nějaké rakvi." Morte začal jakoby v předtuše cvakat zuby. "'Samo že napřed si s nima pohrajou Spalovači, to je jasná věc..."~ */
IF ~~ THEN REPLY #41908 /* ~"Mám ještě nějaký otázky Morte.."~ */ GOTO 444
IF ~~ THEN REPLY #41909 /* ~"Už sem slyšel dost. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 459 // from:
SAY #41910 /* ~"Při bozích. To je ksakru knížka."~ */
IF ~~ THEN REPLY #41911 /* ~"Co to je?"~ */ DO ~SetGlobal("Morte_Mortuary_Walkthrough_2","GLOBAL",1) ~ GOTO 460
END

IF ~~ THEN BEGIN 460 // from: 459.0
SAY #41913 /* ~"Dybych moh hádat, řek bych že to je ta knížka kde sou zapsaný všichni ti chudáci, keří neměli to štestí a zalomili to tady."~ */
IF ~~ THEN REPLY #41914 /* ~"Může tam být i moje jméno?"~ */ GOTO 461
END

IF ~~ THEN BEGIN 461 // from: 460.0
SAY #41915 /* ~"Ech... no asi jo. Abys to zjistil, měl bys protrénovat klapačku s tamtím Spalovačem. Ale nevím esli je to zrovna dobrej nápad."~ */
IF ~~ THEN REPLY #41916 /* ~"No, potřebuju odpovědi. Promluvím si s ním." ~ */ EXIT
END

IF ~~ THEN BEGIN 462 // from:
SAY #41919 /* ~Morte zašeptal: "Občas je i blázinec malej."~ */
IF ~~ THEN REPLY #41920 /* ~"Jumble mám pár otázek..."~ */ EXTERN ~DJUMBLE~ 2
IF ~  Global("Story_Reekwind_Curse","GLOBAL",1) Global("Jumble_Reekwind","GLOBAL",0) ~ THEN REPLY #41921 /* ~"Ty jsi ten kdo proklel Smradodecha, že jo?"~ */ DO ~SetGlobal("Jumble_Reekwind","GLOBAL",1) JOURNAL #67862 /* ~V Hale jsem potkal muže, který proklel Smradodecha. Je to Jumble Vraždosmysl.~ */ EXTERN ~DJUMBLE~ 8
IF ~  Global("Jumble_Reekwind","GLOBAL",1) ~ THEN REPLY #67864 /* ~"Byl bych rád, kdybys sejmul Smradodechovu kletbu."~ */ EXTERN ~DJUMBLE~ 9
IF ~~ THEN REPLY #41922 /* ~"Musím jít. Sbohem."~ */ EXIT
END

IF ~~ THEN BEGIN 463 // from:
SAY #41923 /* ~"Ech, och... zdá se, že sis právě vykoledoval nějakou tu kletbu, šéfe..."~ */
IF ~~ THEN REPLY #41924 /* ~"Jumble, cos mi to udělal?"~ */ EXTERN ~DJUMBLE~ 7
IF ~~ THEN REPLY #41925 /* ~"Jumble... prosím, vezmi to, cos udělal, zase zpátky."~ */ EXTERN ~DJUMBLE~ 7
IF ~~ THEN REPLY #41926 /* ~"Jumble aťs udělal cokoli, vem to zpátky - nebo se ti strašně pomstím."~ */ EXTERN ~DJUMBLE~ 7
IF ~~ THEN REPLY #41927 /* ~"Jdeme Morte."~ */ EXIT
END

IF ~~ THEN BEGIN 464 // from:
SAY #42929 /* ~"Říkám nevšímej si té žáby... jednej rezervovaně a bezstarostně. Podstatně to věci okoření!"~ */
IF ~~ THEN EXTERN ~DMONTAGU~ 29
END

IF ~~ THEN BEGIN 465 // from:
SAY #42930 /* ~"Věř mi, dítě. Začni ji ignorovat, vytvoř nějaké napětí, nech ji, ať začne být zvědavá, a oni budou škrábat všude kolem, jen aby zjistili, co je to za záležitost. Jasný, šéfe?"~ */
IF ~~ THEN REPLY #42931 /* ~"Ano... ona si bude myslet, že něco je špatně, a pro jednou, on bude hrát podle pravidel, spíš než kdyby byl cíl."~ */ EXTERN ~DMONTAGU~ 30
IF ~~ THEN REPLY #42932 /* ~"Ne... to je ubohý nápad."~ */ EXTERN ~DMONTAGU~ 31
END

IF ~~ THEN BEGIN 466 // from:
SAY #43543 /* ~"Tohle je důvod, proč by se githové neměli množit. Pořád pokračují v tom, nebo si to myslí, že 'kde jinde bych mohl zabít nějakého mindflayera nebo githyanki' a tak dále a tak podobně. Myslím, že dokonce neradi pomlouvají jeden druhého. Jsou natvrdlí a často se naštvou, nebo zůstávají stále tak přímí a soustředění, že ztrácí smysl pro humor. Chvástají se svým soustředěním a tím, že mají jedno vědomí a společnou důvěru, jenže všimněte si, že se tato rasa sama rozdělila hned poté, co se rozdělila i jejich mysl. A teď mi řekni, která víra a ideologie nepřinese Sférám zkázu."~ */
IF ~~ THEN EXTERN ~DKIINA~ 35
END

IF ~~ THEN BEGIN 467 // from:
SAY #43908 /* ~"Paráda."~ */
IF ~  PartyHasItem("Decant") Global("Seek_Word","GLOBAL",1) ~ THEN REPLY #43909 /* ~"Jmenuješ se Nemelle? "Bylo mi řečeno, že znáš ovládací slovo pro tuto láhev."~ */ EXTERN ~DNEML~ 4
IF ~  Global("Aelwyn","GLOBAL",2) !Dead("Aelwyn") ~ THEN REPLY #43910 /* ~"Ty jsi Nemelle? Tvá přítelkyně Aelwyn  se po tobě shání."~ */ DO ~SetGlobal("Nemelle","GLOBAL",3) SetGlobal("Aelwyn","GLOBAL",4) JOURNAL #39490 /* ~Řekl jsem Nemelle, že jí hledá její přítelkyně Aelwyn. Odměnila mě magickým polibkem, který mi zvýšil maximální životy o tři.~ */ EXTERN ~DNEML~ 6
IF ~  GlobalLT("Aelwyn","GLOBAL",2) ~ THEN REPLY #43911 /* ~"Hledáš někoho?"~ */ EXTERN ~DNEML~ 14
IF ~~ THEN REPLY #43912 /* ~"Mám nějaké otázky..."~ */ EXTERN ~DNEML~ 11
IF ~~ THEN REPLY #43913 /* ~"Nechci nic, Nemelle. Sbohem."~ */ EXIT
END

IF ~~ THEN BEGIN 468 // from:
SAY #43914 /* ~"Paráda."~ */
IF ~~ THEN EXTERN ~DANNAH~ 209
END

IF ~~ THEN BEGIN 469 // from:
SAY #43915 /* ~"No ne! Jaká malá horkokrevná žabka! Prahnoucí po pozornosti? Můžu slintat blahem i k tobě, estli jenom žárlíš..." Morte začal s mlaskáním plout k Annah...~ */
IF ~~ THEN EXTERN ~DANNAH~ 210
END

IF ~~ THEN BEGIN 470 // from:
SAY #43916 /* ~Morte se náhle zastavil a odvrátil se s nesrozumitelným mumláním.~ */
IF ~  PartyHasItem("Decant") Global("Seek_Word","GLOBAL",1) ~ THEN REPLY #43917 /* ~"Jmenuješ se Nemelle?" Bylo mi řečeno, že znáš ovládací slovo pro tuto láhev."~ */ EXTERN ~DNEML~ 4
IF ~  Global("Aelwyn","GLOBAL",2) !Dead("Aelwyn") ~ THEN REPLY #43918 /* ~"Ty jsi Nemelle? Tvá přítelkyně Aelwyn  se po tobě shání."~ */ DO ~SetGlobal("Nemelle","GLOBAL",3) SetGlobal("Aelwyn","GLOBAL",4) JOURNAL #39490 /* ~Řekl jsem Nemelle, že jí hledá její přítelkyně Aelwyn. Odměnila mě magickým polibkem, který mi zvýšil maximální životy o tři.~ */ EXTERN ~DNEML~ 6
IF ~  GlobalLT("Aelwyn","GLOBAL",2) ~ THEN REPLY #43919 /* ~"Hledáš někoho?"~ */ EXTERN ~DNEML~ 14
IF ~~ THEN REPLY #43920 /* ~"Mám nějaké otázky..."~ */ EXTERN ~DNEML~ 11
IF ~~ THEN REPLY #43921 /* ~"Nechci nic, Nemelle. Sbohem."~ */ EXIT
END

IF ~~ THEN BEGIN 471 // from:
SAY #43922 /* ~"Ale di, šéfiku... Jsem si jistej, že bysme *něco* vymysleli. Co? Co?"~ */
IF ~~ THEN REPLY #43923 /* ~"Zapomeň na to, Morte. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 472 // from:
SAY #44244 /* ~Morte připlul blíž a zašeptal: "Ne, já. Vyřídím to. Co, Šéfe? Mrky mrk, šťouchy šťouch..."~ */
IF ~~ THEN EXTERN ~DGONCAL~ 20
END

IF ~~ THEN BEGIN 473 // from:
SAY #44245 /* ~Morte se zděsil a skočil do potyčky. "Ne!!! Člověče, *zešílels?!* Hloupě plácáš!"~ */
IF ~~ THEN EXTERN ~DANNAH~ 214
END

IF ~~ THEN BEGIN 474 // from:
SAY #44677 /* ~Morte obrátil oči v sloup. "Debilové kupředu..."~ */
IF ~~ THEN EXTERN ~DYI'MINN~ 47
END

IF ~~ THEN BEGIN 475 // from:
SAY #44944 /* ~"Miluju Halu!"~ */
IF ~~ THEN EXTERN ~DUDESIRE~ 2
END

IF ~~ THEN BEGIN 476 // from:
SAY #45026 /* ~Morte hlasitě vzdychl. "Ale no tak sakra, šéfe. To tady fakt zůstanem a budem poslouchat ty debility?"~ */
IF ~~ THEN REPLY #45027 /* ~"Buď chvíli zticha, Morte. Chci si to poslechnout."~ */ EXTERN ~D3PLANEA~ 1
IF ~~ THEN REPLY #45028 /* ~Ignoruj Morta a poslouchej dál.~ */ EXTERN ~D3PLANEA~ 1
IF ~~ THEN REPLY #45029 /* ~"Máš pravdu, Morte - pojďme."~ */ DO ~SetGlobal("Lecture_Death","GLOBAL",2) ~ EXIT
END

IF ~~ THEN BEGIN 477 // from:
SAY #45088 /* ~"Hehe. Vypadá to, že tomu tupounovi někdo zapomněl říct, ať už nechodí podle Zákona tří."~ */
IF ~~ THEN REPLY #45089 /* ~"Co tím myslíš?"~ */ GOTO 478
END

IF ~~ THEN BEGIN 478 // from: 477.0
SAY #45091 /* ~"Tydlecty mrtvoly toho pod čepicí moc nemaj, takže najednou dokážou dělat akorát jednu věc... když jim někdo něco přikáže, tak to budou dělat, dokavad jim někdo nedá jinej rozkaz. Nebo dokud neshnijou a nerozpadnou se na sračky. Tendle kus hniloby asi už dodělal svůj úkol, ale nějak mu někdo zapomněl říct, co má dělat."~ */
IF ~~ THEN REPLY #45092 /* ~"Kdo dává mrtvolám rozkazy?"~ */ GOTO 481
IF ~~ THEN REPLY #45093 /* ~"Říkal jsi něco o Zákonu Tří. Cos tím myslel?"~ */ JOURNAL #39477 /* ~Morte se zmínil o něčem zvaném 'Pravidlo Tří'. Někteří lidé zjevně věří, že se vše stává v trojicích a dávají tomuto číslu velký význam.~ */ GOTO 479
IF ~~ THEN REPLY #45094 /* ~"Dobrá. Tak pojď, jdeme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 479 // from: 478.1 481.0
SAY #45095 /* ~"Eh? No tak Zákon tří, to je jeden z těch 'zákonů' ve Sférách, co povídá, že se věci dějou třikrát... nebo že se všecko skládá ze tří částí... nebo že jsou vždycky na výběr tři věci a tak dál."~ */
IF ~~ THEN REPLY #45096 /* ~"Mám pocit, že ty tomu moc nevěříš."~ */ GOTO 480
END

IF ~~ THEN BEGIN 480 // from: 479.0
SAY #45098 /* ~"Je to pěkná hovadina, esli se ptáš mě. Když si vezmeš jakýkoli číslo a budeš se k němu snažit připlácnout ňákej smysl, dycinky najdeš spoustu náhodnejch shod."~ */
IF ~~ THEN REPLY #45099 /* ~"Aha. Říkal jsi něco o tom, že ta mrtvola dostala rozkaz a někdo jí zapomněl přikázat, ať se zastaví. Kdo jim dává rozkazy?"~ */ GOTO 481
IF ~~ THEN REPLY #45100 /* ~"Rozumím. Chci si tuhle zombii ještě prohlídnout..."~ */ EXTERN ~DZM965~ 1
IF ~~ THEN REPLY #45101 /* ~"Dobrá. Tak pojď, jdeme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 481 // from: 478.0 480.0
SAY #45102 /* ~"Buďto jeden z dozorců nebo jakejkoli nekrofilní nekromancer, co toho chcípáka oživil z Knihy mrtvejch. Nejspíš jeden ze zřízenců... nakonec právě voni potřebujou levnou pracovní sílu. Anebo sexuální rozptýlení..."~ */
IF ~~ THEN REPLY #45103 /* ~"Aha. Co jsi to říkal o tom zákonu tří?"~ */ JOURNAL #39477 /* ~Morte se zmínil o něčem zvaném 'Pravidlo Tří'. Někteří lidé zjevně věří, že se vše stává v trojicích a dávají tomuto číslu velký význam.~ */ GOTO 479
IF ~~ THEN REPLY #45104 /* ~"Rozumím. Chci si tuhle zombii ještě prohlédnout..."~ */ EXTERN ~DZM965~ 1
IF ~~ THEN REPLY #45105 /* ~"Dobrá. Tak pojď, jdeme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 482 // from:
SAY #45540 /* ~"Uch... šéfe... neměl bys..."~ */
IF ~~ THEN EXTERN ~DZM985~ 3
END

IF ~~ THEN BEGIN 483 // from:
SAY #45709 /* ~"Ooh, aukce! Možná bychom tady mohli prodat Annah."~ */
IF ~~ THEN EXTERN ~DANNAH~ 215
END

IF ~~ THEN BEGIN 484 // from:
SAY #45710 /* ~"Ooh, aukce! Možná bychom tady mohli prodat Dak'kona."~ */
IF ~~ THEN EXTERN ~DDAKKON~ 163
END

IF ~~ THEN BEGIN 485 // from:
SAY #45711 /* ~"Ooh, aukce! Možná bychom tady mohli najít nějaké tělo, které by se mi hodilo."~ */
IF ~~ THEN REPLY #45712 /* ~"Jasně, Morte. Určitě se zeptám."~ */ EXTERN ~DGILTSP~ 4
IF ~~ THEN REPLY #45713 /* ~"Jenom pojďme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 486 // from:
SAY #45714 /* ~"To musí být láska. Je to láska, že jo, šéfe?"~ */
IF ~~ THEN REPLY #45715 /* ~"Nechte toho, vy dva. Potřebuju se tady zeptat na pár věcí."~ */ EXTERN ~DGILTSP~ 4
IF ~~ THEN REPLY #45716 /* ~"No jo, Morte. Nech ho být."~ */ EXIT
END 
IF WEIGHT #0 ~  NumTimesTalkedTo(0) InParty("Morte") !GlobalGT("Fortress_Morte","GLOBAL",2)
~ THEN BEGIN 487 // from:
SAY #45996 /* ~"Hej, dívejte se! Další lítající hlava!"~ */
IF ~~ THEN EXTERN ~DVAULT9~ 0
END

IF ~~ THEN BEGIN 488 // from:
SAY #47813 /* ~"Vypadá to, že tenhle palcát má cosi jako touhu rozumovat."~ */
IF ~~ THEN REPLY #47814 /* ~"Ticho. Mám další otázky..."~ */ EXTERN ~DJUSTFER~ 8
IF ~~ THEN REPLY #47815 /* ~"Pro tentokrát jsme domluvili."~ */ EXIT
END

IF ~~ THEN BEGIN 489 // from:
SAY #49443 /* ~"Ááá, githyanki. Vsadím se, že Dak'kon bude *celý* žhavý pomoct."~ */
IF ~~ THEN REPLY #49444 /* ~"Díky za tvůj neocenitelný vstup, Morte. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 490 // from:
SAY #50162 /* ~"Och, *mají* jména. Jsem si tím jistý."~ */
IF ~~ THEN EXTERN ~DANNAH~ 242
END

IF ~~ THEN BEGIN 491 // from:
SAY #50164 /* ~"Jak říkáš *ty*, fiendko."~ */
IF ~~ THEN REPLY #50165 /* ~"Klid, Morte - Annah, můžeš se ho zeptat na další otázky?"~ */ EXTERN ~DANNAH~ 240
IF ~~ THEN REPLY #50166 /* ~"Nechejme toho. Raději pojďme."~ */ DO ~SetGlobal("Translate_Dabus","GLOBAL",0) ~ EXTERN ~DADABUS~ 6
END

IF ~~ THEN BEGIN 492 // from:
SAY #50263 /* ~Morte se zasmál. "To bych dřív prošel vnitřnostma tanar'ri než bych rozluštil, co se ty lítající kozohlavci snaží říct. Chceš překladatele? Najdi si rodilýho Sigilana."~ */
IF ~~ THEN REPLY #50264 /* ~"Chápu."~ */ EXTERN ~DADABUS~ 2
END

IF ~~ THEN BEGIN 493 // from:
SAY #50266 /* ~Morte se zasmál. "To bych dřív prošel vnitřnostma tanar'riho než bych rozluštil, co se ty lítající kozohlavci snaží říct. Chceš překladatele? Máš tady to fiendský mrně." Kývl k Annah. "Ta se narodila v Sigilu."~ */
IF ~~ THEN REPLY #50267 /* ~"Možná ano..."~ */ EXTERN ~DADABUS~ 2
END

IF ~~ THEN BEGIN 494 // from:
SAY #50269 /* ~Morte se zasmál. "To bych dřív prošel vnitřnostma tanar'ri než bych rozluštil, co se ty lítající kozohlavci snaží říct. Chceš překladatele? Kývl k Dak'konovi. "Přemluv k tlumočení tady toho svatějšího-než-ty-a-dvakrát-tak-tichého."~ */
IF ~~ THEN REPLY #50270 /* ~"Možná ano..."~ */ EXTERN ~DADABUS~ 2
END

IF ~~ THEN BEGIN 495 // from:
SAY #50272 /* ~Morte se zasmál. "To bych dřív prošel vnitřnostma tanar'ri než bych rozluštil, co se ty lítající kozohlavci snaží říct. Chceš překladatele? Přemluv tady tu sukubu." Kývl k Fall-from-Grace. "Možná si s těmi chlapíky celou dobu vyměňovala klepy." ~ */
IF ~~ THEN REPLY #50273 /* ~"Možná ano..."~ */ EXTERN ~DADABUS~ 2
END

IF ~~ THEN BEGIN 496 // from:
SAY #50320 /* ~"Och, ke všem Silám! Přiblblý dabus."~ */
IF ~~ THEN REPLY #50321 /* ~"Co se děje?"~ */ GOTO 497
END

IF ~~ THEN BEGIN 497 // from: 496.0
SAY #50322 /* ~"Je to dabus. 'Mluví' v rébusech, v těch otravnejch slovních hlavolamech. Jestli *ty* nevíš, co říká, pak bysme si měli raděj najít nějakýho místního nebo přijít na jinej způsob komunikace s ním... když to budeme chtít. Můj názor? Oni *uměj* mluvit, jenom se snažej radši každýho nasrat luštěním toho, co říkaj."~ */
IF ~~ THEN REPLY #50323 /* ~"Co je 'dabus?'"~ */ GOTO 498
END

IF ~~ THEN BEGIN 498 // from: 497.0
SAY #50324 /* ~"Říká se, že jsou to domovníci Paní Bolesti. Poletují okolo a bořej, spravují a záplatují Sigil podle jejích vrtochů. Jsou horší než masařky." Morte vzdechl. "Ale zaplácnout je nemůžeš, jinak se Paní... nasere."~ */
IF ~  Global("Know_Lady","GLOBAL",0) ~ THEN REPLY #50325 /* ~"'Paní Bolesti?' Kdo to je?"~ */ DO ~SetGlobal("Know_Lady","GLOBAL",1) ~ GOTO 499
IF ~  Global("Know_Lady","GLOBAL",1) ~ THEN REPLY #50328 /* ~"Co mi můžeš povědět o Paní Bolesti?"~ */ GOTO 499
IF ~  Global("Know_Lady","GLOBAL",1) ~ THEN REPLY #50329 /* ~"Chápu."~ */ EXTERN ~DADABUS~ 2
END

IF ~~ THEN BEGIN 499 // from: 498.0 498.1
SAY #50326 /* ~"Vede město. Poznáš ji, když ji uvidíš: Má kolem vobličeje takový ty čepele, má velikost obra a poletuje nad zemí zrovna jako tihle chlápci." Morte kývl k dabusovi, který se na vás dva dívá. "Nikdo vo ní moc neví... vona moc nemluví. Všechno co potřebuješ vědět je to, že ji určitě nechceš nasrat. A když ji zmerkneš, pak radím: zdrhej."~ */
IF ~~ THEN REPLY #50327 /* ~"Chápu."~ */ EXTERN ~DADABUS~ 2
END

IF ~~ THEN BEGIN 500 // from:
SAY #50410 /* ~"Cože? Cože? Co v něm bylo, šéfe?"~ */
IF ~~ THEN REPLY #50411 /* ~"Nevím co říct, Morte..."~ */ GOTO 501
IF ~~ THEN REPLY #50412 /* ~"Nic, co by tě zajímalo, Morte."~ */ GOTO 501
IF ~~ THEN REPLY #50413 /* ~Ukaž mu Kodex.~ */ GOTO 503
END

IF ~~ THEN BEGIN 501 // from: 500.0 500.1
SAY #50414 /* ~"COŽE?! Ty si snad děláš srandu, ne? No ták, ukaž mi to!"~ */
IF ~~ THEN REPLY #50415 /* ~Ukaž mu Kodex.~ */ GOTO 503
IF ~~ THEN REPLY #50416 /* ~"Ne, Morte. Prostě zapomeň na to, že jsi to viděl."~ */ DO ~MoraleDec("Morte",1) ~ GOTO 502
END

IF ~~ THEN BEGIN 502 // from: 501.1
SAY #50417 /* ~Morte mrzutě zamručel... ale nechal ptaní.~ */
IF ~~ THEN EXTERN ~DCODEXI~ 2
END

IF ~~ THEN BEGIN 503 // from: 500.2 501.0
SAY #50418 /* ~Morte veplul nad tvé rameno, aby si prohlédl obsah Kodexu. Jeho oči téměř vypadly ze svých důlků, jak prohlížejí stránky: "Ooo. Oooooooo. Och, já... ale... jů."~ */
IF ~~ THEN EXTERN ~DCODEXI~ 2
END

IF ~~ THEN BEGIN 504 // from:
SAY #50697 /* ~"Huh! Huh! Huh! *Musíš* si dělat srandu, že? To přece *nemůžeš* myslet vážně, šéfe!"~ */
IF ~~ THEN REPLY #50698 /* ~"Myslím. Bereš ho, Vrischiko?"~ */ EXTERN ~DVRISCH~ 45
IF ~~ THEN REPLY #50699 /* ~"Ne, nemyslím. Měl bych jinou otázku, Vrischiko..."~ */ EXTERN ~DVRISCH~ 7
IF ~~ THEN REPLY #50700 /* ~"Máš pravdu, Morte; nebyl to dobrý nápad. Jdeme."~ */ EXIT
END

IF ~~ THEN BEGIN 505 // from:
SAY #50701 /* ~"Nemůžu tomu uvěřit... už jsi klesl pěkně hluboko, šéfe, ale toto už přesahuje všecky meze. Uvidím *tě* v Baatoru, ty zašpérovanej, krátkobrkej, podrazáckej, nevděčnej, poďobanej, hovnožroutskej, umaštěnej, křivozubej ubohej kuse vygumovanýho odpadu! Pamatuj na má slova, ty zasranej hajzle, pokračuj tak dál a brzo budeš mrtvej *nadobro*... a, och, pak budeš mít cos chtěl!"~ */
IF ~~ THEN DO ~DropInventory() LeaveParty() ~ EXTERN ~DVRISCH~ 46
END

IF ~~ THEN BEGIN 506 // from:
SAY #52571 /* ~"Polklo ho to, ale nevím, jestli vyšel z *tamtoho* konce."~ */
IF ~~ THEN REPLY #52572 /* ~"Už dost - podívej, Ravel, vzala jsi mi mou smrtelnost, a způsobilo to více škody než užitku. Vezmu si jí zpátky. Myslím, že už jsi ji měla dost dlouho."~ */ EXTERN ~DRAVEL~ 126
END

IF ~~ THEN BEGIN 507 // from:
SAY #52573 /* ~"Myslím, že vím, kdo by měl být zavřený v kleci..."~ */
IF ~~ THEN EXTERN ~DRAVEL~ 189
END

IF ~~ THEN BEGIN 508 // from:
SAY #52574 /* ~"No, neměl jsem na práci nic LEPŠÍHO než jít do jednoho z bludišť Paní Bolesti a tam se potkat s nejhrozivějším stvořením, který kdy strčilo čumák do Sigilu, tak sem si řek, no proč ne? Proč n-"~ */
IF ~~ THEN REPLY #52575 /* ~"Morte, zmlkni. Ravel, já..."~ */ GOTO 509
END

IF ~~ THEN BEGIN 509 // from: 508.0
SAY #52576 /* ~"'Zmlkni?!'" Morte zacvakal zubama. "A to sakra teda ne! Myslím, že už jsme slyšeli dost držkování tý báby, která tady mele něco vo tom, že nemám žádnou kůži! Tak CO že nemám?! Je jasný. VONA kůži má, ale copak jí to nějak pomohlo v jejím skvělým VZHLEDU? Myslí si snad, že se mi *líbí* bejt celou dobu NAHATEJ? A *ještě* jedna věc-"~ */
IF ~  NearbyDialog("Dgrace") ~ THEN REPLY #52577 /* ~"Morte! Vykašli se na to! Ravel, podívej --"~ */ DO ~SetGlobal("Ravel_Grace","GLOBAL",2) ~ EXTERN ~DRAVEL~ 66
IF ~  !NearbyDialog("DGrace") NearbyDialog("DAnnah") ~ THEN REPLY #52578 /* ~"Morte! Vykašli se na to! Ravel, podívej --"~ */ DO ~SetGlobal("Ravel_Annah","GLOBAL",2) ~ EXTERN ~DRAVEL~ 67
IF ~  !NearbyDialog("DGrace") !NearbyDialog("DAnnah") ~ THEN REPLY #52579 /* ~"Morte! Vykašli se na to! Ravel, podívej --"~ */ EXTERN ~DRAVEL~ 68
END

IF ~~ THEN BEGIN 510 // from:
SAY #52644 /* ~"Úchylný. Takže technicky vzato, kde vlastně jsme?"~ */
IF ~~ THEN REPLY #52771 /* ~"Odpověď na tohle opravdu nechci znát, Morte."~ */ EXTERN ~DPREGAL~ 10
END

IF ~~ THEN BEGIN 511 // from:
SAY #53623 /* ~"Oh, tak to je *skvělý.*"~ */
IF ~~ THEN EXTERN ~DPILLAR~ 5
END

IF ~~ THEN BEGIN 512 // from: 522.0 523.0 524.0
SAY #53624 /* ~Když jsi přistoupil blíže k Pilíři, Morte na tebe zasyčel: "Pssst! Šéfe! Šéfe... poslouchej, ta věc mě nesmí vidět. Musíš mě odsud dostat... nechat mě někde jinde a pak si mě vyzvednout, nebo tak něco..."~ */
IF ~  Global("Morte_Story","GLOBAL",1) ~ THEN REPLY #53625 /* ~"Zapomeň na to, Morte. Jdu si s tím promluvit..."~ */ DO ~MoraleDec("Morte",1) ~ EXTERN ~DPILLAR~ 9
IF ~  Global("Morte_Story","GLOBAL",0) ~ THEN REPLY #53627 /* ~"Proč, Morte? Co se děje?"~ */ GOTO 513
IF ~~ THEN REPLY #53628 /* ~"Fajn. Tak půjdeme pryč."~ */ EXIT
END

IF ~~ THEN BEGIN 513 // from: 512.1
SAY #53626 /* ~"Eh... Já bych o tom nejraděj nemluvil. Zkrátka pojďme, jo?" Morteho hlas se třese hrůzou. Jeho oči přelétají mezi tebou a obrovským pilířem hlav.~ */
IF ~~ THEN REPLY #53629 /* ~"Nemůžeš mít přede mnou tolik tajemství, Morte. Musíš mi říct, o co tady jde."~ */ DO ~SetGlobal("Morte_Story","GLOBAL",1) JOURNAL #53633 /* ~Morte sdělil, že jsem ho kdysi dávno vytáhl z Pilíře, tak dávno, že už si nepamatuje, jak přesně. Taky mi vysvětlil, že ztratil všechnu shromážděnou znalost Pilíře, když jsem ho od něj odloučil... což by vysvětlovalo, proč nebyl tak *docela* užitečný, jak sliboval mé předchozí inkarnaci.~ */ GOTO 514
IF ~~ THEN REPLY #53630 /* ~"Žádné uhýbání, Morte. *Hned* mi řekneš, o co tady jde, nebo si budeš *přát*, abychom si s těma hlavama promluvili."~ */ DO ~MoraleDec("Morte",1) SetGlobal("Morte_Story","GLOBAL",1) JOURNAL #53661 /* ~Ukázalo se, že Morte pochází z něčeho, zvaného Pilíř lebek, hromady živých, useknutých hlav, na Avernu, první vrstvě Baatoru. Je vytvořený z hlav těch, kteří lhali a jejich lži zavedli jiné na konec jejich životů.~ */ GOTO 514
IF ~~ THEN REPLY #53631 /* ~"Fajn. Tak půjdeme pryč."~ */ EXIT
END

IF ~~ THEN BEGIN 514 // from: 513.0 513.1
SAY #53632 /* ~Morte si povzdychl, není schopen podívat se ti do očí. Nakonec se podvolil. "Fajn, fajn... Povím ti to. Tenhle pilíř v Avernu, první vrstvě Baatoru, je postavenej z kebulí těch, kteří dovedli jiný na smrt tím, že jim lhali. No... je to právě támdle. Víš, tam jsem skončil. Zbytek si snad domyslíš."~ */
IF ~  NearbyDialog("Dannah") ~ THEN REPLY #53662 /* ~"Takže... ty jsi byl jednou z těch hlav?"~ */ GOTO 516
IF ~  !NearbyDialog("Dannah") ~ THEN REPLY #53663 /* ~"Takže... ty jsi byl jednou z těch hlav?"~ */ GOTO 515
END

IF ~~ THEN BEGIN 515 // from: 514.1
SAY #53664 /* ~"Jo. Trocha jsem upravil skutečnosti... jednou nebo dvakrát. Jenže jeden z mejch návrhů ved k tvý smrti. Jedný z nich. Možná vícero. Fakt nevím, tydle vzpomínky jsou už dávno pryč."~ */
IF ~~ THEN REPLY #53665 /* ~"Aha..."~ */ GOTO 518
END

IF ~~ THEN BEGIN 516 // from: 514.0
SAY #53666 /* ~"Jo. Trocha jsem upravil skutečnosti... jednou nebo dvakrát. Jenže jeden z mejch návrhů-"~ */
IF ~~ THEN EXTERN ~DANNAH~ 269
END

IF ~~ THEN BEGIN 517 // from:
SAY #53667 /* ~Morte pokračuje dál. "... jeden z mejch *návrhů* vedl k tvý smrti. Jedné z nich. Možná vícero. Fakt nevím, tydle vzpomínky jsou už dávno pryč."~ */
IF ~~ THEN GOTO 518
END

IF ~~ THEN BEGIN 518 // from: 515.0 517.0
SAY #53668 /* ~Morte zírá před tvé nohy - nikdy jsi ho neviděl tak zoufalého. "Tydle vzpomínky... hele, šéfe, já si dokonce nepamatuju, že bych *byl* člověk. Nepamatuju si, jakej byl život před Pilířem..."~ */
IF ~  NearbyDialog("DDakkon") ~ THEN EXTERN ~DDAKKON~ 183
IF ~  !NearbyDialog("DDakkon") ~ THEN REPLY #54105 /* ~"Pokračuj..."~ */ GOTO 520
END

IF ~~ THEN BEGIN 519 // from:
SAY #53794 /* ~Morte se podíval na Dak'kona, pak na tebe. "Jo. Asi jo. A tak už je to s věcma, když umřeš. Ty... zapomínáš. Řek bych, že sem nebyl zrovna vrchol ctností, když sem byl naživu... ale sakra, kdo je?" Morte si znovu povzdychl. "Já si zkrátka nemůžu pomoct. Není nic horšího, než bejt furt upřímnej. Ale koukni, šéfe, esli mě ta hromada hlav zmerčí, bude mě chtít zpátky - *moc*! To nesmíš dopustit!"~ */
IF ~~ THEN REPLY #53795 /* ~"Zapomeň na to, Morte. Jdu si s nimi promluvit..."~ */ DO ~MoraleDec("Morte",1) ~ EXTERN ~DPILLAR~ 9
IF ~~ THEN REPLY #53796 /* ~"Počkej... jak ses dostal z Pilíře?"~ */ GOTO 521
IF ~~ THEN REPLY #53797 /* ~"Vydrž... proč jsi mi to neřekl všechno už před tím, v Márnici?"~ */ GOTO 523
IF ~~ THEN REPLY #53798 /* ~"Chviličku. Jak dlouho už mě znáš, Morte?"~ */ GOTO 524
IF ~~ THEN REPLY #53799 /* ~"Dobrá. Jdeme, Morte."~ */ EXIT
END

IF ~~ THEN BEGIN 520 // from: 518.1
SAY #53800 /* ~"No, každopádně bych řek, že sem nebyl zrovna vrchol ctností, když sem byl naživu... ale sakra, kdo je?" Morte si znovu povzdychl. "Já si zkrátka nemůžu pomoct. Není nic horšího, než bejt furt upřímnej. Ale koukni, šéfe, esli mě ta hromada hlav zmerčí, bude mě chtít zpátky - *moc*! To nesmíš dopustit!"~ */
IF ~~ THEN REPLY #53801 /* ~"Zapomeň na to, Morte. Jdu si s nimi promluvit..."~ */ DO ~MoraleDec("Morte",1) ~ EXTERN ~DPILLAR~ 9
IF ~~ THEN REPLY #53802 /* ~"Počkej... jak ses dostal z Pilíře?"~ */ GOTO 521
IF ~~ THEN REPLY #53803 /* ~"Vydrž... proč jsi mi to neřekl všechno už před tím, v Márnici?"~ */ GOTO 523
IF ~~ THEN REPLY #53804 /* ~"Chviličku. Jak dlouho už mě znáš, Morte?"~ */ GOTO 524
IF ~~ THEN REPLY #53805 /* ~"Dobrá. Jdeme, Morte."~ */ EXIT
END

IF ~~ THEN BEGIN 521 // from: 519.1 520.1 523.1 524.1
SAY #53806 /* ~"No... tys mě vytáh ven, náčelníku. Proboxoval sem se na předek Pilíře - byl si tam už dřív, víš - řval sem a ječel, dokud sis mě nevšim. Škemral sem, ať mě vyndáš, přisahal sem, že tě budu následovat, podělím se s tebou o své znalosti až do konce tvých dnů... neuvědomil jsem si, jak dlouho to bude, dokud jsi mě nakonec nevytáh."~ */
IF ~~ THEN REPLY #53807 /* ~"A znalosti Pilíře...?"~ */ JOURNAL #53633 /* ~Morte sdělil, že jsem ho kdysi dávno vytáhl z Pilíře, tak dávno, že už si nepamatuje, jak přesně. Taky mi vysvětlil, že ztratil všechnu shromážděnou znalost Pilíře, když jsem ho od něj odloučil... což by vysvětlovalo, proč nebyl tak *docela* užitečný, jak sliboval mé předchozí inkarnaci.~ */ GOTO 522
END

IF ~~ THEN BEGIN 522 // from: 521.0
SAY #53808 /* ~"Oh, to... no, taky sem si neuvědomil, že přindu o většinu vědomostí Pilíře, jakmile budu mimo. U mizernejch mocností, *to* tě teda vytočilo! Ale stejně sis mě nechal u sebe. Nejprv sem se k tobě cítil 'vázanej'... jakoby mě tvá magie změnila na ňákýho služebníčka, magického otroka. Ale za pár set let sem si uvědomil, že je toho *víc*... něco mnohem hlubšího. Více než jenom vděčnost, i když ta s tím taky měla co dělat. Cítil sem, že mě k tobě něco táhne, něco *spojuje* s tebou. Možná všecko tvý utrpení, šéfe... tvý muka. Nevím. Možná mi to připomínalo moje vlastní, když sem byl v Pilíři.~ */
IF ~~ THEN REPLY #53809 /* ~"Teď si půjdu promluvit s Pilířem..."~ */ GOTO 512
IF ~~ THEN REPLY #53810 /* ~"Proč jsi mi to neřekl už v Márnici, že mě znáš?"~ */ GOTO 523
IF ~~ THEN REPLY #53811 /* ~"Jak dlouho už mě znáš, Morte?"~ */ GOTO 524
IF ~~ THEN REPLY #53812 /* ~"Dobrá. Pojďme pryč, Morte."~ */ EXIT
END

IF ~~ THEN BEGIN 523 // from: 519.2 520.2 522.1 524.2
SAY #53813 /* ~Morte se náhle začal bránit. "Protože sem *nevěděl*, kdo budeš! Některý z tvých inkarnací byli magoři, zuřiví šílenci! Jednou ses probral přesvědčený, že *já* jsem tvoje lebka a honil jsi mě kolem dokola, zkoušel jsi mě rozmlátit a sežrat... naštěstí tě na ulici srazil vůz. Jiná inkarnace, 'dobrá a zákonná' se mě snažila narvat do Pilíře, protože 'to je místo, kam patřím'." Morte si odfrkl. "*Proto*. Krom toho ti nijak neublížilo, když jsi to nevěděl..."~ */
IF ~~ THEN REPLY #53814 /* ~"Teď si půjdu promluvit s Pílířem..."~ */ GOTO 512
IF ~~ THEN REPLY #53815 /* ~"Jak ses dostal z Pilíře ven?"~ */ GOTO 521
IF ~~ THEN REPLY #53816 /* ~"Jak dlouho už mě znáš, Morte?"~ */ GOTO 524
IF ~~ THEN REPLY #53817 /* ~"Dobrá. Pojďme pryč, Morte."~ */ EXIT
END

IF ~~ THEN BEGIN 524 // from: 519.3 520.3 522.2 523.2
SAY #53818 /* ~"Nevím. Věky, řek bych. Dělal sem, co sem moh, abych ti pomoh najít cestu, pokaždý ale..." Morte si povzdychl, pozvedl se, aby se ti mohl podívat do očí. "Málokdy ses dostal takhle daleko, šéfe. Vážně. Jenom čtyřikrát nebo pětkrát. Možná že tentokrát... možná tohle 'tu' zjistí, o co tady vlastně jde."~ */
IF ~~ THEN REPLY #53819 /* ~"Teď si půjdu promluvit s Pílířem..."~ */ GOTO 512
IF ~~ THEN REPLY #53820 /* ~"Jak ses dostal z Pilíře ven?"~ */ GOTO 521
IF ~~ THEN REPLY #53821 /* ~"Proč jsi mi to neřekl už v Márnici, že mě znáš?"~ */ GOTO 523
IF ~~ THEN REPLY #53822 /* ~"Dobrá. Pojďme pryč, Morte."~ */ EXIT
END

IF ~~ THEN BEGIN 525 // from:
SAY #53823 /* ~"Oh, ne..."~ */
IF ~~ THEN EXTERN ~DPILLAR~ 10
END

IF ~~ THEN BEGIN 526 // from:
SAY #53824 /* ~Morte se otřásl hrůzou a zaskřípal zuby. "Nemůžu jít zpátky, šéfe! Nemůžu! Nemůžu! Nemůžu!"~ */
IF ~  NearbyDialog("Dgrace") ~ THEN REPLY #53825 /* ~"Nevrátil se k tobě. Ale já mám nějaké otázky, Pilíři lebek..."~ */ DO ~SetGlobal("Pillar_Musk","AR1001",1) ~ EXTERN ~DPILLAR~ 2
IF ~  NearbyDialog("Dannah") !NearbyDialog("Dgrace") ~ THEN REPLY #53826 /* ~"Nevrátil se k tobě. Ale já mám nějaké otázky, Pilíři lebek..."~ */ DO ~SetGlobal("Pillar_Musk","AR1001",1) ~ EXTERN ~DPILLAR~ 2
IF ~  !NearbyDialog("Dgrace") !NearbyDialog("Dannah") ~ THEN REPLY #53827 /* ~"Nevrátil se k tobě, Pilíři lebek. Ale já mám nějaké otázky..."~ */ EXTERN ~DPILLAR~ 12
IF ~~ THEN REPLY #53828 /* ~"Zkrátka pojďme, Morte. No tak pojď."~ */ EXTERN ~DPILLAR~ 50
END

IF ~~ THEN BEGIN 527 // from:
