IF ~~ THEN BEGIN 97 // from: 96.0
SAY #5032 /* ~"Jestli si chceš vykecávat držku se Spalovákama, tak mě z toho teda vynech, jo? Já a voni nejsme zrovna nejlepší kámoši, to teda ne. A ty bys s nima taky neměl nějak moc kámošit. Vypadáš jako něco, co by nejraděj upálili nebo někam pohřbili. A nejspíš by na příležitost moc nečekali. Nebuď magor, zkrátka se seber a poď, vypadnem."~ */
IF ~~ THEN REPLY #5033 /* ~"Dík za radu, ale já si s tímhle chlápkem *stejně* promluvím."~ */ DO ~SetGlobal("Warning","GLOBAL",2) ~ GOTO 99
IF ~~ THEN REPLY #5034 /* ~"Souhlasím, jdeme dál."~ */ EXIT
END

IF ~~ THEN BEGIN 98 // from:
SAY #5035 /* ~"Hej! Jsi hluchej? Co to děláš?"~ */
