IF ~  !NearbyDialog("DMorte") Global("Skeleton_Examine","GLOBAL",1) PartyHasItem("Prybar") ~ THEN REPLY #35531 /* ~Zkus kostlivci vytáhnout svorky z kloubů.~ */ GOTO 6
