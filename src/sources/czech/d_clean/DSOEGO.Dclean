IF ~~ THEN REPLY #4978 /* ~"Ano, *já*. Probral jsem se na jednom stole nahoře."~ */ GOTO 7
IF ~~ THEN REPLY #4979 /* ~"Omlouvám se... přeřekl jsem se."~ */ GOTO 50
