IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #4991 /* ~"Počkej chvíli! Ztratil jsem se... nějak jsem se tady zamotal a teď nemůžu najít východ. Můžeš mi pomoct?"~ */ GOTO 8
IF ~  CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #4992 /* ~"Stop! Nevolej stráže! Já se jenom chci dostat pryč... můžeš mi pomoct?"~ */ GOTO 13
IF ~  CheckStatGT(Protagonist,12,DEX) ~ THEN REPLY #4993 /* ~Zlom mu vaz, než stačí zařvat.~ */ GOTO 19
IF ~  CheckStatLT(Protagonist,13,DEX) ~ THEN REPLY #4994 /* ~Zlom mu vaz, než stačí zařvat.~ */ GOTO 22
