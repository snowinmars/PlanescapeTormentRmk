IF ~~ THEN BEGIN 71 // from: 63.4 64.4 65.3 66.3 67.5 68.4 69.4 70.4 72.6 73.6 74.4 77.2 78.2 79.5 80.1 81.0 101.5 104.3 109.5 110.3 112.1
SAY #21799 /* ~"Ještě trochu tvého času, před tím než půjdeš. Neútoč na žádné nemrtvé tady v katakombách; nezaútočí na tebe, dokud zůstaneš mírumilovný. Když se ukážeš být nepřátelský, tak se budou bránit, a je jich tady... mnoho. Nakonec, můžeš se sem vrátit, když si budeš chtít odpočinout."~ */
IF ~  NumInParty(1) !Global("Visit_Doubtful","AR1500",1) ~ THEN REPLY #21800 /* ~"Počkej... můžu si teď odpočinout?"~ */ JOURNAL #21805 /* ~Soego mi řekl, abych neútočil na žádné nemrtvé v Mrtvých národech, protože mi neublíží, dokud budu mírumilovný.~ */ GOTO 84
IF ~  NumInPartyGT(1) !Global("Visit_Doubtful","AR1500",1) ~ THEN REPLY #64569 /* ~"Počkej... můžeme si odpočinout?"~ */ JOURNAL #21805 /* ~Soego mi řekl, abych neútočil na žádné nemrtvé v Mrtvých národech, protože mi neublíží, dokud budu mírumilovný.~ */ GOTO 84
