IF ~~ THEN BEGIN 63 // from: 43.3 43.4 60.2 61.1 62.0 64.1 64.2
SAY #4619 /* ~Chvíli si tě prohlíží a něco si mumlá, nakonec přikývl. "Jo. Potvebuju fklínku balvamovafí tekutiny." Ukázal na jizvy na tvém hrudníku. "A nějakou nit a jehlu."~ */
IF ~  PartyHasItem("Embalm") PartyHasItem("Needle") ~ THEN REPLY #4620 /* ~"Tady máš."~ */ DO ~SetGlobal("Vaxis_Zombie_Disguise","GLOBAL",2) DestroyPartyItem("Embalm",FALSE) DestroyPartyItem("Needle",FALSE) ~ GOTO 65
IF ~~ THEN REPLY #4621 /* ~"Promyslím si to. Mám nějaké otázky..."~ */ DO ~SetGlobal("Vaxis_Zombie_Disguise","GLOBAL",1) ~ GOTO 43
