END

IF ~~ THEN BEGIN 65 // from: 63.0
SAY #4629 /* ~Zombie si od tebe vzal předměty a pak se pustil do práce...~ */
IF ~  !NearbyDialog("DMorte") Global("Vaxis_Zombie_XP","GLOBAL",0) ~ THEN REPLY #4630 /* ~Zkus vydržet bez hnutí.~ */ DO ~FadeToColor([20.0],0) Wait(1) SetNamelessDisguise(ZOMBIE) Wait(2) FadeFromColor([20.0],0) AddexperienceParty(500) SetGlobal("Vaxis_Zombie_XP","GLOBAL",1) ~ GOTO 66
IF ~  NearbyDialog("DMorte") Global("Morte_Vaxis_Quip_1","GLOBAL",0) ~ THEN REPLY #4631 /* ~Zkus vydržet bez hnutí.~ */ DO ~SetGlobal("Morte_Vaxis_Quip_1","GLOBAL",1) ~ EXTERN ~DMORTE~ 94
IF ~  NearbyDialog("DMorte") Global("Morte_Vaxis_Quip_1","GLOBAL",1) ~ THEN REPLY #4632 /* ~Zkus vydržet bez hnutí.~ */ DO ~FadeToColor([20.0],0) Wait(1) SetNamelessDisguise(ZOMBIE) Wait(2) FadeFromColor([20.0],0) ~ GOTO 66
IF ~  !NearbyDialog("DMorte") Global("Vaxis_Zombie_XP","GLOBAL",1) ~ THEN REPLY #64533 /* ~Ještě se pokus vydržet.~ */ DO ~FadeToColor([20.0],0) Wait(1) SetNamelessDisguise(ZOMBIE) Wait(2) FadeFromColor([20.0],0) ~ GOTO 66
END

IF ~~ THEN BEGIN 66 // from: 65.0 65.2 65.3
