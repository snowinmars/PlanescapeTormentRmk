IF ~~ THEN BEGIN 51 // from: 50.1 50.2 50.3 72.0
SAY #4567 /* ~Zombie kývl. "Chfef pryf, tak projdi vobloukem na prvním patve, feverovápadní míftnoft... Potvebujef koftěnej prft, vkroufenej..." Zvedl ukazováček a ohnul ho. "Av budef mít klíf, jdi do voblouku, fkrofíf do tajný krypty. Vodtamtud můvef utéft. Tajná útěková fefta. Můvef fi tam i FODPOFINOUT."~ */
IF ~  !PartyHasItem("BoneChrm") ~ THEN REPLY #64527 /* ~"Křivou prstní kost? Kde něco takového najdu?"~ */ DO ~AddexperienceParty(250) SetGlobal("Vaxis_Help","GLOBAL",1) JOURNAL #64528 /* ~Vaxis mi řekl, že v severozápadní místnosti prvního patra Márnice je tajný portál - jestliže se k němu přiblížím s prstní kostí, zaktivuje se a přenese mě do tajné krypty, kde si, jak Vaxis říká, mohu dopřát "odpočinek." Sice neví, kde bych nějakou prstní kost mohl najít, nicméně mi navrhl, abych to zkusil někde v horním patře Márnice. ~ */ GOTO 77
IF ~  PartyHasItem("BoneChrm") ~ THEN REPLY #4568 /* ~"Mám nějaké otázky..."~ */ DO ~AddexperienceParty(250) SetGlobal("Vaxis_Help","GLOBAL",1) JOURNAL #64529 /* ~Vaxis mi řekl, že v severozápadní místnosti prvního patra Márnice je tajný portál - jestliže se k němu přiblížím s prstní kostí, zaktivuje se a vezme mě do tajné krypty, kde si, jak Vaxis říká, mohu dopřát "odpočinek." ~ */ GOTO 43
IF ~  PartyHasItem("BoneChrm") ~ THEN REPLY #4569 /* ~"Oblouk na prvním patře, severozápadní místnost. Dobře, půjdu se tam podívat."~ */ DO ~AddexperienceParty(250) SetGlobal("Vaxis_Help","GLOBAL",1) JOURNAL #64529 /* ~Vaxis mi řekl, že v severozápadní místnosti prvního patra Márnice je tajný portál - jestliže se k němu přiblížím s prstní kostí, zaktivuje se a vezme mě do tajné krypty, kde si, jak Vaxis říká, mohu dopřát "odpočinek." ~ */ EXIT
END

IF ~~ THEN BEGIN 52 // from: 43.2
SAY #4570 /* ~"Poflouchej! Pamatuj fi!" Zombie začíná být naštvaný. "Voblouk, první patro, feverovápadní míftnoft." Zvedl ukazováček a zkroutil jej. "Potvebujef prftní koft, vkroufenou. Fkonfíf v tajný mífntnosfti, odkud můvef utéft. Můvef tam taky vodpofívat."~ */
