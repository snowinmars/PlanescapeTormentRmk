IF ~~ THEN REPLY #4623 /* ~"Blazamovací tekutinu a nit? Zkusím se po tom podívat."~ */ DO ~SetGlobal("Vaxis_Zombie_Disguise","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 64 // from: 61.2 61.3 62.1 62.2
SAY #4624 /* ~Prohlédl si tě s podivným výrazem na tváři. "Ty budef DOBRÁ vombie. Můvu tě udělat vombie? Dobrej pvevlek."~ */
IF ~~ THEN REPLY #4625 /* ~"Ne. Ale stejně díky. Mám pro tebe ještě další otázky..."~ */ DO ~SetGlobal("Vaxis_Zombie_Disguise","GLOBAL",1) ~ GOTO 43
IF ~~ THEN REPLY #4626 /* ~"Jistě. Dokážeš to?"~ */ GOTO 63
