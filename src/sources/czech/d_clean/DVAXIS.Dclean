IF ~  Global("Strong_Arm_Vaxis","GLOBAL",0) GlobalGT("Embalm_Key_Quest","GLOBAL",2) Global("Vaxis_Orders","GLOBAL",0) ~ THEN REPLY #64509 /* ~"Můžeš mi ukázat jeden z těch portálů?"~ */ GOTO 51
