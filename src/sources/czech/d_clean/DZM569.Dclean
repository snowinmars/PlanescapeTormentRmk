~ THEN BEGIN 0 // from:
SAY #24575 /* ~Tato belhající se mrtvola vypadá, že je mrtvá už několik let. Kůže kolem čela se už odloupala, čímž se odhalila její křídově bílá lebka. Někdo vyryl na odhalenou kost číslo "569". ~ */
IF ~  Global("Mortuary_Walkthrough","GLOBAL",0) !PartyHasItem("KeyPr") NearbyDialog("DMorte1") ~ THEN REPLY #24576 /* ~"Hledám klíč... je možné, abys ho měl ty?"~ */ EXTERN ~DMORTE1~ 31
IF ~  Global("Mortuary_Walkthrough","GLOBAL",0) !PartyHasItem("KeyPr") !NearbyDialog("DMorte1") ~ THEN REPLY #24579 /* ~"Hledám klíč... je možné, abys ho měl ty?"~ */ GOTO 1
IF ~  GlobalGT("Mortuary_Walkthrough","GLOBAL",0) ~ THEN REPLY #24580 /* ~"Tak... viděl jsi něco zajímavého?"~ */ GOTO 1
IF ~  Global("Vaxis_Exposed","GLOBAL",1) ~ THEN REPLY #24581 /* ~"Vím, že nejsi zombie, víš. Nikoho neoklameš."~ */ GOTO 1
IF ~  Global("Speak_with_Dead","GLOBAL",1) ~ THEN REPLY #24584 /* ~Použij na mrtvolu Kosti vyprávějte.~ */ GOTO 2
IF ~  Global("Mortuary_Walkthrough","GLOBAL",0) !PartyHasItem("KeyPr") ~ THEN REPLY #24585 /* ~Prohledej mrtvolu, koukni se jestli nemá klíč.~ */ GOTO 3
IF ~~ THEN REPLY #42290 /* ~"Bylo skvělý si s tebou poklábosit. Sbohem."~ */ EXIT
IF ~~ THEN REPLY #42291 /* ~Nechej mrtvolu odpočívat v pokoji.~ */ EXIT
END

