SAY #24577 /* ~Mrtvola na tebe tiše zírá..~ */
IF ~~ THEN REPLY #24578 /* ~"No, nevadí. Sbohem."~ */ EXIT
IF ~~ THEN REPLY #42292 /* ~Nechej mrtvolu odpočívat v pokoji.~ */ EXIT
END

