IF ~~ THEN REPLY #19717 /* ~"Also gut. Gehen wir."~ */ EXIT
IF ~~ THEN REPLY #19718 /* ~"Ich werd trotzdem mit ihr reden."~ */ EXTERN ~DGHOCITF~ 1
END

