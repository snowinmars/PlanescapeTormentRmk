IF ~~ THEN REPLY #1821 /* ~"Ich suche gar nichts, aber ich hätte da ein paar Fragen..."~ */ EXTERN ~DHARLOTN~ 9
IF ~~ THEN REPLY #1822 /* ~"Ich muß mich verabschieden. Leb wohl."~ */ EXTERN ~DHARLOTN~ 11
END

IF ~~ THEN BEGIN 38 // from:
