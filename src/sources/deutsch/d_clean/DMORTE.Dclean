IF ~~ THEN REPLY #1845 /* ~"Oh... na gut, ich denke, das wird mir nicht *wehtun*..."~ */ DO ~SetGlobal("Morte_Harlot_Quip_1","GLOBAL",1) ~ EXTERN ~DHARLOTN~ 7
IF ~~ THEN REPLY #1846 /* ~"Ich werde dich nicht mal fragen, wie du das anstellen willst."~ */ DO ~SetGlobal("Morte_Harlot_Quip_1","GLOBAL",1) ~ EXTERN ~DHARLOTN~ 7
IF ~~ THEN REPLY #1847 /* ~"Sieh mal... wir müssen wirklich los, Morte. Leb wohl, Fräulein."~ */ DO ~SetGlobal("Morte_Harlot_Quip_1","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 39 // from:
