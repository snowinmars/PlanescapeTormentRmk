IF ~  GlobalLT("Morte_Mimir","GLOBAL",2) ~ THEN DO ~IncrementGlobalOnceEx("GLOBALMorte_Mimir","GLOBALMorte_Mimir",0) ~ EXTERN ~DADYZOEL~ 36
IF ~  GlobalGT("Morte_Mimir","GLOBAL",1) ~ THEN REPLY #65537 /* ~"Aber du bist KEIN Mimir, Morte..."~ */ EXTERN ~DADYZOEL~ 36
END

IF ~~ THEN BEGIN 180 // from:
SAY #15350 /* ~"Los, Meister... das wirst du ihm doch nicht durchgehen lassen? Dem Schnösel werden wir's zeigen! Ich kümmere mich um seine Augen, schaufel du nur in ihn rein!"~ */
IF ~~ THEN REPLY #15494 /* ~"Du hast recht... greifen wir ihn uns."~ */ EXTERN ~DADYZOEL~ 19
IF ~~ THEN REPLY #15495 /* ~"Jetzt ist nicht die Zeit dafür, Morte. Gehen wir."~ */ DO ~SetGlobal("Adyzoel","AR0400",2) ~ EXIT
END

IF ~~ THEN BEGIN 181 // from: 185.0
SAY #16613 /* ~"Was? Oh, ja, Meister, klar - was auch immer du sagst." ~ */
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #16881 /* ~"Danke. Ich hätte da ein paar Fragen, Der um die Bäume trauert..."~ */ EXTERN ~DMFTREE~ 28
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #16882 /* ~"Ich mein's ernst, Morte. Könntest du dir die Mühe machen?"~ */ DO ~IncrementGlobal("Tree_Helpers","AR0400",1) ~ GOTO 182
IF ~~ THEN REPLY #16883 /* ~"Danke, Morte. Leb wohl, Der um die Bäume trauert."~ */ EXIT
END

IF ~~ THEN BEGIN 182 // from: 181.1
SAY #16614 /* ~Morte schaut dich eine Weile stumm an - dann nickt er. "Ja, kann ich. Wenn es dir so viel bedeutet, mach' ich's."~ */
IF ~  NearbyDialog("DAnnah") Global("Tree_A","AR0400",0) ~ THEN REPLY #16884 /* ~"Danke. Annah? Könntest du's?"~ */ DO ~SetGlobal("Tree_A","AR0400",1) ~ EXTERN ~DANNAH~ 99
IF ~  NearbyDialog("DIgnus") Global("Tree_I","AR0400",0) ~ THEN REPLY #16885 /* ~"Danke. Ignus?"~ */ DO ~SetGlobal("Tree_I","AR0400",1) ~ EXTERN ~DIGNUS~ 11
IF ~  NearbyDialog("DGrace") Global("Tree_G","AR0400",0) ~ THEN REPLY #16886 /* ~"Danke. Grace, könntest du drüber nachdenken?~ */ DO ~SetGlobal("Tree_G","AR0400",1) ~ EXTERN ~DGRACE~ 14
IF ~  NearbyDialog("DDakkon") Global("Tree_D","AR0400",0) ~ THEN REPLY #16887 /* ~"Danke. Dak'kon, könntest du diesem Mann helfen?"~ */ DO ~SetGlobal("Tree_D","AR0400",1) ~ EXTERN ~DDAKKON~ 74
IF ~  NearbyDialog("DDakkon") Global("Tree_D","AR0400",0) Global("Dakkon_Slave","Global",1) ~ THEN REPLY #16888 /* ~"Danke. Dak'kon: Hilf diesem Mann."~ */ DO ~IncrementGlobal("BD_DAKKON_MORALE","GLOBAL",-1) SetGlobal("Tree_D","AR0400",1) ~ EXTERN ~DDAKKON~ 75
IF ~  NearbyDialog("DNordom") Global("Tree_N","AR0400",0) ~ THEN REPLY #16889 /* ~"Danke. Nordom, meinst du, du könntest helfen?"~ */ DO ~SetGlobal("Tree_N","AR0400",1) ~ EXTERN ~DNORDOM~ 1
IF ~  NearbyDialog("DVhail") Global("Tree_V","AR0400",0) ~ THEN REPLY #16890 /* ~"Danke. Vhailor, könntest du helfen?"~ */ DO ~SetGlobal("Tree_V","AR0400",1) ~ EXTERN ~DVHAIL~ 1
IF ~~ THEN REPLY #16891 /* ~"Danke. Ich hätte da ein paar Fragen, Der um die Bäume trauert..."~ */ EXTERN ~DMFTREE~ 28
IF ~~ THEN REPLY #16892 /* ~"Danke, Morte. Leb wohl, Der um die Bäume trauert."~ */ EXIT
END

IF ~~ THEN BEGIN 183 // from:
