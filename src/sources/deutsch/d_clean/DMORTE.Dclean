END

IF ~~ THEN BEGIN 556 // from: 554.0 554.1 555.0 555.1
SAY #54273 /* ~"Nein..." Morte hält inne. "Da ist noch etwas. Ich habe dieses *andere* Ich von dir damals vielleicht nicht besonders gemocht, aber er war ein ziemlich schlauer Kerl - der schlaueste, den ich je kannte. Der ging immer auf Nummer sicher. Wenn er in der Festung gestorben ist, dann heißt das... naja..."~ */
IF ~~ THEN REPLY #54274 /* ~"Du glaubst nicht, daß ich es schaffen kann, was?"~ */ GOTO 557
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) InParty("Morte") ~ THEN REPLY #54275 /* ~"Mach dir nichts draus, Morte. Ich bin bereit, durch das Portal zu gehen - kommst du mit?"~ */ GOTO 534
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) !InParty("Morte") ~ THEN REPLY #54276 /* ~"Mach dir nichts draus, Morte. Was passiert ist, ist passiert. Ich gehe jetzt jedenfalls durch das Portal."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 557 // from: 556.0
SAY #54277 /* ~"Nein..." Morte schüttelt den Kopf. "Das ist es nicht, Meister. Weil es nicht immer darum geht, wer der Cleverste ist, oder wer der Mächtigste ist, oder wer der Härteste ist... Manchmal geht es einfach nur darum, wer du bist und was du *wirklich* willst. Ich meine, du wolltest einmal unsterblich werden - aber nach allem, ist das *wirklich*, was du wolltest? Sei dir diesmal einfach wirklich sicher, was du willst, mehr sag ich gar nicht."~ */
IF ~  InParty("Morte") Global("Morte_Morale_Fortress_Portal","AR0202",0) ~ THEN REPLY #54278 /* ~"In Ordnung. Sieh mal, Morte... Wir haben noch nie darüber gesprochen, aber du mußt nicht mit mir mitkommen, okay? Ich verstehe, wenn du nicht willst."~ */ DO ~IncrementGlobal("BD_MORTE_MORALE","GLOBAL",1) SetGlobal("Morte_Morale_Fortress_Portal","AR0202",1) ~ GOTO 558
IF ~  InParty("Morte") ~ THEN REPLY #54279 /* ~"Verstanden. Wenn du dann fertig bist, können wir ja gehen. Also, bist du bereit?"~ */ GOTO 534
IF ~  !InParty("Morte") ~ THEN REPLY #54280 /* ~"Verstanden. Danke für den Ratschlag, Morte. Ich gehe jetzt durch das Portal."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 558 // from: 557.0
SAY #54281 /* ~"Ja... ich weiß, Meister. Und ich kann dich nicht anlügen... Ich will nicht gehen... aber ich werde. Du mußt wissen: Wenn wir erst durch dieses Portal geschritten sind, dann dreht sich nicht mehr alles um *dich*. Du spielst mit *unserem* Leben, und uns stellt keiner wieder her, wenn wir sterben."~ */
IF ~  GlobalGT("Ravel_Grace","GLOBAL",0) GlobalGT("Ravel_Morte","GLOBAL",0) GlobalLT("Torment_Fell","GLOBAL",2) NearbyDialog("Dgrace") ~ THEN REPLY #54282 /* ~"Warum bist du dann..."~ */ EXTERN ~DGRACE~ 169
IF ~  GlobalGT("Ravel_Grace","GLOBAL",0) GlobalGT("Ravel_Morte","GLOBAL",0) Global("Torment_Fell","GLOBAL",2) NearbyDialog("Dgrace") ~ THEN REPLY #54283 /* ~"Warum bist du dann..."~ */ EXTERN ~DGRACE~ 170
IF ~  GlobalGT("Ravel_Morte","GLOBAL",0) GlobalLT("Torment_Fell","GLOBAL",2) !NearbyDialog("Dgrace") ~ THEN REPLY #54284 /* ~"Warum bist du dann..."~ */ GOTO 562
IF ~  GlobalGT("Ravel_Morte","GLOBAL",0) Global("Torment_Fell","GLOBAL",2) !NearbyDialog("Dgrace") ~ THEN REPLY #54285 /* ~"Warum bist du dann..."~ */ GOTO 563
IF ~  Global("Ravel_Morte","GLOBAL",0) ~ THEN REPLY #54286 /* ~"Warum bist du dann..."~ */ GOTO 564
END

