IF ~~ THEN REPLY #27920 /* ~"Hmm."~ */ EXTERN ~DCWCAFEF~ 52
IF ~~ THEN REPLY #27921 /* ~"Ich verstehe."~ */ EXTERN ~DCWCAFEF~ 52
