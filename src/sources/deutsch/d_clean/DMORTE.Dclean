IF ~~ THEN EXTERN ~DMARTA~ 15
END

IF ~~ THEN BEGIN 209 // from:
SAY #20471 /* ~Morte dreht sich zu Marta um. "Ja, 'Dingerchen'." Dann dreht er sich zu dir. "Alles eine Frage der Semantik."~ */
IF ~  GlobalLT("Know_Marta_Work","GLOBAL",3) ~ THEN REPLY #20612 /* ~"Marta, warum ziehst du der Leiche Zähne und Fäden?"~ */ DO ~SetGlobal("Know_Marta_Work","GLOBAL",3) JOURNAL #20538 /* ~Marta, die Näherin, scheint die Aufgabe zu haben, Leichen, die ihr gegeben werden, die Zähne herauszureißen, ihre Nähte aufzulösen, nach Wertsachen zu suchen, die sie an oder in der Leiche finden kann, und sie dann wieder zusammenzunähen.~ */ EXTERN ~DMARTA~ 16
IF ~  GlobalGT("Know_Marta_Work","GLOBAL",2) ~ THEN REPLY #20613 /* ~"Marta, warum ziehst du der Leiche Zähne und Fäden?"~ */ JOURNAL #20538 /* ~Marta, die Näherin, scheint die Aufgabe zu haben, Leichen, die ihr gegeben werden, die Zähne herauszureißen, ihre Nähte aufzulösen, nach Wertsachen zu suchen, die sie an oder in der Leiche finden kann, und sie dann wieder zusammenzunähen.~ */ EXTERN ~DMARTA~ 16
IF ~~ THEN REPLY #20614 /* ~"Äh... also gut. Ich muß mich verabschieden, Marta. Leb wohl."~ */ EXIT
END

