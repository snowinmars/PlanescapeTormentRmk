SAY #18831 /* ~"Meister! Komm!"~ */
IF ~~ THEN EXTERN ~DCOLYLFN~ 52
END

IF ~~ THEN BEGIN 196 // from:
SAY #18832 /* ~"Das Leben über den Straßen Sigils auch nicht."~ */
IF ~  PartyGoldGT(4) ~ THEN REPLY #18833 /* ~Gib ihm fünf Kupfermünzen.~ */ DO ~TakePartyGold(5) ~ EXTERN ~DCOLYLFN~ 53
IF ~  PartyGoldGT(9) ~ THEN REPLY #18834 /* ~Gib ihm zehn Kupfermünzen. ~ */ DO ~TakePartyGold(10) ~ EXTERN ~DCOLYLFN~ 53
IF ~  PartyGoldGT(49) ~ THEN REPLY #18835 /* ~Gib ihm fünfzig Kupfermünzen.~ */ DO ~TakePartyGold(50) IncrementGlobalOnceEx("GLOBALGood_Yellow_2","GLOBALGood",1) ~ EXTERN ~DCOLYLFN~ 53
IF ~  PartyGoldGT(99) ~ THEN REPLY #18836 /* ~Gib ihm hundert Kupfermünzen.~ */ DO ~TakePartyGold(100) IncrementGlobalOnceEx("GLOBALGood_Yellow_2","GLOBALGood",1) ~ EXTERN ~DCOLYLFN~ 53
IF ~~ THEN REPLY #18837 /* ~"Ich nehm's zurück. Verschwinde und komm mir nie wieder unter die Augen."~ */ EXTERN ~DCOLYLFN~ 61
END

