IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) !InParty("Morte") ~ THEN REPLY #54267 /* ~"Mach dir nichts draus, Morte. Was passiert ist, ist passiert. Ich gehe jetzt jedenfalls durch das Portal."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 555 // from: 553.1
SAY #54268 /* ~"Was ich sagen will ist, daß DU, trotz deines eselshaften Benehmens, mehr Geist besitzt, als er je hatte. Dein anderes Ich, der... der war so distanziert. Darum... will ich, daß du das nicht vergißt."~ */
IF ~  CheckStatGT(Protagonist,15,WIS) ~ THEN REPLY #54269 /* ~"Aber das ist nicht alles, was du sagen willst, stimmt's?"~ */ GOTO 556
IF ~~ THEN REPLY #54270 /* ~"Ist das alles?"~ */ GOTO 556
