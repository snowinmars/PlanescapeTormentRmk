IF ~  Global("Mortai_Contract","GLOBAL",0) Global("Coppereyes_Contract","GLOBAL",0) ~ THEN REPLY #14278 /* ~"Das ist nur gerecht. Verschwinden wir von hier."~ */ EXTERN ~DAWAIT~ 15
END

