IF ~  NearbyDialog("DMorte") Global("Tree_M","AR0400",0) ~ THEN REPLY #16893 /* ~"Ich danke dir, Nordom. Morte? Was denkst du?"~ */ DO ~SetGlobal("Tree_M","AR0400",1) ~ GOTO 181
IF ~  NearbyDialog("DAnnah") Global("Tree_A","AR0400",0) ~ THEN REPLY #16894 /* ~"Ich danke dir, Nordom. Annah? Könntest du?"~ */ DO ~SetGlobal("Tree_A","AR0400",1) ~ EXTERN ~DANNAH~ 99
IF ~  NearbyDialog("DIgnus") Global("Tree_I","AR0400",0) ~ THEN REPLY #16895 /* ~"Ich danke dir, Nordom. Ignus?"~ */ DO ~SetGlobal("Tree_I","AR0400",1) ~ EXTERN ~DIGNUS~ 11
IF ~  NearbyDialog("DGrace") Global("Tree_G","AR0400",0) ~ THEN REPLY #16896 /* ~"Ich danke dir, Nordom. Grace, würdest du es angehen?"~ */ DO ~SetGlobal("Tree_G","AR0400",1) ~ EXTERN ~DGRACE~ 14
IF ~  NearbyDialog("DDakkon") Global("Tree_D","AR0400",0) ~ THEN REPLY #16897 /* ~"Ich danke dir, Nordom. Dak'kon, könntest du diesem Mann helfen?"~ */ DO ~SetGlobal("Tree_D","AR0400",1) ~ EXTERN ~DDAKKON~ 74
IF ~  NearbyDialog("DDakkon") Global("Tree_D","AR0400",0) Global("Dakkon_Slave","Global",1) ~ THEN REPLY #16898 /* ~"Ich danke dir, Nordom. Dak'kon: Hilf diesem Mann."~ */ DO ~IncrementGlobal("BD_DAKKON_MORALE","GLOBAL",-1) SetGlobal("Tree_D","AR0400",1) ~ EXTERN ~DDAKKON~ 75
IF ~  NearbyDialog("DVhail") Global("Tree_V","AR0400",0) ~ THEN REPLY #16899 /* ~"Ich danke dir, Nordom. Vhailor, könntest du helfen?"~ */ DO ~SetGlobal("Tree_V","AR0400",1) ~ EXTERN ~DVHAIL~ 1
IF ~~ THEN REPLY #16900 /* ~"Ich danke dir, Nordom. Ich hätte da ein paar Fragen, Der um die Bäume trauert..."~ */ EXTERN ~DMFTREE~ 28
