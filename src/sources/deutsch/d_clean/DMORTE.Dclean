IF ~  Global("Know_Gith","GLOBAL",0) ~ THEN REPLY #9029 /* ~"Gith?"~ */ DO ~SetGlobal("Know_Gith","GLOBAL",1) ~ GOTO 135
IF ~  Global("Know_Gith","GLOBAL",1) ~ THEN REPLY #9030 /* ~"Gith?"~ */ GOTO 135
