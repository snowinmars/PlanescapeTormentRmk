IF ~~ THEN BEGIN 552 // from: 548.3 551.0
SAY #54243 /* ~"Mehr kann ich dir nicht sagen, Meister... Nur, daß wir unter Garantie getrennt werden, wenn wir ankommen, der Ort ist RIESIG, und es wimmelt dort nur so vor Schatten... Und irgendwo in der Festung ist etwas, das mächtiger ist als *jeder* von uns. Mehr gibt es nicht zu sagen..."~ */
IF ~~ THEN REPLY #54244 /* ~"Bist du *sicher*? Das ist vielleicht unsere letzte Gelegenheit, miteinander zu reden..."~ */ DO ~SetGlobal("Morte_Quip_Regret_Portal","GLOBAL",2) ~ GOTO 553
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) InParty("Morte") ~ THEN REPLY #54245 /* ~"Mach dir nichts draus, Morte. Ich bin bereit, durch das Portal zu gehen - kommst du mit?"~ */ GOTO 534
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) !InParty("Morte") ~ THEN REPLY #54246 /* ~"Mach dir nichts draus, Morte. Was passiert ist, ist passiert. Ich gehe jetzt jedenfalls durch das Portal."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 553 // from: 552.0
SAY #54249 /* ~"Tja..." Morte hält eine Augenblick inne. "Ja, eine Sache solltest du noch wissen: Dein Ich, das ich früher gekannt habe, das Ich, das uns hierher geführt hat - der war nicht wie du. Überhaupt nicht."~ */
IF ~  GlobalGT("BD_MORTE_MORALE","GLOBAL",5) ~ THEN REPLY #54250 /* ~"Was meinst du?"~ */ GOTO 554
IF ~  GlobalLT("BD_MORTE_MORALE","GLOBAL",6) ~ THEN REPLY #54252 /* ~"Was meinst du?"~ */ GOTO 555
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) InParty("Morte") ~ THEN REPLY #54255 /* ~"Mach dir nichts draus, Morte. Ich bin bereit, durch das Portal zu gehen - kommst du mit?"~ */ GOTO 534
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) !InParty("Morte") ~ THEN REPLY #54262 /* ~"Mach dir nichts draus, Morte. Was passiert ist, ist passiert. Ich gehe jetzt jedenfalls durch das Portal."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 554 // from: 553.0
SAY #54263 /* ~"Dein anderes Ich, dem... dem waren die andern egal. Eigentlich alle. Wir hätten ALLE in der Festung draufgehen können, und er hätte nicht mit der Wimper gezuckt. Darum... möchte ich, daß du so bleibst, wie du bist... ich mag dich *so* nämlich lieber. VIEL lieber."~ */
IF ~  CheckStatGT(Protagonist,15,WIS) ~ THEN REPLY #54264 /* ~"Aber das ist nicht alles, was du sagen willst, stimmt's?"~ */ GOTO 556
IF ~~ THEN REPLY #54265 /* ~"Ist das alles?"~ */ GOTO 556
