IF ~~ THEN REPLY #19714 /* ~"Warum nicht, Morte?"~ */ GOTO 205
IF ~~ THEN REPLY #19715 /* ~"Also gut. Gehen wir."~ */ EXIT
IF ~~ THEN REPLY #19716 /* ~Ignoriere Morte und grüß den Ghul.~ */ EXTERN ~DGHOCITF~ 1
END

