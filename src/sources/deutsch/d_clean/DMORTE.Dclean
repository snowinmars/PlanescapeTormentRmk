END

IF ~~ THEN BEGIN 736 // from: 735.0
SAY #68174 /* ~Du wendest deine Macht wieder an...~ */
IF ~  GlobalGT("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68175 /* ~Belebe Annah wieder.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204a0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Dakkon","GLOBAL",0) ~ THEN REPLY #68179 /* ~Belebe Dak'kon wieder.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204d0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Grace","GLOBAL",0) ~ THEN REPLY #68180 /* ~Belebe Grace, die Gefallene, wieder.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204g0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Nordom","GLOBAL",0) ~ THEN REPLY #68181 /* ~Belebe Nordom wieder.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204n0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Ignus","GLOBAL",0) Global("Fortress_Ignus_Battle","GLOBAL",0) ~ THEN REPLY #68182 /* ~Belebe Ignus wieder.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204i0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Vhailor","GLOBAL",0) Global("Fortress_Vhailor_Battle","GLOBAL",0) ~ THEN REPLY #68183 /* ~Belebe Vhailor wieder.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204v0",FALSE) ~ EXIT
END 
IF WEIGHT #2 ~  Global("Fortress_Morte","GLOBAL",3) GlobalGT("Absorb","GLOBAL",0)
~ THEN BEGIN 737 // from:
SAY #68310 /* ~Als du deine Macht anwendest, schwebt Morte plötzlich in die Luft. "Äh... Warte, Meister. Du mußt mich nicht zum Leben erwecken. Ich habe hier nur so ein bißchen, äh, rumgelegen und habe eurem Gespräch gelauscht."~ */
IF ~~ THEN REPLY #68311 /* ~DU HAST DEINEN TOD VORGETÄUSCHT.~ */ GOTO 738
END

IF ~~ THEN BEGIN 738 // from: 737.0
SAY #68312 /* ~"Nun, ja, ich meine, ich *bin* doch schon tot und... äh, Meister, was ist mit deiner *Stimme* los?"~ */
IF ~~ THEN REPLY #68313 /* ~ICH... BIN NUN ETWAS ANDERES. DIE ZEIT WIRD KNAPP, UND BALD WERDEN MICH DIE ZEIT UND DAS SCHICKSAL EINHOLEN. ICH WERDE DICH ZURÜCK NACH SIGIL BRINGEN, MORTE, WENN DU DAS WÜNSCHST.~ */ GOTO 739
END

IF ~~ THEN BEGIN 739 // from: 738.0
SAY #68314 /* ~"Wa...? Mich zurückbringen? Und was ist mit *dir*? Komm schon, Meister, ich mag vielleicht ein *Feigling* sein, aber ich werde dich keinesfalls hier zurücklassen."~ */
IF ~~ THEN REPLY #68315 /* ~VIELE VERBRECHEN WURDEN BEGANGEN, ALS ICH UND MEINE STERBLICHKEIT GETRENNT WAREN. DIESE VERBRECHEN HABEN IHREN... PREIS. WO ICH BALD SEIN WERDE, KANNST DU NICHT HINGEHEN. ~ */ GOTO 740
END

IF ~~ THEN BEGIN 740 // from: 739.0
SAY #68316 /* ~"Nun, ich *könnte* trotzdem mit dir gehen, Meister, wenn du möchtest. Ich meine, wir haben schon Schlimmeres erl..."~ */
IF ~~ THEN REPLY #68317 /* ~NICHT DIESES MAL. VIELLEICHT TREFFEN WIR UNS EINES TAGES WIEDER, AUF EINER ANDEREN EBENE. ABER NICHT JETZT.~ */ GOTO 741
END

IF ~~ THEN BEGIN 741 // from: 740.0
SAY #68318 /* ~Morte starrt dich kurz an und seufzt. "Ohne jetzt sentimental zu werden... aber es war mir ein Vergnügen, Meister."~ [MRT109] */
IF ~  GlobalGT("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68319 /* ~LEB WOHL, MORTE.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204a0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Dakkon","GLOBAL",0) Global("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68320 /* ~LEB WOHL, MORTE.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204d0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Grace","GLOBAL",0) Global("Fortress_Dakkon","GLOBAL",0) Global("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68321 /* ~LEB WOHL, MORTE.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204g0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Nordom","GLOBAL",0) Global("Fortress_Grace","GLOBAL",0) Global("Fortress_Dakkon","GLOBAL",0) Global("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68322 /* ~LEB WOHL, MORTE.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204n0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Ignus","GLOBAL",0) Global("Fortress_Ignus_Battle","GLOBAL",0) Global("Fortress_Nordom","GLOBAL",0) Global("Fortress_Grace","GLOBAL",0) Global("Fortress_Dakkon","GLOBAL",0) Global("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68323 /* ~LEB WOHL, MORTE.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204i0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Vhailor","GLOBAL",0) Global("Fortress_Vhailor_Battle","GLOBAL",0) Global("Fortress_Ignus","GLOBAL",0) Global("Fortress_Nordom","GLOBAL",0) Global("Fortress_Grace","GLOBAL",0) Global("Fortress_Dakkon","GLOBAL",0) Global("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68324 /* ~LEB WOHL, MORTE.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204v0",FALSE) ~ EXIT
IF ~  Global("Fortress_Vhailor","GLOBAL",0) Global("Fortress_Ignus","GLOBAL",0) Global("Fortress_Nordom","GLOBAL",0) Global("Fortress_Grace","GLOBAL",0) Global("Fortress_Dakkon","GLOBAL",0) Global("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68325 /* ~LEB WOHL, MORTE.~ */ DO ~QuitGame(FINALE,0,0) ~ EXIT
