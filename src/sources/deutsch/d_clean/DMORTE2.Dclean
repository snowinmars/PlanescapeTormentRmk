IF ~~ THEN REPLY #41236 /* ~"In Ordnung... Ich... versuche, mir das zu merken."~ */ EXIT
END

IF ~~ THEN BEGIN 24 // from: 23.0
SAY #41237 /* ~"Meister, SIE sind tot, WIR sind tot... verstehst du, worauf ich hinaus will? Nun?"~ */
IF ~~ THEN REPLY #41238 /* ~"Nein... nein, eigentlich nicht."~ */ GOTO 25
IF ~  CheckStatGT(Protagonist,12,INT) ~ THEN REPLY #41239 /* ~"Du *kannst* das nicht ernst meinen."~ */ GOTO 25
IF ~~ THEN REPLY #41240 /* ~"Vergiß es. Ich hätte da noch ein paar andere Fragen an dich..."~ */ GOTO 12
IF ~~ THEN REPLY #41241 /* ~"Ich habe genug gehört. Gehen wir."~ */ EXIT
END

IF ~~ THEN BEGIN 25 // from: 24.0 24.1
SAY #41242 /* ~"Meister, wir haben bereits etwas mit diesen hinkenden Damen gemein. Wir sind *alle* mindestens einmal gestorben: da haben wir doch schon Gesprächsstoff. Sie schätzen Männer mit dieser Art von Erfahrung."~ */
IF ~~ THEN REPLY #41243 /* ~"Warte... Hast du vorhin nicht gesagt, daß ich *nicht* tot bin?"~ */ GOTO 26
IF ~~ THEN REPLY #41244 /* ~"Vergiß es. Ich hätte da noch ein paar andere Fragen an dich..."~ */ GOTO 12
IF ~~ THEN REPLY #41245 /* ~"Ich habe genug gehört. Gehen wir."~ */ EXIT
END

IF ~~ THEN BEGIN 26 // from: 25.0
SAY #41246 /* ~"Tja... okay, *du* bist vielleicht nicht tot, aber *ich* bin's. Und ich für meinen Teil hätte nichts dagegen, einen Sarg mit einem dieser sehnigen Kadaver hier zu teilen." Morte fängt an, in freudiger Erwartung mit den Zähnen zu klappern. "Natürlich müßten die Verwalter sich erst von ihnen trennen, und das ist ziemlich unwahrscheinlich..."~ */
IF ~~ THEN REPLY #41247 /* ~"Ich hätte da noch ein paar Fragen an dich, Morte..."~ */ GOTO 12
IF ~~ THEN REPLY #41248 /* ~"Ich habe genug gehört. Gehen wir."~ */ EXIT
END 
IF WEIGHT #3 /* Triggers after states #: 31 even though they appear after this state */ ~  !InParty("Morte")
~ THEN BEGIN 27 // from:
SAY #41250 /* ~"Ich wußte doch, daß du zurückkommst, Meister! Hast wohl endlich eingesehen, daß du mich brauchst, was?"~ */
IF ~~ THEN REPLY #41251 /* ~"Ja... Gehen wir."~ */ DO ~ChangeAIScript("pcmorte",DEFAULT) JoinPartyEx(TRUE) ~ EXIT
IF ~~ THEN REPLY #41252 /* ~"Nein, Morte, im Moment brauche ich dich nicht."~ */ GOTO 28
END

IF ~~ THEN BEGIN 28 // from: 27.1
SAY #41253 /* ~"Hmmm. Na, ich werde hier nicht ewig warten. Also werde ich dir noch eine LETZTE Chance geben. Bist du sicher, daß du meine weisen Ratschläge und meinen scharfen Verstand nicht brauchst?"~ */
IF ~~ THEN REPLY #41254 /* ~"Morte, du hast WEDER das eine noch das andere."~ */ GOTO 29
IF ~~ THEN REPLY #41255 /* ~"Na gut, ich hab's mir anders überlegt. Komm, laß uns gehen."~ */ DO ~ChangeAIScript("pcmorte",DEFAULT) JoinPartyEx(TRUE) ~ EXIT
IF ~~ THEN REPLY #41256 /* ~"Ja, Morte, im Moment brauche ich weder das eine noch das andere. Aber vielleicht später."~ */ GOTO 29
END

IF ~~ THEN BEGIN 29 // from: 28.0 28.2
SAY #41257 /* ~"Willst du mich beleidigen, Meister? Habe ich was Falsches gesagt? Liegt es daran, daß ich keine Arme habe? Nun sag's mir schon!"~ */
IF ~~ THEN REPLY #41258 /* ~"Na gut, ich hab's mir anders überlegt. Komm, laß uns gehen."~ */ DO ~ChangeAIScript("pcmorte",DEFAULT) JoinPartyEx(TRUE) ~ EXIT
IF ~~ THEN REPLY #41259 /* ~"Das hat überhaupt nichts damit zu tun. Ich brauche dich nur einfach im Moment nicht. Leb wohl, Morte."~ */ GOTO 30
END

IF ~~ THEN BEGIN 30 // from: 29.1
SAY #41260 /* ~"Also, ich werde hier nicht EWIG warten. Solltest du dir's doch noch anders überlegen, dann mußt du dich beeilen."~ */
IF ~~ THEN REPLY #41261 /* ~"Okay. Leb wohl, Morte."~ */ EXIT
END 
IF WEIGHT #2 ~  Global("Mortuary_Walkthrough","GLOBAL",3) InParty("Morte")
~ THEN BEGIN 31 // from:
SAY #41262 /* ~"Du Heiligster. Das ist ein HÖLLISCHES Buch."~ */
IF ~~ THEN REPLY #41263 /* ~"Was ist es?"~ */ DO ~SetGlobal("Morte_Mortuary_Walkthrough_2","GLOBAL",1) ~ GOTO 32
END

IF ~~ THEN BEGIN 32 // from: 31.0
SAY #41264 /* ~"Wenn ich raten müßte, würde ich sagen, das ist das Buch, in das sie die Namen jedes armen Schluckers ritzen, der das Pech hat, hier abgeladen zu werden."~ */
IF ~~ THEN REPLY #41265 /* ~"Könnte mein Name da drin sein?"~ */ GOTO 33
END

IF ~~ THEN BEGIN 33 // from: 32.0
SAY #41266 /* ~"Äh... tja... *könnte* sein. Um das herauszufinden, mußt du deine Knochenschüssel mit dem schwebenden Staubie da drüben rasseln lassen. Ich bin aber nicht sicher, ob das so ne gute Idee ist."~ */
IF ~~ THEN REPLY #41267 /* ~"Na ja, ich brauche Antworten. Ich werde mit ihm sprechen." ~ */ EXIT
END
