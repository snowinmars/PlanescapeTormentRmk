IF ~~ THEN REPLY #20065 /* ~"Ich hätte da ein paar Fragen..."~ */ GOTO 11
IF ~~ THEN REPLY #20066 /* ~"Ich war zufällig in der Gegend. Leb wohl."~ */ EXIT
