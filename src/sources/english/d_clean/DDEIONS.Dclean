END

IF ~~ THEN BEGIN 41 // from: 10.6
SAY #6108 /* ~Deionarra shakes her head sadly. "Once uttered, the curse may not be undone. Forgive me, my Love."~ */
IF ~~ THEN REPLY #6110 /* ~"Isn't there anyone who could remove it?"~ */ GOTO 42
IF ~~ THEN REPLY #6111 /* ~"I... see. I had something else I wanted to ask you..."~ */ GOTO 10
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #6112 /* ~"I think it's a little late to ask for forgiveness now. Farewell, Deionarra."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #6113 /* ~"Perhaps someone can help me. Farewell, Deionarra."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #6114 /* ~"I think it's a little late to ask for forgiveness now. Farewell, Deionarra."~ */ GOTO 0
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #6115 /* ~"Perhaps someone can help me. Farewell, Deionarra."~ */ GOTO 0
END

IF ~~ THEN BEGIN 42 // from: 41.0
SAY #6109 /* ~"If so, they are not known to me." Deionarra looks hopeful. "But there are others who are more powerful than I that might be able to remove it. Again I ask your forgiveness, my Love. I know not what I did."~ */
IF ~~ THEN REPLY #6116 /* ~"I had something else I wanted to ask you..."~ */ GOTO 10
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #6117 /* ~"I think it's a little late to ask for forgiveness now. Farewell, Deionarra."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #6118 /* ~"Perhaps someone can help me. Farewell, Deionarra."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #6119 /* ~"I think it's a little late to ask for forgiveness now. Farewell, Deionarra."~ */ GOTO 0
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #6120 /* ~"Perhaps someone can help me. Farewell, Deionarra."~ */ GOTO 0
END

IF ~~ THEN BEGIN 43 // from: 9.2 10.3 44.0
SAY #6121 /* ~"Leave...?" Deionarra's voice drops to a hiss, then rises again. "*Leave?!* You ask me, who am trapped here because of you, how to *leave* this place?!"~ */
