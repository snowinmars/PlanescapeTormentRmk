~ THEN BEGIN 49 // from:
SAY #63356 /* ~You see a strikingly beautiful ghostly form before you; she has long, flowing hair, and her gown seems stirred by some ethereal breeze. Her eyes rest on yours, and you feel a strange, disjointed sensation, as if you are looking at several pairs of eyes at once.~ */
IF ~~ THEN REPLY #63357 /* ~"Are you Deionarra...?"~ */ GOTO 51
END 
IF WEIGHT #4 ~  GlobalGT("Deionarra","GLOBAL",0) Global("Current_Area","GLOBAL",1203)
~ THEN BEGIN 50 // from:
SAY #63358 /* ~Before you is the ghostly form of Deionarra; her spectral gown seems stirred by some ethereal breeze. Her eyes rest on yours, and you feel a strange, disjointed sensation, as if you are looking at several pairs of eyes at once.~ */
IF ~~ THEN REPLY #63359 /* ~"Deionarra...?"~ */ GOTO 51
END

IF ~~ THEN BEGIN 51 // from: 49.0 50.0
SAY #63360 /* ~"My Love, at last I have *found* you... I searched for you after you were divided by the crystal - this Fortress spans hundreds of miles, and I feared you were lost to me." Her ghostly eyes take your measure, searching your bodies for new wounds. "Are you well?"~ */
IF ~~ THEN REPLY #63362 /* ~"I think so - the crystal divided me, but I am one again. Now I am trapped here, however."~ */ GOTO 52
END

IF ~~ THEN BEGIN 52 // from: 51.0
SAY #63363 /* ~"I suspect trapping you here was the crystal's true purpose. But it poses no barrier for one such as I." She closes her eyes. "Much do my eyes see, and the halls of this Fortress are well known to me."~ */
IF ~~ THEN GOTO 53
END

IF ~~ THEN BEGIN 53 // from: 52.0 58.0 59.0
SAY #63364 /* ~"If you are trapped here, my Love, I shall see to it you are set free. Where is it you wish to go?"~ */
IF ~~ THEN REPLY #63365 /* ~"I wish to find my adversary and defeat him."~ */ GOTO 54
IF ~~ THEN REPLY #63366 /* ~"I wish to go to where my mortality is - and recover it."~ */ GOTO 54
IF ~  GlobalGT("Fortress_Party","GLOBAL",1) !Global("Fortress_Ignus","GLOBAL",1) !Global("Fortress_Vhailor","GLOBAL",1) ~ THEN REPLY #63367 /* ~"I wish to rejoin my friends."~ */ GOTO 54
IF ~  GlobalGT("Fortress_Party","GLOBAL",1) !Global("Fortress_Ignus","GLOBAL",1) !Global("Fortress_Vhailor","GLOBAL",1) ~ THEN REPLY #63368 /* ~"I wish to rejoin my companions. There are things I will need from them."~ */ GOTO 54
IF ~  GlobalGT("Deionarra_Death_Truth","GLOBAL",0) ~ THEN REPLY #63369 /* ~"I wish to speak to you for a moment, and tell you how you died... and why."~ */ GOTO 55
END

IF ~~ THEN BEGIN 54 // from: 53.0 53.1 53.2 53.3
SAY #63370 /* ~"As you wish, My Love." She stretches out her hand. "Touch my hand, and the walls of this Fortress shall be walls no more."~ */
IF ~  Global("Deionarra_Forgives","GLOBAL",1) ~ THEN REPLY #63371 /* ~Touch her hand...~ */ DO ~StartCutSceneMode() StartCutSceneEx("1203cd11",FALSE) ~ EXIT
IF ~  Global("Deionarra_Forgives","GLOBAL",0) ~ THEN REPLY #64594 /* ~Touch her hand...~ */ DO ~StartCutSceneMode() StartCutSceneEx("1203cd21",FALSE) ~ EXIT
END

IF ~~ THEN BEGIN 55 // from: 53.4
SAY #63372 /* ~"What are you speaking of?"~ */
IF ~~ THEN REPLY #63373 /* ~Truth: "When I brought you to this Fortress, it was my intention that you die here. I needed someone to remain behind so that they would serve as a link to this place. I knew because you loved me so much, that your love would stave off death and allow you to become a spirit. And that is why you suffer now."~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Deionarra_2","GLOBALLaw",3) IncrementGlobalOnceEx("GLOBALGood_Deionarra_2","GLOBALGood",1) SetAnimState(Myself,ANIM_MIMESTAND) ~ GOTO 56
IF ~~ THEN REPLY #63374 /* ~Lie: "When you died here in the Fortress, it was because of the adversary that awaits us. He wished you to die so that we would be apart. I go to confront him soon, and I will have my revenge on him."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_5","GLOBALLaw",-3) IncrementGlobalOnceEx("GLOBALEvil_Deionarra_5","GLOBALGood",-1) ~ GOTO 58
END

IF ~~ THEN BEGIN 56 // from: 55.0
SAY #63375 /* ~Deionarra's face is a mask as you speak the words. ~ */
IF ~~ THEN REPLY #63376 /* ~Lie: "I am sorry, Deionarra."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_6","GLOBALLaw",-1) IncrementGlobalOnceEx("GLOBALEvil_Deionarra_6","GLOBALGood",-2) ~ GOTO 57
IF ~~ THEN REPLY #63377 /* ~Truth: "I am sorry, Deionarra."~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Deionarra_3","GLOBALLaw",1) IncrementGlobalOnceEx("GLOBALGood_Deionarra_3","GLOBALGood",1) ~ GOTO 57
IF ~~ THEN REPLY #63378 /* ~Truth: "It was necessary, Deionarra - I am sorry that you have suffered."~ */ GOTO 57
END

IF ~~ THEN BEGIN 57 // from: 56.0 56.1 56.2
SAY #63379 /* ~"Do you *love* me? If you say yes, my Love, then nothing that has happened matters."~ */
IF ~~ THEN REPLY #63380 /* ~Lie: "Of course I love you. Even death cannot kill the bond between us."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_7","GLOBALLaw",-1) IncrementGlobalOnceEx("GLOBALEvil_Deionarra_7","GLOBALGood",-1) ~ GOTO 58
IF ~~ THEN REPLY #63381 /* ~Truth: "Though I did not know you at first, I have come to love you. Your suffering has become mine, and I have found that I will do what I can to help you."~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Deionarra_4","GLOBALLaw",1) IncrementGlobalOnceEx("GLOBALGood_Deionarra_4","GLOBALGood",1) ~ GOTO 58
IF ~~ THEN REPLY #63382 /* ~Truth: "I am sorry, Deionarra. I do not. I never knew you. Perhaps if I had met you under different circumstances..."~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Deionarra_5","GLOBALLaw",2) ~ GOTO 59
END

IF ~~ THEN BEGIN 58 // from: 55.1 57.0 57.1
SAY #63383 /* ~"Then I will aid you, my Love. Tell me how I can help you, and I shall do it."~ */
IF ~~ THEN REPLY #63384 /* ~"I am trapped here. Can you help me escape?"~ */ DO ~SetGlobal("Deionarra_Forgives","GLOBAL",1) ~ GOTO 53
END

IF ~~ THEN BEGIN 59 // from: 57.2
SAY #63385 /* ~"Then... this shall be the ending of things between us, my Love. I have remained here for you - for no other reason. I will help you one last time, then I shall travel beyond the Eternal Boundary, as I was meant." ~ */
IF ~~ THEN REPLY #63386 /* ~"Then I will ask this last thing and leave you in peace: I am trapped here. Can you help me?"~ */ GOTO 53
END 
