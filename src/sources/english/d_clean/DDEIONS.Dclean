IF ~~ THEN REPLY #6138 /* ~"I apologize for my request. I did not mean to offend. Please, I had some other questions..."~ */ GOTO 10
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #6139 /* ~"Deionarra, I am in danger. Can you guide me to a place of safety? I shall return as soon as I can to speak to you again."~ */ GOTO 46
