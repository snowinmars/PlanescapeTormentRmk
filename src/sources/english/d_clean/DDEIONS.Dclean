SAY #817 /* ~"Portals are holes in existence, leading to destinations in the inner and outer planes... if you could find the proper key, you could escape through one of them."~ */
IF ~~ THEN REPLY #819 /* ~"Key?"~ */ GOTO 32
IF ~~ THEN REPLY #818 /* ~"I had some other questions..."~ */ GOTO 10
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #820 /* ~"Farewell, Deionarra."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #1325 /* ~"Farewell, Deionarra."~ */ GOTO 0
END

IF ~~ THEN BEGIN 32 // from: 31.0
SAY #821 /* ~Deionarra pauses for a moment, as if attempting to remember. "Portals will reveal themselves when you have the proper 'key.' Unfortunately, these keys can be almost anything... an emotion, a piece of wood, a dagger of silvered glass, a scrap of cloth, a tune you hum to yourself... I fear that the Dustmen are the only ones who would know the keys you could use to leave their halls, my Love."~ */
IF ~~ THEN REPLY #824 /* ~"I see. I had some other questions..."~ */ GOTO 10
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #823 /* ~"Then I shall ask one of them. Farewell, Deionarra."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #1326 /* ~"Then I shall ask one of them. Farewell, Deionarra."~ */ GOTO 0
END

IF ~~ THEN BEGIN 33 // from: 4.0
SAY #6083 /* ~"I have no answers for you! Your unfaithful heart has guided you this far, let it guide you the rest of the way! Now begone!"~ */
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #6129 /* ~Lie: "This is not the Deionarra I remember. The Deionarra I loved was kind, gentle... and never abandoned a soul in need. Have you truly fallen so far?"~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_4","GLOBALLaw",-1) ~ GOTO 35
IF ~~ THEN REPLY #6130 /* ~"I need your help, Deionarra. Will you spurn me when I need you the most?"~ */ GOTO 37
IF ~  CheckStatGT(Protagonist,11,INT) CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #6131 /* ~Bluff: "Very well. I shall respect your wishes, Deionarra... I will leave and never return."~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_4","GLOBALLaw",-1) ~ GOTO 34
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #6132 /* ~Bluff: "Very well. I shall respect your wishes, Deionarra... I will leave and never return."~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_4","GLOBALLaw",-1) ~ GOTO 34
IF ~~ THEN REPLY #6133 /* ~"I am sorry that I have hurt you, Deionarra. I will leave and torment you no more."~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) ~ GOTO 34
IF ~~ THEN REPLY #6134 /* ~Leave quietly.~ */ GOTO 48
END

IF ~~ THEN BEGIN 34 // from: 33.2 33.3 33.4
SAY #6086 /* ~The furious expression on Deionarra's face melts like water... the speed of the change is as frightening as the desperate expression now on her face. "No! Wait, my Love." Her voice is pleading. "Please forgive me, I beg of you! Do not leave!" ~ */
IF ~~ THEN REPLY #6095 /* ~"Deionarra, my patience for your outbursts wears thin. If we are to continue speaking, you *will* control yourself, or we shall never speak again. You will be alone. Am I making myself plain?"~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Deionarra_4","GLOBALGood",-1) ~ GOTO 36
IF ~~ THEN REPLY #6096 /* ~"I forgive you. Now, I need your help, Deionarra."~ */ GOTO 10
END

IF ~~ THEN BEGIN 35 // from: 33.0
SAY #6087 /* ~The furious expression on Deionarra's face melts like water... the speed of the change is as frightening as the desperate expression now on her face. "No... no, no... I am still the Deionarra you remember, my Love. Please forgive me, I beg of you." ~ */
IF ~~ THEN REPLY #6097 /* ~"Deionarra, my patience for your outbursts wears thin. If we are to continue speaking, you *will* control yourself, or we shall never speak again. You will be alone. Am I making myself plain?"~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Deionarra_4","GLOBALGood",-1) ~ GOTO 36
IF ~~ THEN REPLY #6098 /* ~"I forgive you. Now, I need your help, Deionarra."~ */ GOTO 10
