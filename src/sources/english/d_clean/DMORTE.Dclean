IF ~~ THEN REPLY #68315 /* ~MANY ARE THE CRIMES THAT WERE COMMITTED WHEN MY MORTALITY AND I WERE SPLIT. THESE CRIMES CARRY A... PRICE. YOU MAY NOT GO WHERE I WILL SOON BE. ~ */ GOTO 740
END

