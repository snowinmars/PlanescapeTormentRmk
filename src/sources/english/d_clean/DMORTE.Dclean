IF ~~ THEN REPLY #41841 /* ~"What is this place again?"~ */ GOTO 450
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41842 /* ~"This place is huge... who takes care of it?"~ */ GOTO 451
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41843 /* ~"Who are the caretakers of this place again?"~ */ GOTO 451
IF ~~ THEN REPLY #41844 /* ~"The corpses here... where did they all come from?"~ */ GOTO 454
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41845 /* ~"Before you said something about making sure I didn't kill any *female* corpses. Why?"~ */ GOTO 455
IF ~  PartyHasItem("Bandage") ~ THEN REPLY #41846 /* ~"How do I use these bandages?"~ */ GOTO 453
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",0) ~ THEN REPLY #41847 /* ~"Nothing at the moment, Morte. Just checking to see if you were still with me."~ */ GOTO 440
IF ~  Global("Morte_Mortuary_Walkthrough_1","GLOBAL",1) ~ THEN REPLY #41848 /* ~"Nothing at the moment, Morte. Just checking to see if you were still with me."~ */ EXIT
END

