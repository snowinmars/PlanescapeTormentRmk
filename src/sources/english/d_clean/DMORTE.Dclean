IF ~~ THEN REPLY #4695 /* ~Truth: "That seems like a noble pursuit. Order could use a good tearing down every once in a while."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Vaxis_3","GLOBALLaw",-3) ~ EXTERN ~DVAXIS~ 71
