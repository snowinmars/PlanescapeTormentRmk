IF ~~ THEN REPLY #4679 /* ~Lie: "That seems like a noble pursuit. Any Anarchist dedicated to such a lofty goal is *definitely* a friend of mine."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Vaxis_4","GLOBALLaw",-1) ~ EXTERN ~DVAXIS~ 11
