IF ~  Global("Gate_Open","GLOBAL",1) ~ THEN REPLY #4834 /* ~"Never mind. I must take my leave. Farewell."~ */ EXIT
IF ~  Global("Gate_Open","GLOBAL",0) ~ THEN REPLY #4835 /* ~"Never mind. I must take my leave. Farewell."~ */ GOTO 17
