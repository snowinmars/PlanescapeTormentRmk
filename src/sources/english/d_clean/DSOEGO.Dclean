SAY #1534 /* ~*Something* must have alerted the Dustman... before you can even lunge for him, he leaps back, his eyes gleaming red and his teeth bared. With a hiss, he claps his hands together sharply three times. In response, a great iron bell starts tolling throughout the Mortuary.~ */
IF ~~ THEN REPLY #1535 /* ~"All right then..."~ */ DO ~PlaySoundNotRanged("AMB_M01") Enemy() ForceAttack(Protagonist,Myself) SetGlobal("Mortuary_Alert","GLOBAL",1) Attack(Protagonist) ~ EXIT
END

IF ~~ THEN BEGIN 23 // from: 14.0
SAY #4792 /* ~"There are some that have signed a contract allowing the Dustmen to use their bodies once they have died. It is possible that you were caught in an... unusual mix-up. You seem much brighter than our regular zombies."~ */
IF ~~ THEN REPLY #4793 /* ~"People sell their bodies after death to you?"~ */ GOTO 24
IF ~~ THEN REPLY #4794 /* ~"Oh. I had some other questions..."~ */ GOTO 26
IF ~~ THEN REPLY #4795 /* ~"I don't have time for this. Farewell."~ */ GOTO 17
END

IF ~~ THEN BEGIN 24 // from: 23.0
SAY #4796 /* ~"Oh, yes. In exchange for a small sum of copper, many are willing to sell a body they will no longer need when they reach the True Death."~ */
IF ~~ THEN REPLY #4797 /* ~"What do you do with these bodies?"~ */ GOTO 25
IF ~~ THEN REPLY #4798 /* ~"I... see. Do you mind if I ask you some other questions?"~ */ GOTO 25
IF ~~ THEN REPLY #4799 /* ~"Thanks for the information. Farewell."~ */ GOTO 17
END

IF ~~ THEN BEGIN 25 // from: 24.0 24.1
SAY #4800 /* ~"The shells perform menial tasks around the Mortuary. They haul bodies, clean floors, assist us in preparing bodies for burial... relatively simple tasks. It is unfortunate, but they are not capable of following any complicated instructions."~ */
IF ~~ THEN REPLY #4801 /* ~"Well, 'Contracted' or not, how did I get here if I wasn't dead?"~ */ GOTO 54
IF ~~ THEN REPLY #4802 /* ~"I... see. Do you mind if I ask you some other questions?"~ */ GOTO 26
IF ~~ THEN REPLY #4803 /* ~"Thanks for the information. Farewell."~ */ GOTO 17
END

IF ~~ THEN BEGIN 26 // from: 12.0 23.1 25.1 27.2 28.0 29.1 31.1 32.0 33.2 34.2 35.1 36.1 37.0 58.0
SAY #4804 /* ~Soego nods. "You may ask your questions."~ */
IF ~  CheckStatGT(Protagonist,10,CHR) Global("Gate_Open","GLOBAL",0) ~ THEN REPLY #4805 /* ~"I'd like to leave. Can you guide me to the exit?"~ */ GOTO 8
IF ~  CheckStatLT(Protagonist,11,CHR) Global("Gate_Open","GLOBAL",0) ~ THEN REPLY #4806 /* ~"Can you get me out of here?"~ */ GOTO 13
IF ~  Global("Vaxis","GLOBAL",1) !Dead("Vaxis") Global("Vaxis_Leave","GLOBAL",0) Global("Betray_Vaxis","GLOBAL",0) ~ THEN REPLY #4807 /* ~"Do you know there's a corpse up on the second level that's a human in disguise?"~ */ GOTO 27
IF ~~ THEN REPLY #4809 /* ~"If I may ask... are you all right? You look tired."~ */ DO ~IncrementGlobalOnceEx("GLOBALGood_Soego_1","GLOBALGood",1) ~ GOTO 31
IF ~  CheckStatLT(Protagonist,13,WIS) Global("Vaxis_Exposes_Soego","GLOBAL",1) ~ THEN REPLY #4810 /* ~"You're Soego, right? I heard you're a little odd for a Dustman. That you like rats."~ */ DO ~SetGlobal("Soego_exposed","GLOBAL",1) ~ GOTO 30
IF ~  CheckStatGT(Protagonist,12,WIS) Global("Vaxis_Exposes_Soego","GLOBAL",1) ~ THEN REPLY #4811 /* ~"You're Soego, right? I heard you're a little odd for a Dustman. That you like rats."~ */ GOTO 29
