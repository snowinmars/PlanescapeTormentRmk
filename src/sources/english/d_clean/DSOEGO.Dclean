IF ~  Global("Soego","GLOBAL",0) ~ THEN REPLY #22051 /* ~"Are you Soego? Emoric wanted to know where you were."~ */ DO ~SetGlobal("Met_Soego2","GLOBAL",1) SetGlobal("Soego","GLOBAL",3) SetGlobal("Soego_Talk","AR1500",2) EndCutSceneMode() JOURNAL #22052 /* ~I found Soego. He has discovered a group of undead guardians who were protecting the catacombs. He is trying to convince them to join the True Death.~ */ GOTO 109
IF ~  GlobalGT("Soego","GLOBAL",0) ~ THEN REPLY #66173 /* ~"Soego... Emoric wanted to know where you were."~ */ DO ~SetGlobal("Met_Soego2","GLOBAL",1) SetGlobal("Soego","GLOBAL",3) SetGlobal("Soego_Talk","AR1500",2) EndCutSceneMode() ~ GOTO 109
END

IF ~~ THEN BEGIN 109 // from: 82.2 108.0 108.1
SAY #22053 /* ~"Yes, I am he. I am doing missionary work for the Dustmen, here."~ */
IF ~  Global("Soego_Strangle","GLOBAL",1) Global("Mortuary_Soego_Killed","GLOBAL",0) ~ THEN REPLY #64617 /* ~"All right. But... I thought I'd broken your neck..."~ */ GOTO 73
IF ~  Global("Mortuary_Soego_Killed","GLOBAL",1) ~ THEN REPLY #64618 /* ~"Good. But... I thought I'd *killed* you..."~ */ GOTO 73
IF ~~ THEN REPLY #22054 /* ~"Are there other Dustmen here?"~ */ GOTO 66
IF ~~ THEN REPLY #50792 /* ~"Where am I?"~ */ GOTO 77
IF ~~ THEN REPLY #50793 /* ~"Why have I been made a prisoner here?"~ */ GOTO 78
IF ~~ THEN REPLY #22056 /* ~"I'll take my leave, now. Farewell."~ */ GOTO 71
END

IF ~~ THEN BEGIN 110 // from: 79.0 79.1
SAY #22057 /* ~"Yes, I am he."~ */
IF ~  Global("Soego_Strangle","GLOBAL",1) Global("Mortuary_Soego_Killed","GLOBAL",0) ~ THEN REPLY #64625 /* ~"Wait a moment... didn't I break your neck in the Mortuary?"~ */ GOTO 112
IF ~  Global("Mortuary_Soego_Killed","GLOBAL",1) ~ THEN REPLY #64626 /* ~"Wait a moment... I thought I'd *killed* you at the Mortuary..."~ */ GOTO 112
IF ~  Global("Soego_Strangle","GLOBAL",0) Global("Mortuary_Soego_Killed","GLOBAL",0) ~ THEN REPLY #22058 /* ~"Good. Now, how do I get to the Silent King?"~ */ JOURNAL #21857 /* ~Soego told me that he does not know how to enter the Silent King's throne room, which I will have to do if I am to kill the Silent King.~ */ GOTO 80
IF ~  Global("Soego_Strangle","GLOBAL",0) Global("Mortuary_Soego_Killed","GLOBAL",0) ~ THEN REPLY #22060 /* ~"Good. Farewell."~ */ GOTO 71
END

IF ~~ THEN BEGIN 111 // from: 94.0
SAY #25249 /* ~"Yes, the hive mind of the cranium rats. Go to the catacombs east of Weeping Stone. You shall find the way, there."~ */
IF ~~ THEN REPLY #25250 /* ~"Interesting. I had some questions..."~ */ GOTO 83
IF ~~ THEN REPLY #25251 /* ~"Perhaps. Farewell."~ */ EXIT
END

IF ~~ THEN BEGIN 112 // from: 79.2 79.3 110.0 110.1
SAY #64620 /* ~He waves your words away. "Nothing; it was nothing to me. I had already been blessed with lycanthropy; the wounds healed in little time at all."~ */
IF ~~ THEN REPLY #64621 /* ~"I... see. So, how do I get to the Silent King?"~ */ GOTO 80
IF ~~ THEN REPLY #64622 /* ~"All right... farewell, then."~ */ GOTO 71
END

IF ~~ THEN BEGIN 113 // from: 38.1
SAY #66709 /* ~"Greetings..." The man turns to face you and makes a slight bow. You suddenly notice that his eyes aren't bloodshot so much as they have a red tinge to them. "I am Soego. How may I help you?"~ */
IF ~~ THEN REPLY #66712 /* ~"I would like to leave the Mortuary. Can you help me?"~ */ GOTO 114
IF ~~ THEN REPLY #66713 /* ~"I had some questions..."~ */ GOTO 114
IF ~~ THEN REPLY #66714 /* ~"I was merely passing by. Farewell."~ */ EXIT
END

IF ~~ THEN BEGIN 114 // from: 113.0 113.1
SAY #66710 /* ~Halfway through your comment, Soego's lips suddenly peel back, revealing a row of dirty, sharp teeth, and he leans in, sniffing you. ~ */
IF ~~ THEN REPLY #66715 /* ~"Uh... why in the hells are you sniffing me?"~ */ GOTO 115
IF ~  CheckStatLT(Protagonist,13,DEX) ~ THEN REPLY #66716 /* ~Snap his neck when he leans in.~ */ GOTO 22
IF ~  CheckStatGT(Protagonist,12,DEX) ~ THEN REPLY #66717 /* ~Snap his neck when he leans in.~ */ GOTO 19
IF ~~ THEN REPLY #66718 /* ~"Never mind... farewell."~ */ GOTO 17
END

IF ~~ THEN BEGIN 115 // from: 114.0
SAY #66711 /* ~"Your clothes... those robes. They smell of another. They are not yours." Soego's lips seal into a strange smile, and his eyes gleam with an almost feral light. "Who *are* you?"~ */
IF ~~ THEN REPLY #66719 /* ~"I... only took these robes so I could leave in peace. I woke up on one of the preparation rooms upstairs."~ */ GOTO 42
IF ~~ THEN REPLY #66720 /* ~"You're correct. These robes aren't mine, but who they belong to is not your concern."~ */ GOTO 6
IF ~  CheckStatLT(Protagonist,13,DEX) ~ THEN REPLY #66721 /* ~Snap his neck before he can call for help.~ */ GOTO 22
IF ~  CheckStatGT(Protagonist,12,DEX) ~ THEN REPLY #66722 /* ~Snap his neck before he can call for help.~ */ GOTO 19
IF ~~ THEN REPLY #66723 /* ~"This is of no matter. I will take my leave now."~ */ GOTO 17
END
