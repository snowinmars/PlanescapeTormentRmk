END

IF ~~ THEN BEGIN 11 // from: 10.1
SAY #1489 /* ~Once he reaches the gate, Soego turns the key in the lock. A moment later, a grating sound comes from within the lock chamber... the sound carries throughout the main hall, echoing off the marble floors. ~ */
IF ~~ THEN REPLY #1490 /* ~Wait for him to return.~ */ DO ~SetDoorLocked("fakedoor",FALSE) ~ GOTO 12
END 
