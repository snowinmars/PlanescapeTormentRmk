IF ~~ THEN REPLY #1465 /* ~"I am trying to get out of here."~ */ GOTO 13
IF ~~ THEN REPLY #1466 /* ~"I needed a change."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Soego_2","GLOBALLaw",-1) ~ GOTO 16
IF ~~ THEN REPLY #1467 /* ~"I really don't have time for this. Farewell."~ */ GOTO 17
END

IF ~~ THEN BEGIN 6 // from: 2.0 5.0 15.0 41.1 43.0 50.1 115.1
SAY #1468 /* ~"Oh, but I'm afraid it *is* my concern." Soego's eyes gleam red, and the corners of his mouth twitch slightly, as if in anticipation. "Mayhap..." He sneers, displaying a row of sharp, dirty teeth. "Mayhap I should call the guards? Yes... yes, I think I will do that."~ */
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #1469 /* ~"Hold a moment! I was lost... I just got turned around in the halls here, and I can't seem to find the exit. Can you help me?"~ */ GOTO 8
IF ~  CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #1470 /* ~"Stop! Don't call the guards! I just want to get out of here... can you help me?"~ */ GOTO 13
IF ~  CheckStatGT(Protagonist,12,DEX) ~ THEN REPLY #1471 /* ~Snap his neck before he can call out.~ */ GOTO 19
IF ~  CheckStatLT(Protagonist,13,DEX) ~ THEN REPLY #1472 /* ~Snap his neck before he can call out.~ */ GOTO 22
IF ~~ THEN REPLY #1473 /* ~"Summon them, then. I'd like to meet them."~ */ GOTO 18
END

IF ~~ THEN BEGIN 7 // from: 2.1 5.1 13.3 15.1 42.1 57.0
SAY #1474 /* ~"Really?" The Dustman scrutinizes you. "You *do* look like you've been prepared. I don't know how you would have survived such pain... are you *in* pain? You look it."~ */
IF ~~ THEN REPLY #1475 /* ~"How would I have gotten here in the first place?"~ */ GOTO 54
IF ~~ THEN REPLY #1476 /* ~"I don't have time for this. Farewell."~ */ GOTO 17
END

IF ~~ THEN BEGIN 8 // from: 2.2 5.2 6.0 13.0 15.2 16.0 17.0 26.0 40.0 41.0 50.0 61.0 62.0
SAY #1477 /* ~Soego nods, and the corner of his mouth twitches. "Why... of course. These halls *can* be confusing to visitors. No harm done, but you are not permitted here in the Mortuary after nine bells - let me open the front gate for you."~ */
IF ~  HasItem("KeyMo",Myself) ~ THEN REPLY #1478 /* ~"Thank you."~ */ DO ~AddexperienceParty(500) SetGlobal("Gate_Open","GLOBAL",1) SetGlobal("Gate_Cut_Scene","AR0201",1) StartCutSceneMode() StartCutSceneEx("0201cut1",FALSE) ~ EXIT
IF ~  !HasItem("KeyMo",Myself) ~ THEN REPLY #1479 /* ~"Thank you."~ */ GOTO 9
END

IF ~~ THEN BEGIN 9 // from: 8.1 56.1 60.1
SAY #1480 /* ~Soego reaches to his belt, fumbles at it for a moment, then hisses. "The key!" His eyes gleam a bright red, and his lips peel back in anger... his expression is almost animalistic. "Someone's stolen the key!" He turns to you and snarls. "You! You must have done this!" ~ */
IF ~~ THEN REPLY #1481 /* ~Bluff him: "Uh...wait! Why would I ask you for it if I'd stolen it?"~ */ GOTO 18
IF ~~ THEN REPLY #1482 /* ~Lie: "What are you talking about?! I had nothing to do with it!"~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Soego_3","GLOBALLaw",-1) IncrementGlobalOnceEx("GLOBALEvil_Soego_1","GLOBALGood",-1) ~ GOTO 18
IF ~  CheckStatGT(Protagonist,12,DEX) ~ THEN REPLY #1483 /* ~Snap his neck before he can call out.~ */ GOTO 19
IF ~  CheckStatLT(Protagonist,13,DEX) ~ THEN REPLY #1484 /* ~Snap his neck before he can call out.~ */ GOTO 22
IF ~~ THEN REPLY #1485 /* ~"So what if I did? What are you going to do about it?"~ */ GOTO 18
END

IF ~~ THEN BEGIN 10 // from:
SAY #1486 /* ~Soego takes a large key from his belt and walks to the front gate. You can't help but notice his peculiar walk... he hunches forward, as if to keep balance. ~ */
IF ~  NearbyDialog("DMorte") ~ THEN REPLY #1487 /* ~"Odd walk he's got."~ */ EXTERN ~DMORTE~ 101
