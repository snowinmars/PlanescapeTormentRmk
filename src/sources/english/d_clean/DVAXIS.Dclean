IF ~~ THEN REPLY #4504 /* ~"This Dustman woman sounds really attractive. Are you sure you don't want me to introduce the two of you?"~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Vaxis_6","GLOBALLaw",-1) ~ GOTO 37
