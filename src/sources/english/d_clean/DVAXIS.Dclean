IF ~  CheckStatLT(Protagonist,12,STR) ~ THEN REPLY #4484 /* ~"You look like someone who'd much rather be breathing than saying no to me. Now... for the last time: How do I get out of this place?"~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Vaxis_1","GLOBALGood",-1) ~ GOTO 75
