IF ~  Global("Escape_Mortuary","GLOBAL",0) ~ THEN REPLY #4452 /* ~"I'm looking for a way out of here. Can you help me?"~ */ GOTO 31
IF ~~ THEN REPLY #4453 /* ~"I wanted some information..."~ */ GOTO 43
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #4454 /* ~"Tell me what you're doing here, or I'll call the guards."~ */ GOTO 21
IF ~  CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #4455 /* ~"Tell me what you're doing here, or I'll call the guards."~ */ GOTO 17
IF ~  CheckStatLT(Protagonist,12,STR) ~ THEN REPLY #4456 /* ~"I'm asking the questions here, *zombie.* Tell me who you are, or I'll make that disguise a reality."~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Vaxis_1","GLOBALGood",-1) ~ GOTO 19
IF ~  CheckStatGT(Protagonist,11,STR) ~ THEN REPLY #4457 /* ~"I'm asking the questions here, *zombie.* Tell me who you are, or I'll make that disguise a reality."~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Vaxis_1","GLOBALGood",-1) ~ GOTO 22
IF ~~ THEN REPLY #4458 /* ~"Sorry to trouble you... whoever you are. Farewell."~ */ GOTO 4
END

IF ~~ THEN BEGIN 28 // from: 8.3 8.4 11.1 11.2 11.3 26.0 30.0 43.5
SAY #4459 /* ~"Me spy on Duhstees. Say wut I see. Nuthin' more."~ */
