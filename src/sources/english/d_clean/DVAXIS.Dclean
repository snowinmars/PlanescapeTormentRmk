~ THEN BEGIN 57 // from:
SAY #4585 /* ~You see the false zombie. You're amazed at the man's disguise... his breathing is so subdued, you can barely see it.~ */
IF ~  Global("Embalm_Key_Quest","GLOBAL",1) ~ THEN REPLY #4586 /* ~"Greetings."~ */ GOTO 58
IF ~  Global("Embalm_Key_Quest","GLOBAL",2) ~ THEN REPLY #4587 /* ~"Greetings."~ */ GOTO 58
IF ~  !Global("Embalm_Key_Quest","GLOBAL",1) !Global("Embalm_Key_Quest","GLOBAL",2) Global("Vaxis_Orders","GLOBAL",0) ~ THEN REPLY #4588 /* ~"Greetings."~ */ GOTO 59
IF ~  !Global("Embalm_Key_Quest","GLOBAL",1) !Global("Embalm_Key_Quest","GLOBAL",2) Global("Vaxis_Orders","GLOBAL",1) ~ THEN REPLY #4589 /* ~"Greetings."~ */ GOTO 58
IF ~~ THEN REPLY #4590 /* ~Leave him alone.~ */ EXIT
END

IF ~~ THEN BEGIN 58 // from: 57.0 57.1 57.3
SAY #4591 /* ~The zombie quickly glances around to see if anyone is watching, then turns to face you. "Wut?"~ */
IF ~  Global("Embalm_Key_Quest","GLOBAL",1) PartyHasItem("KeyEm") ~ THEN REPLY #4592 /* ~"Here's that embalming room key you wanted."~ */ DO ~AddexperienceParty(250) TakePartyItemNum("KeyEm",1) ~ GOTO 42
IF ~  Global("Embalm_Key_Quest","GLOBAL",2) PartyHasItem("KeyEm") ~ THEN REPLY #4593 /* ~"Here's that embalming room key you wanted."~ */ DO ~AddexperienceParty(250) TakePartyItemNum("KeyEm",1) ~ GOTO 42
IF ~  Global("Embalm_Key_Quest","GLOBAL",1) !PartyHasItem("KeyEm") ~ THEN REPLY #4594 /* ~"Where is that key you mentioned again?"~ */ GOTO 36
IF ~~ THEN REPLY #4595 /* ~"I had some questions for you..."~ */ GOTO 43
IF ~~ THEN REPLY #4596 /* ~"Never mind."~ */ EXIT
END

IF ~~ THEN BEGIN 59 // from: 57.2
SAY #4597 /* ~The zombie glances around to see if anyone is watching, then makes a shooing motion and hisses at you. "Guh 'way! Git!"~ */
IF ~~ THEN REPLY #4598 /* ~"No. I had some questions for you, first..."~ */ GOTO 43
IF ~  Global("Embalm_Key_Quest","GLOBAL",0) ~ THEN REPLY #4599 /* ~"Never mind then."~ */ GOTO 4
IF ~  GlobalGT("Embalm_Key_Quest","GLOBAL",0) ~ THEN REPLY #4600 /* ~"Never mind then."~ */ EXIT
END

IF ~~ THEN BEGIN 60 // from: 43.11
SAY #4601 /* ~"Me gud at duh-guise. Me ulso gut scars. Me wuhr lots of embalming fluid. Me make GUD zumbie." The zombie giggles through stitched lips, then taps his head. "Duhstees stuh-pud."~ */
IF ~~ THEN REPLY #4602 /* ~"Yeah, they're the stupid ones all right."~ */ GOTO 61
IF ~~ THEN REPLY #4603 /* ~"Doesn't that hurt?"~ */ GOTO 62
IF ~  CheckStatGT(Protagonist,12,INT) !Global("Appearance","GLOBAL",1) ~ THEN REPLY #4604 /* ~"That disguise is pretty good. Say... can you disguise me as a zombie, too?"~ */ GOTO 63
IF ~~ THEN REPLY #4605 /* ~"There was something else I wanted to know..."~ */ GOTO 43
IF ~~ THEN REPLY #4606 /* ~"I have to leave. Farewell."~ */ EXIT
END

IF ~~ THEN BEGIN 61 // from: 60.0
SAY #4607 /* ~The sarcasm is evidently lost on the zombie, who nods eagerly. "Stuh-pud Duhstees. Me make GUD zumbie." ~ */
IF ~~ THEN REPLY #4608 /* ~"Doesn't that hurt?"~ */ GOTO 62
IF ~  CheckStatGT(Protagonist,12,INT) !Global("Appearance","GLOBAL",1) ~ THEN REPLY #4609 /* ~"That disguise is pretty good. Can you disguise me as a zombie?"~ */ GOTO 63
IF ~  CheckStatLT(Protagonist,10,CHR) ~ THEN REPLY #4610 /* ~"There was something else I wanted to know..."~ */ GOTO 64
IF ~  CheckStatLT(Protagonist,10,CHR) ~ THEN REPLY #4611 /* ~"I have to leave. Farewell."~ */ GOTO 64
IF ~  CheckStatGT(Protagonist,9,CHR) ~ THEN REPLY #4612 /* ~"There was something else I wanted to know..."~ */ GOTO 43
IF ~  CheckStatGT(Protagonist,9,CHR) ~ THEN REPLY #4613 /* ~"I have to leave. Farewell."~ */ EXIT
END

IF ~~ THEN BEGIN 62 // from: 60.1 61.0
SAY #4614 /* ~He looks at your scars. "I ask yu same question. Me, it not hurt much." Claps his chest. "Me TUFF."~ */
IF ~  CheckStatGT(Protagonist,12,INT) !Global("Appearance","GLOBAL",1) ~ THEN REPLY #4615 /* ~"That disguise is pretty good. Can you disguise me as a zombie?"~ */ GOTO 63
IF ~  CheckStatLT(Protagonist,13,CHR) ~ THEN REPLY #4616 /* ~"There was something else I wanted to know..."~ */ GOTO 64
IF ~  CheckStatLT(Protagonist,13,CHR) ~ THEN REPLY #4617 /* ~"I have to leave. Farewell."~ */ GOTO 64
IF ~  CheckStatGT(Protagonist,12,CHR) ~ THEN REPLY #4618 /* ~"There was something else I wanted to know..."~ */ GOTO 43
IF ~  CheckStatGT(Protagonist,12,CHR) ~ THEN REPLY #4674 /* ~"I have to leave. Farewell."~ */ EXIT
END

IF ~~ THEN BEGIN 63 // from: 43.3 43.4 60.2 61.1 62.0 64.1 64.2
SAY #4619 /* ~He looks you up and down for a few moments, mumbling to himself, then nods. "U-huh. Me need jar uf embalming flew-id." Points at the scars on your chest. "N' some needle and thread." ~ */
IF ~  PartyHasItem("Embalm") PartyHasItem("Needle") ~ THEN REPLY #4620 /* ~"Here you go."~ */ DO ~SetGlobal("Vaxis_Zombie_Disguise","GLOBAL",2) DestroyPartyItem("Embalm",FALSE) DestroyPartyItem("Needle",FALSE) ~ GOTO 65
IF ~~ THEN REPLY #4621 /* ~"I'll think about it. I had some other questions..."~ */ DO ~SetGlobal("Vaxis_Zombie_Disguise","GLOBAL",1) ~ GOTO 43
IF ~~ THEN REPLY #4622 /* ~"No thanks. Maybe some other time... farewell."~ */ DO ~SetGlobal("Vaxis_Zombie_Disguise","GLOBAL",1) ~ EXIT
IF ~~ THEN REPLY #4623 /* ~"Some embalming fluid and some thread? I'll go see if I can find some."~ */ DO ~SetGlobal("Vaxis_Zombie_Disguise","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 64 // from: 61.2 61.3 62.1 62.2
SAY #4624 /* ~He looks you up and down with a strange expression. "U be GUD zumbie. I cud make u a zumbie? GUD dis-gize."~ */
IF ~~ THEN REPLY #4625 /* ~"Thanks anyway. I had some other questions for you..."~ */ DO ~SetGlobal("Vaxis_Zombie_Disguise","GLOBAL",1) ~ GOTO 43
IF ~~ THEN REPLY #4626 /* ~"Sure. Can you do it?"~ */ GOTO 63
IF ~~ THEN REPLY #4627 /* ~"Why not? I already feel like one of the walking dead."~ */ GOTO 63
IF ~~ THEN REPLY #4628 /* ~"No... no... that's all right. Farewell."~ */ DO ~SetGlobal("Vaxis_Zombie_Disguise","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 65 // from: 63.0
SAY #4629 /* ~The zombie takes the items from you, then sets to work...~ */
IF ~  !NearbyDialog("DMorte") Global("Vaxis_Zombie_XP","GLOBAL",0) ~ THEN REPLY #4630 /* ~Try to hold still.~ */ DO ~FadeToColor([20.0],0) Wait(1) SetNamelessDisguise(ZOMBIE) Wait(2) FadeFromColor([20.0],0) AddexperienceParty(500) SetGlobal("Vaxis_Zombie_XP","GLOBAL",1) ~ GOTO 66
IF ~  NearbyDialog("DMorte") Global("Morte_Vaxis_Quip_1","GLOBAL",0) ~ THEN REPLY #4631 /* ~Try to hold still.~ */ DO ~SetGlobal("Morte_Vaxis_Quip_1","GLOBAL",1) ~ EXTERN ~DMORTE~ 94
IF ~  NearbyDialog("DMorte") Global("Morte_Vaxis_Quip_1","GLOBAL",1) ~ THEN REPLY #4632 /* ~Try to hold still.~ */ DO ~FadeToColor([20.0],0) Wait(1) SetNamelessDisguise(ZOMBIE) Wait(2) FadeFromColor([20.0],0) ~ GOTO 66
IF ~  !NearbyDialog("DMorte") Global("Vaxis_Zombie_XP","GLOBAL",1) ~ THEN REPLY #64533 /* ~Try to hold still.~ */ DO ~FadeToColor([20.0],0) Wait(1) SetNamelessDisguise(ZOMBIE) Wait(2) FadeFromColor([20.0],0) ~ GOTO 66
END

IF ~~ THEN BEGIN 66 // from: 65.0 65.2 65.3
SAY #4633 /* ~The zombie liberally applies the embalming fluid to your body, then stitches up several of your scars. Working from your feet upwards, he stitches up your scars, then finishes off the disguise by stitching up your lips.~ */
IF ~  !NearbyDialog("DMorte") ~ THEN REPLY #4634 /* ~"Mmm-hmmph-mmm... Fanks."~ */ GOTO 67
IF ~  NearbyDialog("DMorte") Global("Morte_Vaxis_Quip_2","GLOBAL",0) ~ THEN REPLY #4635 /* ~"Mmm-hmmph-mmm... Fanks."~ */ DO ~SetGlobal("Morte_Vaxis_Quip_2","GLOBAL",1) ~ EXTERN ~DMORTE~ 95
IF ~  NearbyDialog("DMorte") Global("Morte_Vaxis_Quip_2","GLOBAL",1) ~ THEN REPLY #4636 /* ~"Mmm-hmmph-mmm... Fanks."~ */ GOTO 67
END

IF ~~ THEN BEGIN 67 // from: 66.0 66.2
SAY #4637 /* ~The zombie holds up his hand. "Curful! Talk pulls stitches out, ruin diz-gize. Zumbie no talk. Yoo got to talk? Talk slow, curful."  ^NNOTE: Take heed that no one expects zombies to talk. If you speak to someone as a zombie, you run the risk of exposing your disguise.^-~ */
IF ~~ THEN REPLY #4638 /* ~"Mmph... mmm. I... understand."~ */ JOURNAL #64531 /* ~In exchange for some needle and thread and some embalming fluid, Vaxis disguised me as a zombie. He warned me that running would ruin the disguise, and that I shouldn't talk to others while disguised, as zombies don't "talk." ~ */ GOTO 68
END

IF ~~ THEN BEGIN 68 // from: 67.0
SAY #4639 /* ~The zombie frowns. "Diz-gize wun't last long... um-balming fluid dry up, stitchez fall out." He shrugs. "Prob-lee not last ousside Mortuaree. Uhnd no running! Yoo run, yoo ruin whole diz-gize."  ^NNOTE: Equipping weapons and/or running will instantly nullify your zombie disguise. If you find a new weapon, hold off on equipping it until you no longer wish to be disguised. If you have Always Run on, be sure to switch it off if you want to maintain the disguise when you finish speaking to Vaxis.^-~ */
IF ~~ THEN REPLY #4640 /* ~Nod again, leave.~ */ EXIT
END

IF ~~ THEN BEGIN 69 // from:
SAY #4641 /* ~The 'zombie' frowns. "Yu look familer. Me see yoo beefor?"~ */
IF ~~ THEN REPLY #4642 /* ~"Maybe. Where have you seen me?"~ */ EXIT
IF ~~ THEN REPLY #4643 /* ~X. ~ */ EXIT
END

IF ~~ THEN BEGIN 70 // from: 23.0 23.2 71.0 71.1
SAY #4644 /* ~To your surprise, the zombie turns away from you... he is starting to glance around fearfully.~ */
IF ~~ THEN REPLY #4645 /* ~"You won't talk? Then get ready to start screaming."~ */ DO ~Enemy() Attack(Protagonist) ForceAttack(Protagonist,Myself) ~ EXIT
IF ~~ THEN REPLY #4646 /* ~"Never mind then. What have you seen the Dustmen do?"~ */ GOTO 29
IF ~~ THEN REPLY #4647 /* ~"There was something else I wanted to know..."~ */ GOTO 43
IF ~~ THEN REPLY #4648 /* ~"Forget it, then. Farewell, *zombie.*"~ */ EXIT
END

IF ~~ THEN BEGIN 71 // from:
SAY #4649 /* ~The zombie is watching you both fearfully. He is still silent... but something in his expression tells you Morte's guess was right on the mark.~ */
IF ~~ THEN REPLY #4650 /* ~"The Anarchists, huh? That who you're watching this place for?"~ */ GOTO 70
IF ~~ THEN REPLY #4651 /* ~"It'll be a LOT less painful for you if you tell me now why the Anarchists want you to spy on this place."~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Vaxis_1","GLOBALGood",-1) ~ GOTO 70
IF ~~ THEN REPLY #4652 /* ~"Never mind then. What have you seen the Dustmen do?"~ */ GOTO 29
IF ~~ THEN REPLY #4653 /* ~"There was something else I wanted to know..."~ */ GOTO 43
IF ~~ THEN REPLY #4654 /* ~"Forget it, then. Farewell, *zombie.*"~ */ EXIT
END

IF ~~ THEN BEGIN 72 // from: 30.2
SAY #4655 /* ~The zombie looks disappointed, but he shrugs and begins to fish deeply into his stained tunic. "Beehn quiet, Duhsties beehn quiet, nuthin' new since lahst rehport." After a few moments, he hands you some items, then grunts. "Heer." Judging by the smell, they must have been hidden so as to avoid turning up if he was searched. "Me leeve in shurt while."~ */
IF ~  Global("Vaxis_Help","GLOBAL",0) ~ THEN REPLY #4656 /* ~"Leave? How?"~ */ GOTO 51
IF ~  Global("Vaxis_Help","GLOBAL",1) ~ THEN REPLY #64532 /* ~"Very well. Farewell, Vaxis."~ */ EXIT
END

IF ~~ THEN BEGIN 73 // from:
SAY #4658 /* ~The zombie grunts. "Portal's an arch - fizzzt floor, nurthwest ruhm, needs skel-tun finger bone tuh open." He nods. "Guud luhk."~ */
IF ~~ THEN REPLY #4659 /* ~"Uh... all right."~ */ EXIT
END

IF ~~ THEN BEGIN 74 // from: 34.0
SAY #4660 /* ~The zombie's eyes narrow, and he hisses at you. "Yu TRY n' put me in dead-book? I have frens hid heer, yu got *nubudy.* Yu tuch me, my frends kill YU."~ */
IF ~~ THEN REPLY #4661 /* ~"That was your last chance. Prepare to die."~ */ DO ~Enemy() Attack(Protagonist) ForceAttack(Protagonist,Myself) ~ EXIT
IF ~~ THEN REPLY #4662 /* ~"Burn in hell, then. I'm leaving. You better watch yourself... *zombie!*"~ */ GOTO 4
END

IF ~~ THEN BEGIN 75 // from: 31.4 32.3 35.4
SAY #4663 /* ~He seems frightened for a moment, then studies your build, and a sneer crawls across his face. "YOO try n' put ME in dead-book? I have frens hid heer, yu got *nubudy.* Yu tuch me, my frends kill YU."~ */
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #4664 /* ~"How about I expose your disguise to the guards?"~ */ GOTO 33
IF ~  CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #4665 /* ~"How about I expose your disguise to the guards?"~ */ GOTO 76
IF ~~ THEN REPLY #4666 /* ~"I'll risk it. Prepare to die."~ */ DO ~Enemy() Attack(Protagonist) ForceAttack(Protagonist,Myself) ~ EXIT
IF ~~ THEN REPLY #4667 /* ~"Burn in hell, then. I'm leaving. You better watch yourself... *zombie.*"~ */ GOTO 4
END

IF ~~ THEN BEGIN 76 // from: 75.1
SAY #4668 /* ~The zombie's eyes narrow, and he hisses at you. "Yu spill th' dark on me, me spill dark on *yu.* I have friends hid heer, yu got *nubudy.* Duhstees kill yu. Me escape."~ */
IF ~~ THEN REPLY #4669 /* ~"That was your last chance, corpse. Prepare to die."~ */ DO ~Enemy() Attack(Protagonist) ForceAttack(Protagonist,Myself) ~ EXIT
IF ~~ THEN REPLY #4670 /* ~"Burn in hell, then. I'm leaving. You better watch yourself... *zombie.*"~ */ GOTO 4
END

IF ~~ THEN BEGIN 77 // from: 51.0
SAY #64523 /* ~He shrugs. "Mhust be one 'round sumwhere... look in storage roomz on upper floor. Maybe there."~ */
IF ~~ THEN REPLY #64524 /* ~"All right. I had some other questions..."~ */ GOTO 43
IF ~~ THEN REPLY #64525 /* ~"Very well. I'll check upstairs for this crooked finger bone, then head to the first floor, to one of the arches in the northwest room. Got it."~ */ EXIT
