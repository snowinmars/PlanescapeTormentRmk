IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #4474 /* ~"Maybe we could help each other out. What do you want in return?"~ */ DO ~IncrementGlobalOnceEx("GLOBALGood_Vaxis_3","GLOBALGood",1) ~ GOTO 35
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #4475 /* ~"Because I won't *expose* your little disguise... if you help me."~ */ GOTO 33
IF ~  CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #4476 /* ~"Because I won't *expose* your little disguise... if you help me."~ */ GOTO 34
IF ~  CheckStatLT(Protagonist,12,STR) ~ THEN REPLY #4477 /* ~"You look like someone who'd much rather disguise themselves as a corpse than BE one. That reason enough?"~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Vaxis_1","GLOBALGood",-1) ~ GOTO 75
IF ~  CheckStatGT(Protagonist,11,STR) ~ THEN REPLY #4478 /* ~"You look like someone who'd much rather disguise themselves as a corpse than BE one. That reason enough?"~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Vaxis_1","GLOBALGood",-1) ~ GOTO 33
IF ~~ THEN REPLY #4479 /* ~"Forget we met. I must take my leave. Farewell."~ */ GOTO 4
