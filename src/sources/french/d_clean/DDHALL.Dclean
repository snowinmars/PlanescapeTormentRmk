IF ~~ THEN BEGIN 42 // from: 2.0 12.0 43.0
SAY #5075 /* ~"Dans la Salle de Commémoration du nord-ouest à l'étage en dessous. Vérifie les cercueils… son nom doit figurer sur l'une des plaques commémoratives. Peut-être que ça te rafraîchira la mémoire."~ */
IF ~  Global("Deionarra","GLOBAL",0) ~ THEN REPLY #5076 /* ~"Je ne sais pas. Je ne me souviens pas avoir jamais voyagé avec une femme."~ */ GOTO 43
IF ~  GlobalGT("Deionarra","GLOBAL",0) ~ THEN REPLY #5077 /* ~"Eh bien, elle prétend me connaître, mais je ne me souviens pas d'elle."~ */ GOTO 28
IF ~  CheckStatGT(Protagonist,12,INT) CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #5078 /* ~"Tu as dit qu'il y en avait d'autres. Qui d'autre est là ?"~ */ GOTO 12
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #5079 /* ~"Tu as dit qu'il y en avait d'autres. Qui d'autre est là ?"~ */ GOTO 12
IF ~~ THEN REPLY #6067 /* ~"J'irai peut-être à sa recherche. J'ai d'autres questions à te poser avant de partir…"~ */ GOTO 9
