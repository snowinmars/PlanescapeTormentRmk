IF ~  CheckStatGT(Protagonist,12,INT) CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #5082 /* ~"Tu as dit tout à l'heure qu'il y en avait d'autres enterrés ici qui avaient voyagé avec moi. Où sont-ils ?"~ */ GOTO 12
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #5083 /* ~"Tu as dit tout à l'heure qu'il y en avait d'autres enterrés ici qui avaient voyagé avec moi. Où sont-ils ?"~ */ GOTO 12
