~ THEN BEGIN 0 // from:
SAY #35383 /* ~La bizarrerie de ce squelette (numéro '748' d'après ce qui se trouve gravé sur son front) tient à ses quelques fausses dents faites d'une pierre brun rougeâtre. Elles ne doivent pas avoir de valeur car sinon, ses 'gardiens' les auraient enlevées.~ */
IF ~  Global("Skeleton_Chaotic","GLOBAL",0) ~ THEN REPLY #35384 /* ~"Excuse-moi, tu n'aurais pas vu des squelettes errants dans le coin ?"~ */ DO ~IncrementGlobal("Law","GLOBAL",-1) SetGlobal("Skeleton_Chaotic","GLOBAL",1) ~ GOTO 1
IF ~  Global("Skeleton_Chaotic","GLOBAL",1) ~ THEN REPLY #35407 /* ~"Excuse-moi, tu n'aurais pas vu des squelettes errants dans le coin ?"~ */ GOTO 1
