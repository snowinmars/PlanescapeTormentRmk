IF ~~ THEN BEGIN 51 // from: 50.1 50.2 50.3 72.0
SAY #4567 /* ~Le zombi hoche la tête. "Tu sor, wa juskalarsh sur sètétaj, saleunorouèst, Y te fo un'" Il brandit son index recourbé. "Kantalaclé; wa juskalarsh, sotalakript seukrèt ; éshaptoa parla. Sortiseukrèt." Il hoche la tête. "Tupeu TREUPOSER laba."~ */
IF ~  !PartyHasItem("BoneChrm") ~ THEN REPLY #64527 /* ~"Un doigt crochu squelettique ? Où puis-je en trouver un ?"~ */ DO ~AddexperienceParty(250) SetGlobal("Vaxis_Help","GLOBAL",1) JOURNAL #64528 /* ~Vaxis m'a dit qu'il y avait un portail secret dans la pièce située au nord-ouest du rez-de-chaussée de la Morgue. Il suffit d'y amener un os de doigt tordu pour qu'il s'active et mène à une crypte secrète où Vaxis dit que je pourrai me reposer. Il ignore où trouver l'os nécessaire, mais m'a conseillé d'essayer l'étage supérieur de la Morgue.~ */ GOTO 77
IF ~  PartyHasItem("BoneChrm") ~ THEN REPLY #4568 /* ~"J'ai d'autres questions…"~ */ DO ~AddexperienceParty(250) SetGlobal("Vaxis_Help","GLOBAL",1) JOURNAL #64529 /* ~Vaxis m'a dit qu'il y avait un portail secret dans la pièce située au nord-ouest du rez-de-chaussée de la Morgue. Il suffit d'y amener un os de doigt tordu pour qu'il s'active et mène à une crypte secrète où Vaxis dit que je pourrai me reposer.~ */ GOTO 43
IF ~  PartyHasItem("BoneChrm") ~ THEN REPLY #4569 /* ~"Une voûte au rez-de-chaussée, salle nord-ouest ? Bon, je vais aller voir ça."~ */ DO ~AddexperienceParty(250) SetGlobal("Vaxis_Help","GLOBAL",1) JOURNAL #64529 /* ~Vaxis m'a dit qu'il y avait un portail secret dans la pièce située au nord-ouest du rez-de-chaussée de la Morgue. Il suffit d'y amener un os de doigt tordu pour qu'il s'active et mène à une crypte secrète où Vaxis dit que je pourrai me reposer.~ */ EXIT
END

