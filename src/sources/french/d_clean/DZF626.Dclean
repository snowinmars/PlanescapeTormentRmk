IF ~  True()
~ THEN BEGIN 0 // from:
SAY #35050 /* ~Le côté gauche du visage de cette femme semble s'être enfoncé sous des coups de gourdin, et ses chairs meurtries et boursouflées pendent lamentablement sur son crâne. Le numéro '626' est cousu sur la joue droite, juste sous l'œil.~ */
IF ~  Global("Zombie_Chaotic","GLOBAL",0) ~ THEN REPLY #35051 /* ~"Hum… sale blessure que t'as là."~ */ DO ~IncrementGlobal("Law","GLOBAL",-1) SetGlobal("Zombie_Chaotic","GLOBAL",1) ~ GOTO 1
IF ~  Global("Zombie_Chaotic","GLOBAL",1) ~ THEN REPLY #35068 /* ~"Hum… sale blessure que t'as là."~ */ GOTO 1
IF ~  Global("Vaxis_Exposed","GLOBAL",1) ~ THEN REPLY #35069 /* ~"Je sais que tu n'es pas un zombi, tu sais. Personne n'est dupe."~ */ GOTO 1
