SAY #748 /* ~"당신의 저주의 본질은 명백해요, 내 사랑. 스스로를 보세요," 그녀는 당신을 가리킨다. "죽음이 당신을 거부해요. 당신 기억은 당신을 저버렸어요. 잠시 멈추고 생각해본 적은 없나요?"~ */
IF ~~ THEN REPLY #749 /* ~"실은 아직도 나는 내게 일어난 일을 파악하려고 노력 중이오. 그 밖에 내게 나 자신에 대해 또 뭘 얘기해줄 수가 있겠소?"~ */ GOTO 27
IF ~~ THEN REPLY #750 /* ~"그 밖에도 물어보고 싶은 것들이 좀 있소..."~ */ GOTO 10
IF ~~ THEN REPLY #751 /* ~"기억에 관한 건 제쳐두고... 죽음이 날 거부했다고 한다면... 어째서 그게 저주요?"~ */ GOTO 25
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #790 /* ~"난 떠나야만 하오. 잘 있으시오, 데이오나라."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #1318 /* ~"난 떠나야만 하오. 잘 있으시오, 데이오나라."~ */ GOTO 0
END

IF ~~ THEN BEGIN 14 // from: 12.0
SAY #752 /* ~데이오나라는 슬퍼하는 듯하다. "그건 당신이 결코 넘지 못할 경계예요, 내 사랑. 그것은 당신과 내 잔재 사이에 서 있는 경계예요..."~ */
IF ~~ THEN REPLY #753 /* ~"알겠소... 다른 질문에 좀 대답해주었으면 하오..."~ */ GOTO 10
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #755 /* ~"난 떠나야만 하오. 잘 있으시오, 데이오나라."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #1319 /* ~"난 떠나야만 하오. 잘 있으시오, 데이오나라."~ */ GOTO 0
END

IF ~~ THEN BEGIN 15 // from: 3.4 5.1 6.3 6.4 7.4 9.4 10.7 11.2 12.2 13.3 14.1 25.2 27.3 28.1 28.3 30.1 31.2 32.1 41.2 41.3 42.1 42.2 43.3 44.3 47.3
SAY #756 /* ~"기다리세요... 나는 당신과 여행하는 동안 많은 것을 배웠어요, 내 사랑, 그리고 당신이 잃어버린 것도 난 간직하고 있어요. 난 당신에게 내가 아는 것 전부를 밝히지는 않았어요. 당신은 기억의 불꽃을 찾아 어둠 속에서 헤매고 있지만... 나는 뚜렷하게 볼 수가 있어요."~ */
IF ~~ THEN REPLY #757 /* ~"당신이 뭘 알던 간에 그건 나중에 들어도 되오. 안녕히 계시오."~ */ GOTO 26
IF ~~ THEN REPLY #758 /* ~"당신이 얘기할 수 있는 것들 중 대체 어떤 것이 내게 중요하다는 거요?"~ */ GOTO 17
IF ~~ THEN REPLY #759 /* ~"그리고 당신은 볼 수 있으나 난 볼 수가 없다는 건 대체 어떤 것이오?"~ */ GOTO 17
IF ~~ THEN REPLY #761 /* ~"난 떠나야만 하오. 잘 있으시오, 데이오나라."~ */ GOTO 26
END

IF ~~ THEN BEGIN 16 // from: 20.0 21.0
SAY #762 /* ~데이오나라는 놀란 듯하다, 그리고 그녀의 어조는 마치 간청이라는 하는 것처럼 바뀐다. "난... 당신으로부터 맹세를 받아내려는 건 아니에요. 단지 난 당신이 경계를 넘어 나와 함께 하기를 너무나도 오랫동안 기다렸을..."~ */
IF ~~ THEN REPLY #763 /* ~"데이오나라, 만약 당신이 내게 맹세를 강요할 생각이 아니라면 그렇게 하지 마시오. 자, 내게 당신이 본 영상에 대해 말해주시오, 그리고 맹세나 약속 따위에 대해서는 더 이상 얘기하지 않을 것이오. ~ */ GOTO 40
END

IF ~~ THEN BEGIN 17 // from: 15.1 15.2
SAY #769 /* ~"망각의 냉기가 우리를 천천히 엄습함에 따라 시간조차도 그 손을 늦추고 있어요. 앞으로 벌어질 일들이 벌떼처럼 내 시야를 스쳐 지나가고 있어요. 당신 모습도 보여요, 내 사랑 자금과 같은 당신 모습이 보여요. 그리고..." 데이오나라는 조용해진다. ~ */
IF ~~ THEN REPLY #770 /* ~"왜 갑자기 조용해진 거요? 열변을 토하다 지치기라도 한 거요?"~ */ GOTO 18
IF ~~ THEN REPLY #771 /* ~"그건 무엇이오? 당신에게 어떤 것이 보이는 거요?"~ */ GOTO 18
IF ~~ THEN REPLY #772 /* ~"나는 미래의 영상 따위에는 관심이 없소. 안녕히 계시오."~ */ GOTO 19
END

IF ~~ THEN BEGIN 18 // from: 17.0 17.1
SAY #773 /* ~"내겐 당신을 기다리고 있는 운명이 보여요. 그것은 이 지점에서 시작하여 전 차원에 파문처럼 퍼져 나가고 있어요. 당신에게 내가 보고 있는 것들을 말씀 드릴까요?~ */
IF ~~ THEN REPLY #774 /* ~"말해주시오."~ */ GOTO 20
IF ~~ THEN REPLY #775 /* ~"나는 알고 싶지 않소. 미래는 때가 되면 우리 앞에 그 모습을 드러낼 것이오."~ */ GOTO 19
END

IF ~~ THEN BEGIN 19 // from: 17.2 18.1
SAY #776 /* ~"당신은 항상 그랬어요, 내 사랑. 당신은 늘 죽음의 부름에 귀를 기울이지 않았어요. 당신이 다음에 거부할 대상은 시간이 될 건가요?" 그녀는 눈을 감고 희미한 소리와 함께 사라진다.~ */
IF ~  Global("Morte_Deionarra_Quip_1","GLOBAL",1) ~ THEN REPLY #803 /* ~떠난다.~ */ DO ~SetGlobal("Deio_Wake_Up","GLOBAL",0) ~ EXIT
IF ~  NearbyDialog("DMorte") Global("Morte_Deionarra_Quip_1","GLOBAL",0) ~ THEN REPLY #6085 /* ~떠난다.~ */ DO ~SetGlobal("Deio_Wake_Up","GLOBAL",0) ~ EXTERN ~DMORTE~ 105
IF ~  !NearbyDialog("DMorte") Global("Morte_Deionarra_Quip_1","GLOBAL",0) ~ THEN REPLY #13256 /* ~떠난다.~ */ DO ~SetGlobal("Deio_Wake_Up","GLOBAL",0) ~ EXIT
END

IF ~~ THEN BEGIN 20 // from: 18.0
SAY #777 /* ~"먼저, 내게 약속을 해주세요. 돌아오겠다고 약속해 주세요. 그리고 나와 함께 있을 수 있는 방법을 모색하겠다고."~ */
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #778 /* ~"내가 한때 사랑했던 여인이 계시에 대한 약속을 가지고 내게 공갈을 하여 약속을 강요하려 하다니 그건 정말 믿기 힘든 일이오. 당신은 날 믿지 못하오, 데이오나라?"~ */ GOTO 16
IF ~~ THEN REPLY #779 /* ~"그러한 약속의 대가는 너무나도 크오."~ */ GOTO 21
IF ~~ THEN REPLY #780 /* ~거짓말: "나는 당신을 구하거나 당신과 함께할 수 있는 방법을 찾아내겠다고 맹세하오."~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Deionarra_3","GLOBALGood",-2) IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_3","GLOBALLaw",-2) ~ GOTO 22
IF ~~ THEN REPLY #781 /* ~"나는 그런 약속을 하지 않을 것이오, 망령! 미래를 가지고 날 괴롭히지 마시오... 조용히 하던지 아니면 사라지시오!"~ */ GOTO 26
IF ~~ THEN REPLY #782 /* ~"최선을... 다하리다."~ */ GOTO 40
IF ~~ THEN REPLY #6093 /* ~맹세: "나는 당신을 구하거나 당신과 함께할 수 있는 방법을 찾아내겠다고 맹세하오."~ */ DO ~IncrementGlobalOnceEx("GLOBALGood_Deionarra_1","GLOBALGood",2) IncrementGlobalOnceEx("GLOBALLawful_Deionarra_1","GLOBALLaw",2) ~ GOTO 22
END

IF ~~ THEN BEGIN 21 // from: 20.1
SAY #783 /* ~데이오나라는 그녀의 팔을 접는다. "그건 그래요, 내 사랑. 하지만 불사의 대가는 별로 크지 않았던 것 같군요. 당신과 같은 사람에게 성실하기를 바라는 건 무리인가요?"~ */
