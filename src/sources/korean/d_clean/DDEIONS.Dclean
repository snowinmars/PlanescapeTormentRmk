IF ~~ THEN BEGIN 43 // from: 9.2 10.3 44.0
SAY #6121 /* ~"떠난다고요...?" 데이오나의 목소리는 낮아졌다가 다시 올라간다. "*떠난다고요?!*" 당신 때문에 여기 갇힌 내게 어떻게 하면 여기를 떠날 수 있느냐고 묻는 건가요?"~ */
IF ~~ THEN REPLY #6137 /* ~"그렇소, 나는 이 곳에서 탈출해야 하오. 혹시 나가는 방법을 알고 있소?"~ */ GOTO 47
IF ~~ THEN REPLY #6138 /* ~"내 요구에 대해 사과하오. 나는 당신을 화나게 할 생각은 없었소. 제발, 당신에게 할 다른 질문들이 있소..."~ */ GOTO 10
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #6139 /* ~"데이오나라, 난 위험에 처했소. 날 안전한 곳으로 안내해 줄 수 있겠소? 당신과 다시 얘기를 나누기 위해 가능한 한 빨리 돌아오리다."~ */ GOTO 46
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #6140 /* ~"난 떠나야만 하오. 잘 있으시오, 데이오나라."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #6141 /* ~"난 떠나야만 하오. 잘 있으시오, 데이오나라."~ */ GOTO 0
END

IF ~~ THEN BEGIN 44 // from: 9.3 10.4
SAY #6122 /* ~당신은 데이오나라에게 질문을 하려다 목구멍에서 멈춘다. 만약 그녀에게 탈출로에 대해서 물으면 그녀가 당신이 자신을 버리려고 한다고 느낄지도 모른다는 생각이 든다. 만약 당신이 그녀에게 여기서 나갈 방법에 대해 묻고 싶다면 세심한 주의를 기울여야 할 것 같다.~ */
IF ~~ THEN REPLY #6142 /* ~"이 곳에서 나갈 수 있는 방법을 얘기해줄 수 있겠소?"~ */ GOTO 43
IF ~~ THEN REPLY #6143 /* ~"데이오나라, 난 위험에 처했소. 날 안전한 곳으로 안내해 줄 수 있겠소? 당신과 다시 얘기를 나누기 위해 가능한 한 빨리 돌아오리다."~ */ GOTO 46
IF ~~ THEN REPLY #6144 /* ~"당신에게 질문할 것들이 더 있소..."~ */ GOTO 10
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #6145 /* ~"난 떠나야만 하오. 잘 있으시오, 데이오나라."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #6146 /* ~"난 떠나야만 하오. 잘 있으시오, 데이오나라."~ */ GOTO 0
END

IF ~~ THEN BEGIN 45 // from: 46.0 46.1
SAY #6123 /* ~"이 장소에는 인간의 눈으로는 볼 수 없는 문들이 많이 감추어져 있어요. 당신은 이러한 전이문들 중 하나를 탈출하는 데 이용할 수 있을 거예요."~ */
IF ~~ THEN REPLY #6124 /* ~"전이문?"~ */ GOTO 31
END

IF ~~ THEN BEGIN 46 // from: 43.2 44.1 47.1
SAY #6125 /* ~"위험에 처했다고요?" 데이오나라는 걱정하는 듯하다. "물론이에요, 내 사랑, 난 최선을 다해 당신을 돕겠어요..." 그녀는 잠시 눈을 감는다, 그리고 당신은 에테르의 미풍이 그녀의 몸을 통과함에 따라 그녀의 머리카락이 바람에 날리는 것을 본다. 잠시 후 바람은 가라앉고 그녀는 천천히 눈을 뜬다. "아마 방법이 있을 것 같아요."~ */
IF ~  Global("Deionarra_Portal","GLOBAL",1) ~ THEN REPLY #6147 /* ~"그래서?"~ */ GOTO 45
IF ~  Global("Deionarra_Portal","GLOBAL",0) ~ THEN REPLY #6148 /* ~"그래서?"~ */ DO ~SetGlobal("Deionarra_Portal","GLOBAL",1) AddexperienceParty(500) ~ GOTO 45
END

IF ~~ THEN BEGIN 47 // from: 43.0
