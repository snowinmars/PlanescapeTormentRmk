IF ~~ THEN BEGIN 54 // from: 53.0 53.1 53.2 53.3
SAY #63370 /* ~"당신이 원하시는 대로 해 드리겠어요, 내 사랑." 그녀는 손을 내민다. "제 손을 잡으세요, 그러면 이 요새의 벽도 더 이상 당신을 가로막지 못할 거예요."~ */
IF ~  Global("Deionarra_Forgives","GLOBAL",1) ~ THEN REPLY #63371 /* ~그녀의 손을 만진다...~ */ DO ~StartCutSceneMode() StartCutSceneEx("1203cd11",FALSE) ~ EXIT
IF ~  Global("Deionarra_Forgives","GLOBAL",0) ~ THEN REPLY #64594 /* ~그녀의 손을 만진다...~ */ DO ~StartCutSceneMode() StartCutSceneEx("1203cd21",FALSE) ~ EXIT
