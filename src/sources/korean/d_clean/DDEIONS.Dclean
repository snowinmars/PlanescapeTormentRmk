IF ~~ THEN BEGIN 32 // from: 31.0
SAY #821 /* ~데이오나라는 기억을 해내려고 애쓰는 듯 잠시 말을 멈춘다, "당신이 적절한 '열쇠'를 지니고 있으면 전이문은 당신 앞에 그 모습을 드러낼 거예요. 불행히도 어떤 것이든 이러한 열쇠가 될 수 있어요.. 감정, 나뭇조각, 은박을 입힌 유리로 만든 대거, 천조각, 당신이 부르는 콧노래... 아마 이 곳에서 나가는 데 사용할 수 있는 열쇠를 아는 것은 더스트맨들뿐일 거예요."~ */
IF ~~ THEN REPLY #824 /* ~"알겠소. 그 밖에도 물어보고 싶은 것들이 좀 있소..."~ */ GOTO 10
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #823 /* ~"그럼 그들 중 한 사람에게 물어보겠소. 안녕히 계시오, 데이오나라."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #1326 /* ~"그럼 그들 중 한 사람에게 물어보겠소. 안녕히 계시오, 데이오나라."~ */ GOTO 0
END

IF ~~ THEN BEGIN 33 // from: 4.0
SAY #6083 /* ~"당신에게 해줄 대답 따위는 없어요! 당신의 불성실한 마음이 당신을 여기까지 인도했다면, 그것이 나머지 길도 인도하도록 하세요! 이제 내 앞에서 꺼져요!"~ */
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #6129 /* ~거짓말: "이건 내가 기억하고 있는 네이오나라가 아니오. 내가 사랑한 데이오나라는 자비롭고 친절하며... 도움을 필요로 하는 자를 결코 저버리지 않았소. 당신은 그토록 타락해 버린 거요?"~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_4","GLOBALLaw",-1) ~ GOTO 35
IF ~~ THEN REPLY #6130 /* ~"내겐 당신 도움이 필요하오, 데이오나라. 내가 당신을 가장 절실히 필요로 할 때 날 저버리겠다는 거요?"~ */ GOTO 37
IF ~  CheckStatGT(Protagonist,11,INT) CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #6131 /* ~허풍: "좋소. 당신 의사를 존중하리다, 데이오나라... 이 곳을 떠나 다시는 돌아오지 않겠소."~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_4","GLOBALLaw",-1) ~ GOTO 34
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #6132 /* ~허풍: "좋소. 당신 의사를 존중하리다, 데이오나라... 이 곳을 떠나 다시는 돌아오지 않겠소."~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_4","GLOBALLaw",-1) ~ GOTO 34
IF ~~ THEN REPLY #6133 /* ~"당신에게 상처를 입혀 미안하오, 데이오나라. 난 이 곳을 떠날 것이며 내가 당신을 더 이상 괴롭히는 일은 없을 것이오."~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) ~ GOTO 34
IF ~~ THEN REPLY #6134 /* ~조용히 떠난다.~ */ GOTO 48
END

IF ~~ THEN BEGIN 34 // from: 33.2 33.3 33.4
SAY #6086 /* ~데이오나라의 표정에서 분노가 마치 눈 녹듯이 사라진다... 이러한 변화의 속도는 지금 그녀의 얼굴에 나타난 절박한 표정만큼이나 섬뜩하다. "아니에요! 기다리세요, 내 사랑!" 그녀는 애걸하는 목소리로 말한다. "제발 절 용서하세요, 이렇게 빌겠어요! 제발 떠나지 마세요!"~ */
IF ~~ THEN REPLY #6095 /* ~"데이오나라, 당신의 광분에 대한 내 인내심도 한계에 도달하려고 하고 있소. 만약 계속 얘기를 하려고 한다면 자신의 감정을 억제하시오, 아니면 우린 다시는 얘기를 하는 일이 없을 테니. 내 말을 알아듣겠소?"~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Deionarra_4","GLOBALGood",-1) ~ GOTO 36
IF ~~ THEN REPLY #6096 /* ~"나는 당신을 용서하오. 지금 내게는 당신 도움이 필요하오, 데이오나라."~ */ GOTO 10
END

IF ~~ THEN BEGIN 35 // from: 33.0
SAY #6087 /* ~데이오나라의 표정에서 분노가 마치 눈 녹듯이 사라진다... 이러한 변화의 속도는 지금 그녀의 얼굴에 나타난 절박한 표정만큼이나 섬뜩하다. "아니... 아니에요... 나는 아직도 당신이 기억하는 그대로의 데이오나라예요. 제발 절 용서하세요, 이렇게 빌겠어요."~ */
IF ~~ THEN REPLY #6097 /* ~"데이오나라, 당신의 광분에 대한 내 인내심도 한계에 도달하려고 하고 있소. 만약 계속 얘기를 하려고 한다면 자신의 감정을 억제하시오, 아니면 우린 다시는 얘기를 하는 일이 없을 테니. 내 말을 알아듣겠소?"~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Deionarra_4","GLOBALGood",-1) ~ GOTO 36
IF ~~ THEN REPLY #6098 /* ~"나는 당신을 용서하오. 지금 내게는 당신 도움이 필요하오, 데이오나라."~ */ GOTO 10
END

IF ~~ THEN BEGIN 36 // from: 34.0 35.0
SAY #6088 /* ~그녀의 목소리는 알아듣기 어려울 정도로 작은 속삭임으로 변한다. "그래요... 제발. 떠나지 마세요." 그녀의 애걸하는 듯한 표정은 당신을 전율시킨다... 공포 때문이 아니라 쾌락 때문에. 당신이 그녀를 교묘하게 조종한 것은 이번이 처음은 아니라는 생각이 든다. ~ */
IF ~~ THEN REPLY #6099 /* ~"자, 들으시오, 데이오나라. 당신에게 물어볼 것들이 있소..."~ */ GOTO 10
END

IF ~~ THEN BEGIN 37 // from: 33.1 47.0
SAY #6089 /* ~"*당신*을 저버렸다고?! 감히 당신이 내게 그런 말을 하는 건가요?!" 그녀는 팔을 바깥쪽으로 뻗으면서 호를 그린다, 그리고 팔을 다시 자신의 정면으로 가져온 후 양손의 집게손가락으로 당신을 가리킨다. 그녀는 어떤 주문을 영창하려는 것 같다. "감히 당신이...!"~ */
IF ~~ THEN REPLY #6100 /* ~"닥치시오! 내 말을 들으시오, 혼령! 나는 당신의 유희 때문에 인내심을 잃고--"~ */ DO ~SetGlobal("Deionarra_Curse","GLOBAL",1) ~ GOTO 38
IF ~~ THEN REPLY #6101 /* ~자신을 방어할 준비를 한다.~ */ DO ~SetGlobal("Deionarra_Curse","GLOBAL",1) ~ GOTO 38
END

IF ~~ THEN BEGIN 38 // from: 37.0 37.1
SAY #6090 /* ~"타버려요! 당신을 베이터의 업화가 안에서부터 삼키면서 태우듯이 타버려요! 타버려요, 그리고 그것조차도 당신에 대한 내 증오의 *일부*에 불과하다는 걸 아세요! 나는 당신을 저주해요, 난 당신이 자신의 비참한 삶이 아닌 삶의 사슬로부터 영원히 벗어나지 못하도록 저주해요. 당신같은 사람은 시름시름 시들어 가며 죽어야 해요, 그리고 당신의 정신은 그 썩은 몸뚱이 안에서 말라 죽어야 해요!"~ */
IF ~~ THEN REPLY #6102 /* ~"함부로 악담을 하지 마시오! 내 인내심-"~ */ GOTO 39
IF ~~ THEN REPLY #6103 /* ~"데이오나라! 기다리시오, 나는 사과를 하러 왔소..."~ */ GOTO 39
END

IF ~~ THEN BEGIN 39 // from: 38.0 38.1
SAY #6091 /* ~"한 번 건 저주는 풀 수가 없어요." 데이오나라는 속삭이듯 말한다. "이 사실을 아세요: 내게는 영원한 시간이 있어요, '내 사랑.' 나는 당신이 명부로 오기를 기다리겠어요." 그녀는 미소를 짓는다, 하지만 즐거운 기색은 없다. "우리는 다시 함께 있게 될 거예요."~ */
IF ~~ THEN REPLY #6104 /* ~"잠깐 기다리시오! 얘기를 하고-"~ */ GOTO 48
IF ~~ THEN REPLY #6105 /* ~"당신이 한 짓을 되돌려 놓으시오! 경고하--"~ */ GOTO 48
END

IF ~~ THEN BEGIN 40 // from: 16.0 20.4 21.3
SAY #6092 /* ~데이오나라는 경직한다. 그녀 뭔가 말할 것이 있는 듯하나, 체념한 듯 한숨을 쉰다. "알겠어요, 내 사랑... 전과 마찬가지로 당신을 믿어야 할 것 같군요." 그녀는 눈을 감는다."~ */
IF ~~ THEN REPLY #6106 /* ~기다린다...~ */ GOTO 22
END

IF ~~ THEN BEGIN 41 // from: 10.6
SAY #6108 /* ~데이오나라는 슬픈 듯 고개를 젓는다. "일단 건 저주는 풀 수가 없어요. 용서하세요, 내 사랑."~ */
IF ~~ THEN REPLY #6110 /* ~"그것을 제거할 수 있는 사람은 없소?"~ */ GOTO 42
IF ~~ THEN REPLY #6111 /* ~"알겠소... 당신에게 물어보고 싶은 다른 질문이 있소..."~ */ GOTO 10
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #6112 /* ~"용서를 구하기에는 이제 너무 늦은 것 같소. 안녕히 계시오, 데이오나라."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #6113 /* ~"아마 날 도울 수 있는 사람이 있을 것이오. 안녕히 계시오, 데이오나라."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #6114 /* ~"용서를 구하기에는 이제 너무 늦은 것 같소. 안녕히 계시오, 데이오나라."~ */ GOTO 0
