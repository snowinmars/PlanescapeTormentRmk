IF ~~ THEN BEGIN 31 // from: 45.0
SAY #817 /* ~"전이문들은 존재에 생긴 구멍들로, 각 전이문은 다원 우주의 특정한 지점으로 통하고 있어요... 만약 당신이 적절한 열쇠를 찾을 수가 있다면, 그것들 중 하나를 통해 탈출 할 수 있을 거예요."~ */
IF ~~ THEN REPLY #819 /* ~"열쇠?"~ */ GOTO 32
IF ~~ THEN REPLY #818 /* ~"그 밖에도 물어보고 싶은 것들이 좀 있소..."~ */ GOTO 10
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #820 /* ~"안녕히 계시오, 데이오나라."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #1325 /* ~"안녕히 계시오, 데이오나라."~ */ GOTO 0
