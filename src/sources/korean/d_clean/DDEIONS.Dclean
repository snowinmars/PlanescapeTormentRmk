IF ~~ THEN REPLY #63381 /* ~진실: "처음에 나는 당신을 몰랐지만 어느새 당신을 사랑하게 되었소. 당신의 고통은 바로 내 고통이 되었으며, 내가 당신을 위해 할 수 있는 일이라면 무엇이든지 할 거라는 사실을 알게 되었소."~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Deionarra_4","GLOBALLaw",1) IncrementGlobalOnceEx("GLOBALGood_Deionarra_4","GLOBALGood",1) ~ GOTO 58
IF ~~ THEN REPLY #63382 /* ~진실: "미안하오, 데이오나라. 아니오, 난 당신을 안 적이 없소. 아마 만약 다른 상황 아래서 만났더라면..."~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Deionarra_5","GLOBALLaw",2) ~ GOTO 59
END

IF ~~ THEN BEGIN 58 // from: 55.1 57.0 57.1
