IF ~~ THEN REPLY #63373 /* ~진실: "내가 당신을 요새에 데려왔을 때 난 당신이 이 곳에서 죽기를 원했소. 나는 누군가 이 곳에 남아 이 장소와 나를 연결시켜 줄 사람이 필요했소. 나는 당신이 날 너무나도 사랑하기 때문에 죽음조차 뿌리치고 혼령이 될 것이라는 걸 알고 있었소. 그리고 그것이 지금 당신이 고통을 받고 있는 이유요."~ */ DO ~IncrementGlobalOnceEx("GLOBALLawful_Deionarra_2","GLOBALLaw",3) IncrementGlobalOnceEx("GLOBALGood_Deionarra_2","GLOBALGood",1) SetAnimState(Myself,ANIM_MIMESTAND) ~ GOTO 56
IF ~~ THEN REPLY #63374 /* ~거짓말: "당신이 이 요새에서 죽은 건 우릴 기다리고 있는 적 때문이었소. 그는 우리 사이를 갈라놓기 위해 당신이 죽기를 원했소. 나는 곧 그와 대적할 것이고 그에게 복수를 할 것이오."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_5","GLOBALLaw",-3) IncrementGlobalOnceEx("GLOBALEvil_Deionarra_5","GLOBALGood",-1) ~ GOTO 58
END

