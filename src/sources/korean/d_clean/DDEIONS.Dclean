IF ~~ THEN BEGIN 0 // from: 5.2 9.5 10.8 11.3 12.3 13.4 14.2 25.3 27.4 28.4 30.2 31.3 32.2 41.4 41.5 42.3 42.4 43.4 44.4
SAY #69459 /* ~"나는 당신을 죽음의 전당에서 기다리겠어요, 내 사랑." 그녀는 미소를 짓는다, 하지만 그 미소에는 슬픔만이 가득할 뿐이다. 그녀는 눈을 감고 희미한 소리와 함께 사라진다.~ [DEN008B] */
IF ~  Global("Morte_Deionarra_Quip_1","GLOBAL",1) ~ THEN REPLY #701 /* ~떠난다.~ */ DO ~SetGlobal("Deio_Wake_Up","GLOBAL",0) ~ EXIT
IF ~  NearbyDialog("DMorte") Global("Morte_Deionarra_Quip_1","GLOBAL",0) ~ THEN REPLY #699 /* ~떠난다.~ */ DO ~SetGlobal("Deio_Wake_Up","GLOBAL",0) ~ EXTERN ~DMORTE~ 105
IF ~  !NearbyDialog("DMorte") Global("Morte_Deionarra_Quip_1","GLOBAL",0) ~ THEN REPLY #9616 /* ~떠난다.~ */ DO ~SetGlobal("Deio_Wake_Up","GLOBAL",0) ~ EXIT
END 
IF WEIGHT #0 ~  Global("Deionarra","GLOBAL",0) !Global("Current_Area","GLOBAL",1203) !Global("Current_Area","GLOBAL",1200)
~ THEN BEGIN 1 // from:
SAY #5 /* ~당신 앞에는 놀랄 정도로 아름다운 유령이 서 있다. 그녀는 팔을 포개 놓고 있으며 그녀의 눈은 감겨 있다. 그녀는 길고 흐르는 듯한 머리를 지니고 있으며, 그녀의 가운은 희미한 바람에 살랑거리는 것 같다. 당신이 보고 있는 동안 그녀는 약간 움직이며 눈을 깜박이기 시작한다.~ */
IF ~~ THEN REPLY #703 /* ~"안녕하시오...?"~ */ GOTO 2
IF ~~ THEN REPLY #704 /* ~기다린다.~ */ GOTO 2
IF ~~ THEN REPLY #705 /* ~혼령이 눈치채기 전에 떠난다.~ */ DO ~SetGlobal("Deio_Wake_Up","GLOBAL",0) ~ EXIT
END

IF ~~ THEN BEGIN 2 // from: 1.0 1.1
SAY #706 /* ~그녀는 천천히 눈을 뜬다, 그리고 잠시 동안 혼란스러운 듯 눈을 깜박인다, 마치 자신이 어디 있는지 잘 모르겠다는 듯. 그녀는 주변을 천천히 둘러보다가 당신을 보게 된다. 그녀의 평화롭던 표정은 악귀와 같은 표정으로 돌변한다. "당신! 당신은 왜 이 곳에 온 거죠! 당신이 가져온 불행을 직접 구경하고 싶었던 건가요? 아니면 죽어서도 난 당신에게 티끌만한 쓸모라도 있는 건가요? 그녀는 목소리를 낮춘다. "... 내 사랑."~ [DEN001] */
IF ~~ THEN REPLY #707 /* ~"당신은 누구요?"~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) ~ GOTO 3
IF ~  CheckStatGT(Protagonist,11,INT) CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #708 /* ~"'내 사랑?' 내가 당신을 아오?"~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) ~ GOTO 3
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #709 /* ~"'내 사랑?' 내가 당신을 아오?"~ */ DO ~SetGlobal("Deionarra","GLOBAL",1) ~ GOTO 3
END

IF ~~ THEN BEGIN 3 // from: 2.0 2.1 2.2 10.0
SAY #710 /* ~혼령은 애걸하는 듯한 손짓을 한다. "어째서 정신의 도둑들은 계속 당신 기억으로부터 내 이름을 훔쳐 가는 거죠? 내 이름을 *기억*하지 못하시나요, 내 사랑?" 유령은 그녀의 팔을 내뻗는다. "생각하세요..." 그녀의 목소리는 다시 절박해진다. "데이오나라 라는 이름은 분명히 당신 안에서 어떤 기억을 불러낼 거예요."~ */
IF ~~ THEN REPLY #711 /* ~"미안하오. 난 기억을 잃었소."~ */ GOTO 6
IF ~~ THEN REPLY #712 /* ~거짓말: "그래... 그렇소. 그 이름은 어쩐지 귀에 익소."~ */ DO ~IncrementGlobalOnceEx("GLOBALEvil_Deionarra_1","GLOBALGood",-1) IncrementGlobalOnceEx("GLOBALChaotic_Deionarra_1","GLOBALLaw",-1) ~ GOTO 7
IF ~  CheckStatGT(Protagonist,11,INT) CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #713 /* ~"기억이 되살아날 것 같기도 하오... 얘기를 더 해주시오. 아마 당신의 말이 내 정신으로부터 그림자들을 몰아낼 수 있을지도 모르오, 데이오나라. ~ */ GOTO 9
IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #714 /* ~"기억이 되살아날 것 같기도 하오... 얘기를 더 해주시오. 아마 당신의 말이 내 정신으로부터 그림자들을 몰아낼 수 있을지도 모르오, 데이오나라. ~ */ GOTO 9
IF ~  Global("Prophecy","GLOBAL",0) ~ THEN REPLY #1308 /* ~"아니오. 안녕히 계시오... 데이오나라."~ */ GOTO 15
IF ~  Global("Prophecy","GLOBAL",1) ~ THEN REPLY #6080 /* ~"그렇지 않소. 안녕히 계시오, 데이오나라."~ */ GOTO 26
END 
IF WEIGHT #1 ~  Global("Deionarra","GLOBAL",2) !Global("Current_Area","GLOBAL",1203) !Global("Current_Area","GLOBAL",1200)
~ THEN BEGIN 4 // from:
SAY #715 /* ~데이오나라는 다시 한 번 실체화한다.. 이번에 그녀의 얼굴은 절박함으로 가득 차 있으며, 무엇을 잡으려는 듯 팔을 내뻗고 있다. 그녀가 다시 희미해짐에 따라 그녀 얼굴의 절박함은 분노로 변한다. "당신이 또 왔군요! 왜 내게 계속 고통을 주는 거죠?"~ [DEN002] */
IF ~~ THEN REPLY #765 /* ~"나는 많은 것을 알아야만 하오. 당신에게 물어보고 싶은 것들이 있소..."~ */ GOTO 33
