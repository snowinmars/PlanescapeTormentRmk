IF ~~ THEN REPLY #4044 /* ~자이언트 스켈레톤을 조사한다... 조심스럽게.~ */ GOTO 4
IF ~~ THEN REPLY #4046 /* ~스켈레톤을 그냥 내버려 두고 떠난다.~ */ EXIT
END

IF ~~ THEN BEGIN 4 // from: 0.2 1.0 3.1 7.1 15.1 16.3
SAY #4007 /* ~스켈레톤의 정교한 청동 갑옷은 스켈레톤의 흉곽과 어깨뼈에 일련의 철제 볼트들로 고정되어 있다. 갑옷 안의 골격을 살펴보던 중 당신은 전술한 철제 볼트와 동일한 볼트가 스켈레톤의 어깨, 팔꿈치, 골반, 그리고 무릎 관절에도 박혀 있다는 사실을 발견한다. 그리고 스켈레톤의 팔과 다리에는 다량의 두꺼운 가죽끈과 마디가 있는 로프가 마치 근육 및 건과 흡사한 형태로 감겨져 있다.~ */
IF ~~ THEN REPLY #4045 /* ~갑옷을 살펴본다.~ */ GOTO 5
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4048 /* ~스켈레톤의 칼을 그의 손에서 비틀어 빼내려고 시도한다.~ */ GOTO 2
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #4049 /* ~스켈레톤의 칼을 그의 손에서 비틀어 빼내려고 시도한다.~ */ GOTO 3
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4050 /* ~스켈레톤의 갑옷을 고정시키고 있는 볼트들을 비틀어 빼내려고 시도한다.~ */ GOTO 2
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #4051 /* ~스켈레톤의 갑옷을 고정시키고 있는 볼트들을 비틀어 빼내려고 시도한다.~ */ GOTO 3
IF ~  NearbyDialog("DMorte") Global("Morte_Skel_Mort_Quip","GLOBAL",1) ~ THEN REPLY #4052 /* ~"이봐, 이 해골은 어떤가, 모트? 몸으로 쓸만하겠나?"~ */ EXTERN ~DMORTE~ 73
IF ~~ THEN REPLY #4053 /* ~스켈레톤을 그냥 내버려 두고 떠난다.~ */ EXIT
END

IF ~~ THEN BEGIN 5 // from: 4.0
SAY #4008 /* ~갑옷은 오래된 것임에도 불구하고 그 보존 상태가 양호하다. 그것은 환히 반짝이고 있으며, 가슴받이에 새겨진 심벌들은 불빛 아래서 마치 흐르는 것처럼 움직여, 당신이 그것들에게 집중을 하려고 할 때마다 약간씩 그 형체가 변화한다.~ */
IF ~  CheckStatGT(Protagonist,12,INT) CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4054 /* ~심벌들을 연구한다.~ */ GOTO 6
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #4055 /* ~심벌들을 연구한다.~ */ GOTO 6
IF ~  CheckStatLT(Protagonist,13,WIS) CheckStatLT(Protagonist,13,INT) ~ THEN REPLY #64293 /* ~기호들을 연구한다.~ */ GOTO 7
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4056 /* ~스켈레톤의 칼을 그의 손에서 비틀어 빼내려고 시도한다.~ */ GOTO 2
