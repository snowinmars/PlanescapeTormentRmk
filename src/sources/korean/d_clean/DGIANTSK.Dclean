IF ~  True()
~ THEN BEGIN 0 // from:
SAY #292 /* ~당신 앞에는 화려한 청동 갑옷을 입은 자이언트 스켈레톤이 서 있다. 갑옷은 스켈레톤의 골격에 볼트로 고정되어 있으며, 그 가슴받이의 표면 전체에 걸쳐 일련의 정교한 심벌들이 새겨져 있다. 당신은 그 뼈들의 출처가 궁금하다. 당신이 알기로 그토록 거대한 골격을 지닌 인간은 존재하지 않기 때문이다. 그것이 손에 들고 있는 거대한 칼의 무게는 마차 한 대의 무게에 필적할 것처럼 보인다.~ */
IF ~~ THEN REPLY #293 /* ~"내가 잠깐 그 칼을 들고 있어도 괜찮겠소? 틀림없이 당신은 그것을 들고 있는데 지쳤을 거요."~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Giant_Skel_Mort_1","GLOBALLaw",-1) ~ GOTO 1
IF ~~ THEN REPLY #1165 /* ~"그래 얼마나 오랫동안 여기서 서 있었소? 꽤 오랜 시간 동안?"~ */ DO ~IncrementGlobalOnceEx("GLOBALChaotic_Giant_Skel_Mort_1","GLOBALLaw",-1) ~ GOTO 1
IF ~~ THEN REPLY #3996 /* ~자이언트 스켈레톤을 조사한다... 조심스럽게.~ */ GOTO 4
IF ~  GlobalGT("Giant_Skeleton_Enchant","GLOBAL",0) ~ THEN REPLY #3997 /* ~스켈레톤에 가슴받이에 걸린 마법을 당신이 풀 수 있는지 본다. ~ */ GOTO 9
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #3998 /* ~스켈레톤의 칼을 그의 손에서 비틀어 빼내려고 시도한다.~ */ GOTO 2
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #3999 /* ~스켈레톤의 칼을 그의 손에서 비틀어 빼내려고 시도한다.~ */ GOTO 3
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4000 /* ~스켈레톤의 갑옷을 고정시키고 있는 볼트들을 비틀어 빼내려고 시도한다.~ */ GOTO 2
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #4001 /* ~스켈레톤의 갑옷을 고정시키고 있는 볼트들을 비틀어 빼내려고 시도한다.~ */ GOTO 3
IF ~  NearbyDialog("DMorte") Global("Morte_Skel_Mort_Quip","GLOBAL",1) ~ THEN REPLY #4002 /* ~"이봐, 이 해골은 어떤가, 모트? 몸으로 쓸만하겠나?"~ */ EXTERN ~DMORTE~ 73
IF ~  Global("Speak_with_Dead","GLOBAL",1) ~ THEN REPLY #4003 /* ~스켈레톤에게 당신의 뼈들이 해주는 이야기 능력을 사용한다.~ */ GOTO 1
IF ~~ THEN REPLY #4004 /* ~스켈레톤을 그냥 내버려 둔다. ~ */ EXIT
END

IF ~  False()
