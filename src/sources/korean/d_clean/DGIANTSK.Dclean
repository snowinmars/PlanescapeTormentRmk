IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4083 /* ~스켈레톤의 갑옷을 고정시키고 있는 볼트들을 비틀어 빼내려고 시도한다.~ */ GOTO 2
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #4084 /* ~스켈레톤의 갑옷을 고정시키고 있는 볼트들을 비틀어 빼내려고 시도한다.~ */ GOTO 3
