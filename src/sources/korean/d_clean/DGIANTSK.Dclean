END

IF ~~ THEN BEGIN 9 // from: 0.3 1.1 8.0 8.1
SAY #4012 /* ~가슴받이에 새겨진 룬들의 패턴을 훼손하면 마법을 깨트릴 수 있다는 생각이 드나, 쉽지는 않을 듯하다... 패턴은 복잡하며, 엉뚱한 부분을 훼손할 경우 스켈레톤이 깨어날 수도 있다.~ */
IF ~  PartyHasItem("TomeBA") ~ THEN REPLY #64296 /* ~그 패턴을 뼈와 재의 책에 있는 마법들과 비교하여 그것들을 깨트릴 수 있는 방법을 발견할 수 있는지를 알아본다. ~ */ GOTO 16
IF ~~ THEN REPLY #4086 /* ~우선 갑옷의 마법을 유지하는 룬들을 훼손하고, 그 다음에는 사령술과 보호의 마법의 순으로 룬들을 훼손한다.~ */ GOTO 10
IF ~  GlobalLT("Giant_Skeleton_Enchant","GLOBAL",2) ~ THEN REPLY #4087 /* ~우선 보호의 마법을 유지하는 룬들을 훼손한 후, 룬 패턴과는 역순으로 작업하여 사령술과 갑옷의 마법의 순으로 마법을 해제한다. ~ */ DO ~PlaySound("Armsk08") IncrementGlobal("Giant_Skeleton_Enchant","GLOBAL",1) Kill(Myself) ~ GOTO 11
IF ~  GlobalGT("Giant_Skeleton_Enchant","GLOBAL",1) ~ THEN REPLY #4088 /* ~우선 보호의 마법을 유지하는 룬들을 훼손한 후, 룬 패턴과는 역순으로 작업하여 사령술과 갑옷의 마법의 순으로 마법을 해제한다. ~ */ DO ~PlaySound("Armsk08") IncrementGlobal("Giant_Skeleton_Enchant","GLOBAL",1) Kill(Myself) ~ GOTO 13
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4089 /* ~스켈레톤의 칼을 그의 손에서 비틀어 빼내려고 시도한다.~ */ GOTO 2
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #4090 /* ~스켈레톤의 칼을 그의 손에서 비틀어 빼내려고 시도한다.~ */ GOTO 3
IF ~  CheckStatLT(Protagonist,13,WIS) ~ THEN REPLY #4091 /* ~스켈레톤의 갑옷을 고정시키고 있는 볼트들을 비틀어 빼내려고 시도한다.~ */ GOTO 2
IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #4092 /* ~스켈레톤의 갑옷을 고정시키고 있는 볼트들을 비틀어 빼내려고 시도한다.~ */ GOTO 3
IF ~  NearbyDialog("DMorte") Global("Morte_Skel_Mort_Quip","GLOBAL",1) ~ THEN REPLY #4093 /* ~"이봐, 이 해골은 어떤가, 모트? 몸으로 쓸만하겠나?"~ */ EXTERN ~DMORTE~ 73
IF ~~ THEN REPLY #4094 /* ~스켈레톤을 그냥 내버려 두고 떠난다.~ */ EXIT
END

IF ~~ THEN BEGIN 10 // from: 9.1 16.0
SAY #4013 /* ~당신이 가슴받이를 장식하는 룬들을 훼손하기 시작하자 철제 종소리가 시체안치소 안에 울려 퍼지기 시작한다... 그리고 스켈레톤은 번개같은 속도로 깨어나, 칼을 들어 공격한다!~ */
IF ~~ THEN REPLY #4095 /* ~"그냥 죽어있는 게 나을 뻔했다고 생각하게 될 것이네, 해골..."~ */ DO ~Enemy() Attack(Protagonist) ForceAttack(Protagonist,Myself) SetGlobal("Mortuary_Alert","GLOBAL",1) ~ EXIT
END

IF ~~ THEN BEGIN 11 // from: 9.2 16.1
SAY #4014 /* ~그 작업은 처음에는 고통스러울 정도로 어려우나. 서서히 당신은 일에 정신을 집중할 수 있게 되며, 룬들은 당신의 공세 앞에 무릎을 꿇기 시작한다. 몇 분 안에 자이언트 스켈레톤에 걸려 있던 모든 마법은 제거된다. 그것은 무너지면서 굉음과 함께 바닥에 쓰러진다!~ */
IF ~~ THEN REPLY #4096 /* ~"빌어먹을 뼈들...!"~ */ DO ~AddexperienceParty(800) ~ GOTO 12
END

IF ~~ THEN BEGIN 12 // from: 11.0
SAY #4015 /* ~당신은 잠시 기다린다, 하지만 다행히 아무도 그 소리에 반응하지 않는다. 당신은 빠른 동작으로 바닥에 널린 스켈레톤의 잔해들을 살펴본다. 그것들은 대부분 쓸모가 있기에는 너무 낡았거나 무겁다. 하지만 당신은 그 중에서 스켈레톤의 가슴받이의 일부분을 발견하는데, 그것에는 깨어진 마법들 중 하나의 내용 대부분이 새겨져 있다. 당신에게는 그것이 쓸모가 있을 거라는 생각이 든다.~ */
IF ~~ THEN REPLY #4097 /* ~"그럼 그냥 가져가기로 하지..."~ */ DO ~GiveItemCreate("Breast1",Protagonist,1,1,0) ~ EXIT
END

IF ~~ THEN BEGIN 13 // from: 9.3 16.2
SAY #4016 /* ~이번에는 마법을 해제하는 일이 한층 쉽다, 그리고 룬들은 당신의 공세 앞에 금새 무릎을 꿇는다. 불과 몇 분 안에 자이언트 스켈레톤에 걸려 있던 모든 마법은 제거된다. 이전에 무슨 일이 일어났는지를 기억하고 있는 당신은 스켈레톤이 쓰러지기 전에 그것을 잡은 다음, 툴툴거리며 천천히 바닥에 내려놓는다. ~ */
IF ~~ THEN REPLY #4098 /* ~"이번에는 뭐가 나오나 한 번 볼까..."~ */ DO ~AddexperienceParty(800) ~ GOTO 14
END

IF ~~ THEN BEGIN 14 // from: 13.0
SAY #4017 /* ~당신은 재빠르게 스켈레톤의 잔해를 뒤지기 시작한다, 그리고 이번에도 가슴받이의 일부를 발견한다... 첫 번째 것과 마찬가지로 이것에도 깨어진 마법의 일부가 새겨져 있다. 그것은 쓸모가 있을지도 모른다.~ */
IF ~  Global("Giant_Skeleton_Enchant","GLOBAL",3) ~ THEN REPLY #4099 /* ~"그럼 그냥 가져가기로 하지..."~ */ DO ~GiveItemCreate("Breast2",Protagonist,1,1,0) ~ EXIT
IF ~  Global("Giant_Skeleton_Enchant","GLOBAL",4) ~ THEN REPLY #4100 /* ~"그럼 그냥 가져가기로 하지..."~ */ DO ~GiveItemCreate("Breast3",Protagonist,1,1,0) ~ EXIT
IF ~  Global("Giant_Skeleton_Enchant","GLOBAL",5) ~ THEN REPLY #4101 /* ~"그럼 그냥 가져가기로 하지..."~ */ DO ~GiveItemCreate("Breast4",Protagonist,1,1,0) Kill(Myself) ~ EXIT
END

IF ~~ THEN BEGIN 15 // from: 7.0
SAY #64295 /* ~당신이 책에 있는 그림들과 가슴받이 표면에 새겨진 심벌들을 비교한다. 가장 기본적인 레벨의 룬들은 하급 갑옷의 주문이나, 갑옷의 가장자리 부분에 있는 여러 개의 해골 모양의 룬들과 원형 기호들은 당신으로 하여금 갑옷에는 여러 종류의 상급 사령술과 상급 보호 마법 역시 걸려 있는 것이 아닌가 하고 생각하게 만든다. 스켈레톤을 만지면 그것이 깨어나... 자신을 방어할 가능성이 높다.~ */
IF ~~ THEN REPLY #64298 /* ~뼈와 재의 책을 참조하여 그들을 깨트릴 수 있는 방법을 발견할 수 있는지를 알아본다. ~ */ GOTO 16
IF ~~ THEN REPLY #64299 /* ~룬들을 그냥 내버려 두고 스켈레톤을 다시 조사한다.~ */ GOTO 4
END

IF ~~ THEN BEGIN 16 // from: 9.0 15.0
SAY #64297 /* ~당신이 책으로부터 이해한 바에 따르면, 갑옷의 마법은 가슴받이에만 걸려 있고, 스켈레톤이 다시 일어나 움직이게 하는 것은 사령술이나, 그것에게 주변 환경에 대한 기본적인 인지 능력을 부여하고 있는 것은 보호의 마법이다. 만약 당신이 스켈레톤의 룬을 훼손하면 그 행위가 스켈레톤에 의해 공격으로 간주될 것이다... 하지만 사전에 그것이 당신의 존재를 인지할 수 없게 한다면...~ */
IF ~~ THEN REPLY #64300 /* ~우선 갑옷의 마법을 유지하는 룬들을 훼손하고, 그 다음에는 사령술과 보호의 마법의 순으로 룬들을 훼손한다.~ */ GOTO 10
IF ~  GlobalLT("Giant_Skeleton_Enchant","GLOBAL",2) ~ THEN REPLY #64301 /* ~우선 보호의 마법을 유지하는 룬들을 훼손한 후, 룬 패턴과는 역순으로 작업하여 사령술과 갑옷의 마법의 순으로 마법을 해제한다. ~ */ DO ~PlaySound("Armsk08") IncrementGlobal("Giant_Skeleton_Enchant","GLOBAL",1) Kill(Myself) ~ GOTO 11
IF ~  GlobalGT("Giant_Skeleton_Enchant","GLOBAL",1) ~ THEN REPLY #64302 /* ~우선 보호의 마법을 유지하는 룬들을 훼손한 후, 룬 패턴과는 역순으로 작업하여 사령술과 갑옷의 마법의 순으로 마법을 해제한다. ~ */ DO ~PlaySound("Armsk08") IncrementGlobal("Giant_Skeleton_Enchant","GLOBAL",1) Kill(Myself) ~ GOTO 13
IF ~~ THEN REPLY #64303 /* ~룬들을 그냥 내버려 두고 스켈레톤을 다시 조사한다.~ */ GOTO 4
END
