IF ~  Global("Morte_Talent","GLOBAL",1) ~ THEN REPLY #66348 /* ~"모트... 자네의 특수한 재능이 어떤 것들인지 다시 얘기해주겠나?"~ */ GOTO 666
IF ~  Global("Morte_Tattoo_XP","GLOBAL",1) ~ THEN REPLY #66349 /* ~"모트, 내 등에 새겨진 문신의 나머지 한 줄에 대해서 왜 내게 얘기하지 않았나?"~ */ GOTO 654
