IF ~~ THEN REPLY #65540 /* ~"내게 시길에 대해 좀 얘기해줄 수 있겠나?"~ */ GOTO 659
IF ~  Global("Morte_Talent","GLOBAL",0) ~ THEN REPLY #65541 /* ~"모트... 자네가 날 따라오는 건 개의치 않네, 하지만 수다떠는 것 말고 자네가 할 수 있은 없나?"~ */ GOTO 663
IF ~  Global("Morte_Talent","GLOBAL",1) ~ THEN REPLY #65542 /* ~"모트... 자네의 특수한 재능이 어떤 것들인지 다시 얘기해주겠나?"~ */ GOTO 666
IF ~  Global("Morte_Tattoo_XP","GLOBAL",1) ~ THEN REPLY #65543 /* ~"모트, 내 등에 새겨진 문신의 나머지 한 줄에 대해서 왜 내게 얘기하지 않았나?"~ */ GOTO 654
IF ~~ THEN REPLY #65544 /* ~"조언이 좀 필요하네. 우리가 다음에 무엇을 해야 한다고 생각하나?"~ */ GOTO 669
IF ~  Global("Know_Mimir","GLOBAL",1) Global("Morte_Story","GLOBAL",0) ~ THEN REPLY #65545 /* ~"자네는 자신이 미미르라고 했네, 맞나, 모트?"~ */ GOTO 684
IF ~  Global("Morte_Story","GLOBAL",1) ~ THEN REPLY #65546 /* ~"자네가 왜 해골들의 기둥에 떨어지게 되었는지 다시 말해주게."~ */ GOTO 693
IF ~  Global("Know_Morte_Pillar","GLOBAL",1) ~ THEN REPLY #65547 /* ~"모트. 내가 기둥으로부터 자네를 빼낸 후에 왜 나와 함께 여행을 계속한 건가?"~ */ GOTO 715
IF ~  GlobalGT("Know_Blood_War","GLOBAL",0) ~ THEN REPLY #65548 /* ~"자네는 블러드 워에 대해 무엇을 아나?"~ */ GOTO 723
IF ~  GlobalGT("Know_Ravel","GLOBAL",0) Global("Ravel","GLOBAL",0) ~ THEN REPLY #65549 /* ~"자네는 나이트 해그 래벌에 대해 무엇을 아나?"~ */ GOTO 722
IF ~~ THEN REPLY #65550 /* ~"자네는 어떻게 죽었나, 모트?"~ */ GOTO 726
IF ~~ THEN REPLY #65551 /* ~"아무 것도 아니네, 모트. 자네가 아직 나와 함께하고 있는 확인했을 뿐이네."~ */ EXIT
END

IF ~~ THEN BEGIN 330 // from:
SAY #34990 /* ~"잠깐. 대장은 그녀가 날 어떤 눈으로 쳐다보는지 봤어? 허? 보이지? 내 후두부를 바라보는 그녀의 시선이?"~ */
