IF ~  Global("Know_Chaosmen","GLOBAL",1) ~ THEN REPLY #13776 /* ~"그로부터 뭔가를 배울 수 있으리라 생각했는데. 관두세. 가세."~ */ DO ~SetGlobal("Morte_SDThug_Quip_1","GLOBAL",1) ~ EXIT
