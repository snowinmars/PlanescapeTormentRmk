IF ~  GlobalGT("Fortress_Annah","GLOBAL",0) ~ THEN REPLY #68175 /* ~안나를 소생시킨다.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204a0",FALSE) ~ EXIT
IF ~  GlobalGT("Fortress_Dakkon","GLOBAL",0) ~ THEN REPLY #68179 /* ~다콘을 소생시킨다.~ */ DO ~StartCutSceneMode() StartCutSceneEx("1204d0",FALSE) ~ EXIT
