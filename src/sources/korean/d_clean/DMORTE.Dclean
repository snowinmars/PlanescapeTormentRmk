IF ~  Global("Morte_Story","GLOBAL",1) ~ THEN REPLY #66352 /* ~"자네가 왜 해골들의 기둥에 떨어지게 되었는지 다시 말해주게."~ */ GOTO 693
IF ~  Global("Know_Morte_Pillar","GLOBAL",1) ~ THEN REPLY #66353 /* ~"모트. 내가 기둥으로부터 자네를 빼낸 후에 왜 나와 함께 여행을 계속한 건가?"~ */ GOTO 715
