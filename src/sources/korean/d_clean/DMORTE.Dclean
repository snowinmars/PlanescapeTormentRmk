IF ~  Global("Good_Ingress_Teeth_1","GLOBAL",1) ~ THEN REPLY #11990 /* ~"어... 복수는 아무에게도 도움이 되지 않네, 모트. 어... 가세.~ */ EXIT
IF ~  Global("Evil_Ingress_Teeth_1","GLOBAL",1) ~ THEN REPLY #11991 /* ~"나중에 내게 감사할 걸세. 두고 보라고."~ */ EXIT
