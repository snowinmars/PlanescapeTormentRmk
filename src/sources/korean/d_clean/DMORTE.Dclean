IF ~~ THEN REPLY #1113 /* ~"나는 이 곳에 있어야 하는 건가? 난 죽었나?"~ */ GOTO 7
IF ~~ THEN REPLY #1114 /* ~"내 모습이 어떤가? 흉터가 심한가?"~ */ GOTO 13
IF ~~ THEN REPLY #1115 /* ~"관두게. 그 밖에도 질문할 것들이 좀 있네... "~ */ GOTO 31
