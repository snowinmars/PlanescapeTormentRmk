IF ~~ THEN BEGIN 139 // from:
SAY #11948 /* ~"말도 안돼." 모트는 몸서리친다. "대장이라면 그런 걸 몸 안에 넣고 싶겠어?"~ */
IF ~~ THEN REPLY #11976 /* ~"자, 모트, 그들을 좋아하는 것 같네. 그들이 자네를 쳐다보는 모습 좀 보게."~ */ GOTO 140
IF ~~ THEN REPLY #11977 /* ~모트를 잡아 그의 입에 그 이빨들을 밀어 넣는다.~ */ DO ~SetGlobal("Ingress_Teeth_Installed","GLOBAL",1) IncrementGlobalOnceEx("GLOBALChaotic_Ingress_Teeth_2","GLOBALLaw",-1) IncrementGlobalOnceEx("GLOBALEvil_Ingress_Teeth_1","GLOBALGood",-1) ~ GOTO 141
