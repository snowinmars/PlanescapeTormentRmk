IF ~~ THEN REPLY #11980 /* ~모트를 잡아 그의 입에 그 이빨들을 밀어 넣는다.~ */ DO ~SetGlobal("Ingress_Teeth_Installed","GLOBAL",1) IncrementGlobalOnceEx("GLOBALChaotic_Ingress_Teeth_2","GLOBALLaw",-1) IncrementGlobalOnceEx("GLOBALEvil_Ingress_Teeth_1","GLOBALGood",-1) ~ GOTO 141
IF ~~ THEN REPLY #11981 /* ~"그럼 관두게."~ */ EXIT
