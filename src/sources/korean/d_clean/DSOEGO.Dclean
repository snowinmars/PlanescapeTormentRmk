IF ~~ THEN REPLY #4945 /* ~"그렇소 이제 가서 애도의 뜻을 표하도록 하겠소."~ */ GOTO 62
END

IF ~~ THEN BEGIN 48 // from: 47.0
SAY #4946 /* ~"모르겠소, 하지만 그녀는 이 곳에 상당히 오래 전부터 있었소. 그녀의 아버지라면 그녀에게 어떤 일이 일어났었는지 알지 모르오... 그는 상부 구역에 있는 사무실로부터 이 곳을 자주 방문하오. 그녀가 이 곳의 기념 홀에 안장된 것은 그의 희망에 의한 것이었소."~ */
