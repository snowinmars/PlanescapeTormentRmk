IF ~  CheckStatGT(Protagonist,10,CHR) ~ THEN REPLY #1440 /* ~죽은듯이 조용히 한다.~ */ GOTO 3
IF ~  CheckStatLT(Protagonist,11,CHR) ~ THEN REPLY #1441 /* ~죽은듯이 조용히 한다.~ */ GOTO 4
