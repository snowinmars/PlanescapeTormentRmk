END

IF ~~ THEN BEGIN 51 // from: 41.5 50.5 53.5
SAY #4957 /* ~당신이 몸을 구부리자 소에고는 눈살을 찌푸린다, 그리고 당신은 그가 무슨 시험이라도 하듯 공기 냄새를 맡고 있다는 것을 알아챈다. 그는 마치 당장이라도 경비병들을 부를 것처럼 눈을 가늘게 뜬다.~ */
IF ~  CheckStatGT(Protagonist,12,DEX) ~ THEN REPLY #4958 /* ~그가 미처 소리를 지르기 전에 그의 목을 부러트린다.~ */ GOTO 19
