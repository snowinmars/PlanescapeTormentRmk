IF ~~ THEN REPLY #1434 /* ~"이 곳은 어떤 곳이오?"~ */ GOTO 1
IF ~~ THEN REPLY #1435 /* ~"질문할 것들이 좀 있소..."~ */ GOTO 1
IF ~~ THEN REPLY #1436 /* ~그를 그냥 내버려 두고 떠난다.~ */ EXIT
