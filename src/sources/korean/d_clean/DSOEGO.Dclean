SAY #66710 /* ~당신이 말을 반쯤 끝냈을 때, 소에고가 갑자기 입을 연다, 그러자 더럽고 날카로운 이빨들이 드러난다. 그는 당신에게 다가와 킁킁거리며 냄새를 맡는다. ~ */
IF ~~ THEN REPLY #66715 /* ~"어... 내 냄새를 맡는 이유가 대체 뭐요?"~ */ GOTO 115
IF ~  CheckStatLT(Protagonist,13,DEX) ~ THEN REPLY #66716 /* ~그가 몸을 구부릴 때 목을 부러트린다.~ */ GOTO 22
IF ~  CheckStatGT(Protagonist,12,DEX) ~ THEN REPLY #66717 /* ~그가 몸을 구부릴 때 목을 부러트린다.~ */ GOTO 19
IF ~~ THEN REPLY #66718 /* ~"관두시오... 안녕히 계시오."~ */ GOTO 17
END

IF ~~ THEN BEGIN 115 // from: 114.0
SAY #66711 /* ~"당신 옷... 이 법복... 냄새가 다르오. 그건 당신 것이 아니오." 소에고는 입가에 기묘한 미소를 띄운다, 그리고 그의 눈은 야수와 같은 눈빛으로 번득인다. "당신은 대체 누구요."~ */
IF ~~ THEN REPLY #66719 /* ~"나는 평화롭게 이 곳을 떠나기 위해 이 법복을 훔쳤을 뿐이오. 나는 위층의 준비실들 중 하나에서 눈을 떴소."~ */ GOTO 42
IF ~~ THEN REPLY #66720 /* ~"당신 말이 맞소. 이 법복은 내 것이 아니오, 하지만 그것이 원래 누구 것이었는지 당신이 알 바가 아니오."~ */ GOTO 6
IF ~  CheckStatLT(Protagonist,13,DEX) ~ THEN REPLY #66721 /* ~그가 도와달라고 외치기 전에 그의 목을 부러트린다. ~ */ GOTO 22
IF ~  CheckStatGT(Protagonist,12,DEX) ~ THEN REPLY #66722 /* ~그가 도와달라고 외치기 전에 그의 목을 부러트린다. ~ */ GOTO 19
IF ~~ THEN REPLY #66723 /* ~"상관없는 일이오. 이만 떠나도록 하겠소."~ */ GOTO 17
END
