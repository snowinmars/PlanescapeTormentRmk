SAY #20061 /* ~"또 왔소?" 그는 환하게 미소를 짓는다. ~ */
IF ~~ THEN REPLY #20063 /* ~"질문할 것들이 좀 있소..."~ */ GOTO 22
IF ~~ THEN REPLY #20064 /* ~"그냥 지나다가 들렸을 뿐이오. 안녕히 계시오."~ */ EXIT
END

