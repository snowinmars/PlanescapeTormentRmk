IF ~  Global("Speak_with_Dead","GLOBAL",1) ~ THEN REPLY #6568 /* ~시체에게 당신의 뼈들이 해주는 이야기 능력을 사용한다.~ */ DO ~SetGlobal("Asonje","GLOBAL",1) ~ GOTO 2
