IF ~~ THEN REPLY #9308 /* ~"당신은 어디서 왔소?"~ */ GOTO 16
IF ~~ THEN REPLY #9309 /* ~"당신은 어떻게 이 곳에 오게 되었소? 내 말은 좀비로서 말이오."~ */ GOTO 17
IF ~~ THEN REPLY #9310 /* ~"당신은 어디 있소... 당신의 혼령은 이제 어디에 있소?"~ */ GOTO 18
IF ~~ THEN REPLY #9311 /* ~"이 곳에 대해 무엇을 아시오?"~ */ GOTO 19
IF ~  Global("Pharod","GLOBAL",0) ~ THEN REPLY #9312 /* ~"파로드란 이름의 사람을 아시오?"~ */ GOTO 20
IF ~~ THEN REPLY #9321 /* ~"아무 것도 아니오. 신경 쓰지 마시오."~ */ EXIT
END

IF ~~ THEN BEGIN 23 // from: 21.1
SAY #9244 /* ~당신의 낭패를 눈치챈 혼령은 정답게 웃는다. "거참 딱한 일이오! 그럼 그냥 아단이라고 합시다, 친구. 자, 내게 뭐 물어볼 거라도 있소?"~ */
IF ~~ THEN REPLY #9313 /* ~"그렇소..."~ */ GOTO 22
IF ~~ THEN REPLY #9314 /* ~"아니오. 안녕히 계시오."~ */ EXIT
END

IF ~~ THEN BEGIN 24 // from: 19.0
SAY #9245 /* ~"뭐, 시길?" 당신이 고개를 끄덕이는 것을 보자 그는 장난기 어린 얼굴로 히죽 웃는다. "아, 미리 얘기해서 당신 흥을 깨는 일은 하지 않겠소! 가서 당신 눈으로 직접 보시오! 그 곳의 거리, 선술집, 그리고 사람들 사이에서 마음껏 헤매 보시오. 하지만 조심을 하시오! 시길은 멋진 곳이지만 동시에 매우 위험한 곳이기도 하오. 하지만 바로 그 점이 이 도시를 흥미롭게 만든다오. 그렇게 생각하지 않소?"~ */
IF ~~ THEN REPLY #9315 /* ~"그렇겠군... 다른 질문이 있소..."~ */ GOTO 22
IF ~~ THEN REPLY #9316 /* ~"아마 그럴지도. 안녕히 계시오."~ */ EXIT
END

IF ~~ THEN BEGIN 25 // from: 14.1 22.1
SAY #9283 /* ~"내 이름은 아손제였소."~ */
IF ~~ THEN REPLY #9284 /* ~"다른 질문이 있소..."~ */ GOTO 22
IF ~~ THEN REPLY #9285 /* ~"내가 알고 싶었던 건 그것이 전부요. 안녕히 계시오."~ */ EXIT
END

