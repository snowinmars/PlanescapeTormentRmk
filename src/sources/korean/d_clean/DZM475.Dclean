IF ~  True()
~ THEN BEGIN 0 // from:
SAY #6584 /* ~이 시체의 머리는 여러 개의 얇은 철판을 볼트로 해골에 직접 덧대 놓은 기형적인 모습을 하고 있다. 왼쪽 눈을 덮고 있는 녹슨 철판에는 "475"라는 숫자가 새겨져 있다. 볼트로 굳게 닫아 놓은 입에서는 방부제의 악취가 나고 있다.~ */
IF ~  Global("Zombie_Chaotic","GLOBAL",0) ~ THEN REPLY #6587 /* ~"그래... 뭐 재미있는 일은 없소?"~ */ DO ~IncrementGlobal("Law","GLOBAL",-1) SetGlobal("Zombie_Chaotic","GLOBAL",1) ~ GOTO 1
IF ~  Global("Zombie_Chaotic","GLOBAL",1) ~ THEN REPLY #6588 /* ~"그래... 뭐 재미있는 일은 없소?"~ */ GOTO 1
