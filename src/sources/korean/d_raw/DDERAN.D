  IF ~~ THEN REPLY #35894 /* ~"당신은 노예를 판매하오?"~ */ GOTO 3
  IF ~~ THEN REPLY #35895 /* ~"그 밖에도 물어보고 싶은 것들이 좀 있소..."~ */ GOTO 7
  IF ~~ THEN REPLY #35896 /* ~"사양하겠소, 안녕히 계시오."~ */ EXIT
END

