  IF ~~ THEN REPLY #10773 /* ~"그럼 당신은 존재의 비밀을 알지 못하오?"~ */ GOTO 19
  IF ~~ THEN REPLY #10774 /* ~"그럼 당신은 아무 것도 알지 못하오. 하지만 내 질문들에는 대한 답은 알고 있지 않겠소?"~ */ GOTO 11
  IF ~~ THEN REPLY #10775 /* ~"여러 수준에 걸친 훌륭한 암유요. 안녕히 계시오."~ */ EXIT
END

IF ~~ THEN BEGIN 19 // from: 18.0
  SAY #10776 /* ~"그렇게 말하지는 않았소. 설령 홀로 있더라도 하나의 글자는 강대한 힘을 지니고 있소. 내가 그대에게 보여 주리다." 그는 입을 점점 더 크게 벌린다. 그의 안면은 눈, 입, 그리고 코 주변에서 찢어지며 당신이 전에 흘긋 본 적이 있는 영원의 극히 일부를 드러낸다. 당신은 그 안에서 방향을 잃고 떠다닌다... 잠시 후 당신은 다시 세속적인 감각으로 돌아온다, 그리고 O가 사라졌다는 사실을 깨닫는다. 하지만 그 체험을 통해 당신의 시야와 견식은 한층 넓어졌다. ~ */
  IF ~~ THEN REPLY #10777 /* ~"그건... 형언할 수가 없었소."~ */ DO ~PermanentStatChange(Protagonist,WIS,RAISE,1)
DestroySelf()
~ EXIT
END

IF ~~ THEN BEGIN 20 // from: 1.4 11.3
  SAY #10778 /* ~"이 장소에는 여러 종류의 사람들이 있소, 하지만 모두 죽어야 하는 존재라는 점에서는 차이가 없소. 다른 사람들과 마찬가지로 그들의 관심은 극히 제한되어 있으며, 진실을 깨달을 가능성도 지니고 있소. 하지만 그대에게 이 사실은 이야기해줄 수 있소: 그대는 여기서 그대에게 소중한 동료를 만날지도 모르오 - 적어도 당신 마음이 허용하는 한도 내에서 소중한 동료를."~ */
  IF ~~ THEN REPLY #10779 /* ~"난 모욕을 당한 것 같소, 하지만 그냥 넘어가 주도록 하겠소. 다른 질문에나 대답해주시오."~ */ GOTO 11
  IF ~~ THEN REPLY #10780 /* ~"나는 당신 말투가 마음에 들지 않소."~ */ GOTO 4
  IF ~~ THEN REPLY #10781 /* ~"고맙소. 안녕히 계시오."~ */ EXIT
END
