        '"그녀는 날 안다고 하나 난 그녀를 기억할 수가 없소."' if dhallLogic.r5072_condition():
            # a3 # r5072
            jump dhall_s28

        '"당신은 다른 이들도 있었다고 했소. 이 곳에 또 누가 있소?"' if dhallLogic.r5073_condition():
            # a4 # r5073
            jump dhall_s12

        '"당신은 다른 이들도 있었다고 했소. 이 곳에 또 누가 있소?"' if dhallLogic.r5074_condition():
            # a5 # r5074
            jump dhall_s12

        '"아마 그럴지도. 그 밖에도 당신에게 물어보고 싶은 것들이 좀 있소…"':
            # a6 # r6063
            jump dhall_s9

        '"아래층에 있는 기념 홀로 가서 그녀의 유해를 찾을 수 있는지 보겠소."' if dhallLogic.r6064_condition():
            # a7 # r6064
