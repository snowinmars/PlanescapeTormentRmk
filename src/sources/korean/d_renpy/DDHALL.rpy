    menu:
        '"그녀의 유해는 어디 있소?"' if dhallLogic.r5070_condition():
            # a1 # r5070
            jump dhall_s42

        '"나는 그녀에 대해 아무 것도 모르오."' if dhallLogic.r5071_condition():
