    menu:
        '"왜 더스트맨이 내가 죽기를 바라는지 설명해 줄 수 있겠소?"' if dhallLogic.r6032_condition():
            # a174 # r6032
            jump dhall_s22

        '"진정한 죽음?"':
            # a175 # r6033
            $ dhallLogic.r6033_action()
