# s0 # say6562
label zm1094_s0: # - # IF ~  Global("Asonje","GLOBAL",0)
    nr '이 걸어다니는 시체의 이마에는 "1094"이라는 번호가 새겨져 있다. 그것의 입은 단단히 꿰매져 있으며, 그것의 전신으로부터는 신선한 포름알데히드의 냄새가 강렬하게 발산되고 있다. 창백하고 움푹 들어간 용모와 생기없는 우윳빛 눈에도 불구하고, 그것은 한때 잘생긴 청년이었음이 틀림없다.{#zm1094_s0_1}'

    menu:
        '"그래… 뭐 재미있는 일은 없소?"{#zm1094_s0_r6565}' if zm1094Logic.r6565_condition():
            # a0 # r6565
            $ zm1094Logic.r6565_action()
            jump zm1094_s1

        '"그래… 뭐 재미있는 일이라도 있소?"{#zm1094_s0_r6566}' if zm1094Logic.r6566_condition():
            # a1 # r6566
            jump zm1094_s1

        '"난 당신이 좀비가 아니라는 걸 아오. 당신은 아무도 속이지 못할 거요."{#zm1094_s0_r6567}' if zm1094Logic.r6567_condition():
            # a2 # r6567
            jump zm1094_s1

        '시체에게 당신의 뼈들이 해주는 이야기 능력을 사용한다.{#zm1094_s0_r6568}' if zm1094Logic.r6568_condition():
            # a3 # r6568
            $ zm1094Logic.r6568_action()
            jump zm1094_s2

        '"당신과 얘기를 나눌 수가 있어서 즐거웠소. 안녕히 계시오."{#zm1094_s0_r6569}':
            # a4 # r6569
            jump zm1094_dispose

        '시체를 그냥 내버려 두고 떠난다.{#zm1094_s0_r6570}':
