# s0 # say6518
label zm1146_s0: # - # IF ~  Global("Crispy","GLOBAL",0)
    nr '이 걸어다니는 시체의 이마에는 "1146"이라는 번호가 새겨져 있으며, 그 입술은 굵고 거친 실로 꿰매져 있다. 시체는 불에 타서 죽은 듯 전신에 당신 것보다 더 끔찍한 흉터들로 뒤덮여 있다. 그것에는 코, 귀, 그리고 손가락 몇 개가 없는데, 아마 오래 전의 대화재에 의하여 타 없어진 것 같다. 당신이 „그것의 “관심„을 끌기 위해 길을 막고 서자, 그것은 당신을 공허한 눈으로 바라본다.{#zm1146_s0_}'

    menu:
        '"그래… 뭐 재미있는 일은 없소?"{#zm1146_s0_r6521}' if zm1146Logic.r6521_condition():
            # a0 # r6521
            $ zm1146Logic.r6521_action()
            jump zm1146_s1

        '"그래… 뭐 재미있는 일은 없소?"{#zm1146_s0_r6522}' if zm1146Logic.r6522_condition():
            # a1 # r6522
            jump zm1146_s1

        '"난 당신이 좀비가 아니라는 것을 아오. 당신은 아무도 속이지 못할 거요."{#zm1146_s0_r6523}' if zm1146Logic.r6523_condition():
            # a2 # r6523
            jump zm1146_s1

        '시체에게 당신의 뼈들이 해주는 이야기 능력을 사용한다.{#zm1146_s0_r6524}' if zm1146Logic.r6524_condition():
            # a3 # r6524
            $ zm1146Logic.r6524_action()
            jump zm1146_s2

        '"당신과 얘기를 나눌 수가 있어서 즐거웠소. 안녕히 계시오."{#zm1146_s0_r6525}':
            # a4 # r6525
            jump zm1146_dispose

        '시체를 그냥 내버려 두고 떠난다.{#zm1146_s0_r6526}':
            # a5 # r6526
            jump zm1146_dispose


