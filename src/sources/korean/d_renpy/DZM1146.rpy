            # a24 # r9430
            jump zm1146_s12

        '"당신은 어디 있소… 당신의 혼령은 이제 어디에 있소?"{#zm1146_s9_r9431}':
            # a25 # r9431
            jump zm1146_s13

        '"무슨 짓을 했기에 그런 고통을 겪게 된 거요?"{#zm1146_s9_r9432}':
            # a26 # r9432
            jump zm1146_s14

        '"이 곳에 대해 무엇을 아시오?"{#zm1146_s9_r9433}':
            # a27 # r9433
            jump zm1146_s15

        '"파로드란 이름의 사람을 아시오?"{#zm1146_s9_r9434}' if zm1146Logic.r9434_condition():
