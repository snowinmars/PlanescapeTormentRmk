IF ~  CheckStatGT(Protagonist,12,WIS) ~ THEN REPLY #5083 /* ~"Wspomniałeś wcześniej, że pochowani są tu również inni, którzy ze mną podróżowali. Gdzie oni są?"~ */ GOTO 12
