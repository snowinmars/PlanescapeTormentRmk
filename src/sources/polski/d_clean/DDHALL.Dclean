IF ~~ THEN BEGIN 48 // from: 32.1 33.0 38.0 41.1 47.1
SAY #848 /* ~"Prawdziwa Śmierć to niebyt. Stan pozbawienia myśli, zmysłów, uczuć." Dhall kaszle, po czym bierze chrapliwy oddech. "Stan czystości."~ */
