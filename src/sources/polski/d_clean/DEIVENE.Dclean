IF ~  Global("Embalm_Key_Quest","GLOBAL",1) !HasItem("KeyEm","EiVene") ~ THEN REPLY #3502 /* ~"Poczekaj chwilę." (Robisz ręką ruch jakbyś obracał klucz.) "Potrzebuję klucza, masz taki?"~ */ GOTO 24
