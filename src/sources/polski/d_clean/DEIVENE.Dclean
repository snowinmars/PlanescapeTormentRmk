IF ~~ THEN BEGIN 24 // from: 14.1 17.2 22.1
SAY #4200 /* ~Pochyla się, patrzy na ruchy twoich dłoni, pociąga nosem. Jej dłoń znika w fałdach togi, szpera tam przez chwilę i wzrusza ramionami. "Nie mieć klucz." Robi ruch, jakby chciała coś pokazać. "Idź - idź - idź".~ */
IF ~~ THEN REPLY #4201 /* ~Odejdź.~ */ EXIT
END

IF ~~ THEN BEGIN 25 // from:
SAY #4353 /* ~Przyglądasz jej się przez chwilę, a rytm jej dłoni wywołuje dwa wspomnienia. Pierwsze - gry na jakimś instrumencie strunowym, może na harfie. Drugie o kradzieży sakiewki... ku twemu zdumieniu to wspomnienie wywołuje nagłą pokusę, by dobrać się do kieszeni Ei-Vene.  Uwaga: Odzyskałeś część pamięci. Wspomnienia mogą przynieść ci dodatkowe punkty doświadczenia, umiejętności, a nawet umożliwić dalsze odzyskiwanie pamięci.~ */
IF ~  Global("EiVene_Delivery","GLOBAL",0) ~ THEN REPLY #4354 /* ~Klepnij ją w ramię, ściągnij jej uwagę.~ */ GOTO 17
IF ~  Global("EiVene_Delivery","GLOBAL",1) ~ THEN REPLY #4355 /* ~Klepnij ją w ramię, ściągnij jej uwagę.~ */ GOTO 22
IF ~~ THEN REPLY #4356 /* ~Odejdź.~ */ EXIT
END

IF ~~ THEN BEGIN 26 // from: 16.0
SAY #63477 /* ~...stoisz przed świeżymi zwłokami, ich wargi wykrzywia stężenie pośmiertne; na głowie wydrapany został numer '42'. Zombi leży na płycie, a ty właśnie skończyłeś zszywać jego klatkę piersiową. Włożyłeś coś do środka, coś, co może okazać się przydatne, gdybyś jeszcze tędy przechodził...~ */
IF ~  Global("42_Secret","GLOBAL",0) ~ THEN REPLY #63478 /* ~Echo: "Pilnuj tych rzeczy i poczekaj, aż wrócę."~ */ DO ~GiveExperience(Protagonist,250) SetGlobal("42_Secret","GLOBAL",1) ~ GOTO 27
IF ~  Global("42_Secret","GLOBAL",1) ~ THEN REPLY #63479 /* ~Echo: "Pilnuj tych rzeczy i poczekaj, aż wrócę."~ */ GOTO 27
END

IF ~~ THEN BEGIN 27 // from: 26.0 26.1
SAY #63480 /* ~Wspomnienie głosu to dziwne puste echo w twych uszach. Krzyżujesz ramiona na piersiach i ku twemu zdumieniu zwłoki robią to samo. Po chwili jego ręce opadają z powrotem i wizja znika... do czasu, gdy jeszcze raz obserwujesz jak Ei-Vene robi ruchy jakby coś zszywała.~ */
IF ~  Global("EiVene_Delivery","GLOBAL",0) ~ THEN REPLY #63482 /* ~Klepnij ją w ramię, ściągnij jej uwagę.~ */ GOTO 17
IF ~  Global("EiVene_Delivery","GLOBAL",1) ~ THEN REPLY #63481 /* ~Klepnij ją w ramię, ściągnij jej uwagę.~ */ GOTO 22
IF ~~ THEN REPLY #63483 /* ~Odejdź.~ */ EXIT
END
