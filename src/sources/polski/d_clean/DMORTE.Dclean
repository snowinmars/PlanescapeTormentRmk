IF ~~ THEN EXTERN ~DDHALL~ 1
END

IF ~~ THEN BEGIN 105 // from:
SAY #6071 /* ~"Znowu jesteś ze mną, szefie? Już myślałem, że utonąłeś w myślach."~ */
