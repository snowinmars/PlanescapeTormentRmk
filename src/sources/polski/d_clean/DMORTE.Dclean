IF ~  PartyGoldGT(99) ~ THEN REPLY #18836 /* ~Daj mu sto miedziaków.~ */ DO ~TakePartyGold(100) IncrementGlobalOnceEx("GLOBALGood_Yellow_2","GLOBALGood",1) ~ EXTERN ~DCOLYLFN~ 53
IF ~~ THEN REPLY #18837 /* ~"Odwołuję co powiedziałem. Odejdź, i nie pokazuj mi się już więcej na oczy."~ */ EXTERN ~DCOLYLFN~ 61
END

