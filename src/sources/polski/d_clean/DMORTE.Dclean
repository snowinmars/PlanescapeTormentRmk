IF ~  CheckStatGT(Protagonist,14,CHR) ~ THEN REPLY #28744 /* ~"Przepraszam, przyjacielu. Chodziło mi tylko o to, żeby z nim zablefować."~ */ DO ~IncrementGlobal("BD_MORTE_MORALE","GLOBAL",2) SetGlobal("Morte_Stolen","GLOBAL",3) ~ GOTO 282
IF ~  CheckStatLT(Protagonist,15,CHR) ~ THEN REPLY #28745 /* ~"Przepraszam, przyjacielu. Chodziło mi tylko o to, żeby z nim zablefować."~ */ DO ~SetGlobal("Morte_Stolen","GLOBAL",3) ~ GOTO 283
