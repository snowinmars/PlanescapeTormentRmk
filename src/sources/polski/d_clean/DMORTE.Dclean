IF ~  Global("Know_Ravel","GLOBAL",1) Global("Know_Ravel_Key","GLOBAL",0) ~ THEN REPLY #65644 /* ~"Mów dalej..."~ */ GOTO 675
IF ~  Global("Know_Ravel","GLOBAL",1) GlobalGT("Know_Ravel_Key","GLOBAL",0) Global("AR0610_Visited","GLOBAL",0) ~ THEN REPLY #65645 /* ~"Mów dalej..."~ */ GOTO 677
IF ~  Global("AR0610_Visited","GLOBAL",1) Global("AR0700_Visited","GLOBAL",0) ~ THEN REPLY #65646 /* ~"Mów dalej..."~ */ GOTO 680
