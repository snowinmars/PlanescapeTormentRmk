IF ~  Global("Where_Fhjull","AR1001",0) ~ THEN REPLY #53836 /* ~"Dobrze, Morte. Słupie Czaszek: Jaki inny rodzaj trybutu zgodzisz się przyjąć?"~ */ EXTERN ~DPILLAR~ 19
IF ~  Global("Where_Fhjull","AR1001",1) PartyHasItem("Cube") ~ THEN REPLY #53837 /* ~"Dobrze, Morte. Słupie Czaszek: Jaki inny rodzaj trybutu zgodzisz się przyjąć?"~ */ EXTERN ~DPILLAR~ 20
