IF ~~ THEN BEGIN 552 // from: 548.3 551.0
SAY #54243 /* ~"Nic więcej nie mogę ci powiedzieć. Pamiętaj tylko, że zaraz jak tam przybędziemy, na pewno zostaniemy rozłączeni. To OGROMNE miejsce, wszędzie czają się cienie... i gdzieś w tej Fortecy znajduje się coś lub ktoś bardziej potężny niż *ktokolwiek* z nas."~ */
IF ~~ THEN REPLY #54244 /* ~"Jesteś *pewien*? Może nie będziemy już mieli szansy ze sobą porozmawiać..."~ */ DO ~SetGlobal("Morte_Quip_Regret_Portal","GLOBAL",2) ~ GOTO 553
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) InParty("Morte") ~ THEN REPLY #54245 /* ~"Mniejsza z tym, Morte. Jestem gotowy, żeby przejść przez portal - idziesz ze mną?"~ */ GOTO 534
