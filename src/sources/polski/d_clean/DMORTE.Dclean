IF ~  NearbyDialog("DDakkon") CheckStatGT(Protagonist,13,WIS) ~ THEN REPLY #54166 /* ~"Gdzie 'BYLIŚMY'? O czym ty gadasz?"~ */ EXTERN ~DDAKKON~ 174
IF ~  NearbyDialog("DDakkon") CheckStatLT(Protagonist,14,WIS) ~ THEN REPLY #54167 /* ~"Gdzie 'BYLIŚMY'? O czym ty gadasz?"~ */ GOTO 540
END

