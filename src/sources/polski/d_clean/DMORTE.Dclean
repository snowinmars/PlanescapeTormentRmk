END

IF ~~ THEN BEGIN 557 // from: 556.0
SAY #54277 /* ~"Nie..." Morte kręci przecząco głową. "To nie o to chodzi. Nie zawsze chodzi o to, kto ma najwięcej sprytu, albo kto jest najsilniejszy, albo najtwardszy... czasami najważniejsze jest to, kim się jest i czego się *naprawdę* chce. Chodzi o to, że kiedyś chciałeś stać się nieśmiertelny - ale czy to jest właśnie to, czego *naprawdę* chcesz? Chcę tylko powiedzieć, że tym razem musisz być pewien tego, o co ci chodzi."~ */
IF ~  InParty("Morte") Global("Morte_Morale_Fortress_Portal","AR0202",0) ~ THEN REPLY #54278 /* ~"Dzięki za szczerość. Słuchaj, Morte... Nie mówiliśmy o tym, ale nie musisz ze mną tam iść. Zrozumiem, jeśli nie będziesz chciał mi towarzyszyć."~ */ DO ~IncrementGlobal("BD_MORTE_MORALE","GLOBAL",1) SetGlobal("Morte_Morale_Fortress_Portal","AR0202",1) ~ GOTO 558
IF ~  InParty("Morte") ~ THEN REPLY #54279 /* ~"Rozumiem. Jeśli jesteś gotów, to ruszajmy, dobrze?"~ */ GOTO 534
IF ~  !InParty("Morte") ~ THEN REPLY #54280 /* ~"Rozumiem. Dzięki za radę, Morte. Teraz przejdę przez portal."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 558 // from: 557.0
SAY #54281 /* ~"Tak... Wiem, szefie. I nie mogę cię okłamywać... Nie chcę iść... ale pójdę. Wiedz tylko, że kiedy przekroczymy portal, to już nie będzie chodziło tylko o *ciebie*. Tam będzie chodziło o nasze życia, a nas po śmierci nikt nie zastąpi."~ */
IF ~  GlobalGT("Ravel_Grace","GLOBAL",0) GlobalGT("Ravel_Morte","GLOBAL",0) GlobalLT("Torment_Fell","GLOBAL",2) NearbyDialog("Dgrace") ~ THEN REPLY #54282 /* ~"W takim razie dlaczego ty..."~ */ EXTERN ~DGRACE~ 169
IF ~  GlobalGT("Ravel_Grace","GLOBAL",0) GlobalGT("Ravel_Morte","GLOBAL",0) Global("Torment_Fell","GLOBAL",2) NearbyDialog("Dgrace") ~ THEN REPLY #54283 /* ~"W takim razie dlaczego ty..."~ */ EXTERN ~DGRACE~ 170
IF ~  GlobalGT("Ravel_Morte","GLOBAL",0) GlobalLT("Torment_Fell","GLOBAL",2) !NearbyDialog("Dgrace") ~ THEN REPLY #54284 /* ~"W takim razie dlaczego ty..."~ */ GOTO 562
