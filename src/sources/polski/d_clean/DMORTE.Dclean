SAY #53831 /* ~"Szefie?! Nie! Nie! *Nie możesz* tego zrobić!"~ */
IF ~  Global("Specialist","GLOBAL",4) ~ THEN REPLY #53832 /* ~"Nie martw się, Morte - wyciągnę cię później z powrotem."~ */ GOTO 530
IF ~  Global("Specialist","GLOBAL",5) ~ THEN REPLY #53833 /* ~"Nie martw się, Morte - wyciągnę cię później z powrotem."~ */ GOTO 530
IF ~  Global("Specialist","GLOBAL",6) ~ THEN REPLY #53834 /* ~"Nie martw się, Morte - wyciągnę cię później z powrotem."~ */ GOTO 530
