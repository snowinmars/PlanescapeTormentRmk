IF ~~ THEN REPLY #18828 /* ~"Teraz, gdy już mamy to za sobą, Żółtopalcy, mam do ciebie parę pytań..."~ */ EXTERN ~DCOLYLFN~ 23
IF ~  CheckStatGT(Protagonist,11,INT) ~ THEN REPLY #18829 /* ~"Żegnaj, Żółtopalcy."~ */ EXTERN ~DCOLYLFN~ 41
