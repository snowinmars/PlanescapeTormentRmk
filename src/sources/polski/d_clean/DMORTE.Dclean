IF ~~ THEN BEGIN 209 // from:
SAY #20471 /* ~Morte odwraca się w kierunku Marty. "Tak, 'trzewusie'." Potem czaszka odwraca się do ciebie. "Ach, ta semantyka."~ */
IF ~  GlobalLT("Know_Marta_Work","GLOBAL",3) ~ THEN REPLY #20612 /* ~"Marto, dlaczego wyciągasz z tych zwłok zęby i szwy?"~ */ DO ~SetGlobal("Know_Marta_Work","GLOBAL",3) JOURNAL #20538 /* ~Zadaniem Marty Szwaczki jest chyba zajmowanie się przyniesionymi do niej zwłokami. Wyrywa im zęby, rozpruwa szwy, szuka wszelakich cennych rzeczy jakie mogłyby znajdować się w ciele, a następnie zszywa zwłoki z powrotem.~ */ EXTERN ~DMARTA~ 16
IF ~  GlobalGT("Know_Marta_Work","GLOBAL",2) ~ THEN REPLY #20613 /* ~"Marto, dlaczego wyciągasz z tych zwłok zęby i szwy?"~ */ JOURNAL #20538 /* ~Zadaniem Marty Szwaczki jest chyba zajmowanie się przyniesionymi do niej zwłokami. Wyrywa im zęby, rozpruwa szwy, szuka wszelakich cennych rzeczy jakie mogłyby znajdować się w ciele, a następnie zszywa zwłoki z powrotem.~ */ EXTERN ~DMARTA~ 16
IF ~~ THEN REPLY #20614 /* ~"Uch... dobrze. Muszę już iść, Marto. Żegnaj."~ */ EXIT
END

