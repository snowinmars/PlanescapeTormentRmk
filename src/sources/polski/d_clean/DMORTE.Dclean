IF ~~ THEN REPLY #19717 /* ~"W takim razie w porządku. Ruszajmy."~ */ EXIT
IF ~~ THEN REPLY #19718 /* ~"I tak z nią porozmawiam."~ */ EXTERN ~DGHOCITF~ 1
