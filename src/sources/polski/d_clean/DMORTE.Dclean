IF ~  Global("Morte_Talent","GLOBAL",0) ~ THEN REPLY #65541 /* ~"Morte... nie mam nic przeciwko temu, żebyś ze mną wędrował, ale czy umiesz robić coś *innego* oprócz trajkotania?"~ */ GOTO 663
IF ~  Global("Morte_Talent","GLOBAL",1) ~ THEN REPLY #65542 /* ~"Morte... możesz mi jeszcze raz opowiedzieć o twoich specjalnych zdolnościach?"~ */ GOTO 666
IF ~  Global("Morte_Tattoo_XP","GLOBAL",1) ~ THEN REPLY #65543 /* ~"Morte, dlaczego mi nie powiedziałeś o dodatkowej linii tatuaży na moich plecach?"~ */ GOTO 654
IF ~~ THEN REPLY #65544 /* ~"Chyba przydałaby mi się jakaś rada. Co według ciebie powinniśmy teraz zrobić?"~ */ GOTO 669
IF ~  Global("Know_Mimir","GLOBAL",1) Global("Morte_Story","GLOBAL",0) ~ THEN REPLY #65545 /* ~"Mówiłeś, że jesteś mimirem, prawda, Morte?"~ */ GOTO 684
IF ~  Global("Morte_Story","GLOBAL",1) ~ THEN REPLY #65546 /* ~"Opowiedz mi jeszcze raz o tym, jak wylądowałeś w Słupie Czaszek."~ */ GOTO 693
IF ~  Global("Know_Morte_Pillar","GLOBAL",1) ~ THEN REPLY #65547 /* ~"Morte, dlaczego przyłączyłeś się do mnie z powrotem, kiedy odszedłem od Słupa?"~ */ GOTO 715
IF ~  GlobalGT("Know_Blood_War","GLOBAL",0) ~ THEN REPLY #65548 /* ~"Co wiesz o Wojnie Krwi?"~ */ GOTO 723
IF ~  GlobalGT("Know_Ravel","GLOBAL",0) Global("Ravel","GLOBAL",0) ~ THEN REPLY #65549 /* ~"Co wiesz o nocnej wiedźmie Raveli?"~ */ GOTO 722
IF ~~ THEN REPLY #65550 /* ~"W jaki sposób umarłeś, Morte?"~ */ GOTO 726
IF ~~ THEN REPLY #65551 /* ~"Nic, Morte. Tylko sprawdzam, czy wciąż ze mną jesteś."~ */ EXIT
END

