IF ~~ THEN REPLY #45027 /* ~"Bądź cicho przez chwilę, Morte. Chcę tego posłuchać."~ */ EXTERN ~D3PLANEA~ 1
IF ~~ THEN REPLY #45028 /* ~Nie zwracaj uwagi na Mortego i słuchaj wykładu.~ */ EXTERN ~D3PLANEA~ 1
