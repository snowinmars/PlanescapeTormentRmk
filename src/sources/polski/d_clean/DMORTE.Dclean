IF ~~ THEN EXTERN ~DCOLYLFN~ 16
END

IF ~~ THEN BEGIN 193 // from:
SAY #18819 /* ~"Szefie, *nie* rób tego."~ */
IF ~  PartyGoldGT(4) ~ THEN REPLY #18820 /* ~Daj mu pięć miedziaków.~ */ DO ~TakePartyGold(5) ~ EXTERN ~DCOLYLFN~ 18
IF ~  PartyGoldGT(49) ~ THEN REPLY #18821 /* ~Daj mu pięćdziesiąt miedziaków.~ */ DO ~TakePartyGold(50) ~ EXTERN ~DCOLYLFN~ 18
IF ~  PartyGoldGT(99) ~ THEN REPLY #18822 /* ~Daj mu sto miedziaków.~ */ DO ~TakePartyGold(100) ~ EXTERN ~DCOLYLFN~ 18
