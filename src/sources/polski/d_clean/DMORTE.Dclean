IF ~~ THEN BEGIN 421 // from:
SAY #40068 /* ~Morte zaczyna kręcić się wokół ciebie, przedrzeźniając naiwność dziewczyny. "Na wszystkie moce, szefie... Ona ma rację! Że też wcześniej tego nie zauważyłem... jesteś cały w *bliznach*!"~ */
IF ~  !NearbyDialog("DMorte") HPPercent(Protagonist,100) ~ THEN REPLY #40069 /* ~"To stare blizny. Nic mi nie jest."~ */ EXTERN ~DNENNY~ 2
IF ~  !NearbyDialog("DMorte") HPPercentGT(Protagonist,49) ~ THEN REPLY #40070 /* ~"Tylko trochę. Nic mi nie będzie."~ */ EXTERN ~DNENNY~ 2
