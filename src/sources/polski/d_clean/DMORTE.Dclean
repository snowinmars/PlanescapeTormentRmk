IF ~  Global("Vaxis_Zombie_XP","GLOBAL",1) ~ THEN REPLY #64534 /* ~"Niewiele, jak sądzę..."~ */ DO ~FadeToColor([20.0],0) Wait(1) SetNamelessDisguise(ZOMBIE) Wait(2) FadeFromColor([20.0],0) ~ EXTERN ~DVAXIS~ 66
