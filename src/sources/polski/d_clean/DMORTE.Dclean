IF ~~ THEN REPLY #19694 /* ~"W takim razie w porządku. Ruszajmy."~ */ EXIT
IF ~~ THEN REPLY #19695 /* ~"I tak z nim porozmawiam."~ */ EXTERN ~DGHOCITM~ 1
END

IF ~~ THEN BEGIN 204 // from:
SAY #19702 /* ~"Ech... Nie wiem, czy warto rozmawiać z tym... czymś."~ */
