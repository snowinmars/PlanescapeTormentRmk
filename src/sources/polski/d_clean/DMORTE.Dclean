END

IF ~~ THEN BEGIN 554 // from: 553.0
SAY #54263 /* ~"Ten inny TY... nie obchodził go nikt inny. Nikt. Mogliśmy wszyscy umrzeć w Fortecy, a on nawet nie mrugnąłby okiem. Więc... Lepiej nie staraj się do niego upodobnić, bo... hmm, bo *ty* bardziej mi odpowiadasz. O WIELE bardziej."~ */
IF ~  CheckStatGT(Protagonist,15,WIS) ~ THEN REPLY #54264 /* ~"Ale to nie wszystko, co chciałeś mi powiedzieć, prawda?"~ */ GOTO 556
IF ~~ THEN REPLY #54265 /* ~"To wszystko?"~ */ GOTO 556
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) InParty("Morte") ~ THEN REPLY #54266 /* ~"Mniejsza z tym, Morte. Jestem gotowy, żeby przejść przez portal - idziesz ze mną?"~ */ GOTO 534
IF ~  GlobalGT("Morte_Quip_Regret_Portal","GLOBAL",1) !InParty("Morte") ~ THEN REPLY #54267 /* ~"Trudno, Morte. Co się stało, to się nie odstanie. I tak mam zamiar przejść przez portal."~ */ DO ~SetPortalCursor("Fort_Port",PORTAL_CURSOR_VISIBLE,TRUE) SetPortalCursor("Fort_Port",PORTAL_ENABLED,TRUE) ~ EXIT
END

IF ~~ THEN BEGIN 555 // from: 553.1
SAY #54268 /* ~"Chcę tylko powiedzieć, że pomimo swojego uporu, masz więcej zapału niż tamten. On... nie wkładał w to, co robił, całego siebie. Więc... po prostu chciałem, żebyś o tym pamiętał."~ */
IF ~  CheckStatGT(Protagonist,15,WIS) ~ THEN REPLY #54269 /* ~"Ale to nie wszystko, co chciałeś mi powiedzieć, prawda?"~ */ GOTO 556
IF ~~ THEN REPLY #54270 /* ~"Skończyłeś?"~ */ GOTO 556
