IF ~~ THEN REPLY #40278 /* ~"Mam do ciebie parę pytań..."~ */ EXTERN ~DSADJULI~ 24
IF ~~ THEN REPLY #40279 /* ~"Nie mam już więcej pytań. żegnaj."~ */ EXIT
END

