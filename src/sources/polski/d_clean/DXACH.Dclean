IF ~~ THEN REPLY #526 /* ~"Opowiedz mi o którymś z moich dawnych towarzyszy."~ */ GOTO 23
IF ~  Global("Xachariah_Request","GLOBAL",0) ~ THEN REPLY #527 /* ~"Czas już na mnie. Żegnaj."~ */ GOTO 41
IF ~  Global("Xachariah_Request","GLOBAL",1) ~ THEN REPLY #1392 /* ~"Muszę już iść. Żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 7 // from: 8.0 9.1 10.2 11.1 12.1 13.0 14.0 15.0 16.2 17.1 18.1 19.3 22.1 23.5 24.2 25.0 26.2 27.4 28.1 29.1 32.1 33.2 35.0 36.1 40.0 46.1 47.1 48.0 49.1
SAY #528 /* ~"Tak?"~ */
IF ~  Global("Xachariah_Ring","GLOBAL",1) ~ THEN REPLY #63484 /* ~"Chciałby teraz wydobyć ten przedmiot, Zachariaszu..."~ */ GOTO 34
IF ~~ THEN REPLY #637 /* ~"Co doprowadziło cię do takiego stanu?"~ */ GOTO 8
IF ~~ THEN REPLY #638 /* ~"Opowiedz mi o Kostnicy."~ */ GOTO 9
IF ~~ THEN REPLY #639 /* ~"Opowiedz mi o moim poprzednim życiu."~ */ GOTO 16
IF ~~ THEN REPLY #640 /* ~"Opowiedz mi o którymś z moich dawnych towarzyszy."~ */ GOTO 23
