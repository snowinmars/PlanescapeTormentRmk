IF ~  Global("Xachariah_Request","GLOBAL",1) ~ THEN REPLY #1390 /* ~"Dość już usłyszałem. Żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 9 // from: 6.1 7.2
SAY #533 /* ~"Miejsce dla martwych prowadzone przez Martwych... Ale są tu pewne rzeczy, które toczą się podejrzanym torem..."~ */
IF ~~ THEN REPLY #534 /* ~"Na przykład co?"~ */ GOTO 10
IF ~~ THEN REPLY #536 /* ~"Mam do ciebie jeszcze kilka pytań..."~ */ GOTO 7
IF ~  Global("Xachariah_Request","GLOBAL",0) ~ THEN REPLY #537 /* ~"Nie mam już czasu na dalszą rozmowę. Żegnaj."~ */ GOTO 41
IF ~  Global("Xachariah_Request","GLOBAL",1) ~ THEN REPLY #1389 /* ~"Nie mam już czasu na dalszą rozmowę. Żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 10 // from: 9.0
SAY #535 /* ~"Zdradzę ci ten cień. Jest tutaj zombie, który udaje, że jest zombie, ale nie jest nim w istocie. Nie ciekawi mnie przyczyna pojawienia się tu takiej postaci, ale rzecz ta sama w sobie jest bardzo dziwna."~ */
IF ~  CheckStatGT(Player1,15,INT) ~ THEN REPLY #538 /* ~"Coś jeszcze?"~ */ GOTO 11
IF ~~ THEN REPLY #539 /* ~"Który to zombie?"~ */ GOTO 12
IF ~~ THEN REPLY #540 /* ~"Interesujące. Mam jeszcze kilka pytań..."~ */ GOTO 7
IF ~  Global("Xachariah_Request","GLOBAL",0) ~ THEN REPLY #546 /* ~"Nie mam już czasu na dalszą rozmowę. Żegnaj."~ */ GOTO 41
IF ~  Global("Xachariah_Request","GLOBAL",1) ~ THEN REPLY #1388 /* ~"Nie mam już czasu na dalszą rozmowę. Żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 11 // from: 10.0 12.0
SAY #541 /* ~"I jeszcze jedna rzecz. Ten stary githzerai, ten, który zajmuje salę przygotowań... Dhall. On wielokrotnie uratował cię przed piecem krematoryjnym. Twoje szczęście, że masz takiego sprzymierzeńca."~ */
IF ~  CheckStatGT(Player1,17,INT) ~ THEN REPLY #542 /* ~"Co takiego Dhall zrobił, aby mnie ocalić?"~ */ GOTO 13
IF ~~ THEN REPLY #543 /* ~"Wiem. Mam jeszcze kilka innych pytań."~ */ GOTO 7
IF ~  Global("Xachariah_Request","GLOBAL",0) ~ THEN REPLY #544 /* ~"Nie mam już czasu na dalsze rozmowę. Żegnaj."~ */ GOTO 41
IF ~  Global("Xachariah_Request","GLOBAL",1) ~ THEN REPLY #1387 /* ~"Nie mam już czasu na dalszą rozmowę. Żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 12 // from: 10.1
SAY #547 /* ~"Nawet gdyby moje oczy pozwoliłyby mi go zobaczyć, trudno byłoby mi podać liczbę na jego czole. Mogę ci tylko rzec, jak można go odróżnić od innych, śmiałku: jego głos nie jest głosem zombie... reaguje inaczej, niż inne zombie."~ */
IF ~  CheckStatGT(Player1,15,INT) ~ THEN REPLY #548 /* ~"Zauważyłeś jeszcze jakieś inne osobliwe rzeczy w Kostnicy?"~ */ GOTO 11
IF ~~ THEN REPLY #554 /* ~"Hm... Interesujące. Mam jeszcze kilka innych pytań."~ */ GOTO 7
IF ~  Global("Xachariah_Request","GLOBAL",0) ~ THEN REPLY #549 /* ~"Poszukam tego zombie. Żegnaj."~ */ GOTO 41
IF ~  Global("Xachariah_Request","GLOBAL",1) ~ THEN REPLY #1386 /* ~"Poszukam tego zombie. Żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 13 // from: 11.0
SAY #550 /* ~"On dbał o to, aby odwlec kremację na tyle, abyś zdążył się wcześniej obudzić. Ale nie wiem, dlaczego to czynił."~ */
IF ~~ THEN REPLY #552 /* ~"Interesujące. Mam jeszcze kilka pytań..."~ */ GOTO 7
