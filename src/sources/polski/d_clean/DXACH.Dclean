IF ~  True()
~ THEN BEGIN 0 // from:
SAY #500 /* ~Widzisz ciało mężczyzny z numerem "331" wyciętym na czole. Jego powieki i wargi są skrupulatnie zaszyte, natomiast w jego szyi tkwi pokaźna wyrwa. Fetor, jaki od niego bije, mógłby zapewne zabić kogoś o delikatniejszych nozdrzach.~ */
IF ~  Global("Zombie_Chaotic","GLOBAL",0) ~ THEN REPLY #502 /* ~"Więc, cóż? Jakieś ciekawe wrażenia z podróży po okolicy?"~ */ DO ~IncrementGlobal("Law","GLOBAL",-1) SetGlobal("Zombie_Chaotic","GLOBAL",1) ~ GOTO 1
IF ~  Global("Zombie_Chaotic","GLOBAL",1) ~ THEN REPLY #503 /* ~"Więc, cóż? Jakieś ciekawe wrażenia z podróży po okolicy?"~ */ GOTO 1
IF ~  Global("Vaxis_Exposed","GLOBAL",1) ~ THEN REPLY #1354 /* ~"Przecież wiem, że nie jesteś zombie. Nikogo nie oszukasz."~ */ GOTO 1
IF ~  Global("Speak_with_Dead","GLOBAL",1) ~ THEN REPLY #1355 /* ~Posłuż się swoją umiejętnością Gadaj-Kości-Opowieści.~ */ GOTO 2
IF ~~ THEN REPLY #1357 /* ~"Miło było z tobą pogadać. Żegnaj."~ */ GOTO 1
IF ~~ THEN REPLY #1358 /* ~Zostaw truposza w spokoju.~ */ EXIT
END

IF ~~ THEN BEGIN 1 // from: 0.0 0.1 0.2 0.4
SAY #501 /* ~Truposz w milczeniu spogląda przed siebie przez zasznurowane powieki.~ */
IF ~~ THEN REPLY #505 /* ~"Zatem żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 2 // from: 0.3
SAY #504 /* ~"Kk-kk..." Zombie niezdarnie odzyskuje głos i sprawia wrażenia silnie wystraszonego. "Kto tam? Odpowiadaj!"~ */
IF ~~ THEN REPLY #507 /* ~"Nie widzisz mnie?"~ */ GOTO 3
IF ~  CheckStatGT(Player1,16,INT) CheckStatLT(Player1,17,CHR) ~ THEN REPLY #508 /* ~Spróbuj improwizacji: "To ja. Nie poznajesz mojego głosu?"~ */ GOTO 30
IF ~  CheckStatGT(Player1,16,CHR) ~ THEN REPLY #63307 /* ~Spróbuj improwizacji: "To ja. Nie poznajesz mojego głosu?"~ */ GOTO 30
IF ~~ THEN REPLY #519 /* ~"Kim jesteś?"~ */ GOTO 31
IF ~  Global("Xachariah_Name","GLOBAL",1) ~ THEN REPLY #506 /* ~"Zachariasz?"~ */ GOTO 4
IF ~~ THEN REPLY #520 /* ~"Dzisiaj sobie chyba nie pogadamy, truposzu. Żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 3 // from: 2.0
SAY #509 /* ~"Ślepy jestem, tak samo po śmierci, jak i za życia... A teraz odpowiadaj, kim jesteś?"~ */
IF ~  CheckStatGT(Player1,16,INT) CheckStatLT(Player1,17,CHR) ~ THEN REPLY #510 /* ~Spróbuj improwizacji: "To ja. Nie poznajesz mojego głosu?"~ */ GOTO 30
IF ~  CheckStatGT(Player1,16,CHR) ~ THEN REPLY #63308 /* ~Spróbuj improwizacji: "To ja. Nie poznajesz mojego głosu?"~ */ GOTO 30
IF ~~ THEN REPLY #511 /* ~"Kim jesteś?"~ */ GOTO 31
IF ~  Global("Xachariah_Name","GLOBAL",1) ~ THEN REPLY #521 /* ~"Zachariasz?"~ */ GOTO 4
IF ~~ THEN REPLY #522 /* ~"Dzisiaj sobie chyba nie pogadamy, truposzu. Żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 4 // from: 2.4 3.3 30.0 31.0
SAY #512 /* ~"Co...?" Zombie wygląda na wstrząśniętego, ale jego przerażenie szybko ustępuje miejsca radosnemu zdumieniu. "Na Wzrok Pani..." Truposz sprawia wrażenie, jakby na jego niewidzących oczach rozgrywał się prawdziwy cud. "Nie jesteś *martwy*, śmiałku?"~ */
IF ~~ THEN REPLY #515 /* ~"Kim jesteś?"~ */ GOTO 5
IF ~~ THEN REPLY #516 /* ~"Co tutaj robisz?"~ */ GOTO 47
IF ~~ THEN REPLY #517 /* ~"Co to za miejsce?"~ */ GOTO 6
IF ~  Global("Xachariah_Request","GLOBAL",0) ~ THEN REPLY #518 /* ~"Nie mogę zbyt długo rozmawiać. Czas już na mnie. Żegnaj."~ */ GOTO 41
IF ~  Global("Xachariah_Request","GLOBAL",1) ~ THEN REPLY #1394 /* ~"Nie mogę zbyt długo rozmawiać. Czas już na mnie. Żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 5 // from: 4.0
SAY #514 /* ~"Czy naprawdę tak trudno przebić się wzrokiem przez tę plugawą skorupę i ujrzeć pod nią starego Głupca Zachariasza? To przecież ja, śmiałku. Błogosławione niechaj będą Wszelkie Moce, nie sądziłem, że przyjdzie mi jeszcze kiedykolwiek cię obaczyć... Ale ty się też znacznie zmieniłeś, przynajmniej tak mówi mi mój słuch... Powiedz, czy dalej swoim zwyczajem obierasz błędne i zwodnicze szlaki?" Zachariasz świszczy przez otwór w szyi. "A może też jesteś martwy?"~ */
IF ~~ THEN REPLY #685 /* ~"To długa historia... Ale nie... Nie jestem martwy."~ */ GOTO 46
IF ~~ THEN REPLY #686 /* ~"Co tutaj robisz?"~ */ GOTO 47
IF ~~ THEN REPLY #687 /* ~"Co to za miejsce?"~ */ GOTO 6
IF ~  Global("Xachariah_Request","GLOBAL",0) ~ THEN REPLY #688 /* ~"Nie mam już czasu na dalszą rozmowę. Żegnaj."~ */ GOTO 41
IF ~  Global("Xachariah_Request","GLOBAL",1) ~ THEN REPLY #1393 /* ~"Nie mam już czasu na dalszą rozmowę. Żegnaj."~ */ EXIT
END

IF ~~ THEN BEGIN 6 // from: 4.2 5.2
SAY #513 /* ~"Kostnica, śmiałku. Czy to trudno zauważyć?"~ */
IF ~~ THEN REPLY #523 /* ~"Co doprowadziło cię do takiego stanu?"~ */ GOTO 8
IF ~  CheckStatGT(Player1,12,INT) ~ THEN REPLY #524 /* ~"Opowiedz mi o Kostnicy."~ */ DO ~SetGlobal("Vaxis_Exposed","GLOBAL",1) ~ GOTO 9
